{%- comment -%}
  /* ——— RICH TEXT BLANK – BACK BUTTON (BLACK BG, FINAL FIX) ——— */
{%- endcomment -%}

{%- style -%}
  /* Impact font */
  @font-face {
    font-family: 'Impact';
    src: local('Impact'),
         url('https://fonts.cdnfonts.com/s/17317/Impact.woff') format('woff');
    font-display: swap;
  }

  /* Section padding */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Black background override */
  .rich-text--back-bg {
    background: #000 !important;
  }

  /* Center button layout */
  .rich-text__buttons--solo {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  /* Neon-green glowing BACK button */
  .amerikid-back-btn {
    font-family: 'Impact', sans-serif;
    font-size: 2rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #39ff14;
    background: transparent;
    padding: 1rem 3rem;
    border: 2px solid #39ff14;
    text-decoration: none;
    cursor: pointer;

    box-shadow:
      0 0 8px #39ff14,
      0 0 16px #0f0,
      0 0 24px #0f0,
      inset 0 0 8px #39ff14,
      inset 0 0 16px #0f0;

    animation: amerikidGlowBtn 2.5s ease-in-out infinite;
    transition: transform .3s ease, box-shadow .3s ease;
  }
  .amerikid-back-btn:hover,
  .amerikid-back-btn:focus {
    transform: scale(1.05);
    box-shadow:
      0 0 12px #39ff14,
      0 0 24px #0f0,
      0 0 32px #0f0,
      inset 0 0 12px #39ff14,
      inset 0 0 24px #0f0;
  }

  /* Glowing animation */
  @keyframes amerikidGlowBtn {
    0%,100% {
      box-shadow:
        0 0 8px #39ff14,
        0 0 16px #0f0,
        0 0 24px #0f0,
        inset 0 0 8px #39ff14,
        inset 0 0 16px #0f0;
    }
    50% {
      box-shadow:
        0 0 12px #39ff14,
        0 0 24px #0f0,
        0 0 32px #0f0,
        inset 0 0 12px #39ff14,
        inset 0 0 24px #0f0;
    }
  }
{%- endstyle -%}

<!-- MARKUP -->
<div class="isolate{% unless section.settings.full_width %} page-width{% endunless %}">
  <div class="rich-text rich-text--back-bg content-container color-{{ section.settings.color_scheme }}{% if section.settings.full_width %} rich-text--full-width content-container--full-width{% endif %} section-{{ section.id }}-padding">
    <div class="rich-text__wrapper rich-text__wrapper--center{% if section.settings.full_width %} page-width{% endif %}">
      <div class="rich-text__blocks center">
        <div class="rich-text__buttons rich-text__buttons--solo">
          <a
            href="{{ section.settings.button_link | default: '/collections/master-collection' }}"
            class="amerikid-back-btn"
            {{ section.shopify_attributes }}
          >
            {{ section.settings.button_label | default: 'BACK' | escape }}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Rich Text Blank",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "BACK"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Rich Text Blank",
      "category": "Text"
    }
  ]
}
{% endschema %}
