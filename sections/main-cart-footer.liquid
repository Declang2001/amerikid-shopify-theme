{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding{
    padding-top:{{ section.settings.padding_top | times:0.75 | round:0 }}px;
    padding-bottom:{{ section.settings.padding_bottom | times:0.75 | round:0 }}px;
  }
  @media(min-width:750px){
    .section-{{ section.id }}-padding{
      padding-top:{{ section.settings.padding_top }}px;
      padding-bottom:{{ section.settings.padding_bottom }}px;
    }
  }

  /* Remove the forced 60vh "dead space" so it hugs the cart items above */
  @media(min-width:990px){
    #main-cart-footer .page-width{
      width:100%;
      max-width:none;
      padding:0;
      display:flex;
      justify-content:center;
      align-items:flex-start;
      min-height:auto;
    }
  }

  /* ───── FOOTER PANEL: MATCH ITEM CARDS (Option 1) ───── */
  #main-cart-footer .cart__footer{
    width:100%;
    max-width:1200px;
    margin:18px auto 0;
    padding:1.5rem;

    border-radius:22px;
    border:1px solid rgba(255,255,255,.10);
    background:rgba(0,0,0,.78);

    display:flex;
    flex-direction:column;
    align-items:center;
    text-align:center;

    position:relative;
    overflow:hidden;

    transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;

    /* ADDED: contain ambient canvas cleanly */
    isolation:isolate;
  }

  /* ADDED: ambient particle canvas layer (same system as cart items) */
  #main-cart-footer .cart__footer .ak-cart-footer-field{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    z-index:0;
    pointer-events:none;
    mix-blend-mode:screen;
    opacity:1;
    filter:contrast(1.10) saturate(1.10);
  }

  /* subtle micro “HUD” scanline overlay (same vibe as item cards) */
  #main-cart-footer .cart__footer:before{
    content:"";
    position:absolute;
    inset:0;
    pointer-events:none;
    background:repeating-linear-gradient(
      to bottom,
      rgba(255,255,255,.08) 0,
      rgba(255,255,255,.08) 1px,
      transparent 1px,
      transparent 7px
    );
    opacity:.05;
    mix-blend-mode:screen;
  }

  #main-cart-footer .cart__footer:hover{
    border-color:rgba(255,51,255,.22);
    box-shadow:0 0 0 1px rgba(255,51,255,.10), 0 18px 40px rgba(0,0,0,.55);
    transform:translateY(-2px);
  }

  /* Keep all inner content above overlay + canvas */
  #main-cart-footer .cart__footer > *:not(.ak-cart-footer-field){
    position:relative;
    z-index:1;
  }

  /* ————— REMAINDER (STRUCTURE SAFE) ————— */
  #main-cart-footer .cart__blocks,
  #main-cart-footer .js-contents{
    width:100%;
    max-width:720px;
    margin:0 auto;
    display:flex;
    flex-direction:column;
    align-items:center;
  }

  /* Discounts */
  #main-cart-footer .discounts{
    margin:0 0 1rem;
    padding:0;
  }
  #main-cart-footer .discounts__discount{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:.5rem;
    font-size:1.15rem;
    opacity:.95;
  }

  /* Totals block becomes a clean "scoreboard" */
  #main-cart-footer .totals{
    width:100%;
    display:flex;
    flex-direction:column;
    align-items:center;
    margin:0 0 1.25rem;
    padding-top:1.25rem;
    border-top:1px solid rgba(255,255,255,.10);
  }

  #main-cart-footer .totals__row{
    width:100%;
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    gap:1rem;
    font-size:2rem;
  }

  #main-cart-footer .totals__total{
    font-size:1.5rem;
    letter-spacing:.03em;
    color:#fff;
    opacity:.92;
  }

  /* CHANGE REQUEST: Estimated total value -> PURPLE */
  #main-cart-footer .totals__total-value{
    font-size:2.4rem;
    font-weight:800;
    color:#ff33ff;
    text-shadow:
      0 0 8px rgba(255,51,255,.55),
      0 0 18px rgba(255,51,255,.35);
  }

  @media(min-width:750px){
    #main-cart-footer .totals__total{font-size:1.8rem}
    #main-cart-footer .totals__total-value{font-size:3.1rem}
  }

  #main-cart-footer .tax-note{
    margin-top:.6rem;
    font-size:1.1rem;
    opacity:.85;
    text-align:center;
    max-width:56ch;
  }

  /* Cart note (if enabled) */
  #main-cart-footer .cart__note{
    width:100%;
    max-width:720px;
    margin:0 auto 1.25rem;
    text-align:left;
  }
  #main-cart-footer .cart__note label{
    display:block;
    margin-bottom:.5rem;
    opacity:.9;
  }
  #main-cart-footer .cart__note .text-area{
    border-radius:16px;
    border:1px solid rgba(255,255,255,.12);
    background:rgba(0,0,0,.55);
    color:#fff;
  }
  #main-cart-footer .cart__note .text-area:focus{
    outline:none;
    border-color:rgba(255,51,255,.35);
    box-shadow:0 0 0 1px rgba(255,51,255,.18), 0 0 14px rgba(255,51,255,.18);
  }

  /* CTA AREA */
  #main-cart-footer .cart__ctas{
    width:100%;
    max-width:420px;
    margin-top:.25rem;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:1rem;
  }

  /* Checkout button -> PURPLE neon CTA (safe: just styling) */
  #main-cart-footer .cart__checkout-button{
    width:100%;
    border-radius:16px;
    border:2px solid #ff33ff;
    background:#000;
    color:#ff33ff;
    font-weight:900;
    letter-spacing:.06em;
    padding:1.1rem 1.25rem;
    box-shadow:0 0 14px rgba(255,51,255,.55);
    transition:transform .15s ease, box-shadow .15s ease, background .15s ease, color .15s ease;
  }
  #main-cart-footer .cart__checkout-button:hover{
    background:#ff33ff;
    color:#000;
    box-shadow:0 0 22px rgba(255,51,255,.85);
    transform:scale(1.03);
  }
  #main-cart-footer .cart__checkout-button:disabled{
    opacity:.35;
    cursor:not-allowed;
    box-shadow:none;
    transform:none;
  }

  /* Additional checkout buttons: keep contained + aligned */
  #main-cart-footer .cart__dynamic-checkout-buttons.additional-checkout-buttons{
    width:100%;
    display:flex;
    flex-direction:column;
    gap:.75rem;
    align-items:center;
  }
  #main-cart-footer .cart__dynamic-checkout-buttons>div{
    width:100%!important;
    max-width:420px;
  }

  @media (prefers-reduced-motion: reduce){
    #main-cart-footer .cart__footer .ak-cart-footer-field{ display:none !important; }
  }
{%- endstyle -%}

<div
  class="gradient color-{{ section.settings.color_scheme }}{% if cart == empty %} is-empty{% endif %}"
  id="main-cart-footer"
  data-id="{{ section.id }}"
>
  <div class="page-width">
    <div class="cart__footer isolate section-{{ section.id }}-padding">
      <!-- ADDED: Ambient particles canvas (same system as cart items) -->
      <canvas class="ak-cart-footer-field" id="ak-cart-footer-canvas-{{ section.id }}" aria-hidden="true"></canvas>

      {%- if settings.show_cart_note -%}
        <cart-note class="cart__note field">
          <label for="Cart-note">{{ 'sections.cart.note' | t }}</label>
          <textarea
            class="text-area field__input"
            name="note"
            form="cart"
            id="Cart-note"
            placeholder="{{ 'sections.cart.note' | t }}"
          >{{ cart.note }}</textarea>
        </cart-note>
      {%- endif -%}

      <div class="cart__blocks">
        {% for block in section.blocks %}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'subtotal' -%}
              <div class="js-contents" {{ block.shopify_attributes }}>
                <div>
                  {%- if cart.cart_level_discount_applications.size > 0 -%}
                    <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                      {%- for discount in cart.cart_level_discount_applications -%}
                        <li class="discounts__discount discounts__discount--position">
                          {{- 'icon-discount.svg' | inline_asset_content -}}
                          {{ discount.title | escape }}
                          (-{{ discount.total_allocated_amount | money }})
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>

                <div class="totals">
                  <div class="totals__row">
                    <span class="totals__total">{{ 'sections.cart.estimated_total' | t }}</span>
                    <span class="totals__total-value">{{ cart.total_price | money_with_currency }}</span>
                  </div>
                  <small class="tax-note caption-large rte">
                    {%- if cart.duties_included and cart.taxes_included -%}
                      {%- if shop.shipping_policy.body == blank -%}
                        {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
                      {%- else -%}
                        {{
                          'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                          | t: link: shop.shipping_policy.url
                        }}
                      {%- endif -%}
                    {%- elsif cart.duties_included == false and cart.taxes_included -%}
                      {%- if shop.shipping_policy.body == blank -%}
                        {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
                      {%- else -%}
                        {{
                          'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                          | t: link: shop.shipping_policy.url
                        }}
                      {%- endif -%}
                    {%- elsif cart.duties_included and cart.taxes_included == false -%}
                      {%- if shop.shipping_policy.body == blank -%}
                        {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                      {%- else -%}
                        {{
                          'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                          | t: link: shop.shipping_policy.url
                        }}
                      {%- endif -%}
                    {%- else -%}
                      {%- if shop.shipping_policy.body == blank -%}
                        {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                      {%- else -%}
                        {{
                          'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                          | t: link: shop.shipping_policy.url
                        }}
                      {%- endif -%}
                    {%- endif -%}
                  </small>
                </div>
              </div>
            {%- else -%}
              <div class="cart__ctas" {{ block.shopify_attributes }}>
                <button
                  type="submit"
                  id="checkout"
                  class="cart__checkout-button button"
                  name="checkout"
                  {% if cart == empty %}
                    disabled
                  {% endif %}
                  form="cart"
                >
                  {{ 'sections.cart.checkout' | t }}
                </button>
              </div>

              {%- if additional_checkout_buttons -%}
                <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
          {%- endcase -%}
        {% endfor %}
        <div id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

<!-- ADDED: Exact same ambient particle system + shooting stars (scoped to footer canvas) -->
<script>
(function(){
  var canvas = document.getElementById('ak-cart-footer-canvas-{{ section.id }}');
  if(!canvas) return;

  if(canvas.dataset.akInit === '1') return;
  canvas.dataset.akInit = '1';

  var root = canvas.parentElement;
  if(!root) return;

  var reduced = false;
  try { reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch(e){}
  if(reduced) return;

  var ctx = canvas.getContext('2d', { alpha:true });
  var w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);

  var dust = [];
  var floaters = [];
  var shooters = [];
  var nextShooterAt = 0;
  var lastFrameTime = 0;
  var isVisible = true;

  var COLORS = {
    white:  { rgb: "255,255,255", hex: "#ffffff" },
    purple: { rgb: "255,51,255",  hex: "#ff33ff" },
    blue:   { rgb: "127,212,255", hex: "#7fd4ff" },
    yellow: { rgb: "255,211,74",  hex: "#ffd34a" }
  };

  function clamp(v, a, b){ return Math.min(b, Math.max(a, v)); }
  function rand(a, b){ return a + Math.random() * (b - a); }

  function resize(){
    var rect = root.getBoundingClientRect();
    w = Math.max(1, Math.floor(rect.width));
    h = Math.max(1, Math.floor(rect.height));
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function pickAccent(){
    var r = Math.random();
    if(r < 0.44) return COLORS.purple;
    if(r < 0.76) return COLORS.blue;
    return COLORS.yellow;
  }
  function pickDustColor(){ return (Math.random() < 0.90) ? COLORS.white : pickAccent(); }
  function pickFloaterColor(){ return (Math.random() < 0.78) ? COLORS.white : pickAccent(); }

  function densityScale(){
    var mobile = (window.innerWidth || 1200) < 750;
    return mobile ? 0.85 : 1.15;
  }

  function seedDust(){
    var area = w * h;
    var s = densityScale();

    var count = Math.round(clamp((area / 140) * s, 1200, 20000));
    dust = new Array(count);

    for(var i=0;i<count;i++){
      var color = pickDustColor();
      var isAccent = (color !== COLORS.white);

      var vx = rand(-0.028, 0.028);
      var vy = rand(-0.022, 0.022);

      var tw = rand(0.25, 1.05);
      var ph = rand(0, Math.PI * 2);

      var a0 = isAccent ? rand(0.20, 0.44) : rand(0.06, 0.18);
      var size = isAccent ? rand(2.6, 6.0) : rand(1.3, 3.6);

      dust[i] = { x: rand(0,w), y: rand(0,h), vx:vx, vy:vy, color:color, isAccent:isAccent, a0:a0, size:size, tw:tw, ph:ph };
    }
  }

  function pickFloaterKind(){
    var r = Math.random();
    if(r < 0.02) return "blob";
    if(r < 0.22) return "pill";
    return "dot";
  }

  function seedFloaters(){
    var area = w * h;
    var s = densityScale();

    var count = Math.round(clamp((area / 2200) * s, 240, 1400));
    floaters = new Array(count);

    for(var i=0;i<count;i++){
      var kind = pickFloaterKind();
      var color = pickFloaterColor();
      var isAccent = (color !== COLORS.white);

      var vx = rand(-0.16, 0.16);
      var vy = rand(-0.13, 0.13);

      var tw = rand(0.35, 1.30);
      var ph = rand(0, Math.PI * 2);

      var a0 = isAccent ? rand(0.20, 0.52) : rand(0.08, 0.22);
      if(kind === "blob") a0 *= 0.80;

      var p = { x: rand(0,w), y: rand(0,h), vx:vx, vy:vy, kind:kind, color:color, isAccent:isAccent, a0:a0, tw:tw, ph:ph };

      if(kind === "dot"){
        p.r = isAccent ? rand(3.8, 9.2) : rand(2.8, 6.8);
      } else if(kind === "pill"){
        p.pw = rand(12, 40);
        p.phh = rand(3.2, 8.0);
        p.rot = rand(-0.85, 0.85);
      } else {
        p.br = rand(10, 24);
      }

      if(isAccent) p.glowSize = rand(14, 34);
      floaters[i] = p;
    }
  }

  function drawRoundRect(x,y,ww,hh,rr){
    var r = Math.min(rr, ww/2, hh/2);
    ctx.beginPath();
    ctx.moveTo(x+r,y);
    ctx.lineTo(x+ww-r,y);
    ctx.quadraticCurveTo(x+ww,y,x+ww,y+r);
    ctx.lineTo(x+ww,y+hh-r);
    ctx.quadraticCurveTo(x+ww,y+hh,x+ww-r,y+hh);
    ctx.lineTo(x+r,y+hh);
    ctx.quadraticCurveTo(x,y+hh,x,y+hh-r);
    ctx.lineTo(x,y+r);
    ctx.quadraticCurveTo(x,y,x+r,y);
    ctx.closePath();
    ctx.fill();
  }

  function scheduleNextShooter(now){ nextShooterAt = now + rand(2200, 6200); }
  function pickMeteorColor(){ return (Math.random() < 0.80) ? COLORS.white : pickAccent(); }

  function spawnShooter(now){
    var fromLeft = (Math.random() < 0.5);
    var depth = rand(0.55, 1.0);
    var y = rand(h * 0.10, h * 0.90);
    var startX = fromLeft ? -rand(60, 160) : (w + rand(60, 160));
    var angle = fromLeft ? rand(-0.42, 0.42) : rand(Math.PI - 0.42, Math.PI + 0.42);
    var speed = rand(650, 1250) * (0.70 + depth * 0.40);
    var life = rand(0.60, 1.20);

    shooters.push({
      x:startX, y:y,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      t:0, life:life, depth:depth,
      tail: rand(95, 215) * depth * (speed/1000),
      w: rand(0.95, 2.1) * depth,
      color: pickMeteorColor()
    });

    scheduleNextShooter(now);
  }

  function drawShooter(s){
    var p = clamp(s.t / s.life, 0, 1);
    var fadeIn = Math.pow(clamp(p / 0.12, 0, 1), 0.75);
    var fadeOut = 1 - Math.pow(clamp((p - 0.45) / 0.55, 0, 1), 1.9);
    var alpha = fadeIn * fadeOut;
    if(alpha < 0.01) return;

    var spd = Math.sqrt(s.vx*s.vx + s.vy*s.vy) || 1;
    var dx = s.vx / spd;
    var dy = s.vy / spd;

    var tailX = s.x - dx * s.tail;
    var tailY = s.y - dy * s.tail;

    ctx.save();
    ctx.lineCap = "round";

    var g1 = ctx.createLinearGradient(tailX, tailY, s.x, s.y);
    g1.addColorStop(0, "rgba(" + s.color.rgb + ",0)");
    g1.addColorStop(0.55, "rgba(" + s.color.rgb + "," + (0.09*alpha).toFixed(4) + ")");
    g1.addColorStop(1, "rgba(" + s.color.rgb + "," + (0.26*alpha).toFixed(4) + ")");
    ctx.strokeStyle = g1;
    ctx.lineWidth = s.w * 4.9;
    ctx.beginPath();
    ctx.moveTo(tailX, tailY);
    ctx.lineTo(s.x, s.y);
    ctx.stroke();

    var g2 = ctx.createLinearGradient(tailX, tailY, s.x, s.y);
    g2.addColorStop(0, "rgba(255,255,255,0)");
    g2.addColorStop(0.55, "rgba(255,255,255," + (0.20*alpha).toFixed(4) + ")");
    g2.addColorStop(1, "rgba(255,255,255," + (0.72*alpha).toFixed(4) + ")");
    ctx.strokeStyle = g2;
    ctx.lineWidth = s.w * 1.10;
    ctx.beginPath();
    ctx.moveTo(s.x - dx * s.tail * 0.45, s.y - dy * s.tail * 0.45);
    ctx.lineTo(s.x, s.y);
    ctx.stroke();

    ctx.shadowBlur = 14 * s.depth;
    ctx.shadowColor = s.color.hex;

    var r = s.w * 2.2 * s.depth;
    var hg = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, r * 3.0);
    hg.addColorStop(0, "rgba(255,255,255," + (0.82*alpha).toFixed(4) + ")");
    hg.addColorStop(0.18, "rgba(" + s.color.rgb + "," + (0.50*alpha).toFixed(4) + ")");
    hg.addColorStop(0.55, "rgba(" + s.color.rgb + "," + (0.15*alpha).toFixed(4) + ")");
    hg.addColorStop(1, "rgba(" + s.color.rgb + ",0)");
    ctx.fillStyle = hg;
    ctx.beginPath();
    ctx.arc(s.x, s.y, r * 3.0, 0, Math.PI*2);
    ctx.fill();

    ctx.restore();
    ctx.shadowBlur = 0;
    ctx.shadowColor = "transparent";
  }

  function reseed(){
    resize();
    seedDust();
    seedFloaters();
    shooters.length = 0;
    nextShooterAt = 0;
    lastFrameTime = 0;
  }

  function step(t){
    if(!isVisible){
      requestAnimationFrame(step);
      return;
    }

    var now = (t || performance.now());
    var time = now * 0.001;
    var dt = lastFrameTime ? clamp((now - lastFrameTime) / 1000, 0.001, 0.05) : (1/60);
    lastFrameTime = now;

    ctx.clearRect(0,0,w,h);
    ctx.globalCompositeOperation = "lighter";

    for(var i=0;i<dust.length;i++){
      var d = dust[i];
      d.x += d.vx; d.y += d.vy;

      if(d.x < -2) d.x = w + 2;
      if(d.x > w + 2) d.x = -2;
      if(d.y < -2) d.y = h + 2;
      if(d.y > h + 2) d.y = -2;

      var twk = 0.70 + 0.30 * Math.sin(time * d.tw + d.ph);
      var a = d.a0 * twk;

      if(d.isAccent){
        ctx.shadowBlur = 3;
        ctx.shadowColor = d.color.hex;
      } else {
        ctx.shadowBlur = 0;
      }

      ctx.fillStyle = "rgba(" + d.color.rgb + "," + a.toFixed(3) + ")";
      ctx.fillRect(d.x - d.size*0.5, d.y - d.size*0.5, d.size, d.size);
    }

    for(var j=0;j<floaters.length;j++){
      var p = floaters[j];

      p.x += p.vx; p.y += p.vy;

      if(p.x < -30) p.x = w + 30;
      if(p.x > w + 30) p.x = -30;
      if(p.y < -30) p.y = h + 30;
      if(p.y > h + 30) p.y = -30;

      var twk2 = 0.65 + 0.35 * Math.sin(time * p.tw + p.ph);
      var a2 = p.a0 * twk2;

      if(p.isAccent && p.glowSize){
        ctx.shadowBlur = p.glowSize * twk2;
        ctx.shadowColor = p.color.hex;
      } else {
        ctx.shadowBlur = 0;
        ctx.shadowColor = "transparent";
      }

      ctx.fillStyle = "rgba(" + p.color.rgb + "," + a2.toFixed(3) + ")";

      if(p.kind === "dot"){
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
        ctx.fill();
      } else if(p.kind === "pill"){
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        drawRoundRect(-p.pw/2, -p.phh/2, p.pw, p.phh, p.phh/2);
        ctx.restore();
      } else {
        var r2 = p.br;
        ctx.beginPath();
        ctx.arc(p.x, p.y, r2, 0, Math.PI*2);
        ctx.arc(p.x + r2*0.5, p.y - r2*0.2, r2*0.7, 0, Math.PI*2);
        ctx.arc(p.x - r2*0.4, p.y + r2*0.15, r2*0.6, 0, Math.PI*2);
        ctx.fill();
      }
    }

    if(!nextShooterAt) scheduleNextShooter(now);
    if(now >= nextShooterAt) spawnShooter(now);

    for(var k=shooters.length-1;k>=0;k--){
      var s = shooters[k];
      s.t += dt;
      s.x += s.vx * dt;
      s.y += s.vy * dt;

      drawShooter(s);

      var margin = 420;
      if(s.t >= s.life || s.x < -margin || s.x > w + margin || s.y < -margin || s.y > h + margin){
        shooters.splice(k, 1);
      }
    }

    ctx.globalCompositeOperation = "source-over";
    ctx.shadowBlur = 0;
    ctx.shadowColor = "transparent";

    requestAnimationFrame(step);
  }

  reseed();
  requestAnimationFrame(step);

  window.addEventListener('resize', function(){ reseed(); }, { passive:true });

  if('ResizeObserver' in window){
    var ro = new ResizeObserver(function(){ reseed(); });
    ro.observe(root);
  }

  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){ isVisible = entry.isIntersecting; });
    }, { threshold: 0 });
    io.observe(root);
  }
})();
</script>

