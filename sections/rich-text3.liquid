{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* Embedded 8-bit Pixel Font — replace with real base64 if needed */
  @font-face {
    font-family: 'PixelFont';
    src: url("data:font/woff;base64,BASE64_PIXEL_FONT_DATA") format('woff');
    font-display: swap;
  }

  /* ---------- Section padding ---------- */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ---------- Lambent neon animation ---------- */
  @keyframes neonLambent {
    /* bright steady glow */
    0%, 100% {
      text-shadow:
        0 0 6px  #39ff14,
        0 0 12px #39ff14,
        0 0 22px #39ff14,
        0 0 40px #39ff14;
      filter: brightness(1.15);
      opacity: 0.95;
    }

    /* gentle pulse */
    10% {
      text-shadow:
        0 0 4px  #39ff14,
        0 0 10px #39ff14,
        0 0 18px #39ff14,
        0 0 32px #39ff14;
      filter: brightness(0.85);
      opacity: 0.78;
    }

    /* quick flicker (off) */
    11%, 13% {
      text-shadow: none;
      filter: brightness(0.4);
      opacity: 0.25;
    }

    /* surge back on */
    14% {
      text-shadow:
        0 0 5px  #39ff14,
        0 0 12px #39ff14,
        0 0 22px #39ff14,
        0 0 38px #39ff14;
      filter: brightness(1.25);
      opacity: 1;
    }

    /* full glow crescendo */
    50% {
      text-shadow:
        0 0 8px  #39ff14,
        0 0 16px #39ff14,
        0 0 30px #39ff14,
        0 0 50px #39ff14;
      filter: brightness(1.35);
      opacity: 1;
    }

    /* slight dim */
    60% {
      text-shadow:
        0 0 3px  #39ff14,
        0 0 6px  #39ff14,
        0 0 12px #39ff14,
        0 0 20px #39ff14;
      filter: brightness(0.9);
      opacity: 0.8;
    }

    /* quick flicker (off) */
    61%, 63% {
      text-shadow: none;
      filter: brightness(0.35);
      opacity: 0.22;
    }

    /* power back up */
    64% {
      text-shadow:
        0 0 5px  #39ff14,
        0 0 12px #39ff14,
        0 0 22px #39ff14,
        0 0 38px #39ff14;
      filter: brightness(1.2);
      opacity: 1;
    }
  }

  /* ---------- Heading styles ---------- */
  .neon-8bit-heading {
    font-family: 'PixelFont', monospace;
    color: #39ff14;
    text-shadow:
      0 0 6px  #39ff14,
      0 0 12px #39ff14,
      0 0 20px #39ff14,
      0 0 28px #39ff14;
    text-transform: uppercase;
    white-space: nowrap;
    overflow-x: auto;
    padding-inline: 2rem;
    font-size: 2rem;
    line-height: 1.2;
    animation: neonLambent 4s linear infinite;
  }

  @media screen and (min-width: 750px) {
    .neon-8bit-heading {
      font-size: 3.5rem;
    }
  }
{%- endstyle -%}

<div class="isolate{% unless section.settings.full_width %} page-width{% endunless %}">
  <div class="rich-text content-container color-{{ section.settings.color_scheme }} gradient{% if section.settings.full_width %} rich-text--full-width content-container--full-width{% endif %} section-{{ section.id }}-padding">
    <div class="rich-text__wrapper rich-text__wrapper--{{ section.settings.desktop_content_position }}{% if section.settings.full_width %} page-width{% endif %}">
      <div class="rich-text__blocks {{ section.settings.content_alignment }}">
        <h2
          class="rich-text__heading rte inline-richtext neon-8bit-heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: 1;"
          {% endif %}
        >
          ENTER EMAIL TO JOIN CLUB AMERIKID
        </h2>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Big Neon Heading",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "desktop_content_position",
      "label": "Desktop content position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "Full width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Big Neon Heading"
    }
  ]
}
{% endschema %}
