{% comment %}
  ============================================================
  AK-TOP: Combined header + nav section (Phase 1 prototype)
  Replaces the two separate custom-liquid sections:
    1. holo-rail (header bar: logo, cart, canvas)
    2. aknav (nav panel: tiles, drawer, canvas)
  Now uses ONE canvas behind the combined area.
  ============================================================
{% endcomment %}

<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">
{% if settings.predictive_search_enabled %}<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">{% endif %}

<style>
/* =========================================================
   AK-TOP: OUTER WRAPPER (one canvas behind everything)
========================================================= */
.ak-top-wrap{
  position:relative;
  z-index:999;
  width:100%;
  display:block;
  background:#000;
  overflow:visible;
}
.ak-top-canvas{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  pointer-events:none;
  z-index:0;
  mix-blend-mode:screen;
  filter:contrast(1.1);
}
.ak-top-wrap::after{
  content:"";position:absolute;bottom:0;left:0;right:0;
  height:28px;pointer-events:none;z-index:8;
  background:linear-gradient(to bottom,transparent 0%,#000 100%);
  border-radius:0 0 16px 16px;
}
.ak-top-divider{
  display:block;width:min(1200px,92vw);margin:0 auto;
  height:1px;border:0;
  background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,.07) 20%,rgba(255,51,255,.10) 50%,rgba(255,255,255,.07) 80%,transparent 100%);
  position:relative;z-index:6;
}

/* =========================================================
   HEADER BAR (logo + cart)
========================================================= */
.ak-top-header{
  position:relative;
  z-index:5;
  padding:12px 3rem;
  background-color:transparent;
  display:flex;
  align-items:center;
  justify-content:center;
}
@media(min-width:750px){.ak-top-header{padding:16px 3rem}}
.ak-top-header .header__heading-link{text-decoration:none;display:inline-block}
.ak-top-header .header__heading-logo-wrapper{cursor:pointer;display:inline-block}
.ak-top-header .header__heading-logo{
  max-width:180px;height:auto;display:block;
  opacity:0;transform:scale(.8);
  animation:akTopLogoIn .8s ease-out forwards;
  filter:drop-shadow(0 1px 0 rgba(255,255,255,.15)) drop-shadow(0 2px 1px rgba(0,0,0,.3)) drop-shadow(0 4px 3px rgba(0,0,0,.25)) drop-shadow(0 8px 6px rgba(0,0,0,.2)) drop-shadow(0 12px 10px rgba(0,0,0,.15));
}
@keyframes akTopLogoIn{0%{opacity:0;transform:scale(.8) rotate(-10deg)}50%{opacity:1;transform:scale(1.05) rotate(2deg)}100%{opacity:1;transform:scale(1) rotate(0)}}
@media(max-width:749px){.ak-top-header .header__heading-logo{max-width:140px}}

.ak-top-dock{
  --rx:0deg;--ry:0deg;
  position:relative;display:inline-flex;align-items:center;justify-content:center;
  padding:16px 28px;background:0 0;border-radius:18px;
  transform-style:preserve-3d;
  transform:perspective(600px) rotateX(var(--rx)) rotateY(var(--ry));
  transition:transform .15s ease-out;z-index:10;
}
.ak-top-dock-inner{position:relative;z-index:3;display:inline-block}

/* cart bubble */
.ak-top-cart-container{position:fixed;top:1rem;right:1rem;z-index:9999}
.ak-top-cart-float{display:inline-block;animation:akTopCartBob 4s ease-in-out infinite}
@keyframes akTopCartBob{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
.ak-top-cart-link{
  --crx:0deg;--cry:0deg;--cscale:1;
  position:relative;display:inline-block;padding:8px;border-radius:14px;
  transform-style:preserve-3d;
  transform:perspective(400px) rotateX(var(--crx)) rotateY(var(--cry)) scale(var(--cscale));
  transition:transform .08s ease-out;
}
.ak-top-cart-link.is-pop{--cscale:1.15}
.ak-top-cart-link.is-settle{--cscale:.98}
.ak-top-cart-link::after{content:"";position:absolute;inset:0;border-radius:inherit;background:linear-gradient(135deg,rgba(255,255,255,.18) 0%,rgba(255,255,255,0) 50%,rgba(255,255,255,.06) 100%);mix-blend-mode:screen;pointer-events:none;opacity:0;transition:opacity .2s ease}
.ak-top-cart-link:hover::after{opacity:1}
.ak-top-cart-img{width:72px;height:72px;object-fit:contain;display:block;position:relative;z-index:2;pointer-events:none}
.ak-top-oil-level{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);width:8px;height:32px;border-radius:4px;overflow:hidden;background:rgba(255,255,255,.08);z-index:1;pointer-events:none;opacity:0;transition:opacity .3s ease}
.ak-top-cart-link.cart-has-items .ak-top-oil-level{opacity:1}
.ak-top-oil-fill{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,#f3f 0%,#7fd4ff 100%);border-radius:4px;transition:height .4s ease-out;box-shadow:0 0 6px rgba(255,51,255,.5),inset 0 1px 2px rgba(255,255,255,.3)}
.ak-top-cart-link.cart-shimmer::before{content:"";position:absolute;inset:-2px;border-radius:inherit;background:linear-gradient(90deg,transparent 0%,rgba(255,51,255,.6) 50%,transparent 100%);background-size:200% 100%;animation:akTopShimmer .5s ease-out forwards;mix-blend-mode:screen;pointer-events:none;z-index:3}
@keyframes akTopShimmer{0%{background-position:200% 0;opacity:1}100%{background-position:-200% 0;opacity:0}}

/* =========================================================
   NAV PANEL (transparent — particles visible through)
========================================================= */
.ak-top-nav-area{
  --ak-purple:#ff33ff;
  --ak-green:#39ff14;
  --tile-h:clamp(64px,6.2vw,92px);
  --duo-h:clamp(118px,10vw,170px);
  --label:clamp(18px,2.2vw,34px);
  --label-center:clamp(20px,2.6vw,40px);
  --ls:clamp(.14em,.75vw,.28em);
  --ls-long:clamp(.10em,.60vw,.22em);
  --text-front:#fff;
  --glow-x:50%;--glow-y:50%;--glow-opacity:0;
  position:relative;z-index:5;
  width:100%;
  overflow:hidden;isolation:isolate;
  background:transparent;
  margin-top:0;
  perspective:1100px;
}
.ak-top-nav-panel{
  position:relative;z-index:5;
  padding:clamp(16px,2vw,24px);
  padding-top:clamp(20px,2.6vw,30px);
  padding-bottom:calc(clamp(16px,2vw,24px) + 2px);
}
.ak-top-nav-glow{
  position:absolute;inset:-80px;pointer-events:none;z-index:6;
  opacity:var(--glow-opacity);transition:opacity .18s ease;
  mix-blend-mode:screen;filter:blur(12px) saturate(1.2);
  background:radial-gradient(circle 240px at var(--glow-x) var(--glow-y),rgba(255,51,255,.52) 0%,rgba(255,51,255,.22) 36%,rgba(255,51,255,.09) 54%,transparent 70%);
}

/* grid */
.ak-top-grid{
  position:relative;z-index:7;
  width:min(1200px,96vw);margin:0 auto;
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  grid-template-areas:"life products archive" "narrative duo contact";
  gap:clamp(14px,2.6vw,36px) clamp(14px,3.2vw,44px);
  align-items:center;
}
.ak-top-life{grid-area:life}.ak-top-products{grid-area:products}.ak-top-archive{grid-area:archive}
.ak-top-narrative{grid-area:narrative}.ak-top-duo{grid-area:duo}.ak-top-contact{grid-area:contact}

/* tiles */
.ak-top-tile{
  --gx:50%;--gy:50%;
  width:100%;min-width:0;height:var(--tile-h);
  border-radius:20px;background:transparent;border:0;box-shadow:none;
  display:flex;align-items:center;justify-content:center;
  text-decoration:none;color:#fff;position:relative;overflow:visible;
  transform:translateY(16px) rotateX(var(--rx,0deg)) rotateY(var(--ry,0deg));
  opacity:0;
  animation:akTopTileIn .75s cubic-bezier(.16,1,.3,1) forwards;
  animation-delay:var(--d,0s);
  transition:transform .12s ease,color .18s ease,filter .18s ease;
  will-change:transform;
}
@keyframes akTopTileIn{to{opacity:1;transform:translateY(0) rotateX(var(--rx,0deg)) rotateY(var(--ry,0deg))}}
.ak-top-tile::before,.ak-top-tile::after{display:none}
.ak-top-tile:hover{filter:drop-shadow(0 0 16px rgba(255,51,255,.18))}
.ak-top-tile:active{transform:translateY(2px) rotateX(var(--rx,0deg)) rotateY(var(--ry,0deg)) scale(0.96);transition:transform .08s ease}

/* labels */
.ak-top-label{
  font-family:Impact,Haettenschweiler,'Arial Narrow Bold',sans-serif;
  text-transform:uppercase;font-size:var(--label);
  letter-spacing:var(--ls);white-space:nowrap;
  padding:0 clamp(10px,1.2vw,16px);line-height:1;
  position:relative;display:inline-block;color:var(--text-front);
  text-shadow:0 -1px 0 rgba(255,255,255,.28),0 1px 0 rgba(0,0,0,.55),0 2px 0 rgba(0,0,0,.45),0 10px 18px rgba(0,0,0,.38),0 0 18px rgba(255,51,255,.14);
  overflow:visible;transform:translateZ(0);
}
.ak-top-label::before{
  content:attr(data-text);position:absolute;left:0;top:0;width:100%;height:100%;padding:inherit;
  z-index:1;pointer-events:none;color:transparent;-webkit-text-fill-color:transparent;
  background:radial-gradient(circle 110px at var(--gx,50%) var(--gy,50%),rgba(255,255,255,.78) 0%,rgba(255,255,255,.18) 28%,rgba(255,255,255,0) 58%),linear-gradient(120deg,rgba(255,255,255,.10) 0%,rgba(255,51,255,.30) 18%,rgba(127,212,255,.28) 36%,rgba(255,211,74,.18) 52%,rgba(255,255,255,.12) 70%,rgba(255,51,255,.20) 88%,rgba(255,255,255,.10) 100%);
  background-size:180% 180%,240% 240%;
  background-position:var(--gx,50%) var(--gy,50%),calc(var(--gx,50%) - 40%) calc(var(--gy,50%) - 40%);
  -webkit-background-clip:text;background-clip:text;
  mix-blend-mode:screen;opacity:.48;filter:saturate(1.1) contrast(1.05);
}
.ak-top-label::after{
  content:attr(data-text);position:absolute;left:0;top:0;width:100%;height:100%;padding:inherit;
  z-index:2;pointer-events:none;color:transparent;-webkit-text-fill-color:transparent;
  background:linear-gradient(110deg,rgba(255,255,255,0) 0%,rgba(255,255,255,0) 36%,rgba(255,255,255,.92) 48%,rgba(255,255,255,0) 60%,rgba(255,255,255,0) 100%);
  background-size:260% 260%;background-position:-120% 0%;
  -webkit-background-clip:text;background-clip:text;
  mix-blend-mode:screen;opacity:.22;filter:blur(.15px);
  animation:akTopGlint 2.85s linear infinite;
}
@keyframes akTopGlint{0%{background-position:-140% 0%;opacity:.08}12%{opacity:.22}40%{opacity:.26}55%{opacity:.12}100%{background-position:160% 0%;opacity:.08}}

.ak-top-tile:hover .ak-top-label::before,.ak-top-tile.is-active .ak-top-label::before{opacity:.72;filter:saturate(1.35) contrast(1.12)}
.ak-top-tile:hover .ak-top-label::after,.ak-top-tile.is-active .ak-top-label::after{opacity:.44;filter:blur(0px)}
.ak-top-tile--long .ak-top-label{letter-spacing:var(--ls-long);font-size:clamp(17px,2.05vw,32px)}
.ak-top-products .ak-top-label{font-size:var(--label-center)}

.ak-top-products.is-active .ak-top-label,.ak-top-products:hover .ak-top-label,
.ak-top-tile:hover .ak-top-label,.ak-top-tile.is-active .ak-top-label{
  color:var(--ak-purple);
  text-shadow:0 -1px 0 rgba(255,255,255,.18),0 1px 0 rgba(0,0,0,.58),0 2px 0 rgba(0,0,0,.48),0 10px 20px rgba(0,0,0,.40),0 0 22px rgba(255,51,255,.35),0 0 34px rgba(255,51,255,.18);
}

/* duo (BAD + CANDY) */
.ak-top-duo{display:grid;grid-template-columns:1fr 1fr;gap:clamp(12px,2vw,22px);width:100%}
.ak-top-duo-tile{height:var(--duo-h);padding:clamp(10px,1.4vw,16px)}
.ak-top-duo-tile:hover,.ak-top-duo-tile.is-active{filter:drop-shadow(0 0 18px rgba(255,51,255,.55)) drop-shadow(0 0 42px rgba(255,51,255,.22))}
.ak-top-bad{color:#fff}
.ak-top-bad:hover,.ak-top-bad.is-active{color:var(--ak-purple)}
.ak-top-bad-mask{
  width:100%;height:100%;background-color:currentColor;
  -webkit-mask-image:url({{ 'Bad.png' | file_url }});mask-image:url({{ 'Bad.png' | file_url }});
  -webkit-mask-size:contain;mask-size:contain;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;
  -webkit-mask-position:center;mask-position:center;
  display:block;transition:transform .15s ease,filter .18s ease;
}
.ak-top-bad:hover .ak-top-bad-mask,.ak-top-bad.is-active .ak-top-bad-mask{filter:drop-shadow(0 0 12px rgba(255,51,255,.65)) drop-shadow(0 0 28px rgba(255,51,255,.28))}
.ak-top-bad:active .ak-top-bad-mask{transform:scale(0.92)}
.ak-top-bad-fallback{display:none}
@supports not ((-webkit-mask-image:url("")) or (mask-image:url(""))){
  .ak-top-bad-mask{display:none}
  .ak-top-bad-fallback{display:block;width:100%;height:100%;object-fit:contain;transition:transform .15s ease,filter .18s ease}
  .ak-top-bad:hover .ak-top-bad-fallback,.ak-top-bad.is-active .ak-top-bad-fallback{filter:drop-shadow(0 0 12px rgba(255,51,255,.65)) drop-shadow(0 0 28px rgba(255,51,255,.28))}
  .ak-top-bad:active .ak-top-bad-fallback{transform:scale(0.92)}
}
.ak-top-candy{padding:clamp(6px,1vw,10px)!important}
.ak-top-candy-img{width:100%;height:100%;object-fit:contain;display:block;transform:scale(1.28);transform-origin:center;transition:transform .15s ease,filter .18s ease;filter:none}
.ak-top-candy:hover .ak-top-candy-img,.ak-top-candy.is-active .ak-top-candy-img{filter:drop-shadow(0 0 12px rgba(255,51,255,.65)) drop-shadow(0 0 28px rgba(255,51,255,.28))}
.ak-top-candy:active .ak-top-candy-img{transform:scale(1.15)}

/* mobile trigger */
.ak-top-mobile-trigger{
  display:none;position:relative;z-index:7;
  font-family:Impact,Haettenschweiler,'Arial Narrow Bold',sans-serif;
  font-size:clamp(28px,9vw,48px);text-transform:uppercase;letter-spacing:.35em;
  margin:1.2rem auto 0;padding:0.25rem 0.75rem;width:max-content;
  cursor:pointer;user-select:none;color:#fff;
  text-shadow:1px 1px 0 #ccc,2px 2px 0 #999,3px 3px 2px rgba(0,0,0,.4),4px 4px 6px rgba(0,0,0,.3);
}
.ak-top-mobile-trigger:active{transform:scale(0.95)}

/* scroll lock */
html.ak-top-lock,html.ak-top-lock body{overflow:hidden!important;height:100%!important}

/* drawer */
.ak-top-drawer[data-ak-top-drawer]{
  --ak-purple:#ff33ff;
  position:fixed!important;inset:0!important;width:100vw!important;height:100vh!important;height:100dvh!important;z-index:99999!important;
  background:#000!important;
  transform:translate3d(-100%,0,0)!important;transition:transform .35s ease,opacity .2s ease!important;
  padding:calc(env(safe-area-inset-top,0px) + 2rem) 1rem calc(env(safe-area-inset-bottom,0px) + 4rem)!important;
  display:flex!important;flex-direction:column!important;align-items:center!important;gap:.8rem!important;
  overflow-y:auto!important;-webkit-overflow-scrolling:touch;
  opacity:0!important;pointer-events:none!important;
}
.ak-top-drawer[data-ak-top-drawer].open{transform:translate3d(0,0,0)!important;opacity:1!important;pointer-events:auto!important}
.ak-top-drawer .ak-top-drawer-close{align-self:flex-end;margin-left:auto;background:none;border:none;color:#fff;font-size:36px;cursor:pointer;margin-bottom:1rem;transition:transform .15s ease}
.ak-top-drawer .ak-top-drawer-close:active{transform:scale(0.85)}
.ak-top-drawer a{
  width:100%;text-align:center;text-decoration:none;color:#fff;
  font-family:Impact,Haettenschweiler,'Arial Narrow Bold',sans-serif;
  text-transform:uppercase;letter-spacing:.22em;font-size:34px;
  padding:1.4rem 1rem;border-radius:18px;
  text-shadow:1px 1px 0 #aaa,2px 2px 0 #666,3px 3px 3px rgba(0,0,0,.4);
  transition:transform .15s ease,color .2s ease,background .2s ease;
}
.ak-top-drawer a:hover{color:var(--ak-purple);background:rgba(255,255,255,.06)}
.ak-top-drawer a:active{transform:scale(0.96)}
.ak-top-drawer a.active{color:var(--ak-purple)}
.ak-top-drawer .ak-top-mobile-image img{height:120px;width:auto;display:block;margin:0 auto;transition:transform .15s ease}
.ak-top-drawer .ak-top-mobile-image:active img{transform:scale(0.92)}

/* responsive grid */
@media(max-width:980px){
  .ak-top-grid{grid-template-columns:repeat(2,minmax(0,1fr));grid-template-areas:"life products" "archive archive" "narrative narrative" "duo duo" "contact contact"}
}
@media(max-width:768px){
  .ak-top-grid{display:none}
  .ak-top-mobile-trigger{display:block}
}

/* reduced motion */
@media(prefers-reduced-motion:reduce){
  .ak-top-canvas{display:none}
  .ak-top-tile{animation:none;opacity:1;transform:none;--rx:0deg!important;--ry:0deg!important}
  .ak-top-nav-area{perspective:none}
  .ak-top-label::before,.ak-top-label::after{display:none}
  .ak-top-nav-glow{display:none}
  .ak-top-dock{transition:none;transform:perspective(600px) rotateX(0) rotateY(0)!important}
  .ak-top-header .header__heading-logo{animation:none;opacity:1;transform:scale(1)}
  .ak-top-cart-link,.ak-top-cart-float{animation:none!important}
}
</style>

<script src="{{ 'cart-notification.js' | asset_url }}" defer></script>

{%- comment -%} ===== HTML STRUCTURE ===== {%- endcomment -%}
<div class="ak-top-wrap" id="ak-top-{{ section.id }}" data-section-id="{{ section.id }}">
  <canvas class="ak-top-canvas" id="ak-top-cv-{{ section.id }}" aria-hidden="true"></canvas>

  {%- comment -%} HEADER BAR {%- endcomment -%}
  <div class="ak-top-header">
    <a href="{{ routes.root_url }}" id="ak-top-logo-{{ section.id }}" class="header__heading-link link link--text focus-inset" style="margin:0 auto">
      {% if settings.logo != blank %}
        <div class="ak-top-dock" id="ak-top-dock-{{ section.id }}">
          <div class="ak-top-dock-inner">
            <div class="header__heading-logo-wrapper">
              {% assign logo_alt = settings.logo.alt | default: shop.name | escape %}
              {% assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio %}
              {% capture sizes %}(min-width: 750px) 180px, 50vw{% endcapture %}
              {% capture widths %}180, 320, 440{% endcapture %}
              {{ settings.logo | image_url: width:440 | image_tag: class:'header__heading-logo', widths:widths, height:logo_height, width:180, alt:logo_alt, sizes:sizes, preload:true }}
            </div>
          </div>
        </div>
      {% endif %}
    </a>
    <div class="ak-top-cart-container">
      <div class="ak-top-cart-float">
        <a href="/cart" aria-label="View cart" class="ak-top-cart-link">
          <div class="ak-top-oil-level"><div class="ak-top-oil-fill" style="height:0%"></div></div>
          <img src="https://cdn.shopify.com/s/files/1/0930/3267/7656/files/cart.png?v=1750659934" alt="Cart" class="ak-top-cart-img">
        </a>
      </div>
    </div>
  </div>

  <hr class="ak-top-divider" aria-hidden="true">

  {%- comment -%} NAV AREA {%- endcomment -%}
  <div class="ak-top-nav-area" id="ak-top-nav-{{ section.id }}">
    <div class="ak-top-nav-glow" aria-hidden="true"></div>
    <div class="ak-top-nav-panel">
      <span class="ak-top-mobile-trigger" role="button" aria-label="Open navigation" aria-expanded="false" tabindex="0">MENU</span>
      <nav class="ak-top-grid" aria-label="Amerikid Navigation">
        <a href="/pages/the-collective" class="ak-top-tile ak-top-tile--long ak-top-life {% if request.path == '/pages/the-collective' %}is-active{% endif %}" style="--d:.10s"><span class="ak-top-label">LIFE/STYLE</span></a>
        <a href="/collections/master-collection" class="ak-top-tile ak-top-products {% if request.path == '/collections/master-collection' %}is-active{% endif %}" style="--d:.20s"><span class="ak-top-label">PRODUCTS</span></a>
        <a href="/collections/" class="ak-top-tile ak-top-archive {% if request.path == '/collections' or request.path == '/collections/' %}is-active{% endif %}" style="--d:.30s"><span class="ak-top-label">ARCHIVE</span></a>
        <a href="/pages/narrative" class="ak-top-tile ak-top-tile--long ak-top-narrative {% if request.path == '/pages/narrative' %}is-active{% endif %}" style="--d:.40s"><span class="ak-top-label">NARRATIVE</span></a>
        <div class="ak-top-duo" style="--d:.50s">
          <a href="/pages/2025" class="ak-top-tile ak-top-duo-tile ak-top-bad {% if request.path == '/pages/2025' %}is-active{% endif %}" aria-label="BAD Music" style="--d:.50s">
            <span class="ak-top-bad-mask" aria-hidden="true"></span>
            <img class="ak-top-bad-fallback" src="{{ 'Bad.png' | file_url }}" alt="BAD Music">
          </a>
          <a href="/pages/mystery-box" class="ak-top-tile ak-top-duo-tile ak-top-candy {% if request.path == '/pages/mystery-box' %}is-active{% endif %}" aria-label="Candy Facts" style="--d:.55s">
            <img class="ak-top-candy-img" src="{{ 'candyfacts.png' | file_url }}" alt="Candy Facts">
          </a>
        </div>
        <a href="/pages/club-hub" class="ak-top-tile ak-top-tile--long ak-top-contact {% if request.path == '/pages/club-hub' %}is-active{% endif %}" style="--d:.60s"><span class="ak-top-label">CLUBHOUSE</span></a>
      </nav>
      <div class="ak-top-drawer" data-ak-top-drawer="1" aria-hidden="true">
        <button class="ak-top-drawer-close" aria-label="Close menu">&#x2715;</button>
        <a href="/pages/the-collective" class="{% if request.path == '/pages/the-collective' %}active{% endif %}">LIFE/STYLE</a>
        <a href="/collections/master-collection" class="{% if request.path == '/collections/master-collection' %}active{% endif %}">PRODUCTS</a>
        <a href="/collections/" class="{% if request.path == '/collections' or request.path == '/collections/' %}active{% endif %}">ARCHIVE</a>
        <a href="/pages/narrative" class="{% if request.path == '/pages/narrative' %}active{% endif %}">NARRATIVE</a>
        <a href="/pages/2025" class="ak-top-mobile-image {% if request.path == '/pages/2025' %}active{% endif %}" aria-label="BAD Music"><img src="{{ 'Bad.png' | file_url }}" alt="BAD Music"></a>
        <a href="/pages/mystery-box" class="ak-top-mobile-image {% if request.path == '/pages/mystery-box' %}active{% endif %}" aria-label="Candy Facts"><img src="{{ 'candyfacts.png' | file_url }}" alt="Candy Facts"></a>
        <a href="/pages/club-hub" class="{% if request.path == '/pages/club-hub' %}active{% endif %}">CLUBHOUSE</a>
      </div>
    </div>
  </div>
</div>

<script>
/* =========================================================
   AK-TOP: Combined interactive JS
   - Cart tilt/update, logo tilt, nav drawer, glow tracking
   - ONE canvas particle system (simplified)
========================================================= */
(function(){
var S = '{{ section.id }}';
var root = document.getElementById('ak-top-' + S);
if(!root || root.__akTopInit) return;
root.__akTopInit = true;

var cv = document.getElementById('ak-top-cv-' + S);
var dock = document.getElementById('ak-top-dock-' + S);
var navArea = document.getElementById('ak-top-nav-' + S);
var prm = false;
try { prm = window.matchMedia('(prefers-reduced-motion:reduce)').matches; } catch(e){}

/* ---- data-text for label pseudo-elements ---- */
var labels = root.querySelectorAll('.ak-top-label');
for(var i = 0; i < labels.length; i++){
  labels[i].setAttribute('data-text', (labels[i].textContent || '').trim());
}

/* ---- LOGO TILT ---- */
if(dock && !prm){
  var mt = 7;
  dock.addEventListener('mousemove', function(e){
    var r = dock.getBoundingClientRect();
    var ox = (e.clientX - r.left - r.width/2) / (r.width/2);
    var oy = (e.clientY - r.top - r.height/2) / (r.height/2);
    dock.style.setProperty('--rx', -oy*mt + 'deg');
    dock.style.setProperty('--ry', ox*mt + 'deg');
  });
  dock.addEventListener('mouseleave', function(){
    dock.style.setProperty('--rx', '0deg');
    dock.style.setProperty('--ry', '0deg');
  });
}

/* ---- CART TILT + UPDATE ---- */
var cLnk = root.querySelector('.ak-top-cart-link');
var cFill = root.querySelector('.ak-top-oil-fill');
var lcc = 0;

if(cLnk && !prm){
  var cmt = 12, trx = 0, try_ = 0, crx = 0, cry = 0, cRaf = null, cHov = 0;
  function uct(){
    if(!cHov){
      crx += (0 - crx) * .15; cry += (0 - cry) * .15;
      if(Math.abs(crx) < .01 && Math.abs(cry) < .01){
        crx = cry = 0; cLnk.style.setProperty('--crx','0deg'); cLnk.style.setProperty('--cry','0deg'); cRaf = null; return;
      }
    } else {
      crx += (trx - crx) * .22; cry += (try_ - cry) * .22;
    }
    cLnk.style.setProperty('--crx', crx + 'deg'); cLnk.style.setProperty('--cry', cry + 'deg');
    cRaf = requestAnimationFrame(uct);
  }
  cLnk.addEventListener('pointerenter', function(){ cHov = 1; if(!cRaf) cRaf = requestAnimationFrame(uct); });
  cLnk.addEventListener('pointermove', function(e){
    var r = cLnk.getBoundingClientRect();
    trx = -((e.clientY - r.top - r.height/2) / (r.height/2)) * cmt;
    try_ = ((e.clientX - r.left - r.width/2) / (r.width/2)) * cmt;
  });
  cLnk.addEventListener('pointerleave', function(){ cHov = 0; trx = try_ = 0; if(!cRaf) cRaf = requestAnimationFrame(uct); });
}

function cpop(){
  if(!cLnk) return;
  cLnk.classList.add('is-pop','cart-shimmer');
  setTimeout(function(){ cLnk.classList.remove('is-pop'); cLnk.classList.add('is-settle'); setTimeout(function(){ cLnk.classList.remove('is-settle'); }, 100); }, 180);
  setTimeout(function(){ cLnk.classList.remove('cart-shimmer'); }, 500);
}

async function ucs(){
  if(!cLnk) return;
  try {
    var c = await fetch('/cart.js').then(function(r){ return r.json(); });
    var n = c ? c.item_count : 0;
    if(n > 0){ cLnk.classList.add('cart-has-items'); if(cFill) cFill.style.height = Math.min(n,10)*10 + '%'; }
    else { cLnk.classList.remove('cart-has-items'); if(cFill) cFill.style.height = '0%'; }
    if(n > lcc && lcc >= 0) cpop();
    lcc = n;
  } catch(e){}
}
ucs();
document.addEventListener('cart:updated', ucs);
setInterval(ucs, 10000);

/* ---- NAV GLOW TRACKING ---- */
if(navArea && !prm){
  navArea.addEventListener('pointerenter', function(){ navArea.style.setProperty('--glow-opacity','1'); }, { passive:true });
  navArea.addEventListener('pointermove', function(ev){
    var r = navArea.getBoundingClientRect();
    navArea.style.setProperty('--glow-x', (ev.clientX - r.left).toFixed(1) + 'px');
    navArea.style.setProperty('--glow-y', (ev.clientY - r.top).toFixed(1) + 'px');
    navArea.style.setProperty('--glow-opacity','1');
  }, { passive:true });
  navArea.addEventListener('pointerleave', function(){ navArea.style.setProperty('--glow-opacity','0'); }, { passive:true });
}

/* ---- NAV DRAWER ---- */
var trigger = root.querySelector('.ak-top-mobile-trigger');
var drawer = root.querySelector('.ak-top-drawer');
var closeBtn = drawer ? drawer.querySelector('.ak-top-drawer-close') : null;

if(drawer && !drawer.dataset.akMoved){
  drawer.dataset.akMoved = '1';
  document.body.appendChild(drawer);
}

function openDrawer(){
  if(!drawer) return;
  drawer.classList.add('open');
  drawer.setAttribute('aria-hidden','false');
  if(trigger) trigger.setAttribute('aria-expanded','true');
  document.documentElement.classList.add('ak-top-lock');
  setTimeout(function(){ if(closeBtn) closeBtn.focus(); }, 50);
}
function closeDrawer(){
  if(!drawer) return;
  drawer.classList.remove('open');
  drawer.setAttribute('aria-hidden','true');
  if(trigger) trigger.setAttribute('aria-expanded','false');
  document.documentElement.classList.remove('ak-top-lock');
  setTimeout(function(){ if(trigger) trigger.focus(); }, 50);
}

if(trigger){
  trigger.addEventListener('click', openDrawer);
  trigger.addEventListener('keydown', function(e){ if(e.key === 'Enter' || e.key === ' ') openDrawer(); });
}
if(closeBtn) closeBtn.addEventListener('click', closeDrawer);
document.addEventListener('click', function(e){
  if(!drawer || !drawer.classList.contains('open')) return;
  if(drawer.contains(e.target)) return;
  if(trigger && trigger.contains(e.target)) return;
  closeDrawer();
});
document.addEventListener('keydown', function(e){
  if(!drawer || !drawer.classList.contains('open')) return;
  if(e.key === 'Escape') closeDrawer();
});

/* ---- TILE TILT ---- */
if(!prm){
  var tiles = root.querySelectorAll('.ak-top-tile');
  for(var j = 0; j < tiles.length; j++){
    (function(tile){
      tile.addEventListener('pointermove', function(ev){
        var r = tile.getBoundingClientRect();
        var px = (ev.clientX - r.left) / r.width;
        var py = (ev.clientY - r.top) / r.height;
        tile.style.setProperty('--rx', ((0.5 - py) * 8).toFixed(2) + 'deg');
        tile.style.setProperty('--ry', ((px - 0.5) * 10).toFixed(2) + 'deg');
        tile.style.setProperty('--gx', (px * 100).toFixed(1) + '%');
        tile.style.setProperty('--gy', (py * 100).toFixed(1) + '%');
      }, { passive:true });
      tile.addEventListener('pointerleave', function(){
        tile.style.setProperty('--rx','0deg');
        tile.style.setProperty('--ry','0deg');
        tile.style.setProperty('--gx','50%');
        tile.style.setProperty('--gy','50%');
      }, { passive:true });
    })(tiles[j]);
  }
}

/* =========================================================
   ONE CANVAS: Simplified ambient particles + shooting stars
   - Dust: capped at 400-800 (was 1500-3400)
   - No dust shadowBlur
   - Floater glow: preserved for accents
   - Shooting stars: full system preserved
========================================================= */
if(!cv || prm) return;

(function(){
  var canvas = cv;
  var ctx = canvas.getContext('2d', { alpha:true });
  var w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
  var dust = [], floaters = [], shooters = [];
  var nextShooterAt = 0, lastFrameTime = 0;
  var animationId = null, seededOnce = false, resizeRaf = 0;

  var COLORS = {
    white:  { rgb:"255,255,255", hex:"#ffffff" },
    purple: { rgb:"255,51,255",  hex:"#ff33ff" },
    blue:   { rgb:"127,212,255", hex:"#7fd4ff" },
    yellow: { rgb:"255,211,74",  hex:"#ffd34a" }
  };

  function clamp(v, mn, mx){ return Math.min(mx, Math.max(mn, v)); }
  function rand(a, b){ return a + Math.random() * (b - a); }

  function resize(){
    var rect = root.getBoundingClientRect();
    w = Math.max(1, Math.floor(rect.width));
    h = Math.max(1, Math.floor(rect.height));
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function pickAccent(){
    var r = Math.random();
    if(r < 0.40) return COLORS.purple;
    if(r < 0.72) return COLORS.blue;
    return COLORS.yellow;
  }
  function pickDustColor(){ return (Math.random() < 0.88) ? COLORS.white : pickAccent(); }
  function pickFloaterColor(){ return (Math.random() < 0.76) ? COLORS.white : pickAccent(); }
  function pickFloaterKind(){
    var r = Math.random();
    if(r < 0.015) return 'blob';
    if(r < 0.18) return 'pill';
    return 'dot';
  }

  function densityScale(){
    var vw = window.innerWidth || 1200;
    if(vw < 520) return 0.28;
    if(vw < 750) return 0.38;
    return 0.85;
  }

  /* DUST: reduced density, no shadowBlur */
  function seedDust(){
    var area = w * h, s = densityScale();
    var vw = window.innerWidth || 1200;
    var tiny = vw < 520, mobile = vw < 750;
    var div = mobile ? (tiny ? 600 : 500) : 400;
    var minC = mobile ? (tiny ? 120 : 160) : 400;
    var maxC = mobile ? (tiny ? 300 : 450) : 800;
    var count = Math.round(clamp((area / div) * s, minC, maxC));
    dust = new Array(count);
    for(var i = 0; i < count; i++){
      var color = pickDustColor();
      var isAccent = (color !== COLORS.white);
      dust[i] = {
        bx: rand(0, w), by: rand(0, h),
        vx: rand(-0.028, 0.028), vy: rand(-0.022, 0.022),
        color: color, isAccent: isAccent,
        a0: isAccent ? rand(0.18, 0.40) : rand(0.05, 0.15),
        size: isAccent ? rand(1.8, 3.2) : ((Math.random() < 0.78) ? rand(1.2, 2.2) : rand(2.2, 3.0)),
        tw: rand(0.25, 1.10), ph: rand(0, Math.PI * 2)
      };
    }
  }

  /* FLOATERS: slight reduction, accent glow preserved */
  function seedFloaters(){
    var area = w * h, s = densityScale();
    var vw = window.innerWidth || 1200;
    var tiny = vw < 520, mobile = vw < 750;
    var div = mobile ? (tiny ? 7000 : 6000) : 1800;
    var minC = mobile ? (tiny ? 40 : 50) : 200;
    var maxC = mobile ? (tiny ? 100 : 130) : 400;
    var count = Math.round(clamp((area / div) * s, minC, maxC));
    floaters = new Array(count);
    for(var i = 0; i < count; i++){
      var kind = pickFloaterKind();
      var color = pickFloaterColor();
      var isAccent = (color !== COLORS.white);
      var a0 = isAccent ? rand(0.20, 0.50) : rand(0.07, 0.18);
      if(kind === 'blob') a0 *= 0.78;
      if(kind === 'pill') a0 *= 0.90;
      var p = {
        bx: rand(0, w), by: rand(0, h),
        vx: rand(-0.16, 0.16), vy: rand(-0.13, 0.13),
        kind: kind, color: color, isAccent: isAccent,
        a0: a0, tw: rand(0.35, 1.35), ph: rand(0, Math.PI * 2)
      };
      if(kind === 'dot') p.r = isAccent ? rand(3.0, 6.0) : ((Math.random() < 0.60) ? rand(2.0, 3.6) : rand(3.6, 5.2));
      else if(kind === 'pill'){ p.pw = rand(10, 28); p.phh = rand(2.4, 5.0); p.rot = rand(-0.85, 0.85); }
      else p.br = rand(7, 14);
      if(isAccent) p.glowSize = rand(7, 16);
      floaters[i] = p;
    }
  }

  function drawRoundRect(x, y, ww, hh, rr){
    var r = Math.min(rr, ww/2, hh/2);
    ctx.beginPath();
    ctx.moveTo(x+r, y); ctx.lineTo(x+ww-r, y);
    ctx.quadraticCurveTo(x+ww, y, x+ww, y+r);
    ctx.lineTo(x+ww, y+hh-r);
    ctx.quadraticCurveTo(x+ww, y+hh, x+ww-r, y+hh);
    ctx.lineTo(x+r, y+hh);
    ctx.quadraticCurveTo(x, y+hh, x, y+hh-r);
    ctx.lineTo(x, y+r);
    ctx.quadraticCurveTo(x, y, x+r, y);
    ctx.closePath(); ctx.fill();
  }

  /* SHOOTING STARS: full system preserved */
  function scheduleNextShooter(now){ nextShooterAt = now + rand(2200, 6500); }
  function pickMeteorColor(){ return (Math.random() < 0.78) ? COLORS.white : pickAccent(); }

  function createSpark(x, y, bvx, bvy, color, depth){
    var sa = rand(-0.8, 0.8), sm = rand(0.08, 0.25);
    var cos = Math.cos(sa), sin = Math.sin(sa);
    return {
      x: x + rand(-3,3), y: y + rand(-2,2),
      vx: (bvx*cos - bvy*sin)*sm + rand(-30,30),
      vy: (bvx*sin + bvy*cos)*sm + rand(-20,20),
      t:0, life: rand(0.15, 0.4), r: rand(0.8, 2.0)*depth,
      a0: rand(0.5, 0.9), color: color
    };
  }

  function noise1D(seed, t){
    var x = Math.sin(seed + t*1.7) * 43758.5453;
    return (x - Math.floor(x))*2 - 1;
  }

  function spawnShooter(now, isFrag, pd){
    isFrag = !!isFrag; pd = pd || null;
    var fromLeft = pd ? pd.fromLeft : (Math.random() < 0.5);
    var depth = isFrag ? rand(0.45, 0.7) : rand(0.4, 1.0);
    var y, sx, angle, speed, life;
    if(pd){
      sx = pd.x + rand(-8,8); y = pd.y + rand(-6,6);
      angle = pd.angle + rand(-0.5, 0.5); speed = pd.speed * rand(0.45, 0.7); life = rand(0.2, 0.4);
    } else {
      y = rand(h*0.05, h*0.95);
      sx = fromLeft ? -rand(50,140) : (w + rand(50,140));
      angle = fromLeft ? rand(-0.45, 0.45) : rand(Math.PI-0.45, Math.PI+0.45);
      speed = rand(650, 1400) * (0.65 + depth*0.45); life = rand(0.55, 1.15);
    }
    var color = pickMeteorColor();
    var wf = !isFrag && Math.random() < 0.12;
    var ft = wf ? rand(0.25, 0.55) : -1;
    var fc = wf ? Math.floor(rand(2,4)) : 0;
    var sc = isFrag ? Math.floor(rand(1,3)) : Math.floor(rand(3,9));
    var st = [];
    for(var i=0; i<sc; i++) st.push(rand(0.08, 0.82)*life);
    st.sort(function(a,b){return a-b});
    shooters.push({
      x:sx, y:y, vx: Math.cos(angle)*speed, vy: Math.sin(angle)*speed,
      angle:angle, speed:speed,
      curvature: rand(-0.12, 0.12), noiseSeed: rand(0,1000), noiseAmp: rand(0.3, 1.2),
      t:0, life:life, depth:depth,
      tailLen: rand(90, 200)*depth*(speed/1000), w: rand(1.0, 2.4)*depth,
      color:color, fromLeft:fromLeft,
      willFragment:wf, fragmentTime:ft, fragmentCount:fc, fragmented:false,
      sparkTimes:st, sparkIndex:0, sparks:[],
      shimmerPhase: rand(0, Math.PI*2), shimmerSpeed: rand(18, 35), shimmerAmp: rand(0.04, 0.10),
      isFragment:isFrag
    });
    if(!isFrag) scheduleNextShooter(now);
  }

  function drawShooter(s, dt){
    var p = clamp(s.t/s.life, 0, 1);
    var fadeIn = Math.pow(clamp(p/0.12, 0, 1), 0.7);
    var peakHold = 1 - 0.15*clamp((p-0.12)/0.30, 0, 1);
    var fadeOut = 1 - Math.pow(clamp((p-0.45)/0.55, 0, 1), 1.8);
    var alpha = fadeIn * peakHold * fadeOut;
    var shimmer = 1 - s.shimmerAmp + s.shimmerAmp*(0.5 + 0.5*Math.sin(s.t*s.shimmerSpeed + s.shimmerPhase));
    var fa = alpha * shimmer;
    if(fa < 0.005) return;
    var spd = Math.sqrt(s.vx*s.vx + s.vy*s.vy) || 1;
    var dx = s.vx/spd, dy = s.vy/spd, px = -dy, py = dx;
    var nd = noise1D(s.noiseSeed, s.t*8)*s.noiseAmp;
    var dtl = s.tailLen*(0.6 + 0.4*alpha);
    var co = s.curvature*dtl*0.35*Math.sin(p*Math.PI);
    var to = co + nd;
    var tx = s.x - dx*dtl + px*to, ty = s.y - dy*dtl + py*to;
    var mx = s.x - dx*dtl*0.45 + px*to*0.6, my = s.y - dy*dtl*0.45 + py*to*0.6;
    var csx = s.x - dx*dtl*0.38, csy = s.y - dy*dtl*0.38;

    ctx.save(); ctx.lineCap = 'round';
    /* outer tail */
    var g1 = ctx.createLinearGradient(tx,ty,s.x,s.y);
    g1.addColorStop(0,'rgba('+s.color.rgb+',0)');
    g1.addColorStop(0.25,'rgba('+s.color.rgb+','+(0.03*fa).toFixed(4)+')');
    g1.addColorStop(0.55,'rgba('+s.color.rgb+','+(0.08*fa).toFixed(4)+')');
    g1.addColorStop(0.80,'rgba('+s.color.rgb+','+(0.14*fa).toFixed(4)+')');
    g1.addColorStop(1,'rgba('+s.color.rgb+','+(0.22*fa).toFixed(4)+')');
    ctx.strokeStyle=g1; ctx.lineWidth=s.w*6*s.depth;
    ctx.beginPath(); ctx.moveTo(tx,ty); ctx.quadraticCurveTo(mx,my,s.x,s.y); ctx.stroke();
    /* mid tail */
    var g2 = ctx.createLinearGradient(tx,ty,s.x,s.y);
    g2.addColorStop(0,'rgba('+s.color.rgb+',0)');
    g2.addColorStop(0.30,'rgba('+s.color.rgb+','+(0.12*fa).toFixed(4)+')');
    g2.addColorStop(0.60,'rgba('+s.color.rgb+','+(0.28*fa).toFixed(4)+')');
    g2.addColorStop(0.85,'rgba('+s.color.rgb+','+(0.50*fa).toFixed(4)+')');
    g2.addColorStop(1,'rgba('+s.color.rgb+','+(0.70*fa).toFixed(4)+')');
    ctx.strokeStyle=g2; ctx.lineWidth=s.w*2.5;
    ctx.beginPath(); ctx.moveTo(tx+(s.x-tx)*0.15, ty+(s.y-ty)*0.15); ctx.quadraticCurveTo(mx,my,s.x,s.y); ctx.stroke();
    /* core */
    var g3 = ctx.createLinearGradient(csx,csy,s.x,s.y);
    g3.addColorStop(0,'rgba(255,255,255,0)');
    g3.addColorStop(0.20,'rgba(255,255,255,'+(0.35*fa).toFixed(4)+')');
    g3.addColorStop(0.50,'rgba(255,255,255,'+(0.65*fa).toFixed(4)+')');
    g3.addColorStop(0.80,'rgba(255,255,255,'+(0.88*fa).toFixed(4)+')');
    g3.addColorStop(1,'rgba(255,255,255,'+(0.98*fa).toFixed(4)+')');
    ctx.strokeStyle=g3; ctx.lineWidth=s.w*0.9;
    ctx.beginPath(); ctx.moveTo(csx,csy); ctx.lineTo(s.x,s.y); ctx.stroke();
    /* head */
    var hr = s.w*2.2*s.depth;
    ctx.shadowBlur=14*s.depth; ctx.shadowColor=s.color.hex;
    var hg1 = ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,hr*3);
    hg1.addColorStop(0,'rgba(255,255,255,'+(0.85*fa).toFixed(4)+')');
    hg1.addColorStop(0.15,'rgba('+s.color.rgb+','+(0.70*fa).toFixed(4)+')');
    hg1.addColorStop(0.40,'rgba('+s.color.rgb+','+(0.35*fa).toFixed(4)+')');
    hg1.addColorStop(0.70,'rgba('+s.color.rgb+','+(0.12*fa).toFixed(4)+')');
    hg1.addColorStop(1,'rgba('+s.color.rgb+',0)');
    ctx.fillStyle=hg1; ctx.beginPath(); ctx.arc(s.x,s.y,hr*3,0,Math.PI*2); ctx.fill();
    ctx.shadowBlur=8*s.depth; ctx.shadowColor='#fff';
    var hg2 = ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,hr*1.2);
    hg2.addColorStop(0,'rgba(255,255,255,'+(0.98*fa).toFixed(4)+')');
    hg2.addColorStop(0.5,'rgba(255,255,255,'+(0.75*fa).toFixed(4)+')');
    hg2.addColorStop(1,'rgba(255,255,255,'+(0.25*fa).toFixed(4)+')');
    ctx.fillStyle=hg2; ctx.beginPath(); ctx.arc(s.x,s.y,hr*1.2,0,Math.PI*2); ctx.fill();
    ctx.shadowBlur=4;
    ctx.fillStyle='rgba(255,255,255,'+(0.95*fa).toFixed(4)+')';
    ctx.beginPath(); ctx.arc(s.x,s.y,hr*0.35,0,Math.PI*2); ctx.fill();
    ctx.shadowBlur=0; ctx.shadowColor='transparent';
    /* sparks */
    for(var i = s.sparks.length-1; i >= 0; i--){
      var sp = s.sparks[i];
      sp.t += dt; sp.x += sp.vx*dt; sp.y += sp.vy*dt;
      sp.vx *= 0.94; sp.vy *= 0.94; sp.vy += 25*dt;
      var sf = (1-clamp(sp.t/sp.life,0,1)); sf *= sf;
      var sa = sf*sp.a0*alpha;
      if(sa > 0.008){
        ctx.shadowBlur=4*sf; ctx.shadowColor=sp.color.hex;
        ctx.fillStyle='rgba('+sp.color.rgb+','+sa.toFixed(4)+')';
        ctx.beginPath(); ctx.arc(sp.x,sp.y,sp.r*(1-clamp(sp.t/sp.life,0,1)*0.6),0,Math.PI*2); ctx.fill();
      }
      if(sp.t >= sp.life) s.sparks.splice(i, 1);
    }
    ctx.restore(); ctx.shadowBlur=0; ctx.shadowColor='transparent';
  }

  /* ---- MAIN LOOP ---- */
  function step(t){
    t = t || performance.now();
    var time = t * 0.001;
    var rdt = lastFrameTime ? clamp((t-lastFrameTime)/1000, 0.001, 0.05) : (1/60);
    lastFrameTime = t;

    ctx.clearRect(0, 0, w, h);
    ctx.globalCompositeOperation = 'lighter';

    /* dust: no shadowBlur */
    ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';
    for(var i = 0; i < dust.length; i++){
      var d = dust[i];
      d.bx += d.vx; d.by += d.vy;
      if(d.bx < -3) d.bx = w+3; if(d.bx > w+3) d.bx = -3;
      if(d.by < -3) d.by = h+3; if(d.by > h+3) d.by = -3;
      var twk = 0.70 + 0.30*Math.sin(time*d.tw + d.ph);
      ctx.fillStyle = 'rgba('+d.color.rgb+','+(d.a0*twk).toFixed(3)+')';
      ctx.fillRect(d.bx - d.size*0.5, d.by - d.size*0.5, d.size, d.size);
    }

    /* floaters: accent glow preserved */
    for(var j = 0; j < floaters.length; j++){
      var p = floaters[j];
      p.bx += p.vx; p.by += p.vy;
      if(p.bx < -30) p.bx = w+30; if(p.bx > w+30) p.bx = -30;
      if(p.by < -30) p.by = h+30; if(p.by > h+30) p.by = -30;
      var tw2 = 0.65 + 0.35*Math.sin(time*p.tw + p.ph);
      var a2 = p.a0*tw2;
      if(p.isAccent && p.glowSize){
        ctx.shadowBlur = p.glowSize*tw2; ctx.shadowColor = p.color.hex;
      } else {
        ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';
      }
      ctx.fillStyle = 'rgba('+p.color.rgb+','+a2.toFixed(3)+')';
      if(p.kind === 'dot'){ ctx.beginPath(); ctx.arc(p.bx, p.by, p.r, 0, Math.PI*2); ctx.fill(); }
      else if(p.kind === 'pill'){ ctx.save(); ctx.translate(p.bx, p.by); ctx.rotate(p.rot); drawRoundRect(-p.pw/2, -p.phh/2, p.pw, p.phh, p.phh/2); ctx.restore(); }
      else { var rr=p.br; ctx.beginPath(); ctx.arc(p.bx,p.by,rr,0,Math.PI*2); ctx.arc(p.bx+rr*0.5,p.by-rr*0.2,rr*0.7,0,Math.PI*2); ctx.arc(p.bx-rr*0.4,p.by+rr*0.15,rr*0.6,0,Math.PI*2); ctx.fill(); }
    }

    /* meteors */
    if(!nextShooterAt) scheduleNextShooter(t);
    if(t >= nextShooterAt) spawnShooter(t, false, null);
    for(var k = shooters.length-1; k >= 0; k--){
      var s = shooters[k];
      s.t += rdt;
      var cf = s.curvature*0.5;
      var pvx = -s.vy/s.speed, pvy = s.vx/s.speed;
      s.x += (s.vx + pvx*cf*s.speed*0.1)*rdt;
      s.y += (s.vy + pvy*cf*s.speed*0.1)*rdt;
      while(s.sparkIndex < s.sparkTimes.length && s.t >= s.sparkTimes[s.sparkIndex]){
        s.sparks.push(createSpark(s.x, s.y, -s.vx, -s.vy, s.color, s.depth));
        s.sparkIndex++;
      }
      if(s.willFragment && !s.fragmented && s.t >= s.fragmentTime*s.life){
        s.fragmented = true;
        for(var f=0; f<s.fragmentCount; f++) spawnShooter(t, true, {x:s.x, y:s.y, angle:s.angle, speed:s.speed, fromLeft:s.fromLeft});
      }
      drawShooter(s, rdt);
      var mg = 450;
      if(s.t >= s.life || s.x < -mg || s.x > w+mg || s.y < -mg || s.y > h+mg) shooters.splice(k, 1);
    }

    ctx.globalCompositeOperation = 'source-over';
    ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';
    animationId = requestAnimationFrame(step);
  }

  function hardSeed(){
    resize(); seedDust(); seedFloaters(); seededOnce = true;
  }
  function softResize(){
    var ow = w || 1, oh = h || 1;
    resize();
    if(!seededOnce){ seedDust(); seedFloaters(); seededOnce = true; return; }
    var sx = w/ow, sy = h/oh;
    for(var i=0; i<dust.length; i++){ dust[i].bx *= sx; dust[i].by *= sy; }
    for(var j=0; j<floaters.length; j++){ floaters[j].bx *= sx; floaters[j].by *= sy; }
    shooters.length = 0; nextShooterAt = 0;
  }
  function reqSoftResize(){
    if(resizeRaf) return;
    resizeRaf = requestAnimationFrame(function(){ resizeRaf = 0; softResize(); });
  }

  hardSeed();
  animationId = requestAnimationFrame(step);

  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if(entry.isIntersecting){ lastFrameTime = 0; if(!animationId) animationId = requestAnimationFrame(step); }
        else { if(animationId){ cancelAnimationFrame(animationId); animationId = null; } }
      });
    }, { threshold: 0 });
    io.observe(root);
  }

  window.addEventListener('resize', reqSoftResize, { passive:true });
  if(window.visualViewport) window.visualViewport.addEventListener('resize', reqSoftResize, { passive:true });
  if('ResizeObserver' in window){ var ro = new ResizeObserver(function(){ reqSoftResize(); }); ro.observe(root); }
})();

})();
</script>

