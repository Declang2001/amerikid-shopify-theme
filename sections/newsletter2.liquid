{%- comment -%}
  Club Amerikid Newsletter
  Neutral glass panel + full ambient starfield background with shooting stars
  FIX: remove the top “white gap” (was coming from outer spacing). The section now has NO outer margin/border.
  Panel width still matches Contact Form (1200px shell + same side gutters).
{%- endcomment -%}

{%- assign show_modal = false -%}

<section id="ak-newsletter-{{ section.id }}" class="ak-newsletter" aria-label="Club Amerikid Newsletter">
  <!-- Full-bleed ambient background (behind the panel + visible on the sides) -->
  <canvas class="ak-newsletter-bg" aria-hidden="true"></canvas>

  <!-- Same width shell as the contact form (1200px) -->
  <div class="ak-newsletter-shell section-{{ section.id }}-padding">
    <div class="ak-newsletter-panel color-{{ section.settings.color_scheme }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div
        class="ak-signup-shell{% if form.posted_successfully? %} active{% endif %}"
        id="ak-signup-shell-{{ section.id }}"
        onclick="this.classList.add('active'); setTimeout(function(){ var el=document.getElementById('ak-email-{{ section.id }}'); if(el){ el.focus(); } }, 90);"
      >
        <div class="ak-typing">ENTER EMAIL TO JOIN CLUB AMERIKID</div>
        <span class="ak-caret">|</span>

        {%- liquid
          assign form_id = 'ak-form-' | append: section.id
        -%}

        {% form 'customer', id: form_id, class: 'ak-form-row' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="hidden" name="contact[accepts_marketing]" value="true">
          <input type="hidden" id="ak-hcaptcha-{{ section.id }}" name="h-captcha-response">

          <input
            type="email"
            name="contact[email]"
            id="ak-email-{{ section.id }}"
            class="ak-email"
            placeholder="you@example.com"
            required
            value="{{ form.email }}"
          >

          <button type="submit" class="ak-btn">ENTER</button>

          {% if form.errors %}
            <small class="ak-error">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </small>
          {% endif %}

          {% if form.posted_successfully? %}
            {%- assign show_modal = true -%}
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% if show_modal %}
  <div id="ak-modal-{{ section.id }}" class="ak-modal">
    <div class="ak-modal-card">
      💥 THANKS FOR JOINING!<br><br>
      USE CODE <strong id="ak-code-{{ section.id }}">ILOVEAMERIKID</strong> FOR 10% OFF.<br><br>
      <button type="button" id="ak-copy-{{ section.id }}" class="ak-btn ak-copy">COPY CODE</button><br>
      <button type="button" id="ak-close-{{ section.id }}" class="ak-btn" style="margin-top:1rem;">CLOSE</button>
    </div>
  </div>
{% endif %}

{%- style -%}
  #ak-newsletter-{{ section.id }}{
    --ak-purple:#ff33ff;
    --ak-bg:#000;
    --ak-line:rgba(255,255,255,.10);

    /* neutral glass */
    --ak-glass-bg:rgba(255,255,255,.018);
    --ak-glass-border:rgba(255,255,255,.12);
    --ak-glass-highlight:rgba(255,255,255,.08);
  }

  /* IMPORTANT: no outer margin/border here (prevents the gap you saw) */
  #ak-newsletter-{{ section.id }}{
    position:relative;
    width:100%;
    background:#000;
    overflow:hidden;
    isolation:isolate;
    margin:0;            /* FIX */
    border:0;            /* FIX */
    border-radius:0;     /* FIX */
    box-shadow:none;     /* FIX */
  }

  /* Force Dawn gradients/backgrounds to black inside this section wrapper */
  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} .gradient{
    background:#000 !important;
  }

  /* Full-bleed ambient canvas */
  #ak-newsletter-{{ section.id }} .ak-newsletter-bg{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    display:block;
    pointer-events:none;
    z-index:0;
    opacity:1;
    mix-blend-mode:screen;
    filter:contrast(1.1);
    transform:translateZ(0);
  }

  /* SAME WIDTH AS CONTACT FORM ABOVE */
  #ak-newsletter-{{ section.id }} .ak-newsletter-shell{
    position:relative;
    z-index:2;
    max-width:1200px;
    margin:0 auto;
    padding:0 18px;
  }
  @media (max-width: 749px){
    #ak-newsletter-{{ section.id }} .ak-newsletter-shell{ padding:0 10px; }
  }

  .section-{{ section.id }}-padding{
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media (min-width: 750px){
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @keyframes akShimmer{ 0%{ transform:translateX(-60%) } 100%{ transform:translateX(60%) } }
  @keyframes akBlink { 50%{ opacity:0 } }

  /* Panel */
  #ak-newsletter-{{ section.id }} .ak-newsletter-panel{
    position:relative;
    overflow:hidden;
    border-radius:22px;
    padding:3.2rem 2.2rem;
    text-align:center;

    background:var(--ak-glass-bg);
    -webkit-backdrop-filter:blur(56px) saturate(210%) contrast(112%);
    backdrop-filter:blur(56px) saturate(210%) contrast(112%);

    border:1px solid var(--ak-glass-border);
    box-shadow:
      inset 0 1px 0 0 var(--ak-glass-highlight),
      inset 0 -1px 0 0 rgba(0,0,0,.22),
      0 18px 60px rgba(0,0,0,.65);

    font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
    text-transform:uppercase;
    isolation:isolate;
  }

  /* Neutral scan film */
  #ak-newsletter-{{ section.id }} .ak-newsletter-panel::before{
    content:"";
    position:absolute;
    inset:0;
    pointer-events:none;
    z-index:0;
    background:
      repeating-linear-gradient(
        to bottom,
        rgba(255,255,255,.04) 0,
        rgba(255,255,255,.04) 1px,
        transparent 1px,
        transparent 8px
      ),
      linear-gradient(115deg,
        transparent 0%,
        rgba(255,255,255,.10) 45%,
        transparent 60%
      );
    opacity:.06;
    transform:translateX(-40%);
    animation: akShimmer 6.5s linear infinite;
    mix-blend-mode:screen;
  }

  /* Neutral specular highlight */
  #ak-newsletter-{{ section.id }} .ak-newsletter-panel::after{
    content:"";
    position:absolute;
    inset:-1px;
    border-radius:22px;
    pointer-events:none;
    z-index:0;
    background:linear-gradient(
      165deg,
      rgba(255,255,255,.12) 0%,
      rgba(255,255,255,.04) 25%,
      transparent 50%
    );
    mix-blend-mode:screen;
    opacity:1;
  }

  #ak-newsletter-{{ section.id }} .ak-newsletter-panel > *{
    position:relative;
    z-index:2;
  }

  #ak-newsletter-{{ section.id }} .ak-signup-shell{
    display:flex;
    flex-direction:column;
    align-items:center;
  }

  /* Typing heading */
  #ak-newsletter-{{ section.id }} .ak-typing{
    font-size: clamp(2.0rem, 4.6vw, 4.2rem);
    color:#fff;
    letter-spacing:8px;
    white-space:nowrap;
    overflow:hidden;
    border-right:3px solid var(--ak-purple);
    text-shadow:0 0 14px rgba(255,255,255,.10);
    width:0;
    margin-bottom:1.4rem;
    animation:
      akType 4s steps(45, end) forwards,
      akCaret 0.75s step-end infinite,
      akCaretOff 0.55s ease 4s forwards;
  }
  @keyframes akType{ from{ width:0 } to{ width:45ch } }
  @keyframes akCaret{ 0%,100%{ border-color:var(--ak-purple)} 50%{ border-color:transparent } }
  @keyframes akCaretOff{ to{ border-right-color:transparent } }

  #ak-newsletter-{{ section.id }} .ak-caret{
    font-size:2.0rem;
    color:var(--ak-purple);
    animation:akBlink 1s step-start infinite;
    margin-bottom:1rem;
  }

  /* Form reveal */
  #ak-newsletter-{{ section.id }} .ak-form-row{
    display:flex;
    flex-direction:column;
    gap:1.1rem;
    width:100%;
    max-width:460px;
    opacity:0;
    transition:opacity .45s ease;
  }
  #ak-newsletter-{{ section.id }} .ak-signup-shell.active .ak-form-row{ opacity:1; }

  #ak-newsletter-{{ section.id }} .ak-email{
    background:rgba(0,0,0,.38);
    color:#fff;
    border:1px solid rgba(255,255,255,.14);
    border-radius:16px;
    text-align:center;

    font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
    font-size:1.25rem;
    padding:0.95rem 1.25rem;
    text-transform:uppercase;

    outline:none;
    transition: box-shadow .22s ease, transform .18s ease, border-color .22s ease;
  }
  #ak-newsletter-{{ section.id }} .ak-email::placeholder{ color:rgba(255,255,255,.55); opacity:1; }
  #ak-newsletter-{{ section.id }} .ak-email:focus{
    border-color: rgba(255,51,255,.40);
    box-shadow: 0 0 0 1px rgba(255,51,255,.18), 0 0 16px rgba(255,51,255,.18);
    transform:scale(1.02);
  }

  #ak-newsletter-{{ section.id }} .ak-btn{
    background:#000;
    color:var(--ak-purple);
    border:2px solid var(--ak-purple);
    border-radius:16px;

    font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
    font-size:1.12rem;
    padding:0.85rem 1.75rem;
    cursor:pointer;
    text-transform:uppercase;

    box-shadow:0 0 14px rgba(255,51,255,.55);
    transition: transform .15s ease, box-shadow .15s ease, background .15s ease, color .15s ease;
  }
  #ak-newsletter-{{ section.id }} .ak-btn:hover{
    background:var(--ak-purple);
    color:#000;
    box-shadow:0 0 22px rgba(255,51,255,.85);
    transform:scale(1.04);
  }
  #ak-newsletter-{{ section.id }} .ak-btn:active{ transform:scale(1.01); }

  #ak-newsletter-{{ section.id }} .ak-error{
    color:rgba(255,255,255,.85);
    margin-top:.35rem;
    display:block;
  }

  /* Modal */
  #ak-newsletter-{{ section.id }} .ak-modal{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.90);
    display:flex;
    align-items:center;
    justify-content:center;
    z-index:9999;
    overflow:hidden;
  }

  #ak-newsletter-{{ section.id }} .ak-modal-card{
    background: rgba(0,0,0,.82);
    border-radius:22px;
    padding:2.5rem;
    max-width:92%;
    color:#fff;
    text-align:center;

    border:1px solid rgba(255,255,255,.12);
    box-shadow:
      inset 0 1px 0 0 rgba(255,255,255,.10),
      0 18px 60px rgba(0,0,0,.65),
      0 0 26px rgba(255,51,255,.12);

    font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
    font-size:1.18rem;
    text-transform:uppercase;
    position:relative;
    overflow:hidden;
  }

  #ak-newsletter-{{ section.id }} .ak-modal-card strong{
    color:var(--ak-purple);
    text-shadow:0 0 12px rgba(255,51,255,.45);
  }

  #ak-newsletter-{{ section.id }} .ak-copy{ margin-top:1rem; }

  #ak-newsletter-{{ section.id }} .ak-emoji{
    position:absolute;
    font-size:2rem;
    opacity:0;
    pointer-events:none;
    animation: akEmoji 3s ease-out forwards;
  }
  @keyframes akEmoji{
    0%{ transform:translateY(0) scale(1); opacity:0; }
    20%{ opacity:1; }
    100%{ transform:translateY(-120px) scale(1.5); opacity:0; }
  }

  @media (max-width: 749px){
    #ak-newsletter-{{ section.id }} .ak-newsletter-panel{ padding:1.6rem 1.1rem; }
    #ak-newsletter-{{ section.id }} .ak-email{ font-size:1.05rem; }
    #ak-newsletter-{{ section.id }} .ak-btn{ font-size:1rem; padding:0.72rem 1.2rem; }
    #ak-newsletter-{{ section.id }} .ak-modal-card{ font-size:1rem; padding:1.75rem; }
    #ak-newsletter-{{ section.id }} .ak-caret{ font-size:1.5rem; }

    #ak-newsletter-{{ section.id }} .ak-typing{
      font-size: clamp(1.5rem, 7.6vw, 3rem);
      letter-spacing:4px;
      white-space:normal;
      width:auto;
      animation:none;
      border-right:none;
    }
  }

  @media (prefers-reduced-motion: reduce){
    #ak-newsletter-{{ section.id }} .ak-newsletter-bg{ display:none !important; }
    #ak-newsletter-{{ section.id }} .ak-newsletter-panel::before{ animation:none; }
    #ak-newsletter-{{ section.id }} .ak-btn,
    #ak-newsletter-{{ section.id }} .ak-email{ transition:none; }
  }
{%- endstyle -%}

<script src="https://hcaptcha.com/1/api.js?render=explicit" async defer></script>

<script>
(function(){
  function initAkNewsletter(){
    const root = document.getElementById('ak-newsletter-{{ section.id }}');
    if(!root || root.dataset.akInit === '1') return;
    root.dataset.akInit = '1';

    /* Modal + copy */
    const modal = document.getElementById('ak-modal-{{ section.id }}');
    const copyBtn = document.getElementById('ak-copy-{{ section.id }}');
    const closeBtn = document.getElementById('ak-close-{{ section.id }}');

    if(modal){
      for(let i=0;i<10;i++){
        const e=document.createElement('div');
        e.className='ak-emoji';
        e.textContent='💯';
        e.style.left=(Math.random()*80+10)+'%';
        e.style.top='70%';
        e.style.animationDelay=(Math.random()*1.2)+'s';
        modal.appendChild(e);
      }
    }

    if(copyBtn){
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText('ILOVEAMERIKID');
        copyBtn.textContent='COPIED!';
        setTimeout(() => copyBtn.textContent='COPY CODE', 2000);
      });
    }

    if(closeBtn && modal){
      const hide=() => modal.style.display='none';
      closeBtn.addEventListener('click', hide);
      modal.addEventListener('click', (ev) => { if(ev.target === modal) hide(); });
    }

    /* hCaptcha (kept) */
    const form = document.getElementById('ak-form-{{ section.id }}');
    const hField = document.getElementById('ak-hcaptcha-{{ section.id }}');
    const sitekey = 'YOUR_SITE_KEY_HERE';
    let cid;

    function ensureCaptcha(){
      if(cid !== undefined || !window.hcaptcha) return;
      const m=document.createElement('div');
      m.style.display='none';
      document.body.appendChild(m);
      cid = hcaptcha.render(m, {
        sitekey: sitekey,
        size: 'invisible',
        callback: (tok) => { hField.value = tok; form.submit(); }
      });
    }

    if(form){
      form.addEventListener('submit', (ev) => {
        if(!hField || hField.value) return;
        ev.preventDefault();
        ensureCaptcha();
        if(window.hcaptcha && cid !== undefined) hcaptcha.execute(cid);
      });
    }

    /* Ambient starfield + shooting stars */
    const canvas = root.querySelector('.ak-newsletter-bg');
    if(!canvas) return;

    let reduced=false;
    try{ reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches; }catch(e){}
    if(reduced) return;

    const ctx = canvas.getContext('2d', { alpha:true });
    const host = root;

    let w=0,h=0,dpr=1, dust=[], flo=[], met=[];
    let next=0,last=0, raf=0, run=false;

    const C=[
      {r:"255,255,255",h:"#ffffff"},
      {r:"255,51,255", h:"#ff33ff"},
      {r:"127,212,255",h:"#7fd4ff"},
      {r:"255,211,74", h:"#ffd34a"}
    ];
    const R=(a,b)=>a+Math.random()*(b-a);
    const CL=(v,a,b)=>v<a?a:v>b?b:v;

    function rs(){
      const r=host.getBoundingClientRect();
      w=Math.max(1, r.width|0);
      h=Math.max(1, r.height|0);
      dpr=Math.min(window.devicePixelRatio||1,2);
      canvas.width=(w*dpr)|0; canvas.height=(h*dpr)|0;
      canvas.style.width=w+'px'; canvas.style.height=h+'px';
      ctx.setTransform(dpr,0,0,dpr,0,0);
    }

    function pickAccent(){ const x=Math.random(); return x<0.40?1:(x<0.72?2:3); }
    function pickDust(){ return Math.random()<0.86?0:pickAccent(); }
    function pickFlo(){ return Math.random()<0.73?0:pickAccent(); }
    function pickMet(){ return Math.random()<0.78?0:pickAccent(); }
    function kind(){ const x=Math.random(); return x<0.015?2:(x<0.18?1:0); } /* 0 dot, 1 pill, 2 blob */

    function seed(){
      const area=w*h;

      const dc = (CL(area/320, 900, 2400))|0;
      dust=new Array(dc);
      for(let i=0;i<dc;i++){
        const ci=pickDust(), acc=ci!==0;
        dust[i]={
          x:R(0,w), y:R(0,h),
          vx:R(-0.026,0.026), vy:R(-0.022,0.022),
          tw:R(0.28,1.05), ph:R(0,Math.PI*2),
          a:acc?R(0.38,0.66):R(0.12,0.30),
          s:acc?R(1.05,2.25):((Math.random()<0.78)?R(0.55,1.25):R(1.25,1.85)),
          ci:ci, acc:acc
        };
      }

      const fc = (CL(area/5200, 160, 360))|0;
      flo=new Array(fc);
      for(let i=0;i<fc;i++){
        const k=kind(), ci=pickFlo(), acc=ci!==0;
        let a=acc?R(0.42,0.78):R(0.16,0.36);
        if(k===2) a*=0.75; if(k===1) a*=0.9;
        const p={x:R(0,w),y:R(0,h),vx:R(-0.15,0.15),vy:R(-0.13,0.13),k:k,ci:ci,acc:acc,a:a,tw:R(0.38,1.25),ph:R(0,Math.PI*2)};
        if(k===0) p.r=acc?R(2.0,4.6):((Math.random()<0.65)?R(1.2,2.6):R(2.6,3.9));
        else if(k===1){ p.pw=R(6,18); p.phh=R(1.6,3.4); p.rot=R(-0.7,0.7); }
        else p.br=R(4.5,10.5);
        if(acc) p.gl=R(5,11);
        flo[i]=p;
      }
    }

    function rr(x,y,ww,hh,rad){
      const r=Math.min(rad, ww/2, hh/2);
      ctx.beginPath();
      ctx.moveTo(x+r,y); ctx.lineTo(x+ww-r,y); ctx.quadraticCurveTo(x+ww,y,x+ww,y+r);
      ctx.lineTo(x+ww,y+hh-r); ctx.quadraticCurveTo(x+ww,y+hh,x+ww-r,y+hh);
      ctx.lineTo(x+r,y+hh); ctx.quadraticCurveTo(x,y+hh,x,y+hh-r);
      ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y);
      ctx.closePath(); ctx.fill();
    }

    function sched(now){ next = now + R(2400, 6800); }

    function spawn(now){
      const left=Math.random()<0.5;
      const depth=R(0.55,1.0);
      const y=R(h*0.08, h*0.92);
      const x=left?-R(60,140):(w+R(60,140));
      const ang=left?R(-0.42,0.42):R(Math.PI-0.42, Math.PI+0.42);
      const sp=R(720,1450)*(0.70+depth*0.45);
      const life=R(0.60,1.15);
      const ci=pickMet();
      met.push({x:x,y:y,vx:Math.cos(ang)*sp,vy:Math.sin(ang)*sp,t:0,life:life,d:depth,tl:R(120,240)*depth*(sp/1000),lw:R(1.1,2.5)*depth,ci:ci});
      sched(now);
    }

    function drawM(m){
      const p=CL(m.t/m.life,0,1);
      const a=Math.pow(CL(p/0.12,0,1),0.7) * (1-Math.pow(CL((p-0.45)/0.55,0,1),1.8));
      if(a<0.01) return;

      const sp=Math.sqrt(m.vx*m.vx+m.vy*m.vy)||1;
      const dx=m.vx/sp, dy=m.vy/sp;
      const tl=m.tl*(0.65+0.35*a);
      const tx=m.x-dx*tl, ty=m.y-dy*tl;
      const col=C[m.ci];

      ctx.save();
      ctx.lineCap="round";

      let g=ctx.createLinearGradient(tx,ty,m.x,m.y);
      g.addColorStop(0,`rgba(${col.r},0)`);
      g.addColorStop(0.35,`rgba(${col.r},${(0.10*a).toFixed(4)})`);
      g.addColorStop(1,`rgba(${col.r},${(0.28*a).toFixed(4)})`);
      ctx.strokeStyle=g; ctx.lineWidth=m.lw*6;
      ctx.beginPath(); ctx.moveTo(tx,ty); ctx.lineTo(m.x,m.y); ctx.stroke();

      g=ctx.createLinearGradient(tx,ty,m.x,m.y);
      g.addColorStop(0,`rgba(${col.r},0)`);
      g.addColorStop(1,`rgba(${col.r},${(0.62*a).toFixed(4)})`);
      ctx.strokeStyle=g; ctx.lineWidth=m.lw*2.35;
      ctx.beginPath(); ctx.moveTo(tx+(m.x-tx)*0.18, ty+(m.y-ty)*0.18); ctx.lineTo(m.x,m.y); ctx.stroke();

      const hr=m.lw*2.2;
      ctx.shadowBlur=14*m.d; ctx.shadowColor=col.h;

      const hg=ctx.createRadialGradient(m.x,m.y,0,m.x,m.y,hr*3.0);
      hg.addColorStop(0,`rgba(255,255,255,${(0.92*a).toFixed(4)})`);
      hg.addColorStop(0.22,`rgba(${col.r},${(0.60*a).toFixed(4)})`);
      hg.addColorStop(1,`rgba(${col.r},0)`);
      ctx.fillStyle=hg; ctx.beginPath(); ctx.arc(m.x,m.y,hr*3.0,0,Math.PI*2); ctx.fill();

      ctx.restore();
      ctx.shadowBlur=0; ctx.shadowColor="transparent";
    }

    function tick(t){
      const now=t||performance.now();
      const dt=last?CL((now-last)/1000,0.001,0.05):(1/60);
      last=now;

      const time=now*0.001;
      ctx.clearRect(0,0,w,h);
      ctx.globalCompositeOperation="lighter";

      for(let i=0;i<dust.length;i++){
        const d=dust[i], col=C[d.ci];
        d.x+=d.vx; d.y+=d.vy;
        if(d.x<-2) d.x=w+2; else if(d.x>w+2) d.x=-2;
        if(d.y<-2) d.y=h+2; else if(d.y>h+2) d.y=-2;

        const tw=0.70+0.30*Math.sin(time*d.tw+d.ph);
        const a=d.a*tw;

        if(d.acc){ ctx.shadowBlur=3.2; ctx.shadowColor=col.h; } else { ctx.shadowBlur=0; }
        ctx.fillStyle=`rgba(${col.r},${a.toFixed(3)})`;
        ctx.fillRect(d.x-d.s*0.5, d.y-d.s*0.5, d.s, d.s);
      }

      for(let i=0;i<flo.length;i++){
        const p=flo[i], col=C[p.ci];
        p.x+=p.vx; p.y+=p.vy;
        if(p.x<-25) p.x=w+25; else if(p.x>w+25) p.x=-25;
        if(p.y<-25) p.y=h+25; else if(p.y>h+25) p.y=-25;

        const tw=0.65+0.35*Math.sin(time*p.tw+p.ph);
        const a=p.a*tw;

        if(p.acc && p.gl){ ctx.shadowBlur=p.gl*tw; ctx.shadowColor=col.h; }
        else { ctx.shadowBlur=0; ctx.shadowColor="transparent"; }

        ctx.fillStyle=`rgba(${col.r},${a.toFixed(3)})`;

        if(p.k===0){
          ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2); ctx.fill();
        }else if(p.k===1){
          ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rot);
          rr(-p.pw/2,-p.phh/2,p.pw,p.phh,p.phh/2);
          ctx.restore();
        }else{
          const r=p.br;
          ctx.beginPath();
          ctx.arc(p.x,p.y,r,0,Math.PI*2);
          ctx.arc(p.x+r*0.5,p.y-r*0.2,r*0.7,0,Math.PI*2);
          ctx.arc(p.x-r*0.4,p.y+r*0.15,r*0.6,0,Math.PI*2);
          ctx.fill();
        }
      }

      if(!next) sched(now);
      if(now>=next) spawn(now);

      for(let i=met.length-1;i>=0;i--){
        const m=met[i];
        m.t+=dt; m.x+=m.vx*dt; m.y+=m.vy*dt;
        drawM(m);
        const margin=520;
        if(m.t>=m.life || m.x<-margin || m.x>w+margin || m.y<-margin || m.y>h+margin) met.splice(i,1);
      }

      ctx.globalCompositeOperation="source-over";
      ctx.shadowBlur=0; ctx.shadowColor="transparent";

      if(run) raf=requestAnimationFrame(tick); else raf=0;
    }

    function start(){ if(run) return; run=true; if(!raf) raf=requestAnimationFrame(tick); }
    function stop(){ run=false; if(raf){ cancelAnimationFrame(raf); raf=0; } }

    rs(); seed();

    const io=new IntersectionObserver((ents)=>{
      for(const e of ents){ e.isIntersecting ? start() : stop(); }
    }, { threshold:0.12 });
    io.observe(host);

    window.addEventListener('resize', () => { rs(); seed(); }, { passive:true });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', initAkNewsletter, { once:true });
  }else{
    initAkNewsletter();
  }

  document.addEventListener('shopify:section:load', (e) => {
    if(e && e.detail && e.detail.sectionId === '{{ section.id }}'){
      initAkNewsletter();
    }
  });
})();
</script>

