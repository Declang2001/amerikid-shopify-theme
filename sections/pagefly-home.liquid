<script>
  (function () {
    const root = document.documentElement;
    const v = document.getElementById("akLandingVideo");
    if (!v) return;

    const isDesktop = window.matchMedia("(min-width: 768px)").matches;
    if (!isDesktop) return; // on mobile we’re intentionally showing the image

    const fail = () => root.classList.add("ak-video-failed");
    const ready = () => root.classList.add("ak-video-ready");

    v.muted = true;
    v.playsInline = true;

    v.addEventListener("error", fail, { once: true });
    v.addEventListener("playing", ready, { once: true });
    v.addEventListener("canplay", ready, { once: true });

    // Force autoplay
    const tryPlay = () => {
      const p = v.play();
      if (p && typeof p.catch === "function") p.catch(fail);
    };

    if (v.readyState >= 2) tryPlay();
    else v.addEventListener("loadeddata", tryPlay, { once: true });
  })();
