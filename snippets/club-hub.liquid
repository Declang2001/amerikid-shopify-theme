<script>

document.addEventListener('DOMContentLoaded', () => {

const akProxyAction = '{{ ak_proxy_action }}';

const input = document.getElementById('ak-id-photo-input');

const uploadLabel = input ? input.closest('.ak-id-photo-upload') : null;

const uploadLabelSpan = uploadLabel ? uploadLabel.querySelector('span') : null;

const errorEl = document.getElementById('ak-id-photo-error');

function showError(msg) {

if (!errorEl) return;

errorEl.textContent = msg || 'Upload failed. Try again.';

errorEl.classList.add('is-visible');

    }

function hideError() {

if (!errorEl) return;

errorEl.textContent = '';

errorEl.classList.remove('is-visible');

    }

function setBusy(busy, text) {

if (!uploadLabel || !uploadLabelSpan) return;

if (busy) {

uploadLabel.classList.add('is-busy');

uploadLabelSpan.textContent = text || 'UPLOADING…';

if (input) input.disabled = true;

      } else {

uploadLabel.classList.remove('is-busy');

uploadLabelSpan.textContent = text || 'UPLOAD';

if (input) input.disabled = false;

      }

    }

function normalizeMime(t) {

const s = (t || '').toString().toLowerCase().trim();

if (s === 'image/jpg') return 'image/jpeg';

return s;

    }

async function readJsonSafe(res) {

const txt = await res.text();

if (!txt) return null;

try { return JSON.parse(txt); } catch(e) {

return { ok:false, _nonJson:true, _raw: txt };

      }

    }

function safeErrMessage(data, fallback) {

if (!data) return fallback;

if (data.userErrors && data.userErrors.length && data.userErrors[0] && data.userErrors[0].message) {

return data.userErrors[0].message;

      }

if (data._nonJson) return fallback;

if (typeof data.error === 'string' && data.error.length < 240) return data.error;

if (typeof data.message === 'string' && data.message.length < 240) return data.message;

return fallback;

    }

if (input) {

input.addEventListener('change', async (e) => {

const file = e.target.files && e.target.files[0];

if (!file) return;

hideError();

const mime = normalizeMime(file.type);

const allowedTypes = ['image/jpeg', 'image/png'];

if (!allowedTypes.includes(mime)) {

showError('Please upload a JPG or PNG (HEIC/WEBP not supported).');

input.value = '';

return;

        }

const frame = document.querySelector('.ak-id-photo-frame');

if (!frame) return;

// Local preview

const previewUrl = URL.createObjectURL(file);

let img = frame.querySelector('.ak-id-photo-img');

const placeholder = frame.querySelector('.ak-id-photo-placeholder');

if (!img) {

img = document.createElement('img');

img.className = 'ak-id-photo-img';

img.alt = 'Member photo preview';

frame.insertBefore(img, frame.firstChild);

        }

img.src = previewUrl;

if (placeholder) placeholder.remove();

setBusy(true, 'UPLOADING…');

try {

// B) photo_stage

const stageRes = await fetch(`${akProxyAction}?op=photo_stage`, {

method: 'POST',

credentials: 'same-origin',

headers: {

'Content-Type': 'application/json',

'Accept': 'application/json'

            },

body: JSON.stringify({

filename: file.name,

mimeType: mime,

fileSize: file.size

            })

          });

const stageData = await readJsonSafe(stageRes);

if (!stageRes.ok || (stageData && stageData.ok === false)) {

if (stageData && stageData._nonJson && stageData._raw) console.error('photo_stage non-JSON:', stageData._raw);

const msg = safeErrMessage(stageData, `Failed to stage upload (${stageRes.status}).`);

throw new Error(msg);

          }

const uploadUrl = (stageData && (stageData.uploadUrl || stageData.url)) || '';

const resourceUrl = (stageData && stageData.resourceUrl) || '';

let parameters = (stageData && stageData.parameters) || [];

if (parameters && !Array.isArray(parameters) && typeof parameters === 'object') {

parameters = Object.entries(parameters).map(([name, value]) => ({ name, value }));

          }

if (!uploadUrl || !resourceUrl) {

throw new Error('Stage response missing uploadUrl/resourceUrl.');

          }

// C) Upload to staged URL

const form = new FormData();

if (parameters && Array.isArray(parameters)) {

for (const param of parameters) {

if (param && param.name != null && param.value != null) {

form.append(param.name, param.value);

              }

            }

          }

form.append('file', file);

const uploadRes = await fetch(uploadUrl, {

method: 'POST',

body: form

          });

if (!uploadRes.ok) {

let bodyText = '';

try { bodyText = await uploadRes.text(); } catch(err) {}

const trimmed = (bodyText || '').replace(/\s+/g, ' ').trim();

if (trimmed) console.error('storage upload error body:', trimmed);

throw new Error(`Upload to storage failed (${uploadRes.status}).`);

          }

// D) photo_finish

const finishRes = await fetch(`${akProxyAction}?op=photo_finish`, {

method: 'POST',

credentials: 'same-origin',

headers: {

'Content-Type': 'application/json',

'Accept': 'application/json'

            },

body: JSON.stringify({ resourceUrl })

          });

const finishData = await readJsonSafe(finishRes);

if (!finishRes.ok || (finishData && finishData.ok === false)) {

if (finishData && finishData._nonJson && finishData._raw) console.error('photo_finish non-JSON:', finishData._raw);

const msg = safeErrMessage(finishData, `Failed to finalize upload (${finishRes.status}).`);

throw new Error(msg);

          }

const finalUrl =

            (finishData && (finishData.photo_url || finishData.photoUrl || finishData.imageUrl || finishData.url)) || '';

if (finalUrl && img) {

img.src = finalUrl + (finalUrl.indexOf('?') === -1 ? '?' : '&') + 'v=' + Date.now();

setTimeout(() => { try { URL.revokeObjectURL(previewUrl); } catch(e) {} }, 2000);

          } else {

// Keep preview if backend did not return a URL yet

console.warn('photo_finish succeeded but no URL returned. Response:', finishData);

          }

setBusy(false, 'SAVED');

setTimeout(() => {

setBusy(false, 'UPLOAD');

          }, 1500);

        } catch (err) {

console.error('Photo upload error:', err);

showError((err && err.message) ? err.message : 'Upload failed. Try again.');

setBusy(false, 'UPLOAD');

        } finally {

input.value = '';

        }

      });

    }

// Prevent submit until backend is wired

document.addEventListener('submit', (e) => {

const form = e.target;

if (!form || !form.classList || !form.classList.contains('ak-id-form')) return;

const enabled = (form.dataset.backend || '').toString() === 'true';

if (!enabled) {

e.preventDefault();

const note = document.getElementById('ak-save-note');

if (note) note.textContent = 'Backend not wired yet. Next step: App Proxy endpoint to save customer metafields securely.';

      }

    });

/* ============================================
   EMAIL DROPS: Captcha UX — fully reworked
   ============================================ */
(function(){
  var dropsForm = document.getElementById('ak-drops-form');
  var dropsModule = document.getElementById('ak-drops-module');
  var dropsBtn = document.getElementById('ak-drops-submit');
  var captchaDrawer = document.getElementById('ak-drops-captcha');
  var captchaLoading = document.getElementById('ak-captcha-loading');
  var captchaWidget = document.getElementById('ak-captcha-widget');
  if(!dropsForm || !dropsModule || !dropsBtn) return;

  var captchaOpened = false;
  var autoSubmitted = false;
  var pollTimer = null;
  var pollCount = 0;
  var POLL_INTERVAL = 300;
  var MAX_POLLS = Math.ceil(90000 / POLL_INTERVAL); /* 90s timeout */
  var originalBtnText = dropsBtn.textContent;

  /* ---------- Hide Shopify-injected junk text ---------- */
  function scrubJunkText(root){
    if(!root) return;
    /* Remove bare text nodes and labels that Shopify injects (e.g. "CustomerContactFormDrop") */
    var walk = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null, false);
    var toRemove = [];
    while(walk.nextNode()){
      var n = walk.currentNode;
      var txt = (n.textContent || '').trim();
      if(!txt) continue;
      /* Detect Shopify form label junk — anything containing "FormDrop" or the raw form ID pattern */
      if(/FormDrop|CustomerContact|contact_form/i.test(txt)){
        toRemove.push(n);
      }
    }
    toRemove.forEach(function(n){
      if(n.parentNode) n.parentNode.removeChild(n);
    });
    /* Also hide any stray <label> elements not inside our own fields */
    root.querySelectorAll('label').forEach(function(el){
      var txt = (el.textContent || '').trim();
      if(/FormDrop|CustomerContact|contact_form/i.test(txt) || (!el.closest('.ak-drops-bar') && !el.querySelector('input,select,textarea'))){
        el.style.display = 'none';
      }
    });
  }

  /* MutationObserver: catch dynamically-injected captcha nodes and junk text */
  if('MutationObserver' in window){
    var observer = new MutationObserver(function(mutations){
      var needsScrub = false;
      for(var i = 0; i < mutations.length; i++){
        if(mutations[i].addedNodes && mutations[i].addedNodes.length){
          needsScrub = true;
          break;
        }
      }
      if(needsScrub){
        scrubJunkText(dropsForm);
        /* Once captcha iframe appears, hide loading spinner */
        if(captchaWidget && captchaLoading){
          var hasIframe = captchaWidget.querySelector('iframe');
          var hasCheckbox = captchaWidget.querySelector('.h-captcha, .g-recaptcha, [data-sitekey]');
          if(hasIframe || hasCheckbox){
            captchaLoading.classList.add('is-hidden');
          }
        }
      }
    });
    observer.observe(dropsForm, { childList:true, subtree:true });
  }

  /* Initial scrub */
  scrubJunkText(dropsForm);

  /* ---------- Token detection ---------- */
  function findToken(){
    var selectors = [
      'textarea[name="g-recaptcha-response"]',
      'textarea[name="h-captcha-response"]',
      'input[name="g-recaptcha-response"]',
      'input[name="h-captcha-response"]'
    ];
    for(var k = 0; k < selectors.length; k++){
      var el = dropsForm.querySelector(selectors[k]) || document.querySelector(selectors[k]);
      if(el && el.value && el.value.length > 10) return true;
    }
    return false;
  }

  /* ---------- Polling for auto-submit ---------- */
  function startPolling(){
    if(pollTimer) return;
    pollCount = 0;
    pollTimer = setInterval(function(){
      pollCount++;
      if(autoSubmitted || pollCount > MAX_POLLS){
        clearInterval(pollTimer);
        pollTimer = null;
        if(!autoSubmitted){
          dropsBtn.textContent = originalBtnText;
          dropsBtn.removeAttribute('disabled');
        }
        return;
      }
      if(findToken()){
        autoSubmitted = true;
        clearInterval(pollTimer);
        pollTimer = null;
        dropsBtn.textContent = 'JOINING…';
        dropsBtn.setAttribute('disabled', '');
        dropsForm.submit();
      }
    }, POLL_INTERVAL);
  }

  /* ---------- Smooth scroll helper ---------- */
  function scrollDrawerIntoView(){
    if(!captchaDrawer) return;
    setTimeout(function(){
      captchaDrawer.scrollIntoView({ behavior:'smooth', block:'center' });
    }, 180);
  }

  /* ---------- Form submit handler ---------- */
  dropsForm.addEventListener('submit', function(ev){
    /* Always prevent default — we auto-submit programmatically once token exists */
    if(autoSubmitted) return; /* let the real submit go through */

    ev.preventDefault();

    if(!captchaOpened){
      captchaOpened = true;
      dropsModule.classList.add('is-captcha-open');
      dropsBtn.textContent = 'VERIFY…';
      dropsBtn.setAttribute('disabled', '');
      scrollDrawerIntoView();
      startPolling();
      /* Check if captcha widget already loaded (cached) */
      if(captchaWidget && captchaLoading){
        var alreadyLoaded = captchaWidget.querySelector('iframe') || captchaWidget.querySelector('.h-captcha, .g-recaptcha, [data-sitekey]');
        if(alreadyLoaded){
          captchaLoading.classList.add('is-hidden');
        }
      }
      return;
    }

    /* If captcha already open but token exists (edge case: user somehow clicks again) */
    if(findToken()){
      autoSubmitted = true;
      dropsBtn.textContent = 'JOINING…';
      dropsBtn.setAttribute('disabled', '');
      dropsForm.submit();
    }
  });

})();

  });

</script>

<!-- Ambient particles + shooting stars system -->

<script>

(function(){

var canvas = document.getElementById('ak-clubhub-field');

var root = document.querySelector('.ak-clubhub');

if(!canvas || !root) return;

if(canvas.dataset.akInit === '1') return;

canvas.dataset.akInit = '1';

var reduced = false;

try { reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch(e){}

if(reduced) return;

var ctx = canvas.getContext('2d', { alpha:true });

var w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);

var dust = [];

var floaters = [];

var shooters = [];

var nextShooterAt = 0;

var lastFrameTime = 0;

var isVisible = true;

var COLORS = {

white:  { rgb: "255,255,255", hex: "#ffffff" },

purple: { rgb: "255,51,255",  hex: "#ff33ff" },

blue:   { rgb: "127,212,255", hex: "#7fd4ff" },

yellow: { rgb: "255,211,74",  hex: "#ffd34a" }

  };

function clamp(v, a, b){ return Math.min(b, Math.max(a, v)); }

function rand(a, b){ return a + Math.random() * (b - a); }

function resize(){

var rect = root.getBoundingClientRect();

w = Math.max(1, Math.floor(rect.width));

h = Math.max(1, Math.floor(rect.height));

dpr = Math.min(window.devicePixelRatio || 1, 2);

canvas.width = Math.floor(w * dpr);

canvas.height = Math.floor(h * dpr);

canvas.style.width = w + "px";

canvas.style.height = h + "px";

ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  }

function pickAccent(){

var r = Math.random();

if(r < 0.44) return COLORS.purple;

if(r < 0.76) return COLORS.blue;

return COLORS.yellow;

  }

function pickDustColor(){ return (Math.random() < 0.90) ? COLORS.white : pickAccent(); }

function pickFloaterColor(){ return (Math.random() < 0.78) ? COLORS.white : pickAccent(); }

function densityScale(){

var mobile = (window.innerWidth || 1200) < 750;

return mobile ? 0.85 : 1.15;

  }

function seedDust(){

var area = w * h;

var s = densityScale();

var count = Math.round(clamp((area / 140) * s, 1200, 20000));

dust = new Array(count);

for(var i=0;i<count;i++){

var color = pickDustColor();

var isAccent = (color !== COLORS.white);

var vx = rand(-0.028, 0.028);

var vy = rand(-0.022, 0.022);

var tw = rand(0.25, 1.05);

var ph = rand(0, Math.PI * 2);

var a0 = isAccent ? rand(0.20, 0.44) : rand(0.06, 0.18);

var size = isAccent ? rand(2.6, 6.0) : rand(1.3, 3.6);

dust[i] = { x: rand(0,w), y: rand(0,h), vx:vx, vy:vy, color:color, isAccent:isAccent, a0:a0, size:size, tw:tw, ph:ph };

    }

  }

function pickFloaterKind(){

var r = Math.random();

if(r < 0.02) return "blob";

if(r < 0.22) return "pill";

return "dot";

  }

function seedFloaters(){

var area = w * h;

var s = densityScale();

var count = Math.round(clamp((area / 2200) * s, 240, 1400));

floaters = new Array(count);

for(var i=0;i<count;i++){

var kind = pickFloaterKind();

var color = pickFloaterColor();

var isAccent = (color !== COLORS.white);

var vx = rand(-0.16, 0.16);

var vy = rand(-0.13, 0.13);

var tw = rand(0.35, 1.30);

var ph = rand(0, Math.PI * 2);

var a0 = isAccent ? rand(0.20, 0.52) : rand(0.08, 0.22);

if(kind === "blob") a0 *= 0.80;

var p = { x: rand(0,w), y: rand(0,h), vx:vx, vy:vy, kind:kind, color:color, isAccent:isAccent, a0:a0, tw:tw, ph:ph };

if(kind === "dot"){

p.r = isAccent ? rand(3.8, 9.2) : rand(2.8, 6.8);

      } else if(kind === "pill"){

p.pw = rand(12, 40);

p.phh = rand(3.2, 8.0);

p.rot = rand(-0.85, 0.85);

      } else {

p.br = rand(10, 24);

      }

if(isAccent) p.glowSize = rand(14, 34);

floaters[i] = p;

    }

  }

function drawRoundRect(x,y,ww,hh,rr){

var r = Math.min(rr, ww/2, hh/2);

ctx.beginPath();

ctx.moveTo(x+r,y);

ctx.lineTo(x+ww-r,y);

ctx.quadraticCurveTo(x+ww,y,x+ww,y+r);

ctx.lineTo(x+ww,y+hh-r);

ctx.quadraticCurveTo(x+ww,y+hh,x+ww-r,y+hh);

ctx.lineTo(x+r,y+hh);

ctx.quadraticCurveTo(x,y+hh,x,y+hh-r);

ctx.lineTo(x,y+r);

ctx.quadraticCurveTo(x,y,x+r,y);

ctx.closePath();

ctx.fill();

  }

function scheduleNextShooter(now){ nextShooterAt = now + rand(2200, 6200); }

function pickMeteorColor(){ return (Math.random() < 0.80) ? COLORS.white : pickAccent(); }

function spawnShooter(now){

var fromLeft = (Math.random() < 0.5);

var depth = rand(0.55, 1.0);

var y = rand(h * 0.10, h * 0.90);

var startX = fromLeft ? -rand(60, 160) : (w + rand(60, 160));

var angle = fromLeft ? rand(-0.42, 0.42) : rand(Math.PI - 0.42, Math.PI + 0.42);

var speed = rand(650, 1250) * (0.70 + depth * 0.40);

var life = rand(0.60, 1.20);

shooters.push({

x:startX, y:y,

vx: Math.cos(angle) * speed,

vy: Math.sin(angle) * speed,

t:0, life:life, depth:depth,

tail: rand(95, 215) * depth * (speed/1000),

w: rand(0.95, 2.1) * depth,

color: pickMeteorColor()

    });

scheduleNextShooter(now);

  }

function drawShooter(s){

var p = clamp(s.t / s.life, 0, 1);

var fadeIn = Math.pow(clamp(p / 0.12, 0, 1), 0.75);

var fadeOut = 1 - Math.pow(clamp((p - 0.45) / 0.55, 0, 1), 1.9);

var alpha = fadeIn * fadeOut;

if(alpha < 0.01) return;

var spd = Math.sqrt(s.vx*s.vx + s.vy*s.vy) || 1;

var dx = s.vx / spd;

var dy = s.vy / spd;

var tailX = s.x - dx * s.tail;

var tailY = s.y - dy * s.tail;

ctx.save();

ctx.lineCap = "round";

var g1 = ctx.createLinearGradient(tailX, tailY, s.x, s.y);

g1.addColorStop(0, "rgba(" + s.color.rgb + ",0)");

g1.addColorStop(0.55, "rgba(" + s.color.rgb + "," + (0.09*alpha).toFixed(4) + ")");

g1.addColorStop(1, "rgba(" + s.color.rgb + "," + (0.26*alpha).toFixed(4) + ")");

ctx.strokeStyle = g1;

ctx.lineWidth = s.w * 4.9;

ctx.beginPath();

ctx.moveTo(tailX, tailY);

ctx.lineTo(s.x, s.y);

ctx.stroke();

var g2 = ctx.createLinearGradient(tailX, tailY, s.x, s.y);

g2.addColorStop(0, "rgba(255,255,255,0)");

g2.addColorStop(0.55, "rgba(255,255,255," + (0.20*alpha).toFixed(4) + ")");

g2.addColorStop(1, "rgba(255,255,255," + (0.72*alpha).toFixed(4) + ")");

ctx.strokeStyle = g2;

ctx.lineWidth = s.w * 1.10;

ctx.beginPath();

ctx.moveTo(s.x - dx * s.tail * 0.45, s.y - dy * s.tail * 0.45);

ctx.lineTo(s.x, s.y);

ctx.stroke();

ctx.shadowBlur = 14 * s.depth;

ctx.shadowColor = s.color.hex;

var r = s.w * 2.2 * s.depth;

var hg = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, r * 3.0);

hg.addColorStop(0, "rgba(255,255,255," + (0.82*alpha).toFixed(4) + ")");

hg.addColorStop(0.18, "rgba(" + s.color.rgb + "," + (0.50*alpha).toFixed(4) + ")");

hg.addColorStop(0.55, "rgba(" + s.color.rgb + "," + (0.15*alpha).toFixed(4) + ")");

hg.addColorStop(1, "rgba(" + s.color.rgb + ",0)");

ctx.fillStyle = hg;

ctx.beginPath();

ctx.arc(s.x, s.y, r * 3.0, 0, Math.PI*2);

ctx.fill();

ctx.restore();

ctx.shadowBlur = 0;

ctx.shadowColor = "transparent";

  }

/* =========================================================

     FIX: Mobile scroll/viewport resize should NOT reseed particles.

     Instead, resize canvas and scale existing particle positions.

  ========================================================= */

var seededOnce = false;

var resizeRaf = 0;

function hardSeedOnce(){

resize();

seedDust();

seedFloaters();

shooters.length = 0;

nextShooterAt = 0;

lastFrameTime = 0;

seededOnce = true;

  }

function softResizeKeepPositions(){

var oldW = w || 1;

var oldH = h || 1;

resize();

if(!seededOnce){

seedDust();

seedFloaters();

seededOnce = true;

return;

    }

var sx = w / oldW;

var sy = h / oldH;

for(var i = 0; i < dust.length; i++){

dust[i].x *= sx;

dust[i].y *= sy;

    }

for(var j = 0; j < floaters.length; j++){

floaters[j].x *= sx;

floaters[j].y *= sy;

    }

/* meteors are ephemeral, clear them cleanly on resize */

shooters.length = 0;

nextShooterAt = 0;

  }

function requestSoftResize(){

if(resizeRaf) return;

resizeRaf = requestAnimationFrame(function(){

resizeRaf = 0;

softResizeKeepPositions();

    });

  }

function step(t){

if(!isVisible){

requestAnimationFrame(step);

return;

    }

var now = (t || performance.now());

var time = now * 0.001;

var dt = lastFrameTime ? clamp((now - lastFrameTime) / 1000, 0.001, 0.05) : (1/60);

lastFrameTime = now;

ctx.clearRect(0,0,w,h);

ctx.globalCompositeOperation = "lighter";

for(var i=0;i<dust.length;i++){

var d = dust[i];

d.x += d.vx; d.y += d.vy;

if(d.x < -2) d.x = w + 2;

if(d.x > w + 2) d.x = -2;

if(d.y < -2) d.y = h + 2;

if(d.y > h + 2) d.y = -2;

var twk = 0.70 + 0.30 * Math.sin(time * d.tw + d.ph);

var a = d.a0 * twk;

if(d.isAccent){

ctx.shadowBlur = 3;

ctx.shadowColor = d.color.hex;

      } else {

ctx.shadowBlur = 0;

      }

ctx.fillStyle = "rgba(" + d.color.rgb + "," + a.toFixed(3) + ")";

ctx.fillRect(d.x - d.size*0.5, d.y - d.size*0.5, d.size, d.size);

    }

for(var j=0;j<floaters.length;j++){

var p = floaters[j];

p.x += p.vx; p.y += p.vy;

if(p.x < -30) p.x = w + 30;

if(p.x > w + 30) p.x = -30;

if(p.y < -30) p.y = h + 30;

if(p.y > h + 30) p.y = -30;

var twk2 = 0.65 + 0.35 * Math.sin(time * p.tw + p.ph);

var a2 = p.a0 * twk2;

if(p.isAccent && p.glowSize){

ctx.shadowBlur = p.glowSize * twk2;

ctx.shadowColor = p.color.hex;

      } else {

ctx.shadowBlur = 0;

ctx.shadowColor = "transparent";

      }

ctx.fillStyle = "rgba(" + p.color.rgb + "," + a2.toFixed(3) + ")";

if(p.kind === "dot"){

ctx.beginPath();

ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);

ctx.fill();

      } else if(p.kind === "pill"){

ctx.save();

ctx.translate(p.x, p.y);

ctx.rotate(p.rot);

drawRoundRect(-p.pw/2, -p.phh/2, p.pw, p.phh, p.phh/2);

ctx.restore();

      } else {

var r2 = p.br;

ctx.beginPath();

ctx.arc(p.x, p.y, r2, 0, Math.PI*2);

ctx.arc(p.x + r2*0.5, p.y - r2*0.2, r2*0.7, 0, Math.PI*2);

ctx.arc(p.x - r2*0.4, p.y + r2*0.15, r2*0.6, 0, Math.PI*2);

ctx.fill();

      }

    }

if(!nextShooterAt) scheduleNextShooter(now);

if(now >= nextShooterAt) spawnShooter(now);

for(var k=shooters.length-1;k>=0;k--){

var s = shooters[k];

s.t += dt;

s.x += s.vx * dt;

s.y += s.vy * dt;

drawShooter(s);

var margin = 420;

if(s.t >= s.life || s.x < -margin || s.x > w + margin || s.y < -margin || s.y > h + margin){

shooters.splice(k, 1);

      }

    }

ctx.globalCompositeOperation = "source-over";

ctx.shadowBlur = 0;

ctx.shadowColor = "transparent";

requestAnimationFrame(step);

  }

/* initial seed */

hardSeedOnce();

requestAnimationFrame(step);

/* resize listeners now do SOFT resize, not reseed */

window.addEventListener('resize', requestSoftResize, { passive:true });

if(window.visualViewport){

window.visualViewport.addEventListener('resize', requestSoftResize, { passive:true });

  }

if('ResizeObserver' in window){

var ro = new ResizeObserver(function(){ requestSoftResize(); });

ro.observe(root);

  }

if('IntersectionObserver' in window){

var io = new IntersectionObserver(function(entries){

entries.forEach(function(entry){ isVisible = entry.isIntersecting; });

    }, { threshold: 0 });

io.observe(root);

  }

})();

</script>