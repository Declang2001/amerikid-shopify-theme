{%- comment -%}

  Club Hub page content

  File: snippets/club-hub.liquid

  ID / Passport layout concept.

  Profile saving is stubbed until App Proxy backend is wired.

{%- endcomment -%}

{%- assign ak_backend_enabled = true -%}

{%- assign ak_proxy_action = '/apps/club/profile' -%}

{%- comment -%} ADDED: Watermark image URL - update this to the actual kid logo asset path {%- endcomment -%}

{%- assign ak_kid_watermark_src = '' -%}


<script>

  (function(){ document.documentElement.classList.add('ak-clubhub-page'); })();

</script>

<div class="ak-clubhub" role="region" aria-label="Club AmeriKid Hub">

<!-- ADDED: Ambient particles + shooting stars background -->

<canvas class="ak-clubhub-field" id="ak-clubhub-field" aria-hidden="true"></canvas>

<div class="ak-clubhub-inner">

{% if customer == blank %}

<div class="ak-id-shell ak-logged-out">

<div class="ak-id-card">

<div class="ak-id-topbar">

<div class="ak-id-brand">

<div class="ak-id-title">AMERIKID MEMBER ID</div>

<div class="ak-id-sub">Log in to access your card, spins, and profile.</div>

</div>

<div class="ak-id-actions">

<a class="ak-id-btn ak-primary"

href="{{ routes.account_login_url }}?return_to={{ '/pages/club-hub' | url_encode }}">

                LOG IN

</a>

<a class="ak-id-btn"

href="{{ routes.account_register_url }}?return_to={{ '/pages/club-hub' | url_encode }}">

                JOIN

</a>

</div>

</div>

<div class="ak-id-body ak-id-body--loggedout">

<div class="ak-id-photo">

<div class="ak-id-photo-frame">

<div class="ak-id-photo-placeholder">

<div class="ak-id-photo-mark">PHOTO</div>

<div class="ak-id-photo-note">Upload after login</div>

</div>

</div>

</div>

<div class="ak-id-fields">

<div class="ak-field">

<div class="ak-label">STATUS</div>

<div class="ak-value">NOT LOGGED IN</div>

</div>

<div class="ak-field">

<div class="ak-label">BENEFIT</div>

<div class="ak-value">ACCESS TO SPINS + MEMBER DROPS + YOUR ID</div>

</div>

<div class="ak-field">

<div class="ak-label">NEXT</div>

<div class="ak-value">LOG IN OR JOIN TO ISSUE YOUR CARD</div>

</div>

<div class="ak-id-hint">

                This page is your "best of both worlds" hub. It's custom AmeriKid UI, but still links into Shopify's official Orders and Account pages.

</div>

</div>

</div>

</div>

</div>

{% else %}

{%- assign spins = customer.metafields.club.spins_available.value | default: 0 -%}

{%- assign joined_at = customer.metafields.club.joined_at.value -%}

{%- assign birthday = customer.metafields.club.birthday.value -%}

{%- assign top_size = customer.metafields.club.top_size.value -%}

{%- assign bottom_size = customer.metafields.club.bottom_size.value -%}

{%- assign favorite_color = customer.metafields.club.favorite_color.value -%}

{%- assign favorite_album = customer.metafields.club.favorite_album.value -%}

{%- assign dream_piece = customer.metafields.club.dream_piece.value -%}

{%- assign photo_val = customer.metafields.club.photo_url.value -%}

{%- assign photo_src = '' -%}

{%- if photo_val != blank -%}

{%- if photo_val.url -%}

{%- assign photo_src = photo_val.url -%}

{%- else -%}

{%- assign photo_src = photo_val -%}

{%- endif -%}

{%- endif -%}

{%- assign member_id_num = customer.id | modulo: 1000000 -%}

{%- assign issued_date = joined_at | default: 'now' | date: "%b %d, %Y" -%}

{%- comment -%} Email marketing subscription check {%- endcomment -%}
{%- assign ak_already_subscribed = false -%}
{%- if customer.accepts_marketing == true -%}
{%- assign ak_already_subscribed = true -%}
{%- endif -%}
{%- if customer.email_marketing_consent -%}
{%- if customer.email_marketing_consent.state == "subscribed" or customer.email_marketing_consent.state == "pending" -%}
{%- assign ak_already_subscribed = true -%}
{%- endif -%}
{%- endif -%}

<div class="ak-id-shell ak-logged-in">

{%- unless ak_already_subscribed -%}
<div class="ak-drops-module" id="ak-drops-module">
{% form 'customer', id: 'ak-drops-form', class: 'ak-drops-inner' %}
<input type="hidden" name="contact[accepts_marketing]" value="true">
<input type="hidden" name="contact[tags]" value="club_amerikid,newsletter">
<input type="hidden" name="return_to" value="/pages/club-hub">
{% if form.posted_successfully? %}
<div class="ak-drops-bar">
<div class="ak-drops-success">📡 EMAIL DROPS: ACTIVE</div>
</div>
{% else %}
<div class="ak-drops-bar">
<div class="ak-drops-heading">📡 SIGN UP FOR EMAIL DROPS</div>
{% if form.errors %}
<div class="ak-drops-error">{{ form.errors | default_errors }}</div>
{% endif %}
<div class="ak-drops-row">
<input type="email" name="contact[email]" class="ak-input ak-drops-email" value="{{ customer.email | escape }}" placeholder="you@example.com" required autocomplete="email">
<button type="submit" class="ak-id-btn ak-primary ak-drops-btn" id="ak-drops-submit">SUBSCRIBE</button>
</div>
</div>
<div class="ak-drops-captcha" id="ak-drops-captcha">
<div class="ak-captcha-note" aria-live="polite">COMPLETE VERIFICATION TO FINISH SUBSCRIBING</div>
<div class="ak-captcha-helper">Once verified, you'll be subscribed automatically.</div>
<div class="ak-captcha-loading" id="ak-captcha-loading">
<div class="ak-captcha-spinner"></div>
<span>LOADING VERIFICATION…</span>
</div>
<div class="ak-captcha-widget" id="ak-captcha-widget">
{{ form | captcha }}
</div>
</div>
{% endif %}
{% endform %}
</div>
{%- endunless -%}

<div class="ak-id-card">

<div class="ak-id-topbar">

<div class="ak-id-brand">

<div class="ak-id-title">AMERIKID MEMBER ID</div>

<div class="ak-id-sub">

                ISSUED: <strong>{{ issued_date }}</strong>

<span class="ak-dot">•</span>

                MEMBER ID: <strong>AK-{{ member_id_num }}</strong>

</div>

<div class="ak-id-chips">

<span class="ak-chip">SPINS: <strong>{{ spins }}</strong></span>

</div>

</div>

<div class="ak-id-actions">

<a class="ak-id-btn" href="/account/orders">ORDERS</a>

<a class="ak-id-btn" href="{{ routes.account_url }}">ACCOUNT</a>

<a class="ak-id-btn ak-warn" href="{{ routes.account_logout_url }}">LOG OUT</a>

</div>

</div>

<div class="ak-id-body">

<!-- PHOTO COLUMN -->

<div class="ak-id-photo">

<div class="ak-id-photo-frame">

{% if photo_src != blank %}

<img class="ak-id-photo-img" src="{{ photo_src }}" alt="Member photo">

{% else %}

<div class="ak-id-photo-placeholder">

<div class="ak-id-photo-mark">PHOTO</div>

<div class="ak-id-photo-note">Add photo (next)</div>

</div>

{% endif %}

<!-- Upload -->

<label class="ak-id-photo-upload">

<input type="file" accept="image/png,image/jpeg" id="ak-id-photo-input" />

<span>UPLOAD</span>

</label>

<div class="ak-id-photo-error" id="ak-id-photo-error"></div>

<!-- ADDED: Holographic strip decoration -->

<div class="ak-holo-strip" aria-hidden="true"></div>

</div>

<div class="ak-id-mini">

<div class="ak-mini-label">EMAIL</div>

<div class="ak-mini-value">{{ customer.email }}</div>

</div>

<!-- ADDED: Phone mini card -->

<div class="ak-id-mini">

<div class="ak-mini-label">PHONE</div>

<div class="ak-mini-value">

{% if customer.phone != blank %}

{{ customer.phone | escape }}

{% else %}

NOT SET

{% endif %}

</div>

</div>

</div>

<!-- FIELDS COLUMN -->

<div class="ak-id-fields">

<div class="ak-id-section-title">YOUR ID DETAILS</div>

<form class="ak-id-form"

method="post"

action="{{ ak_proxy_action }}"

data-backend="{{ ak_backend_enabled }}">

<input type="hidden" name="return_to" value="/pages/club-hub">

<div class="ak-grid">

<div class="ak-field">

<label class="ak-label" for="ak-first">FIRST NAME</label>

<input id="ak-first" class="ak-input" type="text" name="first_name"

value="{{ customer.first_name | escape }}" placeholder="First name" autocomplete="given-name">

</div>

<div class="ak-field">

<label class="ak-label" for="ak-last">LAST NAME</label>

<input id="ak-last" class="ak-input" type="text" name="last_name"

value="{{ customer.last_name | escape }}" placeholder="Last name" autocomplete="family-name">

</div>

<!-- ADDED: Phone field -->

<div class="ak-field">

<label class="ak-label" for="ak-phone">PHONE</label>

<input id="ak-phone" class="ak-input" type="tel" name="phone"

value="{{ customer.phone | escape }}"

placeholder="ex: +1 555 123 4567" autocomplete="tel">

</div>

<div class="ak-field">

<label class="ak-label" for="ak-bday">DATE OF BIRTH</label>

<input id="ak-bday" class="ak-input" type="date" name="birthday"

value="{% if birthday %}{{ birthday | date: "%Y-%m-%d" }}{% endif %}">

</div>

<!-- SMS Opt-In: hidden once customer has already consented -->

{%- assign sms_consent_raw = customer.metafields.club.sms_consent.value | default: customer.metafields.club.sms_consent -%}

{%- assign smsOptedIn = false -%}

{%- if sms_consent_raw == true or sms_consent_raw == "true" -%}

{%- assign smsOptedIn = true -%}

{%- endif -%}

{% unless smsOptedIn %}

<div class="ak-field ak-span-2">

<label class="ak-label" for="ak-sms-consent">SMS OPT-IN</label>

<label style="display:flex; gap:10px; align-items:flex-start;">

<input id="ak-sms-consent" type="checkbox" name="sms_consent" value="1" style="margin-top:4px;">

<span style="font-size:13px; line-height:1.4; opacity:0.9;">

I agree to receive marketing texts from AmeriKid. Msg and data rates may apply. Reply STOP to unsubscribe.

</span>

</label>

</div>

{% endunless %}

<div class="ak-field">

<label class="ak-label" for="ak-top">TOP SIZE</label>

<select id="ak-top" class="ak-input" name="top_size">

<option value="" {% if top_size == blank %}selected{% endif %}>Select</option>

<option {% if top_size == 'XS' %}selected{% endif %}>XS</option>

<option {% if top_size == 'S' %}selected{% endif %}>S</option>

<option {% if top_size == 'M' %}selected{% endif %}>M</option>

<option {% if top_size == 'L' %}selected{% endif %}>L</option>

<option {% if top_size == 'XL' %}selected{% endif %}>XL</option>

<option {% if top_size == 'XXL' %}selected{% endif %}>XXL</option>

</select>

</div>

<div class="ak-field">

<label class="ak-label" for="ak-bottom">BOTTOM SIZE</label>

<select id="ak-bottom" class="ak-input" name="bottom_size">

<option value="" {% if bottom_size == blank %}selected{% endif %}>Select</option>

<option {% if bottom_size == '28' %}selected{% endif %}>28</option>

<option {% if bottom_size == '30' %}selected{% endif %}>30</option>

<option {% if bottom_size == '32' %}selected{% endif %}>32</option>

<option {% if bottom_size == '34' %}selected{% endif %}>34</option>

<option {% if bottom_size == '36' %}selected{% endif %}>36</option>

<option {% if bottom_size == '38' %}selected{% endif %}>38</option>

</select>

</div>

<div class="ak-field">

<label class="ak-label" for="ak-color">FAVORITE COLOR</label>

<input id="ak-color" class="ak-input" type="text" name="favorite_color"

value="{{ favorite_color | escape }}" placeholder="ex: purple / black / neon green" maxlength="24">

</div>

<div class="ak-field ak-span-2">

<label class="ak-label" for="ak-album">FAVORITE ALBUM</label>

<input id="ak-album" class="ak-input" type="text" name="favorite_album"

value="{{ favorite_album | escape }}" placeholder="ex: Bad Music Vol. 1" maxlength="40">

</div>

<div class="ak-field ak-span-2">

<label class="ak-label" for="ak-dream">DREAM AMERIKID PIECE (MAX 60)</label>

<textarea id="ak-dream" class="ak-input ak-textarea" name="dream_piece"

maxlength="60" rows="2"

placeholder="ex: a zombie-slayer hat with glow ink">{% if dream_piece %}{{ dream_piece | escape }}{% endif %}</textarea>

</div>

</div>

<div class="ak-form-footer">

<button class="ak-id-btn ak-primary" type="submit">

                    SAVE PROFILE

</button>

<div class="ak-save-note" id="ak-save-note">

                    Saved to your member profile.

</div>

</div>

</form>

</div>

</div>

<!-- Watermark seal — visible bottom-left of logged-in card -->

<div class="ak-card-seal" aria-hidden="true">
  <img
    src="https://cdn.shopify.com/s/files/1/0930/3267/7656/files/KID_SCRIBBLE_OUTLINE_6bd5ffa8-d310-4eb9-be67-23cf56737678.png?v=1747881692"
    alt=""
    loading="lazy"
    decoding="async"
  >
</div>


</div>

</div>

{% endif %}

</div>

</div>

<style>

/* IMPACT FONT: Force across entire Club Hub */
.ak-clubhub, .ak-clubhub *{
font-family: Impact, Haettenschweiler, "Arial Black", "Arial Narrow Bold", sans-serif !important;
  }

:root{

--ak-purple:#ff33ff;

--ak-cyan:#33ffff;

--ak-green:#33ff66;

--ak-black:#000;

--ak-paper:#f6f4ee;

--ak-ink:#121218;

  }

.ak-clubhub-page body,

.ak-clubhub-page #MainContent{

background:#000 !important;

  }

.ak-clubhub-page #MainContent .page-width{

max-width: none !important;

padding-left: 0 !important;

padding-right: 0 !important;

  }

.ak-clubhub{

background:#000;

color:#fff;

padding: clamp(14px, 2vw, 26px) 18px clamp(40px, 7vw, 90px);

min-height: 100svh;

display:flex;

align-items:flex-start;

position: relative;

isolation: isolate;

overflow: hidden;

  }

.ak-clubhub .ak-clubhub-field{

position:absolute;

inset:0;

width:100%;

height:100%;

z-index:0;

pointer-events:none;

mix-blend-mode:screen;

opacity:1;

filter:contrast(1.10) saturate(1.10);

  }

.ak-clubhub-inner{

width:100%;

max-width: 1180px;

margin: 0 auto;

position: relative;

z-index: 1;

  }

.ak-id-shell{

width: 100%;

display:flex;

justify-content:center;

  }

.ak-id-card{

width: 100%;

border-radius: 22px;

border: 2px solid rgba(255,51,255,0.35);

background:

radial-gradient(900px 400px at 20% -10%, rgba(255,51,255,0.18), transparent 55%),

radial-gradient(900px 400px at 80% 0%, rgba(51,255,255,0.14), transparent 55%),

linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));

box-shadow:

0 22px 55px rgba(0,0,0,0.60),

0 0 55px rgba(255,51,255,0.12);

backdrop-filter: blur(12px);

-webkit-backdrop-filter: blur(12px);

padding: clamp(16px, 2.4vw, 26px);

overflow:hidden;

position: relative;

isolation: isolate;

  }

/* ADDED: Watermark background using kid logo */

{% if ak_kid_watermark_src != blank %}

.ak-logged-in .ak-id-card::before{

content: '';

position: absolute;

inset: 0;

background-image: url('{{ ak_kid_watermark_src }}');

background-repeat: no-repeat;

background-position: center center;

background-size: 45% auto;

opacity: 0.05;

pointer-events: none;

z-index: 0;

filter: grayscale(100%) brightness(2);

  }

{% endif %}

/* Guilloche / microline security pattern overlay */

.ak-logged-in .ak-id-card::after{

content: '';

position: absolute;

inset: 0;

pointer-events: none;

z-index: 0;

opacity: 0.025;

background-image:

repeating-linear-gradient(

0deg,

transparent 0px,

transparent 2px,

rgba(255,255,255,0.5) 2px,

rgba(255,255,255,0.5) 3px

      ),

repeating-linear-gradient(

90deg,

transparent 0px,

transparent 2px,

rgba(255,255,255,0.3) 2px,

rgba(255,255,255,0.3) 3px

      ),

repeating-linear-gradient(

45deg,

transparent 0px,

transparent 8px,

rgba(255,51,255,0.2) 8px,

rgba(255,51,255,0.2) 9px

      ),

repeating-linear-gradient(

-45deg,

transparent 0px,

transparent 8px,

rgba(51,255,255,0.2) 8px,

rgba(51,255,255,0.2) 9px

      );

mix-blend-mode: overlay;

  }

/* Watermark seal — bottom-left of logged-in card, VISIBLE */
.ak-card-seal{
  position: absolute;
  bottom: 18px;
  left: 22px;
  width: 130px;
  height: 130px;
  opacity: 0.18;
  pointer-events: none;
  z-index: 6;
  transform: rotate(-12deg);
  filter: brightness(2.2) contrast(1.1) drop-shadow(0 0 18px rgba(255,51,255,0.20));
}

.ak-card-seal img{
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}


.ak-id-title,

.ak-id-sub,

.ak-id-section-title,

.ak-label,

.ak-mini-label,

.ak-mini-value{

color:#fff !important;

position: relative;

z-index: 1;

  }

.ak-id-topbar{

display:flex;

align-items:flex-start;

justify-content:space-between;

gap: 16px;

flex-wrap:wrap;

margin-bottom: 16px;

position: relative;

z-index: 1;

  }

.ak-id-title{

font-weight: 900;

letter-spacing: 0.14em;

text-transform: uppercase;

font-size: clamp(20px, 2.1vw, 28px);

line-height: 1.1;

  }

.ak-id-sub{

margin-top: 6px;

color: rgba(255,255,255,0.80) !important;

font-size: 12px;

letter-spacing: 0.06em;

text-transform: uppercase;

  }

.ak-dot{ margin: 0 8px; opacity: 0.8; }

.ak-id-chips{

display:flex;

gap: 10px;

flex-wrap:wrap;

margin-top: 10px;

  }

.ak-chip{

display:inline-flex;

gap: 6px;

align-items:center;

padding: 9px 12px;

border-radius: 999px;

border: 1px solid rgba(255,255,255,0.16);

background: rgba(0,0,0,0.35);

font-size: 12px;

font-weight: 800;

letter-spacing: 0.08em;

text-transform: uppercase;

  }

.ak-id-actions{

display:flex;

gap: 10px;

flex-wrap:wrap;

position: relative;

z-index: 1;

  }

.ak-id-btn{

display:inline-flex;

align-items:center;

justify-content:center;

padding: 12px 16px;

border-radius: 14px;

border: 1px solid rgba(255,255,255,0.20);

background: rgba(0,0,0,0.38);

color:#fff !important;

text-decoration:none;

font-weight: 900;

letter-spacing: 0.10em;

text-transform: uppercase;

font-size: 12px;

transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, filter 160ms ease;

user-select:none;

position: relative;

z-index: 1;

  }

.ak-id-btn:hover{

transform: translateY(-1px);

background: rgba(255,255,255,0.06);

border-color: rgba(255,255,255,0.30);

  }

.ak-primary{

border-color: rgba(255,51,255,0.65);

box-shadow: 0 0 34px rgba(255,51,255,0.18);

  }

.ak-warn{

border-color: rgba(255,255,255,0.26);

  }

.ak-id-body{

display:grid;

grid-template-columns: 260px minmax(0, 1fr);

gap: 18px;

align-items:start;

position: relative;

z-index: 1;

  }

.ak-id-body--loggedout{

grid-template-columns: 260px minmax(0, 1fr);

  }

.ak-id-photo-frame{

border-radius: 18px;

border: 1px solid rgba(255,255,255,0.18);

background: rgba(0,0,0,0.45);

padding: 12px;

position: relative;

overflow:hidden;

min-height: 260px;

display:flex;

align-items:center;

justify-content:center;

  }

/* Holographic strip effect */

.ak-holo-strip{

position: absolute;

bottom: 52px;

left: 12px;

width: calc(100% - 24px);

height: 6px;

border-radius: 3px;

pointer-events: none;

z-index: 2;

background: linear-gradient(

90deg,

rgba(255,51,255,0.3) 0%,

rgba(51,255,255,0.4) 20%,

rgba(255,211,74,0.3) 40%,

rgba(51,255,102,0.4) 60%,

rgba(255,51,255,0.3) 80%,

rgba(51,255,255,0.4) 100%

    );

background-size: 200% 100%;

animation: ak-holo-shift 4s ease-in-out infinite;

opacity: 0.7;

mix-blend-mode: screen;

  }

@keyframes ak-holo-shift{

    0%, 100% { background-position: 0% 50%; }

    50% { background-position: 100% 50%; }

  }

.ak-id-photo-img{

width:100%;

height:100%;

object-fit: cover;

border-radius: 12px;

display:block;

  }

.ak-id-photo-placeholder{

width:100%;

height:100%;

min-height: 220px;

border-radius: 12px;

display:flex;

flex-direction:column;

align-items:center;

justify-content:center;

border: 1px dashed rgba(255,255,255,0.22);

background: rgba(255,255,255,0.04);

text-align:center;

  }

.ak-id-photo-mark{

font-weight: 900;

letter-spacing: 0.18em;

text-transform: uppercase;

font-size: 14px;

  }

.ak-id-photo-note{

margin-top: 8px;

opacity: 0.75;

font-size: 12px;

letter-spacing: 0.08em;

text-transform: uppercase;

  }

.ak-id-photo-upload{

position:absolute;

bottom: 12px;

right: 12px;

cursor:pointer;

user-select:none;

display:inline-flex;

align-items:center;

justify-content:center;

padding: 10px 12px;

border-radius: 12px;

border: 1px solid rgba(255,255,255,0.22);

background: rgba(0,0,0,0.55);

font-weight: 900;

letter-spacing: 0.10em;

text-transform: uppercase;

font-size: 11px;

z-index: 3;

  }

.ak-id-photo-upload input{

display:none;

  }

.ak-id-photo-upload.is-busy{

opacity: 0.6;

pointer-events: none;

  }

.ak-id-photo-error{

position: absolute;

bottom: 52px;

right: 12px;

left: 12px;

text-align: center;

font-size: 11px;

font-weight: 700;

letter-spacing: 0.06em;

color: #ff6b6b;

background: rgba(0,0,0,0.75);

border-radius: 8px;

padding: 6px 8px;

display: none;

z-index: 4;

  }

.ak-id-photo-error.is-visible{

display: block;

  }

.ak-id-mini{

margin-top: 10px;

border-radius: 14px;

border: 1px solid rgba(255,255,255,0.14);

