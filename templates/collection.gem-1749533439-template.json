    "custom_liquid_J6HYJT": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- Stylesheet imports -->\n<link rel=\"stylesheet\" href=\"{{ 'component-list-menu.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n<link rel=\"stylesheet\" href=\"{{ 'component-search.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n<link rel=\"stylesheet\" href=\"{{ 'component-menu-drawer.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n<link rel=\"stylesheet\" href=\"{{ 'component-cart-notification.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n\n{% if settings.predictive_search_enabled %}\n  <link rel=\"stylesheet\" href=\"{{ 'component-price.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n{% endif %}\n\n{% if section.settings.menu_type_desktop == 'mega' %}\n  <link rel=\"stylesheet\" href=\"{{ 'component-mega-menu.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n{% endif %}\n\n<!-- Custom Styles -->\n<style>\n  .header-wrapper {\n    background: white !important;\n  }\n\n  .header__heading-logo-wrapper {\n    cursor: pointer;\n    display: inline-block;\n  }\n\n  .header__heading-link {\n    text-decoration: none;\n    display: inline-block;\n  }\n\n  header-drawer {\n    justify-self: start;\n    margin-left: -1.2rem;\n  }\n\n  {% if section.settings.sticky_header_type == 'reduce-logo-size' %}\n    .scrolled-past-header .header__heading-logo-wrapper {\n      width: 75%;\n    }\n  {% endif %}\n\n  {% if section.settings.menu_type_desktop != \"drawer\" %}\n    @media screen and (min-width: 990px) {\n      header-drawer {\n        display: none;\n      }\n    }\n  {% endif %}\n\n  .menu-drawer-container {\n    display: flex;\n  }\n\n  .list-menu {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n  }\n\n  .list-menu--inline {\n    display: inline-flex;\n    flex-wrap: wrap;\n  }\n\n  summary.list-menu__item {\n    padding-right: 2.7rem;\n  }\n\n  .list-menu__item {\n    display: flex;\n    align-items: center;\n    line-height: calc(1 + 0.3 \/ var(--font-body-scale));\n  }\n\n  .list-menu__item--link {\n    text-decoration: none;\n    padding: 1rem 0;\n    line-height: calc(1 + 0.8 \/ var(--font-body-scale));\n  }\n\n  @media screen and (min-width: 750px) {\n    .list-menu__item--link {\n      padding: 0.5rem 0;\n    }\n  }\n\n  .cart-bubble-container {\n    position: absolute;\n    top: 50%;\n    right: 2rem;\n    transform: translateY(-50%);\n    z-index: 1000;\n  }\n<\/style>\n\n{% style %}\n  .header {\n    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 3rem;\n  }\n\n  .section-header {\n    position: sticky;\n    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;\n  }\n\n  @media screen and (min-width: 750px) {\n    .section-header {\n      margin-bottom: {{ section.settings.margin_bottom }}px;\n    }\n  }\n\n  @media screen and (min-width: 990px) {\n    .header {\n      padding-top: {{ section.settings.padding_top }}px;\n      padding-bottom: {{ section.settings.padding_bottom }}px;\n    }\n  }\n{% endstyle %}\n\n<script src=\"{{ 'cart-notification.js' | asset_url }}\" defer=\"defer\"><\/script>\n\n{% liquid\n  assign header_tag = 'div'\n  if section.settings.sticky_header_type != 'none'\n    assign header_tag = 'sticky-header'\n  endif\n%}\n\n<{{ header_tag }}\n  class=\"header-wrapper color-{{ section.settings.color_scheme }}{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}\"\n  {% if header_tag == 'sticky-header' %}\n    data-sticky-type=\"{{ section.settings.sticky_header_type }}\"\n  {% endif %}\n>\n  <header class=\"header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}\">\n    \n    {% if section.settings.menu != blank %}\n      {% render 'header-drawer' %}\n    {% endif %}\n\n    {% if section.settings.logo_position == 'top-center' or section.settings.menu == blank %}\n      {% render 'header-search', input_id: 'Search-In-Modal-1' %}\n    {% endif %}\n\n    {% if section.settings.menu != blank and section.settings.menu_type_desktop == 'drawer' %}\n      <a\n        href=\"javascript:void(0)\"\n        id=\"logo-menu-toggle-left\"\n        aria-label=\"Toggle menu\"\n        class=\"header__heading-link focus-inset\"\n      >\n        <div class=\"header__heading-logo-wrapper\">\n          <svg style=\"width: 24px; height: 24px; fill: currentColor;\">\n            <rect y=\"4\" width=\"24\" height=\"2\"><\/rect>\n            <rect y=\"11\" width=\"24\" height=\"2\"><\/rect>\n            <rect y=\"18\" width=\"24\" height=\"2\"><\/rect>\n          <\/svg>\n        <\/div>\n      <\/a>\n    {% endif %}\n\n    <!-- ✅ LOGO now links to \/collections\/all -->\n    <a href=\"{{ shop.url }}\" class=\"header__heading-link link link--text focus-inset\" style=\"margin: 0 auto;\">\n      {% if settings.logo != blank %}\n        <div class=\"header__heading-logo-wrapper\">\n          {% assign logo_alt = settings.logo.alt | default: shop.name | escape %}\n          {% assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio %}\n          {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 50vw{% endcapture %}\n          {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}\n          {{\n            settings.logo\n            | image_url: width: 600\n            | image_tag:\n              class: 'header__heading-logo',\n              widths: widths,\n              height: logo_height,\n              width: settings.logo_width,\n              alt: logo_alt,\n              sizes: sizes,\n              preload: true\n          }}\n        <\/div>\n      {% endif %}\n    <\/a>\n\n    <div class=\"cart-bubble-container\">\n      {% render 'cart-icon-bubble' %}\n    <\/div>\n  <\/header>\n<\/{{ header_tag }}>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const logoToggleLeft = document.getElementById('logo-menu-toggle-left');\n    if (logoToggleLeft) {\n      logoToggleLeft.addEventListener('click', () => {\n        const drawer = document.querySelector('header-drawer');\n        if (drawer) drawer.open = !drawer.open;\n      });\n    }\n  });\n<\/script>",
        "color_scheme": "",
        "padding_top": 12,
        "padding_bottom": 0
      }
    },
