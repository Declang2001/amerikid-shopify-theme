    "custom_liquid_R6CiTK": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div class=\"bouncing-header-box\" id=\"bouncing-container\" style=\"position: relative; height: 150px; border-bottom: 2px solid #000; overflow: hidden; z-index: 999; background: white;\">\n  <!-- Cart button container, positioned center right -->\n  <div id=\"cart-button\" style=\"position: absolute; top: 50%; right: 2rem; transform: translateY(-50%); z-index: 1000;\">\n    {% render 'cart-icon-bubble' %}\n  <\/div>\n<\/div>\n\n<style>\n  \/* Bouncing logos styles *\/\n  .bouncing-logo-link {\n    position: absolute;\n    display: block;\n  }\n\n  .bouncing-logo {\n    width: 45px;\n    height: 45px;\n    display: block;\n    pointer-events: auto;\n    animation: pulseGlow 3s ease-in-out infinite;\n    filter: drop-shadow(0 0 10px white);\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {\n      filter: drop-shadow(0 0 10px white);\n    }\n    50% {\n      filter: drop-shadow(0 0 20px white);\n    }\n  }\n<\/style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const container = document.getElementById(\"bouncing-container\");\n    const cartButton = document.getElementById(\"cart-button\");\n\n    \/\/ Clicking anywhere in the container except the cart button goes to \/collections\/all\n    container.addEventListener(\"click\", function () {\n      window.location.href = \"\/collections\/all\";\n    });\n\n    \/\/ Prevent clicks on cart button from bubbling up to container\n    cartButton.addEventListener(\"click\", function (event) {\n      event.stopPropagation();\n    });\n\n    \/\/ --- Bouncing Logos code ---\n    const logoSrc = \"https:\/\/cdn.shopify.com\/s\/files\/1\/0930\/3267\/7656\/files\/KID_SCRIBBLE_OUTLINE_6bd5ffa8-d310-4eb9-be67-23cf56737678.png?v=1747881692\";\n\n    \/\/ Set logoCount based on screen width: max 10 on mobile (<750px), else 30\n    const logoCount = window.innerWidth < 750 ? 10 : 30;\n\n    const logos = [];\n    const speeds = [];\n    const positions = [];\n\n    const logoWidth = 30;\n    const logoHeight = 30;\n\n    function isOverlapping(x1, y1, w1, h1, x2, y2, w2, h2) {\n      return !(x1 + w1 < x2 || x1 > x2 + w2 || y1 + h1 < y2 || y1 > y2 + h2);\n    }\n\n    function findNonOverlappingPosition() {\n      let tries = 0;\n      while (tries < 1000) {\n        const x = Math.random() * (container.clientWidth - logoWidth);\n        const y = Math.random() * (container.clientHeight - logoHeight);\n        let overlapping = false;\n        for (const pos of positions) {\n          if (isOverlapping(x, y, logoWidth, logoHeight, pos.x, pos.y, logoWidth, logoHeight)) {\n            overlapping = true;\n            break;\n          }\n        }\n        if (!overlapping) {\n          return { x, y };\n        }\n        tries++;\n      }\n      return { x: 0, y: 0 };\n    }\n\n    for (let i = 0; i < logoCount; i++) {\n      const link = document.createElement(\"a\");\n      link.href = \"\/collections\/all\";\n      link.className = \"bouncing-logo-link\";\n\n      const img = document.createElement(\"img\");\n      img.src = logoSrc;\n      img.alt = \"Bouncing Logo\";\n      img.className = \"bouncing-logo\";\n\n      link.appendChild(img);\n      container.appendChild(link);\n\n      const pos = findNonOverlappingPosition();\n      positions.push(pos);\n\n      logos.push(link);\n\n      speeds.push({\n        x: (Math.random() < 0.5 ? -1 : 1) * (0.3 + Math.random() * 0.3),\n        y: (Math.random() < 0.5 ? -1 : 1) * (0.3 + Math.random() * 0.3),\n        posX: pos.x,\n        posY: pos.y\n      });\n    }\n\n    function move() {\n      for (let i = 0; i < logoCount; i++) {\n        const logo = logos[i];\n        const speed = speeds[i];\n\n        speed.posX += speed.x;\n        speed.posY += speed.y;\n\n        if (speed.posX <= 0) {\n          speed.posX = 0;\n          speed.x *= -1;\n        }\n        if (speed.posX + logoWidth >= container.clientWidth) {\n          speed.posX = container.clientWidth - logoWidth;\n          speed.x *= -1;\n        }\n        if (speed.posY <= 0) {\n          speed.posY = 0;\n          speed.y *= -1;\n        }\n        if (speed.posY + logoHeight >= container.clientHeight) {\n          speed.posY = container.clientHeight - logoHeight;\n          speed.y *= -1;\n        }\n\n        for (let j = i + 1; j < logoCount; j++) {\n          const other = speeds[j];\n\n          if (isOverlapping(speed.posX, speed.posY, logoWidth, logoHeight,\n            other.posX, other.posY, logoWidth, logoHeight)) {\n            const tempX = speed.x;\n            const tempY = speed.y;\n            speed.x = other.x;\n            speed.y = other.y;\n            other.x = tempX;\n            other.y = tempY;\n\n            if (speed.posX < other.posX) {\n              speed.posX -= 1;\n              other.posX += 1;\n            } else {\n              speed.posX += 1;\n              other.posX -= 1;\n            }\n            if (speed.posY < other.posY) {\n              speed.posY -= 1;\n              other.posY += 1;\n            } else {\n              speed.posY += 1;\n              other.posY -= 1;\n            }\n          }\n        }\n\n        logo.style.left = `${speed.posX}px`;\n        logo.style.top = `${speed.posY}px`;\n      }\n\n      requestAnimationFrame(move);\n    }\n\n    setTimeout(move, 300);\n  });\n<\/script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
