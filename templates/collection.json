      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- \u2014\u2014 START \u2013 PRODUCTS Magnet Banner (Purple Glow \u2013 No Background Animation) \u2014\u2014 -->\n<style>\n@font-face {\n  font-family: 'Impact';\n  src: local('Impact'),\n       url('https://fonts.cdnfonts.com/s/17317/Impact.woff') format('woff');\n  font-display: swap;\n}\n\n/* \u2500\u2500\u2500\u2500\u2500 GLOW BOX (purple) \u2500\u2500\u2500\u2500\u2500 */\n.glow-box {\n  position: relative;\n  border: 3px solid #ff33ff;\n  border-radius: 20px;\n  padding: 1rem;\n  background: #000;\n  overflow: hidden;\n  margin: 2rem auto;\n  max-width: 100%;\n  box-shadow:\n    0 0 8px #ff33ff,\n    0 0 16px #ff33ff,\n    0 0 24px #ff33ff,\n    inset 0 0 8px #ff33ff,\n    inset 0 0 16px #ff33ff;\n  animation: boxGlowPulse 2.5s ease-in-out infinite;\n  contain: layout paint style;\n  will-change: transform, box-shadow;\n}\n\n@keyframes boxGlowPulse {\n  0%, 100% {\n    box-shadow:\n      0 0 8px #ff33ff,\n      0 0 16px #ff33ff,\n      0 0 24px #ff33ff,\n      inset 0 0 8px #ff33ff,\n      inset 0 0 16px #ff33ff;\n  }\n  50% {\n    box-shadow:\n      0 0 12px #ff33ff,\n      0 0 24px #ff33ff,\n      0 0 36px #ff33ff,\n      inset 0 0 12px #ff33ff,\n      inset 0 0 24px #ff33ff;\n  }\n}\n\n/* \u2500\u2500\u2500\u2500\u2500 WRAPPER \u2500\u2500\u2500\u2500\u2500 */\n.products-magnet-wrapper {\n  position: relative;\n  background: #000;\n  padding: 10px 0;\n  text-align: center;\n  overflow: hidden;\n  --tiltX: 0deg;\n  --tiltY: 0deg;\n  will-change: transform;\n  transform-style: preserve-3d;\n  backface-visibility: hidden;\n}\n\n/* \u2500\u2500\u2500\u2500\u2500 3-D TEXT \u2500\u2500\u2500\u2500\u2500 */\n.products-magnet-text {\n  position: relative;\n  z-index: 2;\n  font-family: 'Impact', sans-serif;\n  font-size: clamp(2.5rem, 7vw, 6rem);\n  text-transform: uppercase;\n  letter-spacing: 10px;\n  display: inline-flex;\n  gap: 0.2em;\n  user-select: none;\n  perspective: 1000px;\n  transform-style: preserve-3d;\n  transform: rotateX(var(--tiltX)) rotateY(var(--tiltY));\n  will-change: transform;\n}\n\n/* \u2500\u2500\u2500\u2500\u2500 LETTERS (green) \u2500\u2500\u2500\u2500\u2500 */\n.products-magnet-text span {\n  display: inline-block;\n  color: #39ff14;\n  text-shadow: 0 0 5px #39ff14;\n  opacity: 0;\n  transform: translate(var(--startX), var(--startY)) scale(0.8) rotate(var(--startR));\n  animation:\n    magnetDrop   1.2s ease-out         calc(var(--i) * 0.10s) forwards,\n    shimmerGloss 8s   ease-in-out infinite calc(2s + var(--i) * 0.10s),\n    flagWave     7s   ease-in-out infinite calc(2s + var(--i) * 0.10s);\n}\n\n@keyframes magnetDrop {\n  0%   { opacity: 0; transform: translate(var(--startX), var(--startY)) scale(0.8) rotate(var(--startR)) translateZ(-120px); filter: blur(3px); }\n  60%  { opacity: 1; transform: translate(0, 0) scale(1.05) rotate(0deg) translateZ(30px); text-shadow: 0 0 8px #39ff14; }\n  100% { opacity: 1; transform: translate(0, 0) scale(1) rotate(0deg) translateZ(0); }\n}\n@keyframes shimmerGloss {\n  0%, 80%, 100% { text-shadow: 0 0 5px #39ff14; }\n  40%          { text-shadow: 0 0 10px #39ff14; }\n}\n@keyframes flagWave {\n  0%, 100% { transform: translateY(0) rotateX(0deg) scale(1); }\n  25%      { transform: translateY(-4px) rotateX(10deg) scale(1.03); }\n  50%      { transform: translateY( 3px) rotateX(-8deg) scale(0.98); }\n  75%      { transform: translateY(-3px) rotateX(5deg)  scale(1.01); }\n}\n\n/* Start Positions */\n.products-magnet-text span:nth-child(1) { --startX: -80px; --startY: -50px; --startR: -15deg; }\n.products-magnet-text span:nth-child(2) { --startX:  70px; --startY: -40px; --startR:  12deg; }\n.products-magnet-text span:nth-child(3) { --startX: -60px; --startY:  60px; --startR: -10deg; }\n.products-magnet-text span:nth-child(4) { --startX:  80px; --startY:  40px; --startR:  18deg; }\n.products-magnet-text span:nth-child(5) { --startX: -90px; --startY: -30px; --startR:  -8deg; }\n.products-magnet-text span:nth-child(6) { --startX:  60px; --startY:  50px; --startR:  10deg; }\n.products-magnet-text span:nth-child(7) { --startX: -70px; --startY: -40px; --startR: -14deg; }\n.products-magnet-text span:nth-child(8) { --startX:  90px; --startY:  30px; --startR:  16deg; }\n\n/* \u2500\u2500\u2500\u2500\u2500 MOBILE \u2500\u2500\u2500\u2500\u2500 */\n@media(max-width:600px){\n  .products-magnet-text {\n    font-size: clamp(1.5rem, 8vw, 3.5rem);\n    letter-spacing: 5px;\n    gap: 0.15em;\n  }\n}\n</style>\n\n<div class=\"glow-box\">\n  <div class=\"products-magnet-wrapper\">\n    <div class=\"products-magnet-text\" aria-label=\"Animated Products banner\">\n      <span style=\"--i:0\">P</span><span style=\"--i:1\">R</span>\n      <span style=\"--i:2\">O</span><span style=\"--i:3\">D</span>\n      <span style=\"--i:4\">U</span><span style=\"--i:5\">C</span>\n      <span style=\"--i:6\">T</span><span style=\"--i:7\">S</span>\n    </div>\n  </div>\n</div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', () => {\n  const wrp = document.querySelector('.products-magnet-wrapper');\n  if (!wrp) return;\n  let lastEvt, ticking = false;\n  const updateTilt = () => {\n    const r = wrp.getBoundingClientRect();\n    const x = (lastEvt.clientX - r.left) / r.width - 0.5;\n    const y = (lastEvt.clientY - r.top) / r.height - 0.5;\n    wrp.style.setProperty('--tiltY', `${-x * 8}deg`);\n    wrp.style.setProperty('--tiltX', `${y * 8}deg`);\n    ticking = false;\n  };\n  const handleMove = e => {\n    lastEvt = e;\n    if (!ticking) {\n      ticking = true;\n      requestAnimationFrame(updateTilt);\n    }\n  };\n  wrp.addEventListener('pointermove', handleMove, { passive: true });\n  wrp.addEventListener('pointerleave', () => {\n    wrp.style.setProperty('--tiltX', '0deg');\n    wrp.style.setProperty('--tiltY', '0deg');\n  }, { passive: true });\n});\n</script>\n<!-- \u2014\u2014 END \u2013 PRODUCTS Magnet Banner (No Background Animation) \u2014\u2014 -->",
        "color_scheme": "scheme-4",
        "padding_top": 4,
        "padding_bottom": 4
      }
