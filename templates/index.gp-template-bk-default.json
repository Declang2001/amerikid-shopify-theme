      "settings": {
        "custom_liquid": "<style>\n  /* Floating image button */\n  #floating-enter-btn {\n    position: fixed;\n    top: 150px;\n    left: 50px;\n    z-index: 999999;\n\n    background: transparent;\n    border: none;\n    cursor: pointer;\n\n    animation: fadeInScale 0.8s ease-out forwards;\n    opacity: 0;\n    padding: 0;\n\n    touch-action: manipulation;\n    -webkit-tap-highlight-color: transparent;\n  }\n\n  #floating-enter-btn img {\n    max-width: 220px;\n    height: auto;\n    display: block;\n\n    filter: drop-shadow(0 0 10px white);\n    transform-origin: center;\n    will-change: transform, filter;\n\n    /* Base glow always running */\n    animation: pulseGlow 2s ease-in-out infinite;\n\n    /* rotation variable used during impact */\n    --ak-rot: 0deg;\n  }\n\n  @keyframes fadeInScale {\n    0% { transform: scale(0.6); opacity: 0; }\n    100% { transform: scale(1); opacity: 1; }\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% { filter: drop-shadow(0 0 10px white); }\n    50% { filter: drop-shadow(0 0 20px white); }\n  }\n\n  /* Squash/stretch + subtle tilt (uses --ak-rot set by JS) */\n  @keyframes akSquishX {\n    0%   { transform: scaleX(1.28) scaleY(0.76) rotate(var(--ak-rot)); }\n    55%  { transform: scaleX(0.98) scaleY(1.02) rotate(calc(var(--ak-rot) * -0.35)); }\n    100% { transform: scaleX(1) scaleY(1) rotate(0deg); }\n  }\n  @keyframes akSquishY {\n    0%   { transform: scaleX(0.76) scaleY(1.28) rotate(var(--ak-rot)); }\n    55%  { transform: scaleX(1.02) scaleY(0.98) rotate(calc(var(--ak-rot) * -0.35)); }\n    100% { transform: scaleX(1) scaleY(1) rotate(0deg); }\n  }\n  @keyframes akSquishXY {\n    0%   { transform: scaleX(1.22) scaleY(0.80) rotate(var(--ak-rot)); }\n    55%  { transform: scaleX(0.98) scaleY(1.02) rotate(calc(var(--ak-rot) * -0.35)); }\n    100% { transform: scaleX(1) scaleY(1) rotate(0deg); }\n  }\n\n  /* IMPORTANT: match specificity of #floating-enter-btn img so these win */\n  #floating-enter-btn img.ak-squish-x {\n    animation: pulseGlow 2s ease-in-out infinite, akSquishX 240ms ease-out 1;\n  }\n  #floating-enter-btn img.ak-squish-y {\n    animation: pulseGlow 2s ease-in-out infinite, akSquishY 240ms ease-out 1;\n  }\n  #floating-enter-btn img.ak-squish-xy {\n    animation: pulseGlow 2s ease-in-out infinite, akSquishXY 260ms ease-out 1;\n  }\n\n  @media (max-width: 768px) {\n    #floating-enter-btn img { max-width: 160px; }\n  }\n</style>\n\n<button id=\"floating-enter-btn\" type=\"button\" aria-label=\"Enter AmeriKid\">\n  <img\n    src=\"https://cdn.shopify.com/s/files/1/0930/3267/7656/files/KID_SCRIBBLE_OUTLINE.png?v=1746502793\"\n    alt=\"Enter\"\n  />\n</button>\n\n<script>\n  (function () {\n    if (window.__AK_FLOATING_ENTER_INIT__) return;\n    window.__AK_FLOATING_ENTER_INIT__ = true;\n\n    function init() {\n      const btn = document.getElementById(\"floating-enter-btn\");\n      if (!btn) return;\n\n      const img = btn.querySelector(\"img\");\n\n      // Pause on hover (desktop only)\n      const canHover =\n        window.matchMedia &&\n        window.matchMedia(\"(hover:hover) and (pointer:fine)\").matches;\n\n      let paused = false;\n      if (canHover) {\n        btn.addEventListener(\"pointerenter\", () => { paused = true; });\n        btn.addEventListener(\"pointerleave\", () => { paused = false; });\n      }\n\n      function clamp(val, min, max) {\n        return Math.max(min, Math.min(max, val));\n      }\n\n      function setTilt(deg) {\n        if (!img) return;\n        img.style.setProperty(\"--ak-rot\", deg);\n      }\n\n      function squish(className) {\n        if (!img) return;\n        img.classList.remove(\"ak-squish-x\", \"ak-squish-y\", \"ak-squish-xy\");\n        void img.offsetWidth; // retrigger reliably\n        img.classList.add(className);\n      }\n\n      // Starting position\n      let x = 50;\n      let y = 150;\n\n      // Velocity (px per frame)\n      let dx = 2.2;\n      let dy = 2.2;\n\n      function moveButton() {\n        if (paused) {\n          requestAnimationFrame(moveButton);\n          return;\n        }\n\n        const maxX = window.innerWidth - btn.offsetWidth;\n        const maxY = window.innerHeight - btn.offsetHeight;\n\n        x += dx;\n        y += dy;\n\n        let hitX = false;\n        let hitY = false;\n\n        if (x <= 0 || x >= maxX) { dx *= -1; hitX = true; }\n        if (y <= 0 || y >= maxY) { dy *= -1; hitY = true; }\n\n        x = clamp(x, 0, maxX);\n        y = clamp(y, 0, maxY);\n\n        btn.style.left = x + \"px\";\n        btn.style.top = y + \"px\";\n\n        // Squash/stretch + impact tilt\n        if (hitX && hitY) {\n          // corner: slightly stronger tilt\n          const sign = (dx > 0 ? 1 : -1);\n          setTilt((4 * sign) + \"deg\");\n          squish(\"ak-squish-xy\");\n        } else if (hitX) {\n          // left/right wall: tilt with travel direction\n          setTilt((dx > 0 ? 3 : -3) + \"deg\");\n          squish(\"ak-squish-x\");\n        } else if (hitY) {\n          // top/bottom wall: opposite tilt so it feels like a “bounce”\n          setTilt((dy > 0 ? -3 : 3) + \"deg\");\n          squish(\"ak-squish-y\");\n        }\n\n        requestAnimationFrame(moveButton);\n      }\n\n      requestAnimationFrame(moveButton);\n\n      // Click destination\n      btn.addEventListener(\"click\", function (e) {\n        e.preventDefault();\n        e.stopPropagation();\n        window.location.href = \"/collections/master-collection\";\n      });\n\n      // Keep button on-screen when resizing\n      window.addEventListener(\"resize\", function () {\n        const maxX = window.innerWidth - btn.offsetWidth;\n        const maxY = window.innerHeight - btn.offsetHeight;\n        x = clamp(x, 0, maxX);\n        y = clamp(y, 0, maxY);\n      });\n    }\n\n    if (document.readyState === \"loading\") {\n      document.addEventListener(\"DOMContentLoaded\", init);\n    } else {\n      init();\n    }\n  })();\n</script>",
