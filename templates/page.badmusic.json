        "custom_liquid": "<!-- sections/amerikid-red-banner.liquid -->\n<style>\n  /* ---------- Tunables ---------- */\n  #akrb {\n    --akrb-bg: #ff0000;                    /* background red */\n    --akrb-fg: #ffffff;                    /* white text */\n    --akrb-size: clamp(28px, 6.5vw, 88px); /* responsive font size */\n    --akrb-weight: 900;                    /* Impact look */\n    --akrb-letter: 0.03em;                 /* letter spacing */\n    --akrb-pad-y: 12px;                    /* vertical padding */\n    --akrb-pad-x: 16px;                    /* side padding */\n  }\n\n  /* ---------- Banner (static) ---------- */\n  #akrb {\n    background: var(--akrb-bg);\n    color: var(--akrb-fg);\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: var(--akrb-pad-y) var(--akrb-pad-x);\n    line-height: 1.05;\n    box-shadow:\n      inset 0 1px 0 rgba(0,0,0,.1),\n      inset 0 -1px 0 rgba(0,0,0,.12);\n    /* Remove the edge mask since we\u2019re not scrolling */\n    -webkit-mask-image: none;\n            mask-image: none;\n  }\n\n  #akrb .akrb-text {\n    font-family: Impact, \"Anton\", \"Haettenschweiler\", \"Arial Black\", system-ui, sans-serif;\n    font-weight: var(--akrb-weight);\n    font-size: var(--akrb-size);\n    letter-spacing: var(--akrb-letter);\n    text-transform: uppercase;\n    text-align: center;\n    margin: 0;\n    /* Allow wrapping on small screens, no overflow */\n    white-space: normal;\n    word-break: keep-all;\n  }\n\n  /* Slightly tighter spacing on tiny phones */\n  @media (max-width: 420px) {\n    #akrb { --akrb-pad-x: 12px; }\n  }\n</style>\n\n{%- assign akrb_text = 'GET THE FULL 2025 ALBUM FOR FREE WITH ANY PURCHASE!' -%}\n\n<div id=\"akrb\" role=\"region\" aria-label=\"{{ akrb_text }}\">\n  <p class=\"akrb-text\">{{ akrb_text }}</p>\n</div>",
