      }
    },
    "custom_liquid_JpKeak": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- sections/amerikid-red-banner.liquid -->\n<style>\n  /* ---------- Tunables ---------- */\n  #akrb{\n    --akrb-bg:#ff0000;                    /* red */\n    --akrb-fg:#ffffff;                    /* white */\n    --akrb-speed:10s;                     /* time per cycle (unchanged) */\n    --akrb-gap:3rem;                      /* space between phrases */\n    --akrb-size:clamp(34px,6.5vw,88px);   /* font size */\n    --akrb-weight:900;                    /* Impact look */\n    --akrb-sheen-opacity:.15;\n    --akrb-sheen-speed:6s;\n  }\n\n  /* ---------- Banner shell ---------- */\n  #akrb{\n    background:var(--akrb-bg); color:var(--akrb-fg);\n    overflow:hidden; position:relative; display:flex; align-items:center;\n    padding:10px 0; line-height:1;\n    box-shadow:inset 0 1px 0 rgba(0,0,0,.1), inset 0 -1px 0 rgba(0,0,0,.12);\n    -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;\n    isolation:isolate;\n    /* Edge fade; comment these two if any device still shows shimmer */\n    -webkit-mask-image:linear-gradient(to right, transparent, #000 6%, #000 94%, transparent);\n            mask-image:linear-gradient(to right, transparent, #000 6%, #000 94%, transparent);\n  }\n\n  /* Sheen (runs on its own layer) */\n  #akrb::after{\n    content:\"\"; position:absolute; inset:0; pointer-events:none;\n    background:linear-gradient(100deg,transparent 0%,rgba(255,255,255,var(--akrb-sheen-opacity)) 35%,rgba(255,255,255,calc(var(--akrb-sheen-opacity)*.35)) 50%,transparent 65%);\n    background-size:300% 100%; mix-blend-mode:screen;\n    will-change:background-position;\n    animation:akrb-sheen var(--akrb-sheen-speed) linear infinite;\n  }\n  @keyframes akrb-sheen{from{background-position:-140% 0}to{background-position:140% 0}}\n\n  /* ---------- Moving strip (GPU-only, no layout) ---------- */\n  #akrb .akrb-viewport{width:100%; overflow:hidden}\n  #akrb .akrb-strip{\n    display:inline-flex; align-items:center; white-space:nowrap;\n    contain:paint; will-change:transform; backface-visibility:hidden;\n    transform:translate3d(0,0,0); /* force compositor */\n    pointer-events:none;\n  }\n\n  #akrb .akrb-phrase{\n    display:inline-flex; align-items:center; white-space:nowrap;\n    margin-right:var(--akrb-gap);\n    transform:translateZ(0); /* own layer to avoid text repaint */\n  }\n  #akrb .akrb-word{\n    font-family:Impact,\"Anton\",\"Haettenschweiler\",\"Arial Black\",system-ui,sans-serif;\n    font-weight:var(--akrb-weight); font-size:var(--akrb-size);\n    letter-spacing:.03em; line-height:1; text-transform:uppercase;\n    text-shadow:0 1px 0 rgba(0,0,0,.22);\n  }\n\n  /* Reduced motion */\n  @media (prefers-reduced-motion:reduce){ #akrb::after{animation:none} }\n  @media (max-width:989px){ #akrb{-webkit-mask-image:none; mask-image:none; padding-inline:12px} }\n  @media (max-width:420px){ #akrb{--akrb-gap:2rem} }\n</style>\n\n{%- assign akrb_text = 'GET THE FULL 2025 ALBUM FOR FREE WITH ANY PURCHASE!' -%}\n\n<div id=\"akrb\" aria-label=\"{{ akrb_text }}\">\n  <div class=\"akrb-viewport\" aria-hidden=\"true\">\n    <div class=\"akrb-strip\" id=\"akrb-strip\">\n      {%- for i in (1..8) -%}\n        <span class=\"akrb-phrase\">\n          <span class=\"akrb-word\">{{ akrb_text }}</span>\n        </span>\n      {%- endfor -%}\n    </div>\n  </div>\n</div>\n\n<script>\n/*\n  Ultra-smooth, pixel-snapped loop (no separator):\n  - Measure one phrase width.\n  - Move by an integer #phrases so wraps land exactly in the gap.\n*/\n(function () {\n  const root  = document.getElementById('akrb');\n  const vp    = root?.querySelector('.akrb-viewport');\n  const strip = root?.querySelector('#akrb-strip');\n  if (!root || !vp || !strip) return;\n\n  const speedSec = (() => {\n    const v = getComputedStyle(root).getPropertyValue('--akrb-speed').trim();\n    const n = parseFloat(v);\n    return (v.endsWith('s') && !isNaN(n)) ? n : 10;\n  })();\n\n  // Pixel snap step (0.5px on hi-DPI, 1px otherwise)\n  const dpr = window.devicePixelRatio || 1;\n  const SNAP = dpr >= 1.5 ? 0.5 : 1;\n\n  function phraseStepPx() {\n    // ensure at least 2 phrases for measurement\n    const phrases = strip.querySelectorAll('.akrb-phrase');\n    if (phrases.length < 2) {\n      const clone = strip.firstElementChild?.cloneNode(true);\n      if (clone) strip.appendChild(clone);\n    }\n    const a = strip.querySelectorAll('.akrb-phrase')[0];\n    const b = strip.querySelectorAll('.akrb-phrase')[1];\n    return Math.max(1, (b.offsetLeft - a.offsetLeft)); // includes margin-right gap\n  }\n\n  function densify(minWidth) {\n    const html = strip.innerHTML;\n    while (strip.scrollWidth < minWidth) strip.insertAdjacentHTML('beforeend', html);\n  }\n\n  let distance = 0, pxPerSec = 0, offset = 0, raf = 0, last = 0;\n\n  function compute() {\n    strip.style.transform = 'translate3d(0,0,0)';\n    const step = phraseStepPx();\n    const vw   = vp.clientWidth;\n\n    const k = Math.max(1, Math.round(vw / step));\n    distance = k * step;\n\n    densify(distance + vw + step);\n\n    pxPerSec = distance / speedSec;\n\n    offset = 0; apply(offset);\n  }\n\n  function snapPx(x) { return Math.round(x / SNAP) * SNAP; }\n\n  function apply(x) {\n    strip.style.transform = `translate3d(${ -x }px,0,0)`;\n  }\n\n  function tick(t) {\n    if (!last) last = t;\n    const dt = (t - last) / 1000;\n    last = t;\n\n    offset += pxPerSec * dt;\n    while (offset >= distance) offset -= distance;\n\n    apply(snapPx(offset));\n    raf = requestAnimationFrame(tick);\n  }\n\n  function start() { cancelAnimationFrame(raf); last = 0; raf = requestAnimationFrame(tick); }\n  function refresh() { compute(); start(); }\n\n  if (document.fonts && document.fonts.ready) {\n    document.fonts.ready.then(refresh).catch(()=>{ setTimeout(refresh, 150); });\n  } else {\n    setTimeout(refresh, 150);\n  }\n\n  let rT; window.addEventListener('resize', () => { clearTimeout(rT); rT = setTimeout(refresh, 150); });\n\n  const rm = matchMedia('(prefers-reduced-motion: reduce)');\n  rm.addEventListener?.('change', () => { if (rm.matches) cancelAnimationFrame(raf); else start(); });\n  if (rm.matches) cancelAnimationFrame(raf);\n})();\n</script>",
        "color_scheme": "scheme-4",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_dx4GNc": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- sections/amerikid-3d-retro-tv-smooth.liquid -->\n<section id=\"amerikid-tv-hero\" aria-label=\"3D retro TV with poster and YouTube playback\">\n  <!-- Background wrapper (PNG removed, ambient canvas kept) -->\n  <div class=\"ak-bg\">\n    <!-- Ambient particle background overlay -->\n    <canvas class=\"ak-bg-canvas\" aria-hidden=\"true\"></canvas>\n  </div>\n\n  <div class=\"ak-stack\">\n    <!-- 3D perspective stage -->\n    <div class=\"ak-stage\">\n      <div class=\"ak-tv\" id=\"ak-tv\" role=\"img\" aria-label=\"Retro television body\">\n        <!-- Top cap with vents -->\n        <div class=\"ak-topcap\" aria-hidden=\"true\">\n          <div class=\"ak-vents\"></div>\n        </div>\n\n        <!-- Front face -->\n        <div class=\"ak-face\">\n          <div class=\"ak-bezel\">\n            <div class=\"ak-lip\" aria-hidden=\"true\"></div>\n\n            <!-- Screen (centered 16:9) -->\n            <div class=\"ak-screen\" id=\"ak-screen\" tabindex=\"0\" aria-label=\"Video screen (space to play/pause)\">\n              <div class=\"ak-ratio\"></div>\n\n              <!-- Poster -->\n              <img\n                class=\"ak-poster\"\n                src=\"{{ 'cover.jpg' | file_url }}\"\n                alt=\"AmeriKid 2025 (The Album) — Cover\"\n                decoding=\"async\"\n              />\n\n              <!-- CRT scanline vibe -->\n              <div class=\"ak-scanlines\" aria-hidden=\"true\"></div>\n\n              <!-- OSD text (PLAYING/PAUSED) -->\n              <div class=\"ak-osd\" id=\"ak-osd\" aria-live=\"polite\"></div>\n\n              <!-- Play button (shows at/after release) -->\n              <button class=\"ak-play\" id=\"ak-play\" aria-label=\"Play video\" hidden>\n                <svg width=\"112\" height=\"112\" viewBox=\"0 0 112 112\" aria-hidden=\"true\">\n                  <circle cx=\"56\" cy=\"56\" r=\"52\" fill=\"rgba(0,0,0,0.65)\" />\n                  <polygon points=\"48,36 48,76 82,56\" fill=\"#ffffff\"/>\n                </svg>\n              </button>\n\n              <!-- Coming soon overlay -->\n              <div class=\"ak-coming\" id=\"ak-coming\">\n                <div class=\"ak-coming-inner\">\n                  <span class=\"ak-coming-badge\">COMING SOON</span>\n                  <span class=\"ak-coming-sub\" id=\"ak-countdown\" aria-live=\"polite\"></span>\n                </div>\n              </div>\n\n              <!-- YouTube mount (created on play) -->\n              <div id=\"ak-yt-holder\" class=\"ak-yt-holder\" aria-hidden=\"true\"></div>\n            </div>\n          </div>\n\n          <!-- Controls strip (centered) -->\n          <div class=\"ak-controls\" role=\"group\" aria-label=\"Video controls\">\n            <!-- Decorative progress knob (rotates with progress) -->\n            <button class=\"ak-knob ak-knob--progress\" id=\"ak-knob-progress\" aria-label=\"Playback progress (visual)\" tabindex=\"-1\">\n              <span class=\"ak-knob-cap\"></span>\n            </button>\n\n            <!-- Power = Play/Pause with glyph -->\n            <button class=\"ak-knob ak-knob--power\" id=\"ak-knob-power\" aria-label=\"Play/Pause\" title=\"Play/Pause\">\n              <span class=\"ak-knob-glyph\" id=\"ak-knob-glyph\" aria-hidden=\"true\"></span>\n            </button>\n\n            <!-- Skip -10s -->\n            <button class=\"ak-btn ak-btn--skip ak-btn--back\" id=\"ak-skip-back\" aria-label=\"Back 10 seconds\" title=\"Back 10s\">⟲10</button>\n\n            <!-- Timeline (scrubbable) -->\n            <div\n              class=\"ak-timeline\"\n              id=\"ak-timeline\"\n              role=\"slider\"\n              aria-label=\"Video timeline\"\n              aria-valuemin=\"0\"\n              aria-valuemax=\"100\"\n              aria-valuenow=\"0\"\n              aria-valuetext=\"0:00\"\n              tabindex=\"0\"\n            >\n              <!-- tick grid -->\n              <div class=\"ak-tl-grid\" aria-hidden=\"true\"></div>\n\n              <!-- buffer and base fill -->\n              <div class=\"ak-tl-buffer\" id=\"ak-tl-buffer\"></div>\n              <div class=\"ak-tl-fill\" id=\"ak-tl-fill\" aria-hidden=\"true\"></div>\n\n              <!-- AUDIO WAVE (visualizer) full-width, clipped by progress -->\n              <div class=\"ak-tl-clip\" id=\"ak-tl-clip\">\n                <div class=\"ak-tl-visual\" id=\"ak-tl-visual\" aria-hidden=\"true\"></div>\n              </div>\n\n              <!-- comet highlight + handle -->\n              <div class=\"ak-tl-comet\" id=\"ak-tl-comet\" aria-hidden=\"true\"></div>\n              <div class=\"ak-tl-handle\" id=\"ak-tl-handle\" aria-hidden=\"true\"></div>\n\n              <!-- hover tooltip (time above track) -->\n              <div class=\"ak-tl-tooltip\" id=\"ak-tl-tooltip\">0:00</div>\n\n              <!-- sheen -->\n              <div class=\"ak-tl-sheen\" aria-hidden=\"true\"></div>\n            </div>\n\n            <!-- Time readout (outside the track) -->\n            <div class=\"ak-time\" id=\"ak-time\" aria-live=\"polite\">0:00 / 0:00</div>\n\n            <!-- Skip +10s -->\n            <button class=\"ak-btn ak-btn--skip ak-btn--fwd\" id=\"ak-skip-fwd\" aria-label=\"Forward 10 seconds\" title=\"Forward 10s\">10⟳</button>\n\n            <!-- Mute -->\n            <button class=\"ak-btn ak-btn--mute\" id=\"ak-mute\" aria-label=\"Mute/Unmute\" data-muted=\"false\" title=\"M\">\n              <span class=\"ak-btn-icon\" aria-hidden=\"true\">🔊</span>\n            </button>\n          </div>\n        </div>\n\n        <!-- Feet -->\n        <div class=\"ak-feet\" aria-hidden=\"true\">\n          <div class=\"ak-foot ak-foot--left\"></div>\n          <div class=\"ak-foot ak-foot--right\"></div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Caption -->\n    <h2 class=\"ak-caption\">2025 (The Album)</h2>\n  </div>\n\n  <!-- SVG filters for subtle wave glow -->\n  <svg class=\"ak-svg-filters\" width=\"0\" height=\"0\" aria-hidden=\"true\" focusable=\"false\">\n    <defs>\n      <filter id=\"ak-glowWave\" color-interpolation-filters=\"sRGB\">\n        <feGaussianBlur in=\"SourceGraphic\" stdDeviation=\"1.2\" result=\"b\"/>\n        <feBlend in=\"SourceGraphic\" in2=\"b\"/>\n      </filter>\n    </defs>\n  </svg>\n</section>\n\n<style>\n  /* ---------- Theme + sizing vars ---------- */\n  #amerikid-tv-hero{\n    --ak-accent: #ff33ff; /* AmeriKid purple */\n    --ak-accent-2: #c900ff;\n    --ak-accent-3: #7a00ff;\n    --ak-accent-glow: 0 0 18px rgba(255,51,255,.45), 0 0 36px rgba(255,51,255,.25);\n    --ak-track: #1a1a1a;\n    --ak-track-2: #101010;\n    --ak-buffer: #4b4b4b;\n    --ak-text: #fff;\n    --glass: rgba(20,20,20,.55);\n    --glass-brd: rgba(255,255,255,.12);\n\n    /* Bigger timeline height that still fits the bezel nicely */\n    --tl-h: clamp(28px, 3.6vw, 46px);\n  }\n\n  /* ---------- Layout shell ---------- */\n  #amerikid-tv-hero{\n    position:relative;min-height:100vh;min-height:100svh;width:100%;\n    display:grid;place-items:center;overflow:hidden;background:#000;isolation:isolate;\n    padding-top:clamp(64px,14vh,180px);padding-bottom:clamp(18px,6vh,90px);padding-inline:clamp(8px,2vw,24px);\n    text-align:center;\n  }\n\n  /* Background wrapper */\n  #amerikid-tv-hero .ak-bg{position:absolute;inset:0;z-index:-2;contain:paint;pointer-events:none;}\n\n  /* Ambient canvas overlay */\n  #amerikid-tv-hero .ak-bg-canvas{\n    position:absolute;inset:0;width:100%;height:100%;\n    pointer-events:none;\n    z-index:1;\n    mix-blend-mode: screen;\n    opacity: .95;\n    filter: contrast(1.08) saturate(1.12);\n  }\n\n  .ak-stack{width:100%;display:grid;justify-items:center;gap:clamp(16px,2.6vw,28px);}\n\n  /* ---------- 3D stage ---------- */\n  .ak-stage{width:clamp(360px,96vw,1300px);perspective:1400px;perspective-origin:50% 48%;}\n\n  /* ---------- TV body (movement preserved) ---------- */\n  .ak-tv{\n    --rx:0deg;--ry:0deg;--tx:0px;--ty:0px;--tz:0px;\n    position:relative;width:100%;aspect-ratio:5/3.1;\n    transform-style:preserve-3d;\n    transform:translate3d(var(--tx),var(--ty),var(--tz)) rotateX(var(--rx)) rotateY(var(--ry));\n    will-change:transform;backface-visibility:hidden;\n    box-shadow:0 24px 60px rgba(0,0,0,.6);\n    contain:layout paint style;\n  }\n\n  .ak-topcap{\n    position:absolute;left:2%;right:2%;top:-1.6%;height:6%;\n    background:linear-gradient(180deg,#2b2a28,#1f1e1c);border:1px solid #3a3937;border-radius:10px;\n    transform:translateZ(36px);will-change:transform;backface-visibility:hidden;contain:paint;\n  }\n  .ak-vents{position:absolute;inset:14% 2%;background:repeating-linear-gradient(90deg,#0e0e0e 0 8px,#1f1f1f 8px 16px);\n    border:1px solid #2a2a2a;border-radius:6px;}\n\n  .ak-face{\n    position:absolute;inset:0;display:grid;grid-template-rows:1fr auto;border-radius:22px;\n    background:#22211f;border:2px solid #3a3937;transform:translateZ(24px);overflow:hidden;\n    will-change:transform;backface-visibility:hidden;contain:paint;\n  }\n\n  .ak-bezel{position:relative;margin:min(1.6vw,20px);border-radius:16px;background:#141414;border:1px solid #2b2b2b;overflow:hidden;}\n  .ak-lip{position:absolute;inset:-40px -40px auto -40px;height:40px;background:linear-gradient(180deg,rgba(0,0,0,.7),rgba(0,0,0,0));\n    transform:translateZ(2px);pointer-events:none;}\n\n  /* Screen */\n  .ak-screen{\n    position:relative;width:100%;height:100%;display:grid;place-items:center;background:#000;\n    outline:1px solid #2b2b2b;border-radius:12px;transform:translateZ(6px);\n    will-change:transform;backface-visibility:hidden;overflow:hidden;contain:paint;\n  }\n  .ak-ratio{width:100%;aspect-ratio:16/9;grid-area:1/1;}\n  .ak-poster{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;grid-area:1/1;pointer-events:none;}\n  .ak-scanlines{\n    position:absolute;inset:0;pointer-events:none;mix-blend-mode:screen;opacity:.075;\n    background:\n      repeating-linear-gradient(0deg, rgba(255,255,255,.04) 0 1px, transparent 1px 3px),\n      radial-gradient(1200px 1200px at 50% 0%, rgba(255,255,255,.04), transparent 60%);\n  }\n\n  .ak-yt-holder{position:absolute;inset:0;width:100%;height:100%;display:none;grid-area:1/1;}\n  .ak-yt-holder iframe{width:100%;height:100%;border:0;display:block;}\n\n  /* Play overlay */\n  .ak-play{\n    position:absolute;inset:0;display:grid;place-items:center;background:none;border:0;padding:0;margin:0;cursor:pointer;\n    z-index:5;\n  }\n  .ak-play:focus-visible{outline:2px solid #fff;outline-offset:4px;}\n\n  /* Controls strip */\n  .ak-controls{\n    position:relative;margin:0 min(1.6vw,20px) min(1.6vw,20px);\n    display:grid;grid-template-columns:auto auto auto 1fr auto auto auto;align-items:center;gap:min(2vw,16px);\n    background:var(--glass);border:1px solid var(--glass-brd);border-radius:14px;\n    padding:clamp(12px,2.2vw,18px);transform:translateZ(12px);will-change:transform;contain:paint;\n    backdrop-filter:saturate(1.2) blur(8px);\n    box-shadow:0 10px 30px rgba(0,0,0,.45), inset 0 0 0 1px rgba(255,255,255,.05);\n  }\n\n  .ak-knob{width:min(9vw,76px);height:min(9vw,76px);border-radius:50%;\n    background:conic-gradient(from 210deg at 50% 50%, #2d2d2d, #1f1f1f, #151515 70%, #2d2d2d);\n    border:1px solid #2f2f2f;position:relative;cursor:pointer;will-change:transform;backface-visibility:hidden;\n    box-shadow:inset 0 2px 0 rgba(255,255,255,.05), inset 0 -3px 0 rgba(0,0,0,.6), 0 2px 8px rgba(0,0,0,.35);\n    transition:transform .12s ease, box-shadow .12s ease;\n  }\n  .ak-knob:hover{box-shadow:inset 0 2px 0 rgba(255,255,255,.08), inset 0 -3px 0 rgba(0,0,0,.6), 0 4px 16px rgba(0,0,0,.45);}\n  .ak-knob--power{width:min(7.2vw,60px);height:min(7.2vw,60px);}\n  .ak-knob-cap{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:36%;height:36%;border-radius:50%;\n    background:radial-gradient(circle at 40% 40%,#606060,#2d2d2d);border:1px solid #2b2b2b;}\n  .ak-knob--progress{--deg:0deg;transform:rotate(var(--deg));}\n\n  .ak-knob-glyph{position:absolute;inset:0;display:grid;place-items:center;pointer-events:none;}\n  .ak-knob-glyph::before{\n    content:\"\"; display:block; width:18px; height:18px;\n    mask:var(--icon); -webkit-mask:var(--icon);\n    background:#eee;\n  }\n  .ak-knob--power:not(.is-playing) .ak-knob-glyph{ --icon: url('data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=%220 0 24 24%22><polygon fill=%22%23fff%22 points=%229,6 9,18 18,12%22/></svg>'); }\n  .ak-knob--power.is-playing .ak-knob-glyph{ --icon: url('data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=%220 0 24 24%22><rect x=%228%22 y=%226%22 width=%223%22 height=%2212%22 fill=%22%23fff%22/><rect x=%2213%22 y=%226%22 width=%223%22 height=%2212%22 fill=%22%23fff%22/></svg>'); }\n\n  .ak-btn{\n    appearance:none;border:1px solid #2f2f2f;border-radius:10px;background:linear-gradient(180deg,#2b2b2b,#1b1b1b);\n    padding:10px 12px;line-height:1;cursor:pointer;color:#eee;transition:transform .12s ease, box-shadow .12s ease, border-color .12s ease;\n    box-shadow:inset 0 1px 0 rgba(255,255,255,.06), 0 2px 10px rgba(0,0,0,.35);\n  }\n  .ak-btn:hover{box-shadow:inset 0 1px 0 rgba(255,255,255,.1), 0 4px 18px rgba(0,0,0,.45);}\n  .ak-btn:focus-visible{outline:2px solid var(--ak-accent);outline-offset:2px;box-shadow:var(--ak-accent-glow);}\n  .ak-btn:active{transform:translateY(1px);}\n  .ak-btn--mute[data-muted=\"true\"] .ak-btn-icon{filter:grayscale(1) brightness(.9);}\n  .ak-btn--skip{font-family:ui-monospace,Menlo,Consolas,monospace;font-weight:700}\n\n  /* Timeline */\n  .ak-timeline{\n    position:relative;height:var(--tl-h);border-radius:calc(var(--tl-h)/2);background:\n      linear-gradient(180deg,var(--ak-track),var(--ak-track-2));\n    box-shadow:inset 0 1px 0 rgba(255,255,255,.06), inset 0 -1px 0 rgba(0,0,0,.6);\n    overflow:hidden; touch-action:none;\n  }\n  .ak-tl-grid{\n    position:absolute;inset:0; pointer-events:none; opacity:.20;\n    background:repeating-linear-gradient(90deg, transparent 0 9.5%, rgba(255,255,255,.06) 9.5% 10%);\n  }\n  .ak-tl-buffer, .ak-tl-fill{position:absolute;left:0;top:0;height:100%;width:0%;}\n  .ak-tl-buffer{background:linear-gradient(180deg,#5a5a5a,#3a3a3a);}\n  .ak-tl-fill{\n    background:linear-gradient(90deg,var(--ak-accent) 0%, var(--ak-accent-2) 35%, var(--ak-accent-3) 100%);\n    box-shadow:var(--ak-accent-glow);\n  }\n\n  .ak-tl-clip{position:absolute;left:0;top:0;height:100%;width:0%;overflow:hidden; pointer-events:none;}\n  .ak-tl-visual{position:absolute;left:0;top:0;height:100%;width:100%;filter:url(#ak-glowWave);}\n  .ak-tl-visual::after{\n    content:\"\"; position:absolute; inset:0;\n    background:linear-gradient(180deg, rgba(255,255,255,.18), rgba(255,255,255,0) 40%);\n    mix-blend-mode:overlay; pointer-events:none;\n  }\n  .ak-tl-visual .bar{\n    position:absolute; bottom:0;\n    width:var(--bw,6px); left:var(--x,0px); height:100%;\n    border-radius:calc(var(--tl-h)*.18) calc(var(--tl-h)*.18) 0 0;\n    background:linear-gradient(180deg,#ffd0ff,#ff75ff 60%,#a500ff);\n    transform-origin:50% 100%;\n    transform:scaleY(var(--amp,.2));\n    will-change:transform;\n    box-shadow:0 0 10px rgba(255,51,255,.45);\n  }\n\n  .ak-tl-comet{\n    position:absolute;top:50%;transform:translate(-50%,-50%);left:0%;\n    width:calc(var(--tl-h)*.74);height:calc(var(--tl-h)*.74);border-radius:50%;\n    background:radial-gradient(circle at 40% 40%, #ffe6ff, #ffb3ff 60%, #bb00ff 100%);\n    filter:drop-shadow(0 0 10px rgba(255,51,255,.6));\n    pointer-events:none;\n  }\n  .ak-tl-handle{\n    position:absolute;top:50%;transform:translate(-50%,-50%);left:0%;\n    width:calc(var(--tl-h)*.64);height:calc(var(--tl-h)*.64);border-radius:50%;\n    border:1px solid rgba(255,255,255,.35);\n    background:radial-gradient(circle at 40% 40%, #fefefe, #bdbdbd 60%, #7a7a7a 100%);\n    box-shadow:0 0 0 2px rgba(255,51,255,.25), 0 0 0 5px rgba(255,51,255,.08);\n    pointer-events:none;\n  }\n  .ak-tl-tooltip{\n    position:absolute;bottom:calc(100% + max(10px, var(--tl-h)*.18));left:0;transform:translateX(-50%) translateY(4px);\n    background:rgba(0,0,0,.78);border:1px solid rgba(255,255,255,.18);\n    color:#fff;font-size:12px;padding:6px 8px;border-radius:8px;opacity:0;pointer-events:none;\n    transition:opacity .12s ease, transform .12s ease;white-space:nowrap;\n  }\n  .ak-timeline.ak-showtip .ak-tl-tooltip{opacity:1;transform:translateX(-50%) translateY(0);}\n  .ak-tl-sheen{\n    position:absolute;inset:0; pointer-events:none; opacity:0;\n    background:linear-gradient(120deg, transparent 0%, rgba(255,255,255,.12) 20%, transparent 40%);\n    background-size:200% 100%;\n    animation: akSheen 3.6s linear infinite;\n  }\n  #amerikid-tv-hero.ak-playing .ak-tl-sheen{opacity:.6}\n  @keyframes akSheen{ 0%{background-position:200% 0} 100%{background-position:-200% 0}}\n\n  .ak-time{\n    font-family:ui-monospace,Menlo,Consolas,monospace;\n    font-size:12px;color:#ddd;background:#121212;border:1px solid #2b2b2b;border-radius:8px;padding:6px 8px;\n  }\n\n  .ak-osd{position:absolute;right:10px;top:10px;background:rgba(0,0,0,.55);color:#fff;padding:6px 10px;border-radius:6px;\n    font-size:12px;letter-spacing:.5px;border:1px solid rgba(255,255,255,.18);opacity:0;pointer-events:none;}\n  .ak-osd.ak-show{opacity:1;transition:opacity .18s ease;}\n\n  .is-playing .ak-poster{display:none;}\n  .is-playing #ak-coming{display:none;}\n  .is-playing #ak-play{display:none;}\n  .is-playing .ak-yt-holder{display:block;}\n\n  .ak-caption{margin:0;font-family:Impact,\"Anton\",\"Haettenschweiler\",\"Arial Black\",sans-serif;\n    font-size:clamp(22px,6.2vw,58px);line-height:1.05;color:#fff;letter-spacing:.5px;}\n\n  @media (max-width:980px){\n    :root #amerikid-tv-hero{ --tl-h: clamp(24px, 4.2vw, 36px); }\n    .ak-controls{grid-template-columns:auto auto auto 1fr auto auto;gap:12px;}\n    #ak-knob-progress{display:none;}\n  }\n  @media (max-width:640px){\n    :root #amerikid-tv-hero{ --tl-h: clamp(20px, 5.5vw, 28px); }\n    .ak-controls{grid-template-columns:auto auto 1fr auto auto;gap:10px;}\n    #ak-skip-back, #ak-skip-fwd{display:none;}\n  }\n  @media (max-width:560px){\n    .ak-controls{grid-template-columns:auto 1fr auto auto;gap:10px;}\n    .ak-time{padding:5px 6px;font-size:11px}\n  }\n\n  @media (prefers-reduced-motion:reduce){\n    .ak-tv{will-change:auto;}\n    .ak-tl-sheen{animation:none}\n    #amerikid-tv-hero .ak-bg-canvas{display:none;}\n  }\n\n  @media (max-width: 640px){\n    #amerikid-tv-hero{\n      min-height: 0;\n      padding-top: max(40px, calc(env(safe-area-inset-top, 0px) + 12px));\n      padding-bottom: max(8px, calc(env(safe-area-inset-bottom, 0px) + 4px));\n    }\n    #amerikid-tv-hero .ak-stack{ gap: 12px; }\n  }\n</style>\n\n<script>\n  (function(){\n    const VIDEO_ID = \"1qfiCvXQNmE\";\n    const RELEASE_ISO = \"2025-09-30T15:00:00-07:00\"; // Sep 30, 2025 - 3:00 PM PT\n    const YT_WATCH_URL = \"https://www.youtube.com/watch?v=1qfiCvXQNmE\";\n\n    const root = document.getElementById('amerikid-tv-hero');\n    const stage = document.querySelector('.ak-stage');\n    const tv = document.getElementById('ak-tv');\n    const screenEl = document.getElementById('ak-screen');\n    const playBtn = document.getElementById('ak-play');\n    const coming = document.getElementById('ak-coming');\n    const countdown = document.getElementById('ak-countdown');\n    const holder = document.getElementById('ak-yt-holder');\n    const knobProgress = document.getElementById('ak-knob-progress');\n    const knobPower = document.getElementById('ak-knob-power');\n    const osd = document.getElementById('ak-osd');\n\n    const timeline = document.getElementById('ak-timeline');\n    const tlFill = document.getElementById('ak-tl-fill');\n    const tlBuffer = document.getElementById('ak-tl-buffer');\n    const tlHandle = document.getElementById('ak-tl-handle');\n    const tlComet = document.getElementById('ak-tl-comet');\n\n    const tlClip = document.getElementById('ak-tl-clip');\n    const tlVisual = document.getElementById('ak-tl-visual');\n    const tlTip = document.getElementById('ak-tl-tooltip');\n    const timeReadout = document.getElementById('ak-time');\n    const muteBtn = document.getElementById('ak-mute');\n    const skipBack = document.getElementById('ak-skip-back');\n    const skipFwd = document.getElementById('ak-skip-fwd');\n\n    function showPlay(){ if(playBtn) playBtn.hidden=false; if(coming) coming.style.display='none'; }\n    function showComing(){ if(playBtn) playBtn.hidden=true; if(coming) coming.style.display=''; }\n\n    function startCountdown(untilDate){\n      function tick(){\n        const now = new Date();\n        const diff = untilDate - now;\n        if(diff <= 0){ clearInterval(timer); if(countdown) countdown.textContent=''; showPlay(); return; }\n        const s = Math.floor(diff/1000);\n        const d = Math.floor(s/86400);\n        const h = Math.floor((s%86400)/3600);\n        const m = Math.floor((s%3600)/60);\n        const sec = s%60;\n        if(countdown){\n          countdown.textContent = (d? d+'d ' : '')+String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');\n        }\n      }\n      tick();\n      var timer = setInterval(tick,1000);\n      return timer;\n    }\n\n    (function gate(){\n      const rel = new Date(RELEASE_ISO);\n      if(isFinite(rel)){ if(new Date()<rel){ showComing(); startCountdown(rel); } else { showPlay(); } }\n      else { showPlay(); }\n    })();\n\n    function ensureYT(cb){\n      if(window.YT && window.YT.Player){ cb(); return; }\n      const existing = document.querySelector('script[data-ak-yt-api]');\n      if(existing){\n        const check = setInterval(()=>{ if(window.YT && window.YT.Player){ clearInterval(check); cb(); } }, 50);\n        return;\n      }\n      const tag = document.createElement('script');\n      tag.src=\"https://www.youtube.com/iframe_api\"; tag.async=true; tag.defer=true; tag.setAttribute('data-ak-yt-api','1');\n      document.head.appendChild(tag);\n      const prev = window.onYouTubeIframeAPIReady;\n      window.onYouTubeIframeAPIReady = function(){ if(typeof prev==='function') try{prev();}catch(e){} cb(); };\n    }\n\n    let player=null, rafId=null, waveRAF=null;\n    let isScrubbing = false;\n    let wasPlayingBeforeScrub = false;\n\n    function fmtTime(sec){\n      if(!isFinite(sec) || sec < 0) sec = 0;\n      const m = Math.floor(sec/60);\n      const s = Math.floor(sec%60);\n      return m + \":\" + String(s).padStart(2,'0');\n    }\n    function setOSD(msg){\n      if(!osd) return;\n      osd.textContent = msg||'';\n      osd.classList.add('ak-show');\n      clearTimeout(setOSD._t);\n      setOSD._t = setTimeout(()=> osd.classList.remove('ak-show'), 700);\n    }\n    function clamp01(n){ return Math.max(0, Math.min(1, n)); }\n\n    let bars = [];\n    let lastTrackWidth = 0;\n\n    function rebuildBars(){\n      const rect = timeline.getBoundingClientRect();\n      const px = rect.width || 0;\n      const h  = rect.height || parseFloat(getComputedStyle(timeline).getPropertyValue('--tl-h')) || 32;\n\n      const spacing = Math.max(6, Math.round(h * 0.55));\n      const count = Math.max(28, Math.min(140, Math.floor(px / spacing)));\n\n      tlVisual.innerHTML = '';\n      bars = [];\n\n      const bw = Math.max(4, Math.round(spacing * 0.62));\n      for(let i=0; i<count; i++){\n        const b = document.createElement('span');\n        b.className = 'bar';\n        const x = Math.round(i * (px / count));\n        b.style.setProperty('--bw', bw + 'px');\n        b.style.setProperty('--x', x + 'px');\n        tlVisual.appendChild(b);\n        bars.push({ el:b, seed:(Math.random()*Math.PI*2), jitter:(Math.random()*0.15) });\n      }\n      lastTrackWidth = px;\n    }\n\n    function updateWaveFromTime(tSec){\n      if(bars.length===0) return;\n      const ω1 = 2.2, ω2 = 1.3, ω3 = 0.6;\n\n      for(let i=0; i<bars.length; i++){\n        const {el, seed, jitter} = bars[i];\n        const x = i/(bars.length-1 || 1);\n        const f1 = Math.sin((x*2.0*Math.PI*1.5) + tSec*ω1);\n        const f2 = Math.sin((x*2.0*Math.PI*3.0) - tSec*ω2 + seed*0.35);\n        const f3 = Math.cos((x*2.0*Math.PI*0.7) + tSec*ω3);\n        let v = 0.58 + 0.22*f1 + 0.14*f2 + 0.06*f3 + jitter*0.06;\n        v = Math.max(0.12, Math.min(1.0, v));\n        el.style.transform = `scaleY(${v.toFixed(3)})`;\n      }\n    }\n\n    function startWave(){\n      if(waveRAF) cancelAnimationFrame(waveRAF);\n      const loop = ()=>{\n        if(player && player.getPlayerState && player.getPlayerState()===1){\n          const t = player.getCurrentTime ? player.getCurrentTime() : 0;\n          updateWaveFromTime(t);\n        }\n        waveRAF = requestAnimationFrame(loop);\n      };\n      waveRAF = requestAnimationFrame(loop);\n    }\n    function stopWave(){ if(waveRAF){ cancelAnimationFrame(waveRAF); waveRAF = null; } }\n\n    function placeHandle(pct){\n      const leftPct = Math.round(pct * 100);\n      tlHandle.style.left = leftPct + '%';\n      tlComet.style.left  = leftPct + '%';\n    }\n\n    function updateTimeUI(cur, dur){\n      const p = dur>0 ? clamp01(cur/dur) : 0;\n      const loaded = (typeof player?.getVideoLoadedFraction === 'function') ? player.getVideoLoadedFraction() : 0;\n\n      if(!isScrubbing){\n        const w = (p*100) + '%';\n        tlFill.style.width = w;\n        tlClip.style.width = w;\n        placeHandle(p);\n      }\n\n      tlBuffer.style.width = Math.max(0, Math.min(100, loaded*100)) + '%';\n\n      if(timeReadout) timeReadout.textContent = `${fmtTime(cur)} / ${fmtTime(dur)}`;\n      if(timeline){\n        timeline.setAttribute('aria-valuenow', Math.round(p*100));\n        timeline.setAttribute('aria-valuetext', fmtTime(cur));\n      }\n      if(knobProgress){\n        const deg = Math.round(p * 300);\n        knobProgress.style.setProperty('--deg', deg + 'deg');\n      }\n    }\n\n    function progressLoop(){\n      if(!player){ rafId=null; return; }\n      const dur = player.getDuration ? player.getDuration() : 0;\n      const cur = player.getCurrentTime ? player.getCurrentTime() : 0;\n      updateTimeUI(cur, dur);\n      rafId = requestAnimationFrame(progressLoop);\n    }\n    function stopProgress(){ if(rafId){ cancelAnimationFrame(rafId); rafId=null; } }\n\n    function setPlayingUI(playing){\n      root.classList.toggle('ak-playing', playing);\n      knobPower.classList.toggle('is-playing', playing);\n    }\n\n    function createAndPlay(){\n      if(player){ try{player.playVideo();}catch(e){} return; }\n      const inner = document.createElement('div');\n      holder.appendChild(inner);\n\n      player = new YT.Player(inner, {\n        videoId: VIDEO_ID,\n        playerVars: { autoplay:1, playsinline:1, rel:0, modestbranding:1, enablejsapi:1, origin:window.location.origin },\n        events: {\n          onReady: function(){\n            screenEl.classList.add('is-playing');\n            setPlayingUI(true);\n            holder.setAttribute('aria-hidden','false');\n            try{ player.playVideo(); }catch(e){}\n            setOSD('PLAYING');\n            rebuildBars();\n            startWave();\n            progressLoop();\n          },\n          onStateChange: function(e){\n            if(e.data===1){ setOSD('PLAYING'); setPlayingUI(true); startWave(); progressLoop(); }\n            if(e.data===2){ setOSD('PAUSED');  setPlayingUI(false); stopWave(); stopProgress(); }\n            if(e.data===0){ setOSD('ENDED');   setPlayingUI(false); stopWave(); stopProgress(); updateTimeUI(player.getDuration(), player.getDuration()); }\n          },\n          onError: function(){ window.open(YT_WATCH_URL,'_blank','noopener'); }\n        }\n      });\n      screenEl.classList.add('is-playing');\n    }\n\n    function togglePlayPause(){\n      if(!player){ return; }\n      const st = player.getPlayerState ? player.getPlayerState() : -1;\n      if(st===1){ player.pauseVideo(); }\n      else { player.playVideo(); }\n    }\n\n    playBtn && playBtn.addEventListener('click', function(){\n      playBtn.disabled = true;\n      ensureYT(createAndPlay);\n      setTimeout(()=>{ playBtn.disabled=false; }, 600);\n    });\n    screenEl && screenEl.addEventListener('click', function(e){\n      if(e.target.closest('.ak-timeline')) return;\n      if(player) togglePlayPause();\n    });\n    knobPower && knobPower.addEventListener('click', function(){\n      if(!player){ ensureYT(createAndPlay); }\n      else { togglePlayPause(); }\n    });\n\n    function nudge(seconds){\n      if(!player) return;\n      const dur = player.getDuration ? player.getDuration() : 0;\n      const cur = player.getCurrentTime ? player.getCurrentTime() : 0;\n      if(dur<=0) return;\n      const target = Math.max(0, Math.min(dur, cur + seconds));\n      player.seekTo(target, true);\n      updateTimeUI(target, dur);\n    }\n    muteBtn && muteBtn.addEventListener('click', function(){\n      if(!player) return;\n      const muted = player.isMuted ? player.isMuted() : false;\n      if(muted){ player.unMute(); this.dataset.muted = \"false\"; this.querySelector('.ak-btn-icon').textContent = \"🔊\"; }\n      else { player.mute(); this.dataset.muted = \"true\"; this.querySelector('.ak-btn-icon').textContent = \"🔇\"; }\n    });\n    skipBack && skipBack.addEventListener('click', ()=> nudge(-10));\n    skipFwd && skipFwd.addEventListener('click', ()=> nudge(+10));\n\n    function rect(){ return timeline.getBoundingClientRect(); }\n    function pctFromClientX(clientX){\n      const r = rect();\n      const p = (clientX - r.left) / r.width;\n      return Math.max(0, Math.min(1, p));\n    }\n    function seekToPct(p){\n      if(!player) return;\n      const dur = player.getDuration ? player.getDuration() : 0;\n      if(dur>0 && player.seekTo){ player.seekTo(p * dur, true); }\n    }\n    function showTipAtPct(p, dur){\n      const seconds = (dur>0) ? p*dur : 0;\n      const left = (p*100) + '%';\n      tlTip.textContent = fmtTime(seconds);\n      tlTip.style.left = left;\n    }\n    function beginScrub(e){\n      if(!player) return;\n      isScrubbing = true;\n      const st = player.getPlayerState ? player.getPlayerState() : -1;\n      wasPlayingBeforeScrub = (st===1);\n      if(wasPlayingBeforeScrub) try{ player.pauseVideo(); }catch(_){}\n      stopWave();\n      timeline.classList.add('ak-showtip');\n      const p = pctFromClientX(e.clientX ?? (e.touches && e.touches[0]?.clientX) ?? 0);\n      const w = (p*100)+'%';\n      tlFill.style.width = w;\n      tlClip.style.width = w;\n      showTipAtPct(p, player.getDuration ? player.getDuration() : 0);\n      placeHandle(p);\n      updateTimeUI((player.getDuration()||0)*p, (player.getDuration()||0));\n    }\n    function moveScrub(e){\n      if(!isScrubbing) return;\n      const clientX = e.clientX ?? (e.touches && e.touches[0]?.clientX);\n      if(typeof clientX!==\"number\") return;\n      const p = pctFromClientX(clientX);\n      const w = (p*100)+'%';\n      tlFill.style.width = w;\n      tlClip.style.width = w;\n      showTipAtPct(p, player.getDuration ? player.getDuration() : 0);\n      placeHandle(p);\n      updateTimeUI((player.getDuration()||0)*p, (player.getDuration()||0));\n    }\n    function endScrub(e){\n      if(!isScrubbing) return;\n      isScrubbing = false;\n      timeline.classList.remove('ak-showtip');\n      const clientX = e.clientX ?? (e.changedTouches && e.changedTouches[0]?.clientX);\n      const p = typeof clientX===\"number\" ? pctFromClientX(clientX) : (parseFloat(tlFill.style.width)||0)/100;\n      seekToPct(p);\n      if(wasPlayingBeforeScrub){ try{ player.playVideo(); }catch(_){} startWave(); progressLoop(); }\n    }\n\n    if(timeline){\n      timeline.addEventListener('pointerdown', (e)=>{ e.preventDefault(); timeline.setPointerCapture(e.pointerId); beginScrub(e); });\n      timeline.addEventListener('pointermove', moveScrub, {passive:true});\n      timeline.addEventListener('pointerup', (e)=>{ endScrub(e); });\n      timeline.addEventListener('pointercancel', ()=>{ isScrubbing=false; timeline.classList.remove('ak-showtip'); });\n\n      timeline.addEventListener('mousemove', (e)=>{\n        if(!player || isScrubbing) return;\n        const dur = player.getDuration ? player.getDuration() : 0;\n        const p = pctFromClientX(e.clientX);\n        showTipAtPct(p, dur);\n        timeline.classList.add('ak-showtip');\n        clearTimeout(timeline._hoverT);\n        timeline._hoverT = setTimeout(()=> timeline.classList.remove('ak-showtip'), 240);\n      });\n\n      timeline.addEventListener('keydown', (e)=>{\n        if(!player) return;\n        const dur = player.getDuration ? player.getDuration() : 0;\n        const cur = player.getCurrentTime ? player.getCurrentTime() : 0;\n        if(dur<=0) return;\n        let target = cur;\n        const step = 5;\n        if(e.key === 'ArrowRight'){ target = Math.min(dur, cur + step); e.preventDefault(); }\n        if(e.key === 'ArrowLeft'){ target = Math.max(0, cur - step); e.preventDefault(); }\n        if(e.key === 'Home'){ target = 0; e.preventDefault(); }\n        if(e.key === 'End'){ target = dur; e.preventDefault(); }\n        if(target!==cur){ player.seekTo(target, true); updateTimeUI(target, dur); }\n      });\n    }\n\n    /* ---------- Smooth 3D tilt with inertia (PRESERVED) ---------- */\n    if(stage && tv){\n      let stageRect = stage.getBoundingClientRect();\n      let targetRX = 0, targetRY = 0;\n      let curRX = 0, curRY = 0;\n      let targetTX = 0, targetTY = 0;\n      let curTX = 0, curTY = 0;\n      const MAX_YAW = 10;\n      const MAX_PITCH = 8;\n      const MAX_SHIFT = 8;\n      const EASE = 0.12;\n\n      function onPointerMove(clientX, clientY){\n        const x = (clientX - stageRect.left) / stageRect.width;\n        const y = (clientY - stageRect.top) / stageRect.height;\n        const dx = (x - 0.5) * 2;\n        const dy = (y - 0.5) * 2;\n\n        targetRY = Math.max(-MAX_YAW, Math.min(MAX_YAW, dx * MAX_YAW));\n        targetRX = Math.max(-MAX_PITCH, Math.min(MAX_PITCH, -dy * MAX_PITCH));\n        targetTX = Math.max(-MAX_SHIFT, Math.min(MAX_SHIFT, -dx * MAX_SHIFT));\n        targetTY = Math.max(-MAX_SHIFT, Math.min(MAX_SHIFT,  dy * MAX_SHIFT));\n      }\n\n      function animate(){\n        curRX += (targetRX - curRX) * EASE;\n        curRY += (targetRY - curRY) * EASE;\n        curTX += (targetTX - curTX) * EASE;\n        curTY += (targetTY - curTY) * EASE;\n\n        tv.style.setProperty('--rx', curRX.toFixed(3) + 'deg');\n        tv.style.setProperty('--ry', curRY.toFixed(3) + 'deg');\n        tv.style.setProperty('--tx', curTX.toFixed(3) + 'px');\n        tv.style.setProperty('--ty', curTY.toFixed(3) + 'px');\n\n        requestAnimationFrame(animate);\n      }\n      requestAnimationFrame(animate);\n\n      stage.addEventListener('pointermove', (e)=>{ onPointerMove(e.clientX, e.clientY); }, {passive:true});\n      stage.addEventListener('pointerenter', (e)=>{ stageRect = stage.getBoundingClientRect(); onPointerMove(e.clientX, e.clientY); }, {passive:true});\n      stage.addEventListener('pointerleave', ()=>{ targetRX = targetRY = targetTX = targetTY = 0; }, {passive:true});\n      window.addEventListener('resize', ()=>{\n        stageRect = stage.getBoundingClientRect();\n        const w = timeline.getBoundingClientRect().width;\n        if(Math.abs(w - lastTrackWidth) > 8){ rebuildBars(); }\n      }, {passive:true});\n    }\n\n    rebuildBars();\n    updateTimeUI(0, 0);\n\n    screenEl && screenEl.addEventListener('keydown', (e)=>{\n      if(e.code === 'Space'){ e.preventDefault(); if(!player){ ensureYT(createAndPlay); } else { togglePlayPause(); } }\n      if(e.key.toLowerCase() === 'm'){ if(player){ muteBtn?.click(); } }\n      if(e.key.toLowerCase() === 'j'){ nudge(-10); }\n      if(e.key.toLowerCase() === 'l'){ nudge(+10); }\n      if(e.key === 'ArrowRight'){ nudge(+5); }\n      if(e.key === 'ArrowLeft'){ nudge(-5); }\n    });\n  })();\n</script>\n\n<!-- Ambient background particles (isolated, does not touch TV logic) -->\n<script>\n(function(){\n  var root = document.getElementById('amerikid-tv-hero');\n  if(!root) return;\n\n  var reduced = false;\n  try { reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch(e){}\n  if(reduced) return;\n\n  var canvas = root.querySelector('.ak-bg-canvas');\n  if(!canvas) return;\n\n  var ctx = canvas.getContext('2d', { alpha:true });\n  var w = 0, h = 0;\n  var dpr = Math.min(window.devicePixelRatio || 1, 2);\n\n  var dust = [];\n  var floaters = [];\n\n  // NEW: shooting stars\n  var shooters = [];\n  var nextShooterAt = 0;\n  var lastFrame = 0;\n\n  var COLORS = {\n    white:  { rgb: \"255,255,255\", hex: \"#ffffff\" },\n    purple: { rgb: \"255,51,255\",  hex: \"#ff33ff\" },\n    blue:   { rgb: \"127,212,255\", hex: \"#7fd4ff\" },\n    yellow: { rgb: \"255,211,74\",  hex: \"#ffd34a\" }\n  };\n\n  function clamp(v, min, max){ return Math.min(max, Math.max(min, v)); }\n  function rand(min, max){ return min + Math.random() * (max - min); }\n\n  function resize(){\n    var rect = root.getBoundingClientRect();\n    w = Math.max(1, Math.floor(rect.width));\n    h = Math.max(1, Math.floor(rect.height));\n    dpr = Math.min(window.devicePixelRatio || 1, 2);\n    canvas.width = Math.floor(w * dpr);\n    canvas.height = Math.floor(h * dpr);\n    canvas.style.width = w + \"px\";\n    canvas.style.height = h + \"px\";\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n\n  function pickAccent(){\n    var r = Math.random();\n    if(r < 0.40) return COLORS.purple;\n    if(r < 0.72) return COLORS.blue;\n    return COLORS.yellow;\n  }\n  function pickDustColor(){ return (Math.random() < 0.86) ? COLORS.white : pickAccent(); }\n  function pickFloaterColor(){ return (Math.random() < 0.73) ? COLORS.white : pickAccent(); }\n  function pickFloaterKind(){\n    var r = Math.random();\n    if(r < 0.015) return \"blob\";\n    if(r < 0.18) return \"pill\";\n    return \"dot\";\n  }\n  function pickMeteorColor(){ return (Math.random() < 0.78) ? COLORS.white : pickAccent(); }\n\n  // Bigger + denser than your current hero values\n  function seedDust(){\n    var area = w * h;\n    var count = Math.round(clamp(area / 300, 1200, 2400));\n    dust = new Array(count);\n\n    for(var i = 0; i < count; i++){\n      var color = pickDustColor();\n      var isAccent = (color !== COLORS.white);\n\n      var vx = rand(-0.026, 0.026);\n      var vy = rand(-0.020, 0.020);\n\n      var tw = rand(0.28, 1.05);\n      var ph = rand(0, Math.PI * 2);\n\n      var a0 = isAccent ? rand(0.40, 0.70) : rand(0.12, 0.34);\n\n      // Bigger stars\n      var size = isAccent\n        ? rand(1.2, 2.8)\n        : ((Math.random() < 0.78) ? rand(0.6, 1.45) : rand(1.45, 2.2));\n\n      dust[i] = { x: rand(0, w), y: rand(0, h), vx: vx, vy: vy, color: color, isAccent: isAccent, a0: a0, size: size, tw: tw, ph: ph };\n    }\n  }\n\n  function seedFloaters(){\n    var area = w * h;\n    var count = Math.round(clamp(area / 1900, 220, 420));\n    floaters = new Array(count);\n\n    for(var i = 0; i < count; i++){\n      var kind = pickFloaterKind();\n      var color = pickFloaterColor();\n      var isAccent = (color !== COLORS.white);\n\n      var vx = rand(-0.14, 0.14);\n      var vy = rand(-0.12, 0.12);\n\n      var tw = rand(0.38, 1.25);\n      var ph = rand(0, Math.PI * 2);\n\n      var a0 = isAccent ? rand(0.44, 0.80) : rand(0.16, 0.42);\n      if(kind === \"blob\") a0 *= 0.75;\n      if(kind === \"pill\") a0 *= 0.9;\n\n      var p = { x: rand(0, w), y: rand(0, h), vx: vx, vy: vy, kind: kind, color: color, isAccent: isAccent, a0: a0, tw: tw, ph: ph };\n\n      if(kind === \"dot\"){\n        p.r = isAccent ? rand(2.4, 5.2) : ((Math.random() < 0.65) ? rand(1.4, 3.0) : rand(3.0, 4.6));\n      } else if(kind === \"pill\"){\n        p.pw = rand(7, 20);\n        p.phh = rand(1.8, 3.8);\n        p.rot = rand(-0.7, 0.7);\n      } else {\n        p.br = rand(5, 12);\n      }\n      if(isAccent) p.glowSize = rand(5, 12);\n\n      floaters[i] = p;\n    }\n  }\n\n  function drawRoundRect(x, y, ww, hh, rr){\n    var r = Math.min(rr, ww/2, hh/2);\n    ctx.beginPath();\n    ctx.moveTo(x + r, y);\n    ctx.lineTo(x + ww - r, y);\n    ctx.quadraticCurveTo(x + ww, y, x + ww, y + r);\n    ctx.lineTo(x + ww, y + hh - r);\n    ctx.quadraticCurveTo(x + ww, y + hh, x + ww - r, y + hh);\n    ctx.lineTo(x + r, y + hh);\n    ctx.quadraticCurveTo(x, y + hh, x, y + hh - r);\n    ctx.lineTo(x, y + r);\n    ctx.quadraticCurveTo(x, y, x + r, y);\n    ctx.closePath();\n    ctx.fill();\n  }\n\n  // ===== Shooting stars =====\n  function scheduleNextShooter(now){ nextShooterAt = now + rand(2200, 6500); }\n\n  function spawnShooter(now){\n    var fromLeft = Math.random() < 0.5;\n    var depth = rand(0.55, 1.0);\n\n    var y = rand(h * 0.08, h * 0.92);\n    var startX = fromLeft ? -rand(60, 140) : (w + rand(60, 140));\n    var angle = fromLeft ? rand(-0.42, 0.42) : rand(Math.PI - 0.42, Math.PI + 0.42);\n\n    var speed = rand(720, 1450) * (0.70 + depth * 0.45);\n    var life = rand(0.60, 1.15);\n    var color = pickMeteorColor();\n    var tail = rand(120, 240) * depth * (speed / 1000);\n\n    shooters.push({\n      x: startX, y: y,\n      vx: Math.cos(angle) * speed,\n      vy: Math.sin(angle) * speed,\n      t: 0, life: life, depth: depth,\n      tail: tail,\n      w: rand(1.2, 2.6) * depth,\n      color: color\n    });\n\n    scheduleNextShooter(now);\n  }\n\n  function drawShooter(s){\n    var p = clamp(s.t / s.life, 0, 1);\n    var fadeIn = Math.pow(clamp(p / 0.12, 0, 1), 0.7);\n    var fadeOut = 1 - Math.pow(clamp((p - 0.45) / 0.55, 0, 1), 1.8);\n    var a = fadeIn * fadeOut;\n    if(a < 0.01) return;\n\n    var spd = Math.sqrt(s.vx * s.vx + s.vy * s.vy) || 1;\n    var dx = s.vx / spd, dy = s.vy / spd;\n\n    var tl = s.tail * (0.65 + 0.35 * a);\n    var tx = s.x - dx * tl, ty = s.y - dy * tl;\n\n    ctx.save();\n    ctx.lineCap = \"round\";\n\n    var g1 = ctx.createLinearGradient(tx, ty, s.x, s.y);\n    g1.addColorStop(0, \"rgba(\" + s.color.rgb + \",0)\");\n    g1.addColorStop(0.62, \"rgba(\" + s.color.rgb + \",\" + (0.18 * a).toFixed(4) + \")\");\n    g1.addColorStop(1,  \"rgba(\" + s.color.rgb + \",\" + (0.34 * a).toFixed(4) + \")\");\n    ctx.strokeStyle = g1;\n    ctx.lineWidth = s.w * 5.5;\n    ctx.beginPath();\n    ctx.moveTo(tx, ty);\n    ctx.lineTo(s.x, s.y);\n    ctx.stroke();\n\n    var g2 = ctx.createLinearGradient(tx, ty, s.x, s.y);\n    g2.addColorStop(0, \"rgba(\" + s.color.rgb + \",0)\");\n    g2.addColorStop(1, \"rgba(\" + s.color.rgb + \",\" + (0.70 * a).toFixed(4) + \")\");\n    ctx.strokeStyle = g2;\n    ctx.lineWidth = s.w * 2.2;\n    ctx.beginPath();\n    ctx.moveTo(tx + (s.x - tx) * 0.18, ty + (s.y - ty) * 0.18);\n    ctx.lineTo(s.x, s.y);\n    ctx.stroke();\n\n    var headR = s.w * 2.2;\n    ctx.shadowBlur = 14 * s.depth;\n    ctx.shadowColor = s.color.hex;\n\n    var hg = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, headR * 3.0);\n    hg.addColorStop(0,    \"rgba(255,255,255,\" + (0.95 * a).toFixed(4) + \")\");\n    hg.addColorStop(0.20, \"rgba(\" + s.color.rgb + \",\" + (0.62 * a).toFixed(4) + \")\");\n    hg.addColorStop(1,    \"rgba(\" + s.color.rgb + \",0)\");\n    ctx.fillStyle = hg;\n    ctx.beginPath();\n    ctx.arc(s.x, s.y, headR * 3.0, 0, Math.PI * 2);\n    ctx.fill();\n\n    ctx.shadowBlur = 6 * s.depth;\n    ctx.shadowColor = \"#ffffff\";\n    ctx.fillStyle = \"rgba(255,255,255,\" + (0.95 * a).toFixed(4) + \")\";\n    ctx.beginPath();\n    ctx.arc(s.x, s.y, headR * 0.35, 0, Math.PI * 2);\n    ctx.fill();\n\n    ctx.restore();\n    ctx.shadowBlur = 0;\n    ctx.shadowColor = \"transparent\";\n  }\n\n  function step(t){\n    var now = t || performance.now();\n    var dt = lastFrame ? clamp((now - lastFrame) / 1000, 0.001, 0.05) : (1/60);\n    lastFrame = now;\n\n    var time = now * 0.001;\n\n    ctx.clearRect(0, 0, w, h);\n    ctx.globalCompositeOperation = \"lighter\";\n    ctx.shadowBlur = 0;\n    ctx.shadowColor = \"transparent\";\n\n    for(var i = 0; i < dust.length; i++){\n      var d = dust[i];\n\n      d.x += d.vx;\n      d.y += d.vy;\n\n      if(d.x < -2) d.x = w + 2;\n      if(d.x > w + 2) d.x = -2;\n      if(d.y < -2) d.y = h + 2;\n      if(d.y > h + 2) d.y = -2;\n\n      var twk = 0.70 + 0.30 * Math.sin(time * d.tw + d.ph);\n      var a = d.a0 * twk;\n\n      if(d.isAccent){\n        ctx.shadowBlur = 3.5;\n        ctx.shadowColor = d.color.hex;\n      } else {\n        ctx.shadowBlur = 0;\n        ctx.shadowColor = \"transparent\";\n      }\n\n      ctx.fillStyle = \"rgba(\" + d.color.rgb + \",\" + a.toFixed(3) + \")\";\n      ctx.fillRect(d.x - d.size * 0.5, d.y - d.size * 0.5, d.size, d.size);\n    }\n\n    for(var j = 0; j < floaters.length; j++){\n      var p = floaters[j];\n\n      p.x += p.vx;\n      p.y += p.vy;\n\n      if(p.x < -25) p.x = w + 25;\n      if(p.x > w + 25) p.x = -25;\n      if(p.y < -25) p.y = h + 25;\n      if(p.y > h + 25) p.y = -25;\n\n      var twk2 = 0.65 + 0.35 * Math.sin(time * p.tw + p.ph);\n      var a2 = p.a0 * twk2;\n\n      if(p.isAccent && p.glowSize){\n        ctx.shadowBlur = p.glowSize * twk2;\n        ctx.shadowColor = p.color.hex;\n      } else {\n        ctx.shadowBlur = 0;\n        ctx.shadowColor = \"transparent\";\n      }\n\n      ctx.fillStyle = \"rgba(\" + p.color.rgb + \",\" + a2.toFixed(3) + \")\";\n\n      if(p.kind === \"dot\"){\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);\n        ctx.fill();\n      } else if(p.kind === \"pill\"){\n        ctx.save();\n        ctx.translate(p.x, p.y);\n        ctx.rotate(p.rot);\n        drawRoundRect(-p.pw/2, -p.phh/2, p.pw, p.phh, p.phh/2);\n        ctx.restore();\n      } else {\n        var r = p.br;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, r, 0, Math.PI * 2);\n        ctx.arc(p.x + r * 0.5, p.y - r * 0.2, r * 0.7, 0, Math.PI * 2);\n        ctx.arc(p.x - r * 0.4, p.y + r * 0.15, r * 0.6, 0, Math.PI * 2);\n        ctx.fill();\n      }\n    }\n\n    // Meteors only after base field is drawn\n    if(!nextShooterAt) scheduleNextShooter(now);\n    if(now >= nextShooterAt) spawnShooter(now);\n\n    for(var k = shooters.length - 1; k >= 0; k--){\n      var s = shooters[k];\n      s.t += dt;\n      s.x += s.vx * dt;\n      s.y += s.vy * dt;\n\n      drawShooter(s);\n\n      var m = 520;\n      if(s.t >= s.life || s.x < -m || s.x > w + m || s.y < -m || s.y > h + m){\n        shooters.splice(k, 1);\n      }\n    }\n\n    ctx.globalCompositeOperation = \"source-over\";\n    ctx.shadowBlur = 0;\n    ctx.shadowColor = \"transparent\";\n\n    requestAnimationFrame(step);\n  }\n\n  resize();\n  seedDust();\n  seedFloaters();\n  requestAnimationFrame(step);\n\n  window.addEventListener('resize', function(){\n    resize();\n    seedDust();\n    seedFloaters();\n    shooters.length = 0;\n    nextShooterAt = 0;\n  }, { passive: true });\n})();\n</script>",
        "color_scheme": "scheme-4",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_QcCtY6": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  BAD Vinyl - v4.7.2 (Background Swap Only + MUCH Denser/Bigger Particles + Shooting Stars)\n  Kept: ALL interactions, tilt, hover, click, audio, seek, spin, layout, typography.\n  Changed: Ambient particle canvas now has a lot more particles, bigger particles, and shooting stars.\n{%- endcomment -%}\n\n<section id=\"bad-vinyl\" aria-label=\"BAD Vinyl grid\">\n  <canvas class=\"bv-field\" aria-hidden=\"true\"></canvas>\n  <div class=\"cinema-bars\" aria-hidden=\"true\"><span></span><span></span></div>\n  <div class=\"vinyl-grid\" id=\"vinyl-grid\"></div>\n</section>\n\n<style>\n  #bad-vinyl{\n    position:relative;min-height:100vh;min-height:100svh;width:100%;\n    overflow:hidden;background:#000;isolation:isolate;color:#fff;\n    padding:12px 12px 24px;text-align:center;\n\n    --title-stroke-color: rgba(0,0,0,0.95);\n    --title-stroke-width: 2.5px;\n    --title-shadow: 0 0 0 var(--title-stroke-color),\n      1px 0 0 var(--title-stroke-color), -1px 0 0 var(--title-stroke-color),\n      0 1px 0 var(--title-stroke-color), 0 -1px 0 var(--title-stroke-color),\n      1px 1px 0 var(--title-stroke-color), -1px 1px 0 var(--title-stroke-color),\n      1px -1px 0 var(--title-stroke-color), -1px -1px 0 var(--title-stroke-color);\n  }\n\n  #bad-vinyl .bv-field{\n    position:absolute;inset:0;width:100%;height:100%;\n    pointer-events:none;z-index:0;opacity:1;\n    mix-blend-mode:screen;filter:contrast(1.1);\n    transform:translateZ(0);\n  }\n\n  #bad-vinyl .cinema-bars,\n  #bad-vinyl .vinyl-grid{position:relative;z-index:1;}\n\n  @font-face{ font-family:'Impact'; src:local('Impact'), local('Impact Regular'); font-display:swap; }\n\n  #bad-vinyl .vinyl-grid{\n    display:grid !important;\n    grid-template-columns:repeat(2,minmax(0,1fr)) !important;\n    gap:26px;align-content:start;justify-items:center;\n    min-height:calc(100svh - 64px);\n  }\n  @media (max-width:640px){\n    #bad-vinyl .vinyl-grid{grid-template-columns:1fr !important;gap:10px;}\n    #bad-vinyl{--title-stroke-width:3px;}\n  }\n\n  #bad-vinyl .vinyl-card{\n    position:relative;isolation:isolate;text-align:center;width:100%;\n    background:transparent;padding:10px 4px 14px;contain:paint;\n    border-radius:10px;overflow:hidden;\n  }\n\n  #bad-vinyl .disc-wrap{position:relative;perspective:1400px;perspective-origin:50% 50%;margin-bottom:14px;z-index:1;}\n\n  #bad-vinyl .vinyl-disc{\n    --size: clamp(260px, min(28vh, 34vw), 560px);\n    --spin-idle:18s; --spin-delay:0s; --press-scale:1;\n    --angle:0deg;\n    --rx:0deg; --ry:0deg;\n    --tx:0px; --ty:0px;\n    --ds-x:0px; --ds-y:18px;\n\n    position:relative;width:var(--size);height:var(--size);margin:0 auto;border-radius:50%;\n    border:2px solid #151515;background:#222;\n    box-shadow:var(--ds-x) var(--ds-y) 48px rgba(0,0,0,.65), inset 0 0 0 6px #0b0b0b;\n    cursor:pointer;will-change:transform,box-shadow;overflow:hidden;\n    animation:vinylSpin var(--spin-idle) linear infinite var(--spin-delay);\n    transform-style:preserve-3d;\n    transform:translate3d(var(--tx),var(--ty),0) rotateX(var(--rx)) rotateY(var(--ry)) rotate(var(--angle)) scale(var(--press-scale));\n    transition:box-shadow .12s ease, transform .06s ease;touch-action:manipulation;\n  }\n  #bad-vinyl .vinyl-disc:active{--press-scale:.985;}\n  #bad-vinyl .vinyl-card.is-playing .vinyl-disc{\n    box-shadow:var(--ds-x) calc(var(--ds-y) + 6px) 58px rgba(0,0,0,.7), inset 0 0 0 6px #0b0b0b;\n  }\n\n  #bad-vinyl .cd-art{\n    position:absolute;inset:0;border-radius:50%;\n    background-image:url('{{ 'cd.png' | file_url }}');\n    background-position:center;background-repeat:no-repeat;background-size:100% 100%;\n    z-index:0;filter:saturate(1.02) contrast(1.02);\n    transform:translateZ(1px);\n  }\n\n  #bad-vinyl .sheen{\n    position:absolute;inset:0;border-radius:50%;pointer-events:none;z-index:3;\n    background:radial-gradient(circle at var(--lx,50%) var(--ly,50%), rgba(255,255,255,.26), rgba(255,255,255,0) 38%);\n    mix-blend-mode:screen;filter:blur(.6px);\n    transform:translateZ(3px);\n  }\n\n  #bad-vinyl .progress-ring{\n    position:absolute;inset:0;border-radius:50%;z-index:2;pointer-events:none;\n    background:conic-gradient(#ff33ff calc(var(--p,0) * 1%), transparent 0);\n    opacity:.9;filter:drop-shadow(0 0 8px rgba(255,51,255,.35));\n    -webkit-mask:radial-gradient(circle, transparent calc(50% - 8px), #000 calc(50% - 6px), #000 100%);\n            mask:radial-gradient(circle, transparent calc(50% - 8px), #000 calc(50% - 6px), #000 100%);\n    transform:translateZ(2px);\n  }\n\n  #bad-vinyl .vinyl-disc::after{\n    content:\"\";position:absolute;inset:0;border-radius:50%;z-index:4;pointer-events:none;\n    background:\n      radial-gradient(circle at 50% 50%, rgba(0,0,0,.34) 0 3.2%, rgba(0,0,0,0) 3.3%),\n      repeating-radial-gradient(rgba(255,255,255,.055) 0 2px, rgba(0,0,0,.05) 2px 4px);\n    mix-blend-mode:overlay;\n    transform:translateZ(4px);\n  }\n  #bad-vinyl .vinyl-center{\n    position:absolute;left:50%;top:50%;width:12px;height:12px;\n    transform:translate(-50%,-50%) translateZ(5px);border-radius:50%;\n    background:#000;border:2px solid #222;z-index:5;\n  }\n\n  #bad-vinyl .badge{\n    position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);font-size:48px;\n    color:#fff;text-shadow:0 2px 8px rgba(0,0,0,.7);z-index:6;\n    transition:opacity .15s ease, transform .15s ease;\n    pointer-events:auto;cursor:pointer;user-select:none;background:none;border:none;\n  }\n  #bad-vinyl .badge.pause{opacity:0;}\n  #bad-vinyl .vinyl-card.is-playing .badge.play{opacity:0;}\n  #bad-vinyl .vinyl-card.is-playing .badge.pause{opacity:1;}\n  #bad-vinyl .vinyl-disc:hover ~ .badge.play{transform:translate(-50%,-56%);}\n\n  #bad-vinyl .vinyl-title{\n    margin:6px 0 0;\n    font-family:Impact,Haettenschweiler,'Arial Black',system-ui,sans-serif;\n    font-weight:900;font-size:clamp(36px,7.5vw,98px);\n    line-height:.9;letter-spacing:.01em;color:#f7f7f7;\n    -webkit-text-stroke:var(--title-stroke-width) var(--title-stroke-color);\n    text-shadow:var(--title-shadow);\n    mix-blend-mode:normal;\n    -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;\n    text-rendering:geometricPrecision;\n  }\n  #bad-vinyl .vinyl-card.is-playing .vinyl-title{\n    color:#ffeafd;\n    text-shadow:var(--title-shadow), 0 0 10px rgba(255,51,255,.35), 0 0 18px rgba(88,101,242,.28);\n  }\n\n  .vinyl-artist{\n    margin:6px 0 12px;\n    font:800 clamp(26px,4.8vw,48px)/1 Impact,Haettenschweiler,'Arial Black',system-ui,sans-serif;\n    color:#fff;letter-spacing:.01em;\n    -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;\n    text-rendering:geometricPrecision;\n  }\n  .vinyl-artist:empty{display:none;}\n\n  .seek{position:relative;height:8px;margin:8px auto 10px;width:92%;background:#101010;border-radius:999px;border:1px solid #1b1b1b;cursor:pointer;}\n  .seek .fill{position:absolute;left:0;top:0;height:100%;width:0%;border-radius:999px;background:linear-gradient(90deg,#ff33ff,#ffffff);box-shadow:0 0 12px rgba(255,51,255,.35);}\n  .seek .knob{position:absolute;top:50%;transform:translate(-50%,-50%);width:14px;height:14px;border-radius:50%;background:#fff;box-shadow:0 0 10px rgba(255,255,255,.6),0 0 12px rgba(255,51,255,.45);}\n  .time-row{display:flex;align-items:center;justify-content:center;gap:8px;font-size:12px;color:#cfcfcf;}\n  .time-row .dur{opacity:.8;}\n\n  .is-disabled .vinyl-disc{cursor:not-allowed;filter:grayscale(1) contrast(.85) brightness(.9);}\n  .soon{position:absolute;right:8px;top:8px;background:#1a1a1a;border:1px solid #2a2a2a;color:#bbb;font-size:10px;padding:2px 6px;border-radius:999px;letter-spacing:.08em;text-transform:uppercase;}\n\n  .start-fx{position:absolute;inset:-10%;z-index:8;pointer-events:none;opacity:0;filter:saturate(135%) brightness(1.08);mix-blend-mode:screen;}\n  .start-fx.run{animation:fxContainer 1200ms ease-out both;}\n  .fx-bloom{position:absolute;inset:0;border-radius:50%;\n    background:radial-gradient(circle, rgba(255,255,255,.9), rgba(255,255,255,0) 56%),\n              radial-gradient(circle at 40% 60%, rgba(255,51,255,.8), transparent 62%),\n              radial-gradient(circle at 70% 35%, rgba(57,255,20,.8), transparent 64%);\n    transform:scale(.22);opacity:.95;filter:blur(.2px);\n    animation:fxBloom calc(1200ms*.78) cubic-bezier(.2,.7,.2,1) forwards;\n  }\n  .fx-rings{position:absolute;inset:-2%;border-radius:50%;}\n  .fx-ring{position:absolute;left:50%;top:50%;width:40%;height:40%;transform:translate(-50%,-50%) scale(.35);border-radius:50%;\n    background:radial-gradient(circle, rgba(255,255,255,.9) 0 1px, transparent 2px), radial-gradient(circle, rgba(255,51,255,.7) 0, transparent 70%);\n    -webkit-mask:radial-gradient(circle, transparent 46%, #000 48%, #000 100%); mask:radial-gradient(circle, transparent 46%, #000 48%, #000 100%);\n    filter:blur(.3px);opacity:.95;animation:fxRing calc(1200ms*.9) cubic-bezier(.16,.8,.2,1) forwards;\n  }\n  .fx-ring.r2{width:56%;height:56%;animation-delay:40ms;background:radial-gradient(circle, rgba(255,255,255,.9) 0 1px, transparent 2px), radial-gradient(circle, rgba(57,255,20,.7) 0, transparent 70%);}\n  .fx-ring.r3{width:72%;height:72%;animation-delay:80ms;}\n\n  @keyframes vinylSpin{to{transform:rotate(360deg);}}\n  @keyframes fxContainer{0%{opacity:1} 85%{opacity:1} 100%{opacity:0}}\n  @keyframes fxBloom{0%{transform:scale(.22);opacity:.98;} 70%{transform:scale(2.4);opacity:.55;} 100%{transform:scale(2.76);opacity:0;filter:blur(1px);}}\n\n  @media (prefers-reduced-motion: reduce){\n    #bad-vinyl .vinyl-disc{--rx:0deg;--ry:0deg;--tx:0px;--ty:0px;animation:none;}\n    #bad-vinyl .bv-field{display:none;}\n  }\n\n  @media (max-width: 640px){\n    #bad-vinyl{padding-top:max(18px, calc(env(safe-area-inset-top, 0px) + 8px));}\n    #bad-vinyl .vinyl-card{padding:6px 4px 8px;}\n    #bad-vinyl .disc-wrap{margin-bottom:8px;}\n    #bad-vinyl .seek{margin:6px auto 6px;}\n    #bad-vinyl .time-row{margin-top:2px;}\n\n    #bad-vinyl .vinyl-title{\n      font-size:clamp(30px, 8.6vw, 56px);\n      line-height:1.02;letter-spacing:.006em;\n      -webkit-text-stroke:1.8px var(--title-stroke-color);\n      text-shadow:\n        0 0 0 var(--title-stroke-color),\n        1px 0 0 var(--title-stroke-color), -1px 0 0 var(--title-stroke-color),\n        0 1px 0 var(--title-stroke-color), 0 -1px 0 var(--title-stroke-color),\n        .8px .8px 0 var(--title-stroke-color), -.8px .8px 0 var(--title-stroke-color),\n        .8px -.8px 0 var(--title-stroke-color), -.8px -.8px 0 var(--title-stroke-color);\n    }\n    #bad-vinyl .vinyl-card.is-playing .vinyl-title{\n      text-shadow:\n        0 0 0 var(--title-stroke-color),\n        1px 0 0 var(--title-stroke-color), -1px 0 0 var(--title-stroke-color),\n        0 1px 0 var(--title-stroke-color), 0 -1px 0 var(--title-stroke-color),\n        .8px .8px 0 var(--title-stroke-color), -.8px .8px 0 var(--title-stroke-color),\n        .8px -.8px 0 var(--title-stroke-color), -.8px -.8px 0 var(--title-stroke-color),\n        0 0 8px rgba(255,51,255,.22), 0 0 12px rgba(88,101,242,.20);\n    }\n\n    #bad-vinyl .vinyl-artist{\n      font-size:clamp(18px, 4.4vw, 26px);\n      line-height:1.08;letter-spacing:.004em;\n      text-shadow:0 0 0 #000, 1px 0 0 #000, -1px 0 0 #000, 0 1px 0 #000, 0 -1px 0 #000;\n    }\n  }\n</style>\n\n<script>\n/* ====== EDIT SONGS HERE ====== */\nvar BAD_TRACKS = [\n  { title:\"#AMERIKID\",   artists:[\"6200 BPM (Prod. Bobby)\"], src:\"{{ '1.mp3' | file_url }}\" },\n  { title:\"#ON\",         artists:[\"REDD40 & MACCY (Prod. SWMG)\"], src:\"{{ '2.mp3' | file_url }}\" },\n  { title:\"#VANHALEN\",   artists:[\"LoyalGang Luke & Johnny AppleS33d (Prod. Parti)\"], src:\"{{ '3.mp3' | file_url }}\" },\n  { title:\"#FREEVITALY\", artists:[\"AZDONTCARE & Killa Goo$e (Prod. Parti)\"], src:\"{{ '4.mp3' | file_url }}\" },\n  { title:\"#CHRISEAN\",   artists:[\"LoafBoy Don\"], src:\"{{ '5.mp3' | file_url }}\" },\n  { title:\"#FASHIONING\", artists:[\"REDD40 (Prod. SWMG)\"], src:\"{{ '6.mp3' | file_url }}\" },\n  { title:\"#KIDZYN\",     artists:[\"TWINSTAR\"], src:\"{{ '7.mp3' | file_url }}\" },\n  { title:\"#SUMMER OF THE HOODIE\", artists:[\"Brent Pablo & Killa Goo$e\"], src:\"{{ '8.mp3' | file_url }}\" },\n  { title:\"#KANDY\",      artists:[\"KYS DEVI\"], src:\"{{ '9.mp3' | file_url }}\" },\n  { title:\"#100PAIRS\",   artists:[\"LoafBoy Don\"], src:\"{{ '10.mp3' | file_url }}\" },\n  { title:\"#POISION\",    artists:[\"FXJI (Prod. DW Destroyer)\"], src:\"{{ '11.mp3' | file_url }}\" },\n  { title:\"#DIAMOND\",    artists:[\"Nick Coleman (Prod. Parti)\"], src:\"{{ '12.mp3' | file_url }}\" }\n];\n/* ============================= */\n\n(function(){\n  var sec = document.getElementById('bad-vinyl');\n  var grid = document.getElementById('vinyl-grid');\n  if(!sec || !grid) return;\n\n  function enforceCols(){\n    var cols = (window.innerWidth <= 640) ? 1 : 2;\n    grid.style.display = 'grid';\n    grid.style.gridTemplateColumns = 'repeat('+cols+', minmax(0,1fr))';\n  }\n  enforceCols();\n  window.addEventListener('resize', enforceCols);\n\n  var bars = sec.querySelector('.cinema-bars');\n  function shake(){ sec.classList.remove('shake'); void sec.offsetWidth; sec.classList.add('shake'); setTimeout(function(){sec.classList.remove('shake');}, 500); }\n\n  BAD_TRACKS.forEach(function(track, i){\n    var card = document.createElement('article');\n    card.className = 'vinyl-card';\n    card.id = 'track-'+i;\n    card.dataset.index = i;\n\n    var discWrap = document.createElement('div'); discWrap.className='disc-wrap';\n    var discBtn = document.createElement('button'); discBtn.className='vinyl-disc'; discBtn.type='button';\n    discBtn.setAttribute('aria-label','Play '+(track.title||'Song')); discBtn.dataset.index = i;\n\n    var cd = document.createElement('span'); cd.className='cd-art';\n    var ring = document.createElement('span'); ring.className='progress-ring'; ring.style.setProperty('--p','0%');\n    var center = document.createElement('span'); center.className='vinyl-center';\n    var sheen = document.createElement('span'); sheen.className='sheen';\n\n    var playB = document.createElement('button'); playB.className='badge play'; playB.type='button'; playB.setAttribute('aria-label','Play'); playB.textContent='▶'; playB.dataset.index = i;\n    var pauseB = document.createElement('button'); pauseB.className='badge pause'; pauseB.type='button'; pauseB.setAttribute('aria-label','Pause'); pauseB.textContent='❚❚'; pauseB.dataset.index = i;\n\n    var fx = document.createElement('div'); fx.className='start-fx';\n    fx.innerHTML = '<div class=\"fx-bloom\"></div><div class=\"fx-rings\"><div class=\"fx-ring r1\"></div><div class=\"fx-ring r2\"></div><div class=\"fx-ring r3\"></div></div>';\n\n    discBtn.appendChild(cd); discBtn.appendChild(ring); discBtn.appendChild(center); discBtn.appendChild(sheen);\n    discWrap.appendChild(discBtn); discWrap.appendChild(fx); discWrap.appendChild(playB); discWrap.appendChild(pauseB);\n\n    var audio = document.createElement('audio'); audio.className='vinyl-audio'; audio.preload='metadata';\n    if(track.src) audio.src = track.src;\n\n    var title = document.createElement('h3'); title.className='vinyl-title'; title.textContent = track.title || 'Song';\n    var artist = document.createElement('div'); artist.className='vinyl-artist';\n    var artistList = Array.isArray(track.artists) ? track.artists : (track.artist ? [track.artist] : []);\n    artist.textContent = artistList.join(', ');\n\n    var seek = document.createElement('div'); seek.className='seek';\n    var fill = document.createElement('span'); fill.className='fill';\n    var knob = document.createElement('span'); knob.className='knob'; knob.style.left='0%';\n    seek.appendChild(fill); seek.appendChild(knob);\n\n    var timeRow = document.createElement('div'); timeRow.className='time-row';\n    var el = document.createElement('span'); el.className='el'; el.textContent='0:00';\n    var sep = document.createElement('span'); sep.textContent='•'; sep.style.opacity='.4';\n    var dur = document.createElement('span'); dur.className='dur'; dur.textContent='0:00';\n    timeRow.appendChild(el); timeRow.appendChild(sep); timeRow.appendChild(dur);\n\n    card.appendChild(discWrap);\n    card.appendChild(audio);\n    card.appendChild(title);\n    card.appendChild(artist);\n    card.appendChild(seek);\n    card.appendChild(timeRow);\n    grid.appendChild(card);\n\n    (function initDiscTilt(){\n      if(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;\n\n      var rect = discWrap.getBoundingClientRect();\n      var targetRX=0,targetRY=0,targetTX=0,targetTY=0;\n      var curRX=0,curRY=0,curTX=0,curTY=0;\n      var rafId=null, hover=false;\n\n      var MAX_YAW=22, MAX_PITCH=18, MAX_SHIFT=22, EASE=0.16;\n\n      function updateLighting(dx, dy){\n        var lx = (50 + dx * 28).toFixed(1) + '%';\n        var ly = (50 - dy * 28).toFixed(1) + '%';\n        sheen.style.setProperty('--lx', lx);\n        sheen.style.setProperty('--ly', ly);\n\n        discBtn.style.setProperty('--ds-x', (dx * 12).toFixed(2) + 'px');\n        discBtn.style.setProperty('--ds-y', (18 + Math.abs(dy) * 10).toFixed(2) + 'px');\n      }\n\n      function onMoveXY(clientX, clientY){\n        var x = (clientX - rect.left) / rect.width;\n        var y = (clientY - rect.top) / rect.height;\n        var dx = Math.max(-1, Math.min(1, (x - 0.5) * 2));\n        var dy = Math.max(-1, Math.min(1, (y - 0.5) * 2));\n\n        targetRY = dx * MAX_YAW;\n        targetRX = -dy * MAX_PITCH;\n        targetTX = -dx * MAX_SHIFT;\n        targetTY =  dy * MAX_SHIFT;\n        updateLighting(dx, dy);\n      }\n\n      function animate(){\n        curRX += (targetRX - curRX) * EASE;\n        curRY += (targetRY - curRY) * EASE;\n        curTX += (targetTX - curTX) * EASE;\n        curTY += (targetTY - curTY) * EASE;\n\n        discBtn.style.setProperty('--rx', curRX.toFixed(3) + 'deg');\n        discBtn.style.setProperty('--ry', curRY.toFixed(3) + 'deg');\n        discBtn.style.setProperty('--tx', curTX.toFixed(3) + 'px');\n        discBtn.style.setProperty('--ty', curTY.toFixed(3) + 'px');\n\n        if(hover || Math.abs(curRX)>0.05 || Math.abs(curRY)>0.05 || Math.abs(curTX)>0.05 || Math.abs(curTY)>0.05){\n          rafId = requestAnimationFrame(animate);\n        } else {\n          rafId = null;\n        }\n      }\n\n      function start(){ rect = discWrap.getBoundingClientRect(); hover = true; if(!rafId) rafId = requestAnimationFrame(animate); }\n      function move(e){ onMoveXY(e.clientX, e.clientY); }\n      function end(){ hover = false; targetRX=targetRY=targetTX=targetTY=0; if(!rafId) rafId = requestAnimationFrame(animate); }\n\n      discWrap.addEventListener('pointerenter', start, {passive:true});\n      discWrap.addEventListener('pointermove',  move,  {passive:true});\n      discWrap.addEventListener('pointerleave', end,   {passive:true});\n\n      discWrap.addEventListener('mouseenter', start, {passive:true});\n      discWrap.addEventListener('mousemove',  move,  {passive:true});\n      discWrap.addEventListener('mouseleave', end,   {passive:true});\n\n      window.addEventListener('resize', function(){ rect = discWrap.getBoundingClientRect(); }, {passive:true});\n    })();\n\n    card._rotationsPerTrack = Math.round(14 + Math.random()*16);\n    discBtn.style.setProperty('--spin-idle', (14+Math.random()*16).toFixed(2)+'s');\n    discBtn.style.setProperty('--spin-delay', (-Math.random()*20).toFixed(2)+'s');\n\n    function fmt(t){ t=Math.max(0, t|0); var m=(t/60)|0, s=(t%60)|0; return m+':' + (s<10?'0':'')+s; }\n    function updateTimeAndProgress(){\n      var d=audio.duration||0, ct=audio.currentTime||0;\n      if(d && isFinite(d)) dur.textContent = fmt(d);\n      el.textContent = fmt(ct);\n      var p = d? (ct/d)*100 : 0;\n      fill.style.width = p+'%'; knob.style.left = p+'%'; ring.style.setProperty('--p', p+'%');\n    }\n    function startSpin(){\n      discBtn.style.animation='none';\n      var d=audio.duration||30;\n      function loop(){\n        var t=audio.currentTime||0;\n        var angle=(t/d)*card._rotationsPerTrack*360;\n        discBtn.style.setProperty('--angle', angle+'deg');\n        updateTimeAndProgress();\n        if(!audio.paused && !audio.ended){ card._rafId = requestAnimationFrame(loop); }\n      }\n      cancelAnimationFrame(card._rafId);\n      card._rafId = requestAnimationFrame(loop);\n    }\n    function stopSpin(){\n      cancelAnimationFrame(card._rafId); card._rafId=null;\n      discBtn.style.animation='';\n    }\n\n    function hyperLaunch(){\n      fx.classList.remove('run'); void fx.offsetWidth; fx.classList.add('run');\n      if(bars){ bars.classList.remove('run'); void bars.offsetWidth; bars.classList.add('run'); }\n      shake();\n      setTimeout(function(){ fx.classList.remove('run'); }, 1280);\n    }\n\n    audio.addEventListener('loadedmetadata', updateTimeAndProgress);\n    audio.addEventListener('timeupdate', updateTimeAndProgress);\n\n    audio.addEventListener('play', function(){\n      document.querySelectorAll('#bad-vinyl .vinyl-audio').forEach(function(a){ if(a!==audio){ a.pause(); } });\n      card.classList.add('is-playing'); startSpin();\n      if(!card._launched){ card._launched = true; hyperLaunch(); }\n    });\n    audio.addEventListener('pause', function(){ card.classList.remove('is-playing'); stopSpin(); });\n    audio.addEventListener('ended', function(){ card.classList.remove('is-playing'); stopSpin(); });\n\n    card.addEventListener('mouseenter', function(){\n      if(audio && track.src){ audio.preload='auto'; try{ audio.load(); }catch(e){} }\n    });\n  });\n\n  sec.addEventListener('click', function(e){\n    var hit = e.target.closest('.vinyl-disc, .badge');\n    if(!hit || !sec.contains(hit)) return;\n\n    var card = hit.closest('.vinyl-card');\n    if(!card || card.classList.contains('is-disabled')) return;\n\n    var audio = card.querySelector('.vinyl-audio');\n    if(!audio) return;\n\n    if(audio.paused){\n      audio.play().catch(function(err){ console.warn('Play failed:', err); });\n    } else {\n      audio.pause();\n    }\n  }, { passive:true });\n\n  sec.addEventListener('mousedown', function(e){\n    var seek = e.target.closest('.seek'); if(!seek) return;\n    var card = seek.closest('.vinyl-card'); var audio = card && card.querySelector('.vinyl-audio'); if(!audio) return;\n\n    function seekTo(clientX){\n      var r=seek.getBoundingClientRect();\n      var x=Math.min(Math.max(0, clientX - r.left), r.width);\n      var p=x/r.width;\n      if(isFinite(audio.duration)) audio.currentTime=p*audio.duration;\n\n      var fill = seek.querySelector('.fill');\n      var knob = seek.querySelector('.knob');\n      var pct = (audio.duration? (audio.currentTime/audio.duration)*100 : 0);\n      fill.style.width = pct+'%'; knob.style.left = pct+'%';\n      var ring = card.querySelector('.progress-ring'); if(ring) ring.style.setProperty('--p', pct+'%');\n    }\n\n    seekTo(e.clientX); e.preventDefault();\n    function onMove(ev){ seekTo(ev.clientX); }\n    function onUp(){ window.removeEventListener('mousemove', onMove); window.removeEventListener('mouseup', onUp); }\n    window.addEventListener('mousemove', onMove);\n    window.addEventListener('mouseup', onUp);\n  });\n\n  /* =========================\n     Ambient background (MUCH denser + bigger + shooting stars)\n  ========================= */\n  (function initBadVinylAmbient(){\n    var canvas = sec.querySelector('.bv-field');\n    if(!canvas) return;\n\n    var reduced = false;\n    try { reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch(e){}\n    if(reduced) return;\n\n    var ctx = canvas.getContext('2d', { alpha:true });\n    var w=0,h=0,dpr=Math.min(window.devicePixelRatio||1,2);\n\n    var dust=[], floaters=[], shooters=[];\n    var nextShooterAt=0, lastFrame=0;\n\n    var COLORS = {\n      white:{rgb:\"255,255,255\",hex:\"#ffffff\"},\n      purple:{rgb:\"255,51,255\",hex:\"#ff33ff\"},\n      blue:{rgb:\"127,212,255\",hex:\"#7fd4ff\"},\n      yellow:{rgb:\"255,211,74\",hex:\"#ffd34a\"}\n    };\n\n    function clamp(v,min,max){return Math.min(max,Math.max(min,v));}\n    function rand(min,max){return min+Math.random()*(max-min);}\n\n    function resize(){\n      var r=sec.getBoundingClientRect();\n      w=Math.max(1,Math.floor(r.width));\n      h=Math.max(1,Math.floor(r.height));\n      dpr=Math.min(window.devicePixelRatio||1,2);\n      canvas.width=Math.floor(w*dpr);\n      canvas.height=Math.floor(h*dpr);\n      canvas.style.width=w+\"px\";\n      canvas.style.height=h+\"px\";\n      ctx.setTransform(dpr,0,0,dpr,0,0);\n    }\n\n    function pickAccent(){\n      var r=Math.random();\n      if(r<0.40) return COLORS.purple;\n      if(r<0.72) return COLORS.blue;\n      return COLORS.yellow;\n    }\n    function pickDustColor(){ return (Math.random()<0.84)?COLORS.white:pickAccent(); }\n    function pickFloaterColor(){ return (Math.random()<0.70)?COLORS.white:pickAccent(); }\n    function pickFloaterKind(){\n      var r=Math.random();\n      if(r<0.015) return \"blob\";\n      if(r<0.18) return \"pill\";\n      return \"dot\";\n    }\n    function pickMeteorColor(){ return (Math.random()<0.78)?COLORS.white:pickAccent(); }\n\n    function seedDust(){\n      var area=w*h;\n      var mobile=w<720;\n      var sizeMul=mobile?1.30:1.55;\n      var div=mobile?260:220;\n      var count=Math.round(clamp(area/div, mobile?1100:2400, mobile?2600:5200));\n      dust=new Array(count);\n\n      for(var i=0;i<count;i++){\n        var color=pickDustColor();\n        var isAccent=(color!==COLORS.white);\n\n        var vx=rand(-0.026,0.026);\n        var vy=rand(-0.020,0.020);\n        var tw=rand(0.28,1.05);\n        var ph=rand(0,Math.PI*2);\n\n        var a0=isAccent?rand(0.40,0.70):rand(0.12,0.34);\n        var size=isAccent?rand(1.2,2.8):((Math.random()<0.78)?rand(0.6,1.45):rand(1.45,2.2));\n        size*=sizeMul;\n\n        dust[i]={x:rand(0,w),y:rand(0,h),vx:vx,vy:vy,color:color,isAccent:isAccent,a0:a0,size:size,tw:tw,ph:ph};\n      }\n    }\n\n    function seedFloaters(){\n      var area=w*h;\n      var mobile=w<720;\n      var sizeMul=mobile?1.20:1.45;\n      var div=mobile?1800:1500;\n      var count=Math.round(clamp(area/div, mobile?180:320, mobile?360:650));\n      floaters=new Array(count);\n\n      for(var i=0;i<count;i++){\n        var kind=pickFloaterKind();\n        var color=pickFloaterColor();\n        var isAccent=(color!==COLORS.white);\n\n        var vx=rand(-0.14,0.14);\n        var vy=rand(-0.12,0.12);\n        var tw=rand(0.38,1.25);\n        var ph=rand(0,Math.PI*2);\n\n        var a0=isAccent?rand(0.44,0.80):rand(0.16,0.42);\n        if(kind===\"blob\") a0*=0.75;\n        if(kind===\"pill\") a0*=0.9;\n\n        var p={x:rand(0,w),y:rand(0,h),vx:vx,vy:vy,kind:kind,color:color,isAccent:isAccent,a0:a0,tw:tw,ph:ph};\n\n        if(kind===\"dot\"){\n          p.r=(isAccent?rand(2.4,5.2):((Math.random()<0.65)?rand(1.4,3.0):rand(3.0,4.6))) * sizeMul;\n        } else if(kind===\"pill\"){\n          p.pw=rand(7,20)*sizeMul;\n          p.phh=rand(1.8,3.8)*sizeMul;\n          p.rot=rand(-0.7,0.7);\n        } else {\n          p.br=rand(5,12)*sizeMul;\n        }\n        if(isAccent) p.glowSize=rand(6,14)*sizeMul;\n\n        floaters[i]=p;\n      }\n    }\n\n    function drawRoundRect(x,y,ww,hh,rr){\n      var r=Math.min(rr,ww/2,hh/2);\n      ctx.beginPath();\n      ctx.moveTo(x+r,y);\n      ctx.lineTo(x+ww-r,y);\n      ctx.quadraticCurveTo(x+ww,y,x+ww,y+r);\n      ctx.lineTo(x+ww,y+hh-r);\n      ctx.quadraticCurveTo(x+ww,y+hh,x+ww-r,y+hh);\n      ctx.lineTo(x+r,y+hh);\n      ctx.quadraticCurveTo(x,y+hh,x,y+hh-r);\n      ctx.lineTo(x,y+r);\n      ctx.quadraticCurveTo(x,y,x+r,y);\n      ctx.closePath();\n      ctx.fill();\n    }\n\n    function scheduleNextShooter(now){ nextShooterAt = now + rand(1200, 3400); } // more frequent\n\n    function spawnShooter(now){\n      var fromLeft = Math.random() < 0.5;\n      var depth = rand(0.55, 1.0);\n\n      var y = rand(h*0.08, h*0.92);\n      var x = fromLeft ? -rand(80,160) : (w + rand(80,160));\n      var ang = fromLeft ? rand(-0.42,0.42) : rand(Math.PI-0.42, Math.PI+0.42);\n\n      var speed = rand(820, 1620) * (0.70 + depth*0.45);\n      var life = rand(0.65, 1.20);\n      var color = pickMeteorColor();\n      var tail = rand(150, 300) * depth;\n\n      shooters.push({\n        x:x,y:y,vx:Math.cos(ang)*speed,vy:Math.sin(ang)*speed,\n        t:0,life:life,depth:depth,tail:tail,w:rand(1.2,2.6)*depth,color:color\n      });\n\n      scheduleNextShooter(now);\n    }\n\n    function drawShooter(s){\n      var p=clamp(s.t/s.life,0,1);\n      var fadeIn=Math.pow(clamp(p/0.12,0,1),0.7);\n      var fadeOut=1-Math.pow(clamp((p-0.45)/0.55,0,1),1.8);\n      var a=fadeIn*fadeOut;\n      if(a<0.01) return;\n\n      var spd=Math.sqrt(s.vx*s.vx + s.vy*s.vy) || 1;\n      var dx=s.vx/spd, dy=s.vy/spd;\n      var tl=s.tail*(0.65+0.35*a);\n      var tx=s.x - dx*tl, ty=s.y - dy*tl;\n\n      ctx.save();\n      ctx.lineCap=\"round\";\n\n      var g1=ctx.createLinearGradient(tx,ty,s.x,s.y);\n      g1.addColorStop(0,\"rgba(\"+s.color.rgb+\",0)\");\n      g1.addColorStop(1,\"rgba(\"+s.color.rgb+\",\"+(0.55*a).toFixed(4)+\")\");\n      ctx.strokeStyle=g1;\n      ctx.lineWidth=s.w*4.8;\n      ctx.beginPath(); ctx.moveTo(tx,ty); ctx.lineTo(s.x,s.y); ctx.stroke();\n\n      var g2=ctx.createLinearGradient(tx,ty,s.x,s.y);\n      g2.addColorStop(0,\"rgba(\"+s.color.rgb+\",0)\");\n      g2.addColorStop(1,\"rgba(255,255,255,\"+(0.85*a).toFixed(4)+\")\");\n      ctx.strokeStyle=g2;\n      ctx.lineWidth=s.w*2.0;\n      ctx.beginPath();\n      ctx.moveTo(tx+(s.x-tx)*0.18, ty+(s.y-ty)*0.18);\n      ctx.lineTo(s.x,s.y);\n      ctx.stroke();\n\n      var headR=s.w*2.2;\n      ctx.shadowBlur=14*s.depth;\n      ctx.shadowColor=s.color.hex;\n\n      var hg=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,headR*3.0);\n      hg.addColorStop(0,\"rgba(255,255,255,\"+(0.95*a).toFixed(4)+\")\");\n      hg.addColorStop(0.25,\"rgba(\"+s.color.rgb+\",\"+(0.70*a).toFixed(4)+\")\");\n      hg.addColorStop(1,\"rgba(\"+s.color.rgb+\",0)\");\n      ctx.fillStyle=hg;\n      ctx.beginPath(); ctx.arc(s.x,s.y,headR*3.0,0,Math.PI*2); ctx.fill();\n\n      ctx.restore();\n      ctx.shadowBlur=0; ctx.shadowColor=\"transparent\";\n    }\n\n    function step(ts){\n      var now = ts || performance.now();\n      var dt = lastFrame ? clamp((now-lastFrame)/1000, 0.001, 0.05) : (1/60);\n      lastFrame = now;\n      var time = now * 0.001;\n\n      ctx.clearRect(0,0,w,h);\n      ctx.globalCompositeOperation=\"lighter\";\n      ctx.shadowBlur=0; ctx.shadowColor=\"transparent\";\n\n      for(var i=0;i<dust.length;i++){\n        var d=dust[i];\n        d.x+=d.vx; d.y+=d.vy;\n        if(d.x<-2) d.x=w+2; if(d.x>w+2) d.x=-2;\n        if(d.y<-2) d.y=h+2; if(d.y>h+2) d.y=-2;\n\n        var twk=0.70 + 0.30*Math.sin(time*d.tw + d.ph);\n        var a=d.a0*twk;\n\n        if(d.isAccent){ ctx.shadowBlur=4; ctx.shadowColor=d.color.hex; }\n        else { ctx.shadowBlur=0; ctx.shadowColor=\"transparent\"; }\n\n        ctx.fillStyle=\"rgba(\"+d.color.rgb+\",\"+a.toFixed(3)+\")\";\n        ctx.fillRect(d.x-d.size*0.5, d.y-d.size*0.5, d.size, d.size);\n      }\n\n      for(var j=0;j<floaters.length;j++){\n        var p=floaters[j];\n        p.x+=p.vx; p.y+=p.vy;\n        if(p.x<-25) p.x=w+25; if(p.x>w+25) p.x=-25;\n        if(p.y<-25) p.y=h+25; if(p.y>h+25) p.y=-25;\n\n        var tw2=0.65 + 0.35*Math.sin(time*p.tw + p.ph);\n        var a2=p.a0*tw2;\n\n        if(p.isAccent && p.glowSize){ ctx.shadowBlur=p.glowSize*tw2; ctx.shadowColor=p.color.hex; }\n        else { ctx.shadowBlur=0; ctx.shadowColor=\"transparent\"; }\n\n        ctx.fillStyle=\"rgba(\"+p.color.rgb+\",\"+a2.toFixed(3)+\")\";\n\n        if(p.kind===\"dot\"){\n          ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2); ctx.fill();\n        } else if(p.kind===\"pill\"){\n          ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rot);\n          drawRoundRect(-p.pw/2, -p.phh/2, p.pw, p.phh, p.phh/2);\n          ctx.restore();\n        } else {\n          var r=p.br;\n          ctx.beginPath();\n          ctx.arc(p.x,p.y,r,0,Math.PI*2);\n          ctx.arc(p.x+r*0.5, p.y-r*0.2, r*0.7, 0, Math.PI*2);\n          ctx.arc(p.x-r*0.4, p.y+r*0.15, r*0.6, 0, Math.PI*2);\n          ctx.fill();\n        }\n      }\n\n      if(!nextShooterAt) scheduleNextShooter(now);\n      if(now >= nextShooterAt) spawnShooter(now);\n\n      for(var k=shooters.length-1;k>=0;k--){\n        var s=shooters[k];\n        s.t += dt;\n        s.x += s.vx*dt;\n        s.y += s.vy*dt;\n\n        drawShooter(s);\n\n        var m=560;\n        if(s.t>=s.life || s.x<-m || s.x>w+m || s.y<-m || s.y>h+m){\n          shooters.splice(k,1);\n        }\n      }\n\n      ctx.globalCompositeOperation=\"source-over\";\n      ctx.shadowBlur=0; ctx.shadowColor=\"transparent\";\n      requestAnimationFrame(step);\n    }\n\n    resize();\n    seedDust();\n    seedFloaters();\n    requestAnimationFrame(step);\n\n    if('ResizeObserver' in window){\n      var ro=new ResizeObserver(function(){\n        resize(); seedDust(); seedFloaters();\n        shooters.length=0; nextShooterAt=0; lastFrame=0;\n      });\n      ro.observe(sec);\n    } else {\n      window.addEventListener('resize', function(){\n        resize(); seedDust(); seedFloaters();\n        shooters.length=0; nextShooterAt=0; lastFrame=0;\n      }, {passive:true});\n    }\n  })();\n})();\n</script>",
