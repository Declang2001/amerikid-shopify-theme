        "custom_liquid": "<!-- =========================\n  AMERIKID - HOLOGRAPHIC SOCIAL DOCK (3D) - TILT FIXED\n  - Smooth cursor-tilt (lerped)\n  - Pauses float animation while hovering (prevents transform fighting)\n  - Disables transform transition during active tilt (prevents jitter)\n  - Only runs tilt on hover + fine pointer devices\n========================= -->\n\n<div class=\"ak-social-holo\" aria-label=\"AmeriKid social links\">\n  <canvas class=\"ak-holo-field\" aria-hidden=\"true\"></canvas>\n\n  <div class=\"ak-holo-shell\">\n    <div class=\"ak-holo-header\">\n      <div class=\"ak-holo-kicker\">CONNECT</div>\n      <div class=\"ak-holo-title\">AMERIKID CHANNELS</div>\n      <div class=\"ak-holo-sub\">SELECT A CHANNEL TO ENTER.</div>\n    </div>\n\n    <nav class=\"ak-holo-dock\" aria-label=\"Social links\">\n      <a class=\"ak-holo-card ak-ig\"\n         href=\"https://www.instagram.com/amerikid.ca/\"\n         target=\"_blank\" rel=\"noopener noreferrer\"\n         aria-label=\"Open AmeriKid Instagram (new tab)\">\n        <span class=\"ak-holo-icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M7.5 2.8h9A4.7 4.7 0 0 1 21.2 7.5v9A4.7 4.7 0 0 1 16.5 21.2h-9A4.7 4.7 0 0 1 2.8 16.5v-9A4.7 4.7 0 0 1 7.5 2.8Z\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n            <path d=\"M12 16.3a4.3 4.3 0 1 0 0-8.6 4.3 4.3 0 0 0 0 8.6Z\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n            <path d=\"M17.2 6.8h.01\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n          </svg>\n        </span>\n        <span class=\"ak-holo-label\">INSTAGRAM</span>\n        <span class=\"ak-holo-meta\">PHOTOS + DROPS</span>\n      </a>\n\n      <a class=\"ak-holo-card ak-tt\"\n         href=\"https://www.tiktok.com/@amerikid.ca\"\n         target=\"_blank\" rel=\"noopener noreferrer\"\n         aria-label=\"Open AmeriKid TikTok (new tab)\">\n        <span class=\"ak-holo-icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M14 3v11.2a3.8 3.8 0 1 1-3.2-3.7\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n            <path d=\"M14 3c.8 2.7 2.8 4.7 5.5 5.3\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n            <path d=\"M14 6.3c1.2 1.7 3.1 2.8 5.5 3\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" opacity=\".85\"/>\n          </svg>\n        </span>\n        <span class=\"ak-holo-label\">TIKTOK</span>\n        <span class=\"ak-holo-meta\">CLIPS + CHAOS</span>\n      </a>\n\n      <a class=\"ak-holo-card ak-x\"\n         href=\"https://x.com/xx_amerikid\"\n         target=\"_blank\" rel=\"noopener noreferrer\"\n         aria-label=\"Open AmeriKid X (new tab)\">\n        <span class=\"ak-holo-icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M4 20L20 4\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n            <path d=\"M8 4h4.5l7.5 16H15.5L8 4Z\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linejoin=\"round\"/>\n          </svg>\n        </span>\n        <span class=\"ak-holo-label\">X</span>\n        <span class=\"ak-holo-meta\">UPDATES + ENERGY</span>\n      </a>\n\n      <a class=\"ak-holo-card ak-yt\"\n         href=\"https://www.youtube.com/channel/UCdh2i0KtdQDJ_ks6NcttEag\"\n         target=\"_blank\" rel=\"noopener noreferrer\"\n         aria-label=\"Open AmeriKid YouTube (new tab)\">\n        <span class=\"ak-holo-icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M21 12s0-3.3-.5-4.9a3 3 0 0 0-2.1-2.1C16.8 4.5 12 4.5 12 4.5s-4.8 0-6.4.5A3 3 0 0 0 3.5 7.1C3 8.7 3 12 3 12s0 3.3.5 4.9a3 3 0 0 0 2.1 2.1c1.6.5 6.4.5 6.4.5s4.8 0 6.4-.5a3 3 0 0 0 2.1-2.1c.5-1.6.5-4.9.5-4.9Z\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n            <path d=\"M10.5 9.2 15.8 12l-5.3 2.8V9.2Z\" fill=\"currentColor\"/>\n          </svg>\n        </span>\n        <span class=\"ak-holo-label\">YOUTUBE</span>\n        <span class=\"ak-holo-meta\">VIDEO + LORE</span>\n      </a>\n    </nav>\n  </div>\n</div>\n\n<style>\n  .ak-social-holo{\n    --ak-purple:#ff33ff;\n    --ak-bg:#000;\n    --ak-line:rgba(255,255,255,.10);\n\n    position:relative;\n    width:100%;\n    background:var(--ak-bg);\n    border-radius:22px;\n    overflow:hidden;\n    border:1px solid var(--ak-line);\n    box-shadow:0 18px 60px rgba(0,0,0,.65);\n    padding:22px 18px;\n    margin:18px 0;\n  }\n\n  .ak-holo-field{\n    position:absolute;\n    inset:0;\n    width:100%;\n    height:100%;\n    display:block;\n    opacity:.75;\n    pointer-events:none;\n  }\n\n  .ak-holo-shell{\n    position:relative;\n    z-index:2;\n    max-width:1200px;\n    margin:0 auto;\n  }\n\n  .ak-holo-header{\n    text-align:center;\n    padding:10px 8px 18px;\n  }\n  .ak-holo-kicker{\n    font-family:Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;\n    letter-spacing:.22em;\n    color:rgba(255,255,255,.75);\n    font-size:14px;\n  }\n  .ak-holo-title{\n    font-family:Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;\n    text-transform:uppercase;\n    letter-spacing:.08em;\n    color:#fff;\n    font-size:30px;\n    margin-top:6px;\n    text-shadow:0 0 12px rgba(255,255,255,.12);\n  }\n  .ak-holo-sub{\n    font-family:Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;\n    letter-spacing:.06em;\n    text-transform:uppercase;\n    color:rgba(255,255,255,.70);\n    font-size:14px;\n    margin-top:6px;\n  }\n\n  .ak-holo-dock{\n    perspective:1200px;\n    display:grid;\n    grid-template-columns:repeat(4, minmax(0, 1fr));\n    gap:14px;\n    padding:10px 6px 6px;\n  }\n\n  @media(max-width:980px){\n    .ak-holo-dock{ grid-template-columns:repeat(2, minmax(0, 1fr)); }\n  }\n  @media(max-width:540px){\n    .ak-holo-title{font-size:24px}\n    .ak-holo-dock{grid-template-columns:1fr}\n  }\n\n  .ak-holo-card{\n    position:relative;\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n    padding:18px 16px;\n    border-radius:20px;\n    text-decoration:none;\n    color:#fff;\n\n    background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));\n    border:1px solid rgba(255,255,255,.12);\n    box-shadow:0 14px 40px rgba(0,0,0,.55);\n\n    transform-style:preserve-3d;\n    transform:\n      rotateX(var(--rx, 0deg))\n      rotateY(var(--ry, 0deg))\n      translateZ(var(--tz, 0px));\n    transition:\n      transform .22s ease,\n      border-color .18s ease,\n      box-shadow .18s ease,\n      filter .18s ease;\n\n    overflow:hidden;\n    isolation:isolate;\n    will-change:transform;\n  }\n\n  /* While actively tilting: pause float, remove transform transition so JS feels locked-in */\n  .ak-holo-card.ak-tilt-active{\n    animation-play-state:paused;\n    transition:\n      border-color .18s ease,\n      box-shadow .18s ease,\n      filter .18s ease;\n  }\n\n  .ak-holo-card::after{\n    content:\"\";\n    position:absolute;\n    inset:-1px;\n    border-radius:20px;\n    background:\n      radial-gradient(120% 80% at 20% 10%, rgba(255,51,255,.22), transparent 55%),\n      radial-gradient(120% 80% at 80% 40%, rgba(255,255,255,.10), transparent 60%),\n      radial-gradient(110% 90% at 50% 120%, rgba(255,51,255,.10), transparent 55%);\n    opacity:.85;\n    mix-blend-mode:screen;\n    z-index:0;\n    pointer-events:none;\n  }\n\n  .ak-holo-card::before{\n    content:\"\";\n    position:absolute;\n    inset:0;\n    border-radius:20px;\n    background:\n      repeating-linear-gradient(\n        to bottom,\n        rgba(255,255,255,.10) 0,\n        rgba(255,255,255,.10) 1px,\n        transparent 1px,\n        transparent 8px\n      ),\n      linear-gradient(115deg,\n        transparent 0%,\n        rgba(255,255,255,.18) 45%,\n        transparent 60%\n      );\n    opacity:.08;\n    transform:translateX(-40%);\n    animation:akShimmer 5.5s linear infinite;\n    z-index:1;\n    pointer-events:none;\n  }\n\n  @keyframes akShimmer{\n    0%{ transform:translateX(-60%) }\n    100%{ transform:translateX(60%) }\n  }\n\n  /* Ambient float (paused on hover via .ak-tilt-active) */\n  .ak-holo-card{ animation:akFloat 5.2s ease-in-out infinite; }\n  .ak-holo-card:nth-child(2){ animation-duration:5.8s; }\n  .ak-holo-card:nth-child(3){ animation-duration:6.4s; }\n  .ak-holo-card:nth-child(4){ animation-duration:5.6s; }\n\n  @keyframes akFloat{\n    0%,100%{\n      transform:\n        rotateX(var(--rx, 0deg))\n        rotateY(var(--ry, 0deg))\n        translateZ(var(--tz, 0px))\n        translateY(0px);\n    }\n    50%{\n      transform:\n        rotateX(var(--rx, 0deg))\n        rotateY(var(--ry, 0deg))\n        translateZ(var(--tz, 0px))\n        translateY(-4px);\n    }\n  }\n\n  .ak-holo-icon, .ak-holo-label, .ak-holo-meta{\n    position:relative;\n    z-index:3;\n    transform:translateZ(18px);\n  }\n\n  .ak-holo-icon{\n    width:46px;\n    height:46px;\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    border-radius:14px;\n    border:1px solid rgba(255,255,255,.16);\n    background:rgba(0,0,0,.40);\n    color:var(--ak-purple);\n    box-shadow:0 0 18px rgba(255,51,255,.25);\n  }\n  .ak-holo-icon svg{ width:26px; height:26px; color:currentColor; }\n\n  .ak-holo-label{\n    font-family:Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;\n    text-transform:uppercase;\n    letter-spacing:.08em;\n    font-size:22px;\n    line-height:1.05;\n  }\n  .ak-holo-meta{\n    font-family:Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;\n    text-transform:uppercase;\n    letter-spacing:.12em;\n    font-size:12px;\n    color:rgba(255,255,255,.72);\n  }\n\n  .ak-holo-card:hover,\n  .ak-holo-card:focus-visible{\n    border-color:rgba(255,51,255,.35);\n    box-shadow:\n      0 0 0 1px rgba(255,51,255,.14),\n      0 22px 60px rgba(0,0,0,.65),\n      0 0 26px rgba(255,51,255,.18);\n    filter:saturate(1.06) contrast(1.04);\n    outline:none;\n  }\n  .ak-holo-card:hover{ --tz:14px; }\n\n  .ak-holo-card:active{\n    transform:\n      rotateX(var(--rx, 0deg))\n      rotateY(var(--ry, 0deg))\n      translateZ(6px) scale(.99);\n  }\n\n  @media (prefers-reduced-motion: reduce){\n    .ak-holo-card{ animation:none; transition:none; }\n    .ak-holo-card::before{ animation:none; }\n  }\n</style>\n\n<script>\n  (function(){\n    const root = document.currentScript?.closest('.ak-social-holo') || document.querySelector('.ak-social-holo');\n    if(!root) return;\n\n    const reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n    const canTilt = !reduced && window.matchMedia && window.matchMedia('(hover:hover) and (pointer:fine)').matches;\n\n    // ----- Smooth 3D tilt (lerped) -----\n    const cards = root.querySelectorAll('.ak-holo-card');\n    if(canTilt){\n      cards.forEach(card => {\n        let active = false;\n        let raf = 0;\n\n        let curRx = 0, curRy = 0;\n        let tgtRx = 0, tgtRy = 0;\n\n        const MAX_RX = 12;\n        const MAX_RY = 14;\n        const EASE   = 0.18;\n\n        const clamp = (v, min, max) => Math.min(max, Math.max(min, v));\n\n        function computeTarget(clientX, clientY){\n          const r = card.getBoundingClientRect();\n          const px = (clientX - r.left) / r.width;\n          const py = (clientY - r.top) / r.height;\n\n          const rx = clamp((py - 0.5) * -MAX_RX * 2, -MAX_RX, MAX_RX);\n          const ry = clamp((px - 0.5) *  MAX_RY * 2, -MAX_RY, MAX_RY);\n\n          tgtRx = rx;\n          tgtRy = ry;\n        }\n\n        function tick(){\n          curRx += (tgtRx - curRx) * EASE;\n          curRy += (tgtRy - curRy) * EASE;\n\n          card.style.setProperty('--rx', curRx.toFixed(2) + 'deg');\n          card.style.setProperty('--ry', curRy.toFixed(2) + 'deg');\n\n          const stillMoving =\n            active ||\n            Math.abs(tgtRx - curRx) > 0.02 ||\n            Math.abs(tgtRy - curRy) > 0.02;\n\n          if(stillMoving){\n            raf = requestAnimationFrame(tick);\n          }else{\n            raf = 0;\n          }\n        }\n\n        function ensureRAF(){\n          if(!raf) raf = requestAnimationFrame(tick);\n        }\n\n        card.addEventListener('pointerenter', () => {\n          active = true;\n          card.classList.add('ak-tilt-active');\n          ensureRAF();\n        }, {passive:true});\n\n        card.addEventListener('pointermove', (e) => {\n          if(!active) return;\n          computeTarget(e.clientX, e.clientY);\n          ensureRAF();\n        }, {passive:true});\n\n        const reset = () => {\n          active = false;\n          card.classList.remove('ak-tilt-active');\n          tgtRx = 0; tgtRy = 0;\n          ensureRAF();\n        };\n\n        card.addEventListener('pointerleave', reset, {passive:true});\n        card.addEventListener('blur', reset, {passive:true});\n      });\n    }\n\n    // ----- Ambient particle field (canvas) -----\n    const canvas = root.querySelector('.ak-holo-field');\n    if(!canvas) return;\n    const ctx = canvas.getContext('2d', { alpha: true });\n\n    let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);\n    const particles = [];\n    const COUNT = 70;\n\n    function resize(){\n      const rect = root.getBoundingClientRect();\n      w = Math.max(1, Math.floor(rect.width));\n      h = Math.max(1, Math.floor(rect.height));\n      dpr = Math.min(window.devicePixelRatio || 1, 2);\n      canvas.width  = Math.floor(w * dpr);\n      canvas.height = Math.floor(h * dpr);\n      canvas.style.width  = w + 'px';\n      canvas.style.height = h + 'px';\n      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n    }\n\n    function rand(min, max){ return min + Math.random() * (max - min); }\n\n    function seed(){\n      particles.length = 0;\n      for(let i=0;i<COUNT;i++){\n        particles.push({\n          x: rand(0, w),\n          y: rand(0, h),\n          vx: rand(-0.25, 0.25),\n          vy: rand(-0.22, 0.22),\n          r:  rand(0.8, 2.2),\n          a:  rand(0.10, 0.35)\n        });\n      }\n    }\n\n    function step(){\n      ctx.clearRect(0,0,w,h);\n\n      const g = ctx.createRadialGradient(w*0.5, h*0.55, 40, w*0.5, h*0.55, Math.max(w,h)*0.7);\n      g.addColorStop(0, 'rgba(255,51,255,0.10)');\n      g.addColorStop(1, 'rgba(0,0,0,0)');\n      ctx.fillStyle = g;\n      ctx.fillRect(0,0,w,h);\n\n      for(const p of particles){\n        p.x += p.vx; p.y += p.vy;\n        if(p.x < -10) p.x = w+10;\n        if(p.x > w+10) p.x = -10;\n        if(p.y < -10) p.y = h+10;\n        if(p.y > h+10) p.y = -10;\n\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);\n        ctx.fillStyle = `rgba(255,51,255,${p.a})`;\n        ctx.fill();\n      }\n\n      if(!reduced) requestAnimationFrame(step);\n    }\n\n    resize();\n    seed();\n    step();\n\n    window.addEventListener('resize', () => {\n      resize();\n      seed();\n    }, {passive:true});\n  })();\n</script>",
        "color_scheme": "scheme-4",
        "padding_top": 4,
        "padding_bottom": 4
      }
    },
