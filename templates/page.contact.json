      "settings": {
        "custom_liquid": "<!-- sections/amerikid-rapid-banner.liquid -->\n<style>\n  .amerikid-rapid-banner {\n    background-color: #000;\n    overflow: hidden;\n    position: relative;\n    height: auto;\n    display: flex;\n    align-items: center;\n    padding: 4px 0;       /* slight vertical padding */\n    margin: 0;\n    font-size: 5rem;\n    line-height: 1;\n  }\n\n  .amerikid-rapid-track-wrapper {\n    display: flex;\n    width: 200%;\n    animation: amerikid-rapid-scroll-rtl 25s linear infinite;\n  }\n\n  .amerikid-rapid-track {\n    display: flex;\n    white-space: nowrap;\n  }\n\n  .amerikid-rapid-word {\n    font-family: Impact, sans-serif;\n    font-size: inherit;\n    line-height: 1;\n    margin: 0;\n    padding: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    animation: none !important;\n    transform: none !important;\n  }\n\n  @keyframes amerikid-rapid-scroll-rtl {\n    0% {\n      transform: translateX(0%);\n    }\n    100% {\n      transform: translateX(-50%);\n    }\n  }\n</style>\n\n<div class=\"amerikid-rapid-banner\">\n  <div class=\"amerikid-rapid-track-wrapper\">\n    <div class=\"amerikid-rapid-track\">\n      {% for i in (1..30) %}\n        <div class=\"amerikid-rapid-word\">🍭‼️🇺🇸🛍️🗣️💯🔌💰💧📖🪬🥇🎱</div>\n      {% endfor %}\n    </div>\n    <div class=\"amerikid-rapid-track\">\n      {% for i in (1..30) %}\n        <div class=\"amerikid-rapid-word\">🍭‼️🇺🇸🛍️🗣️💯🔌💰💧📖🪬🥇🎱</div>\n      {% endfor %}\n    </div>\n  </div>\n</div>",
