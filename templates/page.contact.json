      }
    },
    "custom_liquid_EHciek": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- =========================\n  AMERIKID - NAV MENU (GLASS + ORIGINAL STARFIELD)\n  - Preserves ORIGINAL ambient particles + floaters + meteors exactly\n  - Adds continuous wrapper-wide cursor glow (no flicker between buttons)\n  - Candy + BAD glow purple like the rest\n  - Removes top divider seam so it blends with header\n  - FIX: Prevent particle jump on mobile scroll (resize without reseed)\n  - CHANGE: Move mobile drawer close ✕ to top-right\n========================= -->\n\n<div id=\"amerikid-button-wrapper\" class=\"aknav-wrap\">\n  <!-- Ambient particles -->\n  <canvas class=\"aknav-field\" aria-hidden=\"true\"></canvas>\n\n  <!-- CONTINUOUS WRAPPER GLOW (follows cursor anywhere inside wrapper) -->\n  <div class=\"aknav-global-glow\" aria-hidden=\"true\"></div>\n\n  <!-- GLASS PANEL CONTENT -->\n  <div class=\"aknav-panel\">\n    <!-- Mobile \"MENU\" label -->\n    <span\n      class=\"aknav-mobile-trigger\"\n      role=\"button\"\n      aria-label=\"Open navigation\"\n      aria-expanded=\"false\"\n      tabindex=\"0\"\n    >\n      MENU\n    </span>\n\n    <!-- DESKTOP NAV -->\n    <nav class=\"aknav-grid\" aria-label=\"Amerikid Navigation\">\n      <!-- TOP ROW -->\n      <a\n        href=\"/pages/the-collective\"\n        class=\"aknav-tile aknav-tile--long aknav-life {% if request.path == '/pages/the-collective' %}is-active{% endif %}\"\n        style=\"--d: .10s;\"\n      >\n        <span class=\"aknav-label\">LIFE/STYLE</span>\n      </a>\n\n      <a\n        href=\"/collections/master-collection\"\n        class=\"aknav-tile aknav-products {% if request.path == '/collections/master-collection' %}is-active{% endif %}\"\n        style=\"--d: .20s;\"\n      >\n        <span class=\"aknav-label\">PRODUCTS</span>\n      </a>\n\n      <a\n        href=\"/collections/\"\n        class=\"aknav-tile aknav-archive {% if request.path == '/collections' or request.path == '/collections/' %}is-active{% endif %}\"\n        style=\"--d: .30s;\"\n      >\n        <span class=\"aknav-label\">ARCHIVE</span>\n      </a>\n\n      <!-- BOTTOM ROW -->\n      <a\n        href=\"/pages/narrative\"\n        class=\"aknav-tile aknav-tile--long aknav-narrative {% if request.path == '/pages/narrative' %}is-active{% endif %}\"\n        style=\"--d: .40s;\"\n      >\n        <span class=\"aknav-label\">NARRATIVE</span>\n      </a>\n\n      <!-- CENTER DUO -->\n      <div class=\"aknav-duo\" style=\"--d: .50s;\">\n        <!-- BAD -->\n        <a\n          href=\"/pages/2025\"\n          class=\"aknav-tile aknav-duo-tile aknav-bad {% if request.path == '/pages/2025' %}is-active{% endif %}\"\n          aria-label=\"BAD Music\"\n          style=\"--d: .50s;\"\n        >\n          <span class=\"aknav-bad-mask\" aria-hidden=\"true\"></span>\n          <img class=\"aknav-bad-fallback\" src=\"{{ 'Bad.png' | file_url }}\" alt=\"BAD Music\" />\n        </a>\n\n        <!-- CANDY FACTS -->\n        <a\n          href=\"/pages/mystery-box\"\n          class=\"aknav-tile aknav-duo-tile aknav-candy {% if request.path == '/pages/mystery-box' %}is-active{% endif %}\"\n          aria-label=\"Candy Facts\"\n          style=\"--d: .55s;\"\n        >\n          <img class=\"aknav-candy-img\" src=\"{{ 'candyfacts.png' | file_url }}\" alt=\"Candy Facts\" />\n        </a>\n      </div>\n\n      <a\n        href=\"/pages/contact\"\n        class=\"aknav-tile aknav-tile--long aknav-contact {% if request.path == '/pages/contact' %}is-active{% endif %}\"\n        style=\"--d: .60s;\"\n      >\n        <span class=\"aknav-label\">CONTACT</span>\n      </a>\n    </nav>\n\n    <!-- MOBILE DRAWER -->\n    <div class=\"aknav-drawer\" data-aknav-drawer=\"1\" aria-hidden=\"true\">\n      <button class=\"aknav-drawer-close\" aria-label=\"Close menu\">✕</button>\n\n      <a href=\"/pages/the-collective\" class=\"{% if request.path == '/pages/the-collective' %}active{% endif %}\">\n        LIFE/STYLE\n      </a>\n      <a href=\"/collections/master-collection\" class=\"{% if request.path == '/collections/master-collection' %}active{% endif %}\">\n        PRODUCTS\n      </a>\n      <a href=\"/collections/\" class=\"{% if request.path == '/collections' or request.path == '/collections/' %}active{% endif %}\">\n        ARCHIVE\n      </a>\n      <a href=\"/pages/narrative\" class=\"{% if request.path == '/pages/narrative' %}active{% endif %}\">\n        NARRATIVE\n      </a>\n\n      <a\n        href=\"/pages/2025\"\n        class=\"aknav-mobile-image {% if request.path == '/pages/2025' %}active{% endif %}\"\n        aria-label=\"BAD Music\"\n      >\n        <img src=\"{{ 'Bad.png' | file_url }}\" alt=\"BAD Music\" />\n      </a>\n\n      <a\n        href=\"/pages/mystery-box\"\n        class=\"aknav-mobile-image {% if request.path == '/pages/mystery-box' %}active{% endif %}\"\n        aria-label=\"Candy Facts\"\n      >\n        <img src=\"{{ 'candyfacts.png' | file_url }}\" alt=\"Candy Facts\" />\n      </a>\n\n      <a href=\"/pages/contact\" class=\"{% if request.path == '/pages/contact' %}active{% endif %}\">\n        CONTACT\n      </a>\n    </div>\n  </div>\n</div>\n\n<style>\n  /* =========================\n     WRAPPER: SEAMLESS TOP\n  ========================= */\n  #amerikid-button-wrapper.aknav-wrap{\n    --ak-purple:#ff33ff;\n    --ak-green:#39ff14;\n    --ak-line:rgba(255,255,255,.10);\n    --ak-glass:rgba(0,0,0,.72);\n\n    --tile-h: clamp(64px, 6.2vw, 92px);\n    --duo-h: clamp(118px, 10vw, 170px);\n\n    --label: clamp(18px, 2.2vw, 34px);\n    --label-center: clamp(20px, 2.6vw, 40px);\n\n    --ls: clamp(.14em, .75vw, .28em);\n    --ls-long: clamp(.10em, .60vw, .22em);\n\n    --text-front: #ffffff;\n    --text-mid: #cccccc;\n    --text-back: #666666;\n\n    /* slight overlap upward so there is no 1px seam gap */\n    --aknav-nudge: -1px;\n\n    /* global glow tracking */\n    --glow-x: 50%;\n    --glow-y: 50%;\n    --glow-opacity: 0;\n\n    position: relative;\n    z-index: 999;\n\n    width: 100%;\n    display: block;\n\n    margin: var(--aknav-nudge) 0 0 0 !important;\n    padding: 0 !important;\n\n    /* KEY: remove top rounding so this \"continues\" the header above */\n    border-radius: 0 0 22px 22px;\n    overflow: hidden;\n    isolation: isolate;\n\n    background: rgba(255,255,255,.018);\n    -webkit-backdrop-filter: blur(56px) saturate(210%) contrast(112%);\n    backdrop-filter: blur(56px) saturate(210%) contrast(112%);\n\n    border: 1px solid var(--ak-line);\n    border-top: 0 !important;     /* kills the faint top divider line */\n    border-bottom: 0 !important;  /* keep your existing intent */\n    box-shadow: 0 18px 60px rgba(0,0,0,.65);\n\n    margin-bottom: -2px !important;\n\n    perspective: 1100px;\n  }\n\n  #amerikid-button-wrapper .aknav-panel{\n    position: relative;\n    z-index: 5;\n    padding: clamp(16px, 2vw, 24px);\n    padding-top: clamp(20px, 2.6vw, 30px);\n    padding-bottom: calc(clamp(16px, 2vw, 24px) + 2px);\n  }\n\n  #amerikid-button-wrapper .aknav-field{\n    position:absolute;\n    inset:0;\n    width:100%;\n    height:100%;\n    pointer-events:none;\n    z-index:0;\n    opacity:1;\n    mix-blend-mode: screen;\n    filter: contrast(1.18) saturate(1.08);\n  }\n\n  /* =========================\n     CONTINUOUS WRAPPER GLOW\n  ========================= */\n  #amerikid-button-wrapper .aknav-global-glow{\n    position:absolute;\n    inset:-80px;\n    pointer-events:none;\n    z-index:6;\n    opacity: var(--glow-opacity);\n    transition: opacity .18s ease;\n    mix-blend-mode: screen;\n    filter: blur(12px) saturate(1.2);\n    background:\n      radial-gradient(\n        circle 240px at var(--glow-x) var(--glow-y),\n        rgba(255,51,255,.52) 0%,\n        rgba(255,51,255,.22) 36%,\n        rgba(255,51,255,.09) 54%,\n        transparent 70%\n      );\n  }\n\n  /* =========================\n     GRID\n  ========================= */\n  #amerikid-button-wrapper .aknav-grid{\n    position:relative;\n    z-index:7;\n    width:min(1200px, 96vw);\n    margin:0 auto;\n\n    display:grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    grid-template-areas:\n      \"life products archive\"\n      \"narrative duo contact\";\n    gap: clamp(14px, 2.6vw, 36px) clamp(14px, 3.2vw, 44px);\n    align-items:center;\n  }\n\n  #amerikid-button-wrapper .aknav-life{ grid-area: life; }\n  #amerikid-button-wrapper .aknav-products{ grid-area: products; }\n  #amerikid-button-wrapper .aknav-archive{ grid-area: archive; }\n  #amerikid-button-wrapper .aknav-narrative{ grid-area: narrative; }\n  #amerikid-button-wrapper .aknav-duo{ grid-area: duo; }\n  #amerikid-button-wrapper .aknav-contact{ grid-area: contact; }\n\n  /* =========================\n     TILE BASE (KEEP HIT AREA + TILT, NO TILE-GLOW FLICKER)\n  ========================= */\n  #amerikid-button-wrapper .aknav-tile{\n    --gx: 50%;\n    --gy: 50%;\n\n    width:100%;\n    min-width:0;\n    height: var(--tile-h);\n\n    border-radius: 20px;\n    background: transparent;\n    border: 0;\n    box-shadow: none;\n\n    display:flex;\n    align-items:center;\n    justify-content:center;\n\n    text-decoration:none;\n    color:#fff;\n\n    position:relative;\n    overflow: visible;\n\n    transform:\n      translateY(16px)\n      rotateX(var(--rx, 0deg))\n      rotateY(var(--ry, 0deg));\n    opacity:0;\n\n    animation: aknavIn .75s cubic-bezier(.16,1,.3,1) forwards;\n    animation-delay: var(--d, 0s);\n\n    transition: transform .12s ease, color .18s ease, filter .18s ease;\n    will-change: transform;\n  }\n\n  @keyframes aknavIn{\n    to { opacity:1; transform: translateY(0) rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg)); }\n  }\n\n  #amerikid-button-wrapper .aknav-tile::before{ display:none; }\n  #amerikid-button-wrapper .aknav-tile::after{ display:none; }\n\n  #amerikid-button-wrapper .aknav-tile:hover{\n    filter: drop-shadow(0 0 16px rgba(255,51,255,.18));\n  }\n\n  #amerikid-button-wrapper .aknav-tile:active{\n    transform:\n      translateY(2px)\n      rotateX(var(--rx, 0deg))\n      rotateY(var(--ry, 0deg))\n      scale(0.96);\n    transition: transform .08s ease;\n  }\n\n  #amerikid-button-wrapper .aknav-label{\n    font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;\n    text-transform: uppercase;\n    font-size: var(--label);\n    letter-spacing: var(--ls);\n    white-space: nowrap;\n    padding: 0 clamp(10px, 1.2vw, 16px);\n    line-height: 1;\n    position: relative;\n    display: inline-block;\n\n    color: var(--text-front);\n    text-shadow:\n      0 0 10px rgba(255,255,255,.3),\n      0 0 20px rgba(255,51,255,.2);\n\n    overflow: visible;\n  }\n\n  #amerikid-button-wrapper .aknav-label::before{\n    content: attr(data-text);\n    position: absolute;\n    left: 0;\n    top: 0;\n    width: 100%;\n    height: 100%;\n    padding: inherit;\n\n    color: var(--text-mid);\n    z-index: -1;\n\n    transform: translate3d(1px, 1px, -1px);\n    text-shadow:\n      1px 1px 0 var(--text-mid),\n      2px 2px 0 var(--text-back);\n\n    pointer-events: none;\n  }\n\n  #amerikid-button-wrapper .aknav-label::after{\n    content: attr(data-text);\n    position: absolute;\n    left: 0;\n    top: 0;\n    width: 100%;\n    height: 100%;\n    padding: inherit;\n\n    color: var(--text-back);\n    z-index: -2;\n\n    transform: translate3d(3px, 3px, -3px);\n    text-shadow:\n      1px 1px 0 var(--text-back),\n      2px 2px 0 rgba(0,0,0,.5),\n      3px 3px 2px rgba(0,0,0,.4),\n      4px 4px 4px rgba(0,0,0,.3),\n      6px 6px 8px rgba(0,0,0,.25);\n\n    pointer-events: none;\n  }\n\n  #amerikid-button-wrapper .aknav-tile--long .aknav-label{\n    letter-spacing: var(--ls-long);\n    font-size: clamp(17px, 2.05vw, 32px);\n  }\n\n  #amerikid-button-wrapper .aknav-products .aknav-label{ font-size: var(--label-center); }\n\n  /* active/hover text pop */\n  #amerikid-button-wrapper .aknav-products.is-active .aknav-label,\n  #amerikid-button-wrapper .aknav-products:hover .aknav-label,\n  #amerikid-button-wrapper .aknav-tile:hover .aknav-label,\n  #amerikid-button-wrapper .aknav-tile.is-active .aknav-label{\n    color: var(--ak-purple);\n    text-shadow:\n      0 0 18px rgba(255,51,255,.5),\n      0 0 30px rgba(255,51,255,.3);\n  }\n  #amerikid-button-wrapper .aknav-tile:hover .aknav-label::before,\n  #amerikid-button-wrapper .aknav-tile.is-active .aknav-label::before{ color:#cc29cc; }\n  #amerikid-button-wrapper .aknav-tile:hover .aknav-label::after,\n  #amerikid-button-wrapper .aknav-tile.is-active .aknav-label::after{ color:#661a66; }\n\n  #amerikid-button-wrapper .aknav-duo{\n    display:grid;\n    grid-template-columns: 1fr 1fr;\n    gap: clamp(12px, 2vw, 22px);\n    width:100%;\n  }\n  #amerikid-button-wrapper .aknav-duo-tile{\n    height: var(--duo-h);\n    padding: clamp(10px, 1.4vw, 16px);\n  }\n\n  /* =========================\n     DUO GLOW FIX (BAD + CANDY)\n  ========================= */\n\n  /* stronger purple glow on the duo tiles */\n  #amerikid-button-wrapper .aknav-duo-tile:hover,\n  #amerikid-button-wrapper .aknav-duo-tile.is-active{\n    filter:\n      drop-shadow(0 0 18px rgba(255,51,255,.55))\n      drop-shadow(0 0 42px rgba(255,51,255,.22));\n  }\n\n  /* BAD: tint to purple on hover/active, like text tiles */\n  #amerikid-button-wrapper .aknav-bad{ color:#fff; }\n  #amerikid-button-wrapper .aknav-bad:hover,\n  #amerikid-button-wrapper .aknav-bad.is-active{\n    color: var(--ak-purple);\n  }\n\n  #amerikid-button-wrapper .aknav-bad-mask{\n    width:100%;\n    height:100%;\n    background-color: currentColor;\n    -webkit-mask-image: url({{ 'Bad.png' | file_url }});\n    mask-image: url({{ 'Bad.png' | file_url }});\n    -webkit-mask-size: contain;\n    mask-size: contain;\n    -webkit-mask-repeat: no-repeat;\n    mask-repeat: no-repeat;\n    -webkit-mask-position: center;\n    mask-position: center;\n    display:block;\n    transition: transform .15s ease, filter .18s ease;\n  }\n\n  #amerikid-button-wrapper .aknav-bad:hover .aknav-bad-mask,\n  #amerikid-button-wrapper .aknav-bad.is-active .aknav-bad-mask{\n    filter:\n      drop-shadow(0 0 12px rgba(255,51,255,.65))\n      drop-shadow(0 0 28px rgba(255,51,255,.28));\n  }\n\n  #amerikid-button-wrapper .aknav-bad:active .aknav-bad-mask{ transform: scale(0.92); }\n  #amerikid-button-wrapper .aknav-bad-fallback{ display:none; }\n\n  @supports not ((-webkit-mask-image: url(\"\")) or (mask-image: url(\"\"))){\n    #amerikid-button-wrapper .aknav-bad-mask{ display:none; }\n    #amerikid-button-wrapper .aknav-bad-fallback{\n      display:block;\n      width:100%;\n      height:100%;\n      object-fit: contain;\n      transition: transform .15s ease, filter .18s ease;\n    }\n    #amerikid-button-wrapper .aknav-bad:hover .aknav-bad-fallback,\n    #amerikid-button-wrapper .aknav-bad.is-active .aknav-bad-fallback{\n      filter:\n        drop-shadow(0 0 12px rgba(255,51,255,.65))\n        drop-shadow(0 0 28px rgba(255,51,255,.28));\n    }\n    #amerikid-button-wrapper .aknav-bad:active .aknav-bad-fallback{ transform: scale(0.92); }\n  }\n\n  /* Candy: keep PNG as-is, but give it purple glow like text tiles */\n  #amerikid-button-wrapper .aknav-candy{ padding: clamp(6px, 1vw, 10px) !important; }\n  #amerikid-button-wrapper .aknav-candy-img{\n    width:100%;\n    height:100%;\n    object-fit: contain;\n    display:block;\n    transform: scale(1.28);\n    transform-origin: center;\n    transition: transform .15s ease, filter .18s ease;\n    filter: none;\n  }\n\n  #amerikid-button-wrapper .aknav-candy:hover .aknav-candy-img,\n  #amerikid-button-wrapper .aknav-candy.is-active .aknav-candy-img{\n    filter:\n      drop-shadow(0 0 12px rgba(255,51,255,.65))\n      drop-shadow(0 0 28px rgba(255,51,255,.28));\n  }\n\n  #amerikid-button-wrapper .aknav-candy:active .aknav-candy-img{ transform: scale(1.15); }\n\n  #amerikid-button-wrapper .aknav-mobile-trigger{\n    display:none;\n    position:relative;\n    z-index:7;\n    font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;\n    font-size: clamp(28px, 9vw, 48px);\n    text-transform: uppercase;\n    letter-spacing: .35em;\n    margin: 1.2rem auto 0;\n    padding: 0.25rem 0.75rem;\n    width: max-content;\n    cursor: pointer;\n    user-select: none;\n    color: #fff;\n    text-shadow:\n      1px 1px 0 #ccc,\n      2px 2px 0 #999,\n      3px 3px 2px rgba(0,0,0,.4),\n      4px 4px 6px rgba(0,0,0,.3);\n  }\n  #amerikid-button-wrapper .aknav-mobile-trigger:active{ transform: scale(0.95); }\n\n  html.aknav-lock,\n  html.aknav-lock body{\n    overflow: hidden !important;\n    height: 100% !important;\n  }\n\n  .aknav-drawer[data-aknav-drawer=\"1\"]{\n    --ak-purple:#ff33ff;\n\n    position: fixed !important;\n    inset: 0 !important;\n    width: 100vw !important;\n    height: 100vh !important;\n    height: 100dvh !important;\n    z-index: 99999 !important;\n\n    background: #000 !important;\n\n    transform: translate3d(-100%, 0, 0) !important;\n    transition: transform .35s ease, opacity .2s ease !important;\n\n    padding: calc(env(safe-area-inset-top, 0px) + 2rem) 1rem calc(env(safe-area-inset-bottom, 0px) + 4rem) !important;\n\n    display: flex !important;\n    flex-direction: column !important;\n    align-items: center !important;\n    gap: .8rem !important;\n\n    overflow-y: auto !important;\n    -webkit-overflow-scrolling: touch;\n\n    opacity: 0 !important;\n    pointer-events: none !important;\n  }\n\n  .aknav-drawer[data-aknav-drawer=\"1\"].open{\n    transform: translate3d(0,0,0) !important;\n    opacity: 1 !important;\n    pointer-events: auto !important;\n  }\n\n  /* CHANGE: close button goes top-right on mobile drawer */\n  .aknav-drawer[data-aknav-drawer=\"1\"] .aknav-drawer-close{\n    align-self:flex-end;\n    margin-left:auto;\n    background:none;\n    border:none;\n    color:#fff;\n    font-size:36px;\n    cursor:pointer;\n    margin-bottom: 1rem;\n    transition: transform .15s ease;\n  }\n  .aknav-drawer[data-aknav-drawer=\"1\"] .aknav-drawer-close:active{ transform: scale(0.85); }\n\n  .aknav-drawer[data-aknav-drawer=\"1\"] a{\n    width:100%;\n    text-align:center;\n    text-decoration:none;\n    color:#fff;\n    font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;\n    text-transform:uppercase;\n    letter-spacing: .22em;\n    font-size: 34px;\n    padding: 1.4rem 1rem;\n    border-radius: 18px;\n    text-shadow:\n      1px 1px 0 #aaa,\n      2px 2px 0 #666,\n      3px 3px 3px rgba(0,0,0,.4);\n    transition: transform .15s ease, color .2s ease, background .2s ease;\n  }\n\n  .aknav-drawer[data-aknav-drawer=\"1\"] a:hover{\n    color: var(--ak-purple);\n    background: rgba(255,255,255,.06);\n  }\n  .aknav-drawer[data-aknav-drawer=\"1\"] a:active{ transform: scale(0.96); }\n  .aknav-drawer[data-aknav-drawer=\"1\"] a.active{ color: var(--ak-purple); }\n\n  .aknav-drawer[data-aknav-drawer=\"1\"] .aknav-mobile-image img{\n    height: 120px;\n    width: auto;\n    display:block;\n    margin: 0 auto;\n    transition: transform .15s ease;\n  }\n  .aknav-drawer[data-aknav-drawer=\"1\"] .aknav-mobile-image:active img{ transform: scale(0.92); }\n\n  @media (max-width: 980px){\n    #amerikid-button-wrapper .aknav-grid{\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      grid-template-areas:\n        \"life products\"\n        \"archive archive\"\n        \"narrative narrative\"\n        \"duo duo\"\n        \"contact contact\";\n    }\n  }\n\n  @media (max-width: 768px){\n    #amerikid-button-wrapper .aknav-grid{ display:none; }\n    #amerikid-button-wrapper .aknav-mobile-trigger{ display:block; }\n  }\n\n  @media (prefers-reduced-motion: reduce){\n    #amerikid-button-wrapper .aknav-tile{\n      animation:none;\n      opacity:1;\n      transform:none;\n    }\n    #amerikid-button-wrapper.aknav-wrap{ perspective:none; }\n    #amerikid-button-wrapper .aknav-tile{ --rx: 0deg !important; --ry: 0deg !important; }\n    #amerikid-button-wrapper .aknav-label::before,\n    #amerikid-button-wrapper .aknav-label::after{ display: none; }\n    #amerikid-button-wrapper .aknav-global-glow{ display:none; }\n  }\n</style>\n\n<script>\n(function(){\n  var wrap = document.getElementById('amerikid-button-wrapper');\n  if(!wrap) return;\n\n  /* Prevent accidental double-init if Shopify re-injects the section */\n  if(wrap.dataset.aknavInit === '1') return;\n  wrap.dataset.aknavInit = '1';\n\n  var reduced = false;\n  try { reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch(e){}\n\n  /* data-text */\n  var labels = wrap.querySelectorAll('.aknav-label');\n  for(var i = 0; i < labels.length; i++){\n    var label = labels[i];\n    var text = label.textContent || label.innerText || '';\n    label.setAttribute('data-text', (text || '').trim());\n  }\n\n  /* =========================\n     GLOBAL WRAPPER GLOW (NO FLICKER)\n  ========================= */\n  if(!reduced){\n    var glowOn = function(){ wrap.style.setProperty('--glow-opacity','1'); };\n    var glowOff = function(){ wrap.style.setProperty('--glow-opacity','0'); };\n\n    var glowMove = function(ev){\n      var r = wrap.getBoundingClientRect();\n      var x = ev.clientX - r.left;\n      var y = ev.clientY - r.top;\n      wrap.style.setProperty('--glow-x', x.toFixed(1) + 'px');\n      wrap.style.setProperty('--glow-y', y.toFixed(1) + 'px');\n      wrap.style.setProperty('--glow-opacity','1');\n    };\n\n    wrap.addEventListener('pointerenter', glowOn, { passive:true });\n    wrap.addEventListener('pointermove', glowMove, { passive:true });\n    wrap.addEventListener('pointerleave', glowOff, { passive:true });\n  }\n\n  /* Mobile drawer controls */\n  var trigger = wrap.querySelector('.aknav-mobile-trigger');\n  var drawer = wrap.querySelector('.aknav-drawer');\n  var closeBtn = drawer ? drawer.querySelector('.aknav-drawer-close') : null;\n\n  if(drawer && drawer.getAttribute('data-aknav-drawer') === '1' && !drawer.dataset.akMoved){\n    drawer.dataset.akMoved = '1';\n    document.body.appendChild(drawer);\n  }\n\n  function openDrawer(){\n    if(!drawer) return;\n    drawer.classList.add('open');\n    drawer.setAttribute('aria-hidden','false');\n    if(trigger) trigger.setAttribute('aria-expanded','true');\n    document.documentElement.classList.add('aknav-lock');\n    setTimeout(function(){ if(closeBtn) closeBtn.focus(); }, 50);\n  }\n\n  function closeDrawer(){\n    if(!drawer) return;\n    drawer.classList.remove('open');\n    drawer.setAttribute('aria-hidden','true');\n    if(trigger) trigger.setAttribute('aria-expanded','false');\n    document.documentElement.classList.remove('aknav-lock');\n    setTimeout(function(){ if(trigger) trigger.focus(); }, 50);\n  }\n\n  if(trigger){\n    trigger.addEventListener('click', openDrawer);\n    trigger.addEventListener('keydown', function(e){\n      if(e.key === 'Enter' || e.key === ' ') openDrawer();\n    });\n  }\n  if(closeBtn) closeBtn.addEventListener('click', closeDrawer);\n\n  document.addEventListener('click', function(e){\n    if(!drawer || !drawer.classList.contains('open')) return;\n    if(drawer.contains(e.target)) return;\n    if(trigger && trigger.contains(e.target)) return;\n    closeDrawer();\n  });\n\n  document.addEventListener('keydown', function(e){\n    if(!drawer || !drawer.classList.contains('open')) return;\n    if(e.key === 'Escape') closeDrawer();\n  });\n\n  /* 3D hover tilt + glint coords (coords still used for tilt) */\n  if(!reduced){\n    var tiles = wrap.querySelectorAll('.aknav-tile');\n    for(var j = 0; j < tiles.length; j++){\n      (function(tile){\n        tile.addEventListener('pointermove', function(ev){\n          var r = tile.getBoundingClientRect();\n          var px = (ev.clientX - r.left) / r.width;\n          var py = (ev.clientY - r.top) / r.height;\n\n          var ry = (px - 0.5) * 10;\n          var rx = (0.5 - py) * 8;\n          tile.style.setProperty('--rx', rx.toFixed(2) + 'deg');\n          tile.style.setProperty('--ry', ry.toFixed(2) + 'deg');\n\n          var gx = (px * 100).toFixed(1) + '%';\n          var gy = (py * 100).toFixed(1) + '%';\n          tile.style.setProperty('--gx', gx);\n          tile.style.setProperty('--gy', gy);\n        }, { passive: true });\n\n        tile.addEventListener('pointerleave', function(){\n          tile.style.setProperty('--rx','0deg');\n          tile.style.setProperty('--ry','0deg');\n          tile.style.setProperty('--gx','50%');\n          tile.style.setProperty('--gy','50%');\n        }, { passive: true });\n      })(tiles[j]);\n    }\n  }\n\n  /* =========================\n     ORIGINAL Ambient particles + shooting stars\n     (UNCHANGED visuals, ONLY resize behavior changed to prevent jump)\n  ========================= */\n  var canvas = wrap.querySelector('.aknav-field');\n  if(!canvas || reduced) return;\n\n  var ctx = canvas.getContext('2d', { alpha:true });\n  var w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);\n\n  var dust = [];\n  var floaters = [];\n\n  /* Meteors */\n  var shooters = [];\n  var nextShooterAt = 0;\n  var lastFrameTime = 0;\n\n  var COLORS = {\n    white:  { rgb: \"255,255,255\", hex: \"#ffffff\" },\n    purple: { rgb: \"255,51,255\",  hex: \"#ff33ff\" },\n    blue:   { rgb: \"127,212,255\", hex: \"#7fd4ff\" },\n    yellow: { rgb: \"255,211,74\",  hex: \"#ffd34a\" }\n  };\n\n  function clamp(v, min, max){ return Math.min(max, Math.max(min, v)); }\n  function rand(min, max){ return min + Math.random() * (max - min); }\n\n  function resize(){\n    var rect = wrap.getBoundingClientRect();\n    w = Math.max(1, Math.floor(rect.width));\n    h = Math.max(1, Math.floor(rect.height));\n    dpr = Math.min(window.devicePixelRatio || 1, 2);\n\n    canvas.width = Math.floor(w * dpr);\n    canvas.height = Math.floor(h * dpr);\n    canvas.style.width = w + \"px\";\n    canvas.style.height = h + \"px\";\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n\n  function pickAccent(){\n    var r = Math.random();\n    if(r < 0.40) return COLORS.purple;\n    if(r < 0.72) return COLORS.blue;\n    return COLORS.yellow;\n  }\n\n  function pickDustColor(){ return (Math.random() < 0.86) ? COLORS.white : pickAccent(); }\n  function pickFloaterColor(){ return (Math.random() < 0.74) ? COLORS.white : pickAccent(); }\n  function pickFloaterKind(){\n    var r = Math.random();\n    if(r < 0.020) return \"blob\";\n    if(r < 0.22) return \"pill\";\n    return \"dot\";\n  }\n\n  function densityScale(){\n    var vw = (window.innerWidth || 1200);\n    if(vw < 520) return 0.28;\n    if(vw < 750) return 0.38;\n    return 0.85;\n  }\n\n  var ENABLE_BURST = false;\n  var OFFSET_DECAY = 0.968;\n  var KICK_DECAY = 0.925;\n  var emitterX = 0;\n  var emitterY = 0;\n\n  function setEmitterCenter(){\n    emitterX = w * 0.5;\n    emitterY = h * 0.5;\n  }\n\n  function seedDust(){\n    var area = w * h;\n    var s = densityScale();\n    var vw = (window.innerWidth || 1200);\n    var tiny = vw < 520;\n    var mobile = vw < 750;\n\n    var div = mobile ? (tiny ? 420 : 360) : 280;\n    var minC = mobile ? (tiny ? 180 : 240) : 1500;\n    var maxC = mobile ? (tiny ? 520 : 780) : 3400;\n\n    var count = Math.round(clamp((area / div) * s, minC, maxC));\n    dust = new Array(count);\n\n    setEmitterCenter();\n\n    for(var i = 0; i < count; i++){\n      var color = pickDustColor();\n      var isAccent = (color !== COLORS.white);\n\n      var bx = rand(0, w);\n      var by = rand(0, h);\n\n      var vx = rand(-0.030, 0.030);\n      var vy = rand(-0.024, 0.024);\n\n      var tw = rand(0.25, 1.10);\n      var ph = rand(0, Math.PI * 2);\n\n      var a0 = isAccent ? rand(0.20, 0.46) : rand(0.06, 0.18);\n\n      var size = isAccent\n        ? rand(1.7, 3.4)\n        : ((Math.random() < 0.78) ? rand(1.1, 2.1) : rand(2.1, 3.0));\n\n      var ox = 0, oy = 0, ovx = 0, ovy = 0;\n\n      if(ENABLE_BURST){\n        var jitterX = rand(-Math.max(18, w * 0.04), Math.max(18, w * 0.04));\n        var jitterY = rand(-Math.max(14, h * 0.20), Math.max(14, h * 0.20));\n        ox = (emitterX - bx) + jitterX;\n        oy = (emitterY - by) + jitterY;\n\n        var baseAngle = Math.atan2(by - emitterY, bx - emitterX);\n        var angle = (Math.random() < 0.55) ? (baseAngle + rand(-1.15, 1.15)) : rand(0, Math.PI * 2);\n        var kickSpeed = isAccent ? rand(1.0, 4.0) : rand(0.7, 3.3);\n\n        ovx = Math.cos(angle) * kickSpeed;\n        ovy = Math.sin(angle) * kickSpeed;\n      }\n\n      dust[i] = {\n        bx: bx, by: by,\n        vx: vx, vy: vy,\n        ox: ox, oy: oy,\n        ovx: ovx, ovy: ovy,\n        color: color,\n        isAccent: isAccent,\n        a0: a0,\n        size: size,\n        tw: tw, ph: ph\n      };\n    }\n  }\n\n  function seedFloaters(){\n    var area = w * h;\n    var s = densityScale();\n    var vw = (window.innerWidth || 1200);\n    var tiny = vw < 520;\n    var mobile = vw < 750;\n\n    var div = mobile ? (tiny ? 6200 : 5200) : 1200;\n    var minC = mobile ? (tiny ? 55 : 70) : 320;\n    var maxC = mobile ? (tiny ? 150 : 180) : 620;\n\n    var count = Math.round(clamp((area / div) * s, minC, maxC));\n    floaters = new Array(count);\n\n    setEmitterCenter();\n\n    for(var i = 0; i < count; i++){\n      var kind = pickFloaterKind();\n      var color = pickFloaterColor();\n      var isAccent = (color !== COLORS.white);\n\n      var bx = rand(0, w);\n      var by = rand(0, h);\n\n      var vx = rand(-0.18, 0.18);\n      var vy = rand(-0.15, 0.15);\n\n      var tw = rand(0.35, 1.35);\n      var ph = rand(0, Math.PI * 2);\n\n      var a0 = isAccent ? rand(0.22, 0.55) : rand(0.08, 0.20);\n      if(kind === \"blob\") a0 *= 0.78;\n      if(kind === \"pill\") a0 *= 0.90;\n\n      var ox = 0, oy = 0, ovx = 0, ovy = 0;\n\n      if(ENABLE_BURST){\n        var jitterX = rand(-Math.max(22, w * 0.04), Math.max(22, w * 0.04));\n        var jitterY = rand(-Math.max(16, h * 0.22), Math.max(16, h * 0.22));\n        ox = (emitterX - bx) + jitterX;\n        oy = (emitterY - by) + jitterY;\n\n        var baseAngle = Math.atan2(by - emitterY, bx - emitterX);\n        var angle = (Math.random() < 0.50) ? (baseAngle + rand(-1.25, 1.25)) : rand(0, Math.PI * 2);\n        var kickSpeed = isAccent ? rand(1.2, 4.6) : rand(0.9, 3.9);\n\n        ovx = Math.cos(angle) * kickSpeed;\n        ovy = Math.sin(angle) * kickSpeed;\n      }\n\n      var p = {\n        bx: bx, by: by,\n        vx: vx, vy: vy,\n        ox: ox, oy: oy,\n        ovx: ovx, ovy: ovy,\n        kind: kind,\n        color: color,\n        isAccent: isAccent,\n        a0: a0,\n        tw: tw, ph: ph\n      };\n\n      if(kind === \"dot\"){\n        p.r = isAccent ? rand(3.2, 6.4) : ((Math.random() < 0.60) ? rand(2.0, 3.8) : rand(3.8, 5.6));\n      } else if(kind === \"pill\"){\n        p.pw = rand(10, 30);\n        p.phh = rand(2.4, 5.2);\n        p.rot = rand(-0.85, 0.85);\n      } else {\n        p.br = rand(7, 16);\n      }\n      if(isAccent) p.glowSize = rand(7, 18);\n\n      floaters[i] = p;\n    }\n  }\n\n  function drawRoundRect(x, y, ww, hh, rr){\n    var r = Math.min(rr, ww/2, hh/2);\n    ctx.beginPath();\n    ctx.moveTo(x + r, y);\n    ctx.lineTo(x + ww - r, y);\n    ctx.quadraticCurveTo(x + ww, y, x + ww, y + r);\n    ctx.lineTo(x + ww, y + hh - r);\n    ctx.quadraticCurveTo(x + ww, y + hh, x + ww - r, y + hh);\n    ctx.lineTo(x + r, y + hh);\n    ctx.quadraticCurveTo(x, y + hh, x, y + hh - r);\n    ctx.lineTo(x, y + r);\n    ctx.quadraticCurveTo(x, y, x + r, y);\n    ctx.closePath();\n    ctx.fill();\n  }\n\n  function scheduleNextShooter(now){ nextShooterAt = now + rand(2200, 6500); }\n  function pickMeteorColor(){ return (Math.random() < 0.78) ? COLORS.white : pickAccent(); }\n\n  function createSpark(x, y, baseVx, baseVy, color, depth){\n    var spreadAngle = rand(-0.8, 0.8);\n    var speedMult = rand(0.08, 0.25);\n    var cos = Math.cos(spreadAngle);\n    var sin = Math.sin(spreadAngle);\n    var vx = (baseVx * cos - baseVy * sin) * speedMult + rand(-30, 30);\n    var vy = (baseVx * sin + baseVy * cos) * speedMult + rand(-20, 20);\n\n    return {\n      x: x + rand(-3, 3),\n      y: y + rand(-2, 2),\n      vx: vx,\n      vy: vy,\n      t: 0,\n      life: rand(0.15, 0.4),\n      r: rand(0.8, 2.0) * depth,\n      a0: rand(0.5, 0.9),\n      color: color\n    };\n  }\n\n  function noise1D(seed, t){\n    var x = Math.sin(seed + t * 1.7) * 43758.5453;\n    return (x - Math.floor(x)) * 2 - 1;\n  }\n\n  function spawnShooter(now, isFragment, parentData){\n    isFragment = !!isFragment;\n    parentData = parentData || null;\n\n    var fromLeft = parentData ? parentData.fromLeft : (Math.random() < 0.5);\n    var depth = isFragment ? rand(0.45, 0.7) : rand(0.4, 1.0);\n\n    var y, startX, angle, speed, life;\n\n    if(parentData){\n      startX = parentData.x + rand(-8, 8);\n      y = parentData.y + rand(-6, 6);\n      angle = parentData.angle + rand(-0.5, 0.5);\n      speed = parentData.speed * rand(0.45, 0.7);\n      life = rand(0.2, 0.4);\n    } else {\n      y = rand(h * 0.05, h * 0.95);\n      startX = fromLeft ? -rand(50, 140) : (w + rand(50, 140));\n      angle = fromLeft ? rand(-0.45, 0.45) : rand(Math.PI - 0.45, Math.PI + 0.45);\n      speed = rand(650, 1400) * (0.65 + depth * 0.45);\n      life = rand(0.55, 1.15);\n    }\n\n    var color = pickMeteorColor();\n    var curvature = rand(-0.12, 0.12);\n    var noiseSeed = rand(0, 1000);\n    var noiseAmp = rand(0.3, 1.2);\n\n    var willFragment = !isFragment && Math.random() < 0.12;\n    var fragmentTime = willFragment ? rand(0.25, 0.55) : -1;\n    var fragmentCount = willFragment ? Math.floor(rand(2, 4)) : 0;\n\n    var sparkCount = isFragment ? Math.floor(rand(1, 3)) : Math.floor(rand(3, 9));\n    var sparkTimes = [];\n    for(var i = 0; i < sparkCount; i++) sparkTimes.push(rand(0.08, 0.82) * life);\n    sparkTimes.sort(function(a,b){ return a-b; });\n\n    var shimmerPhase = rand(0, Math.PI * 2);\n    var shimmerSpeed = rand(18, 35);\n    var shimmerAmp = rand(0.04, 0.10);\n\n    var tailLen = rand(90, 200) * depth * (speed / 1000);\n\n    shooters.push({\n      x: startX,\n      y: y,\n      vx: Math.cos(angle) * speed,\n      vy: Math.sin(angle) * speed,\n      angle: angle,\n      speed: speed,\n      curvature: curvature,\n      noiseSeed: noiseSeed,\n      noiseAmp: noiseAmp,\n      t: 0,\n      life: life,\n      depth: depth,\n      tailLen: tailLen,\n      w: rand(1.0, 2.4) * depth,\n      color: color,\n      fromLeft: fromLeft,\n      willFragment: willFragment,\n      fragmentTime: fragmentTime,\n      fragmentCount: fragmentCount,\n      fragmented: false,\n      sparkTimes: sparkTimes,\n      sparkIndex: 0,\n      sparks: [],\n      shimmerPhase: shimmerPhase,\n      shimmerSpeed: shimmerSpeed,\n      shimmerAmp: shimmerAmp,\n      isFragment: isFragment\n    });\n\n    if(!isFragment) scheduleNextShooter(now);\n  }\n\n  function drawShooter(s, dt){\n    var p = clamp(s.t / s.life, 0, 1);\n\n    var fadeIn = Math.pow(clamp(p / 0.12, 0, 1), 0.7);\n    var peakHold = 1 - 0.15 * clamp((p - 0.12) / 0.30, 0, 1);\n    var fadeOut = 1 - Math.pow(clamp((p - 0.45) / 0.55, 0, 1), 1.8);\n    var alpha = fadeIn * peakHold * fadeOut;\n\n    var shimmer = 1 - s.shimmerAmp + s.shimmerAmp * (0.5 + 0.5 * Math.sin(s.t * s.shimmerSpeed + s.shimmerPhase));\n    var finalAlpha = alpha * shimmer;\n    if(finalAlpha < 0.005) return;\n\n    var spd = Math.sqrt(s.vx * s.vx + s.vy * s.vy) || 1;\n    var dirX = s.vx / spd;\n    var dirY = s.vy / spd;\n\n    var perpX = -dirY;\n    var perpY = dirX;\n\n    var noiseDrift = noise1D(s.noiseSeed, s.t * 8) * s.noiseAmp;\n\n    var dynamicTailLen = s.tailLen * (0.6 + 0.4 * alpha);\n    var curveOffset = s.curvature * dynamicTailLen * 0.35 * Math.sin(p * Math.PI);\n    var totalOffset = curveOffset + noiseDrift;\n\n    var tailX = s.x - dirX * dynamicTailLen + perpX * totalOffset;\n    var tailY = s.y - dirY * dynamicTailLen + perpY * totalOffset;\n\n    var midFactor = 0.45;\n    var midX = s.x - dirX * dynamicTailLen * midFactor + perpX * totalOffset * 0.6;\n    var midY = s.y - dirY * dynamicTailLen * midFactor + perpY * totalOffset * 0.6;\n\n    var coreStartFactor = 0.38;\n    var coreStartX = s.x - dirX * dynamicTailLen * coreStartFactor;\n    var coreStartY = s.y - dirY * dynamicTailLen * coreStartFactor;\n\n    ctx.save();\n    ctx.lineCap = \"round\";\n\n    var gradOuter = ctx.createLinearGradient(tailX, tailY, s.x, s.y);\n    gradOuter.addColorStop(0, \"rgba(\" + s.color.rgb + \",0)\");\n    gradOuter.addColorStop(0.25, \"rgba(\" + s.color.rgb + \",\" + (0.03 * finalAlpha).toFixed(4) + \")\");\n    gradOuter.addColorStop(0.55, \"rgba(\" + s.color.rgb + \",\" + (0.08 * finalAlpha).toFixed(4) + \")\");\n    gradOuter.addColorStop(0.80, \"rgba(\" + s.color.rgb + \",\" + (0.14 * finalAlpha).toFixed(4) + \")\");\n    gradOuter.addColorStop(1, \"rgba(\" + s.color.rgb + \",\" + (0.22 * finalAlpha).toFixed(4) + \")\");\n    ctx.strokeStyle = gradOuter;\n    ctx.lineWidth = s.w * 6 * s.depth;\n    ctx.beginPath();\n    ctx.moveTo(tailX, tailY);\n    ctx.quadraticCurveTo(midX, midY, s.x, s.y);\n    ctx.stroke();\n\n    var gradMid = ctx.createLinearGradient(tailX, tailY, s.x, s.y);\n    gradMid.addColorStop(0, \"rgba(\" + s.color.rgb + \",0)\");\n    gradMid.addColorStop(0.30, \"rgba(\" + s.color.rgb + \",\" + (0.12 * finalAlpha).toFixed(4) + \")\");\n    gradMid.addColorStop(0.60, \"rgba(\" + s.color.rgb + \",\" + (0.28 * finalAlpha).toFixed(4) + \")\");\n    gradMid.addColorStop(0.85, \"rgba(\" + s.color.rgb + \",\" + (0.50 * finalAlpha).toFixed(4) + \")\");\n    gradMid.addColorStop(1, \"rgba(\" + s.color.rgb + \",\" + (0.70 * finalAlpha).toFixed(4) + \")\");\n    ctx.strokeStyle = gradMid;\n    ctx.lineWidth = s.w * 2.5;\n    ctx.beginPath();\n    var midStartX = tailX + (s.x - tailX) * 0.15;\n    var midStartY = tailY + (s.y - tailY) * 0.15;\n    ctx.moveTo(midStartX, midStartY);\n    ctx.quadraticCurveTo(midX, midY, s.x, s.y);\n    ctx.stroke();\n\n    var gradCore = ctx.createLinearGradient(coreStartX, coreStartY, s.x, s.y);\n    gradCore.addColorStop(0, \"rgba(255,255,255,0)\");\n    gradCore.addColorStop(0.20, \"rgba(255,255,255,\" + (0.35 * finalAlpha).toFixed(4) + \")\");\n    gradCore.addColorStop(0.50, \"rgba(255,255,255,\" + (0.65 * finalAlpha).toFixed(4) + \")\");\n    gradCore.addColorStop(0.80, \"rgba(255,255,255,\" + (0.88 * finalAlpha).toFixed(4) + \")\");\n    gradCore.addColorStop(1, \"rgba(255,255,255,\" + (0.98 * finalAlpha).toFixed(4) + \")\");\n    ctx.strokeStyle = gradCore;\n    ctx.lineWidth = s.w * 0.9;\n    ctx.beginPath();\n    ctx.moveTo(coreStartX, coreStartY);\n    ctx.lineTo(s.x, s.y);\n    ctx.stroke();\n\n    var headRadius = s.w * 2.2 * s.depth;\n\n    ctx.shadowBlur = 14 * s.depth;\n    ctx.shadowColor = s.color.hex;\n\n    var headGradOuter = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, headRadius * 3);\n    headGradOuter.addColorStop(0, \"rgba(255,255,255,\" + (0.85 * finalAlpha).toFixed(4) + \")\");\n    headGradOuter.addColorStop(0.15, \"rgba(\" + s.color.rgb + \",\" + (0.70 * finalAlpha).toFixed(4) + \")\");\n    headGradOuter.addColorStop(0.40, \"rgba(\" + s.color.rgb + \",\" + (0.35 * finalAlpha).toFixed(4) + \")\");\n    headGradOuter.addColorStop(0.70, \"rgba(\" + s.color.rgb + \",\" + (0.12 * finalAlpha).toFixed(4) + \")\");\n    headGradOuter.addColorStop(1, \"rgba(\" + s.color.rgb + \",0)\");\n    ctx.fillStyle = headGradOuter;\n    ctx.beginPath();\n    ctx.arc(s.x, s.y, headRadius * 3, 0, Math.PI * 2);\n    ctx.fill();\n\n    ctx.shadowBlur = 8 * s.depth;\n    ctx.shadowColor = \"#ffffff\";\n    var headGradInner = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, headRadius * 1.2);\n    headGradInner.addColorStop(0, \"rgba(255,255,255,\" + (0.98 * finalAlpha).toFixed(4) + \")\");\n    headGradInner.addColorStop(0.5, \"rgba(255,255,255,\" + (0.75 * finalAlpha).toFixed(4) + \")\");\n    headGradInner.addColorStop(1, \"rgba(255,255,255,\" + (0.25 * finalAlpha).toFixed(4) + \")\");\n    ctx.fillStyle = headGradInner;\n    ctx.beginPath();\n    ctx.arc(s.x, s.y, headRadius * 1.2, 0, Math.PI * 2);\n    ctx.fill();\n\n    ctx.shadowBlur = 4;\n    ctx.fillStyle = \"rgba(255,255,255,\" + (0.95 * finalAlpha).toFixed(4) + \")\";\n    ctx.beginPath();\n    ctx.arc(s.x, s.y, headRadius * 0.35, 0, Math.PI * 2);\n    ctx.fill();\n\n    ctx.shadowBlur = 0;\n    ctx.shadowColor = \"transparent\";\n\n    for(var i = s.sparks.length - 1; i >= 0; i--){\n      var spark = s.sparks[i];\n      spark.t += dt;\n      spark.x += spark.vx * dt;\n      spark.y += spark.vy * dt;\n      spark.vx *= 0.94;\n      spark.vy *= 0.94;\n      spark.vy += 25 * dt;\n\n      var sparkP = clamp(spark.t / spark.life, 0, 1);\n      var sparkFade = (1 - sparkP) * (1 - sparkP);\n      var sparkAlpha = sparkFade * spark.a0 * alpha;\n\n      if(sparkAlpha > 0.008){\n        ctx.shadowBlur = 4 * sparkFade;\n        ctx.shadowColor = spark.color.hex;\n        ctx.fillStyle = \"rgba(\" + spark.color.rgb + \",\" + sparkAlpha.toFixed(4) + \")\";\n        ctx.beginPath();\n        ctx.arc(spark.x, spark.y, spark.r * (1 - sparkP * 0.6), 0, Math.PI * 2);\n        ctx.fill();\n      }\n\n      if(spark.t >= spark.life) s.sparks.splice(i, 1);\n    }\n\n    ctx.restore();\n    ctx.shadowBlur = 0;\n    ctx.shadowColor = \"transparent\";\n  }\n\n  var animationId = null;\n\n  function step(t){\n    t = t || performance.now();\n    var time = t * 0.001;\n\n    var realDt = lastFrameTime ? clamp((t - lastFrameTime) / 1000, 0.001, 0.05) : (1/60);\n    lastFrameTime = t;\n\n    ctx.clearRect(0, 0, w, h);\n    ctx.globalCompositeOperation = \"lighter\";\n\n    for(var i = 0; i < dust.length; i++){\n      var d = dust[i];\n\n      if(ENABLE_BURST){\n        d.ox += d.ovx; d.oy += d.ovy;\n        d.ovx *= KICK_DECAY; d.ovy *= KICK_DECAY;\n        d.ox *= OFFSET_DECAY; d.oy *= OFFSET_DECAY;\n      }\n\n      d.bx += d.vx; d.by += d.vy;\n\n      if(d.bx < -3) d.bx = w + 3;\n      if(d.bx > w + 3) d.bx = -3;\n      if(d.by < -3) d.by = h + 3;\n      if(d.by > h + 3) d.by = -3;\n\n      var x = d.bx + (d.ox || 0);\n      var y = d.by + (d.oy || 0);\n\n      var twk = 0.70 + 0.30 * Math.sin(time * d.tw + d.ph);\n      var a = d.a0 * twk;\n\n      if(d.isAccent){\n        ctx.shadowBlur = 5;\n        ctx.shadowColor = d.color.hex;\n      } else {\n        ctx.shadowBlur = 0;\n        ctx.shadowColor = \"transparent\";\n      }\n\n      ctx.fillStyle = \"rgba(\" + d.color.rgb + \",\" + a.toFixed(3) + \")\";\n      ctx.fillRect(x - d.size * 0.5, y - d.size * 0.5, d.size, d.size);\n    }\n\n    for(var j = 0; j < floaters.length; j++){\n      var p = floaters[j];\n\n      if(ENABLE_BURST){\n        p.ox += p.ovx; p.oy += p.ovy;\n        p.ovx *= KICK_DECAY; p.ovy *= KICK_DECAY;\n        p.ox *= OFFSET_DECAY; p.oy *= OFFSET_DECAY;\n      }\n\n      p.bx += p.vx; p.by += p.vy;\n\n      if(p.bx < -35) p.bx = w + 35;\n      if(p.bx > w + 35) p.bx = -35;\n      if(p.by < -35) p.by = h + 35;\n      if(p.by > h + 35) p.by = -35;\n\n      var px = p.bx + (p.ox || 0);\n      var py = p.by + (p.oy || 0);\n\n      var twk2 = 0.65 + 0.35 * Math.sin(time * p.tw + p.ph);\n      var a2 = p.a0 * twk2;\n\n      if(p.isAccent && p.glowSize){\n        ctx.shadowBlur = p.glowSize * twk2;\n        ctx.shadowColor = p.color.hex;\n      } else {\n        ctx.shadowBlur = 0;\n        ctx.shadowColor = \"transparent\";\n      }\n\n      ctx.fillStyle = \"rgba(\" + p.color.rgb + \",\" + a2.toFixed(3) + \")\";\n\n      if(p.kind === \"dot\"){\n        ctx.beginPath();\n        ctx.arc(px, py, p.r, 0, Math.PI * 2);\n        ctx.fill();\n      } else if(p.kind === \"pill\"){\n        ctx.save();\n        ctx.translate(px, py);\n        ctx.rotate(p.rot);\n        drawRoundRect(-p.pw/2, -p.phh/2, p.pw, p.phh, p.phh/2);\n        ctx.restore();\n      } else {\n        var rr = p.br;\n        ctx.beginPath();\n        ctx.arc(px, py, rr, 0, Math.PI * 2);\n        ctx.arc(px + rr * 0.5, py - rr * 0.2, rr * 0.7, 0, Math.PI * 2);\n        ctx.arc(px - rr * 0.4, py + rr * 0.15, rr * 0.6, 0, Math.PI * 2);\n        ctx.fill();\n      }\n    }\n\n    if(!nextShooterAt) scheduleNextShooter(t);\n    if(t >= nextShooterAt) spawnShooter(t, false, null);\n\n    for(var k = shooters.length - 1; k >= 0; k--){\n      var s = shooters[k];\n      s.t += realDt;\n\n      var curveFactor = s.curvature * 0.5;\n      var perpVx = -s.vy / s.speed;\n      var perpVy = s.vx / s.speed;\n      s.x += (s.vx + perpVx * curveFactor * s.speed * 0.1) * realDt;\n      s.y += (s.vy + perpVy * curveFactor * s.speed * 0.1) * realDt;\n\n      while(s.sparkIndex < s.sparkTimes.length && s.t >= s.sparkTimes[s.sparkIndex]){\n        s.sparks.push(createSpark(s.x, s.y, -s.vx, -s.vy, s.color, s.depth));\n        s.sparkIndex++;\n      }\n\n      if(s.willFragment && !s.fragmented && s.t >= s.fragmentTime * s.life){\n        s.fragmented = true;\n        for(var f = 0; f < s.fragmentCount; f++){\n          spawnShooter(t, true, { x:s.x, y:s.y, angle:s.angle, speed:s.speed, fromLeft:s.fromLeft });\n        }\n      }\n\n      drawShooter(s, realDt);\n\n      var margin = 450;\n      if(s.t >= s.life || s.x < -margin || s.x > w + margin || s.y < -margin || s.y > h + margin){\n        shooters.splice(k, 1);\n      }\n    }\n\n    ctx.globalCompositeOperation = \"source-over\";\n    ctx.shadowBlur = 0;\n    ctx.shadowColor = \"transparent\";\n\n    animationId = requestAnimationFrame(step);\n  }\n\n  /* =========================================================\n     FIX: Mobile scroll/viewport resize should NOT reseed particles\n     We resize the canvas and scale existing positions instead.\n  ========================================================= */\n  var seededOnce = false;\n  var resizeRaf = 0;\n\n  function hardSeedOnce(){\n    resize();\n    seedDust();\n    seedFloaters();\n    seededOnce = true;\n  }\n\n  function softResizeKeepPositions(){\n    var oldW = w || 1;\n    var oldH = h || 1;\n\n    resize();\n    setEmitterCenter();\n\n    if(!seededOnce){\n      seedDust();\n      seedFloaters();\n      seededOnce = true;\n      return;\n    }\n\n    var sx = w / oldW;\n    var sy = h / oldH;\n\n    for(var i = 0; i < dust.length; i++){\n      dust[i].bx *= sx;\n      dust[i].by *= sy;\n      if(dust[i].ox){ dust[i].ox *= sx; }\n      if(dust[i].oy){ dust[i].oy *= sy; }\n    }\n\n    for(var j = 0; j < floaters.length; j++){\n      floaters[j].bx *= sx;\n      floaters[j].by *= sy;\n      if(floaters[j].ox){ floaters[j].ox *= sx; }\n      if(floaters[j].oy){ floaters[j].oy *= sy; }\n    }\n\n    shooters.length = 0;\n    nextShooterAt = 0;\n  }\n\n  function requestSoftResize(){\n    if(resizeRaf) return;\n    resizeRaf = requestAnimationFrame(function(){\n      resizeRaf = 0;\n      softResizeKeepPositions();\n    });\n  }\n\n  hardSeedOnce();\n  animationId = requestAnimationFrame(step);\n\n  window.addEventListener('resize', requestSoftResize, { passive: true });\n\n  if(window.visualViewport){\n    window.visualViewport.addEventListener('resize', requestSoftResize, { passive: true });\n  }\n\n  if('ResizeObserver' in window){\n    var ro = new ResizeObserver(function(){ requestSoftResize(); });\n    ro.observe(wrap);\n  }\n\n  if('IntersectionObserver' in window){\n    var aknavIO = new IntersectionObserver(function(entries){\n      entries.forEach(function(entry){\n        if(entry.isIntersecting){\n          lastFrameTime = 0;\n          if(!animationId) animationId = requestAnimationFrame(step);\n        } else {\n          if(animationId){ cancelAnimationFrame(animationId); animationId = null; }\n        }\n      });\n    }, { threshold: 0 });\n    aknavIO.observe(wrap);\n  }\n})();\n</script>",
