    "custom_liquid_BCikwr": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div\n  id=\"amerikid-button-wrapper\"\n  style=\"position: relative; background: black; z-index: 999; padding: 2rem 0;\"\n>\n  <!-- Mobile “MENU” label (acts like a button) -->\n  <span id=\"mobile-menu-text\" role=\"button\" aria-label=\"Open navigation\" tabindex=\"0\">\n    M&nbsp;E&nbsp;N&nbsp;U\n  </span>\n\n  <!-- DESKTOP NAV -->\n  <div class=\"amerikid-defense-grid\">\n    <!-- TOP ROW -->\n    <a href=\"/pages/the-collective\"\n       class=\"amerikid-button left-edge {% if request.path == '/pages/the-collective' %}active{% endif %} fade-slide\"\n       style=\"animation-delay: 0.10s;\">\n      L&nbsp;I&nbsp;F&nbsp;E&nbsp;/&nbsp;S&nbsp;T&nbsp;Y&nbsp;L&nbsp;E\n    </a>\n\n    <a href=\"/collections/master-collection\"\n       class=\"amerikid-button center-btn {% if request.path == '/collections/master-collection' %}active{% endif %} fade-slide\"\n       style=\"animation-delay: 0.20s;\">\n      P&nbsp;R&nbsp;O&nbsp;D&nbsp;U&nbsp;C&nbsp;T&nbsp;S\n    </a>\n\n    <a href=\"/collections/\"\n       class=\"amerikid-button right-edge {% if request.path == '/collections' or request.path == '/collections/' %}active{% endif %} fade-slide\"\n       style=\"animation-delay: 0.30s;\">\n      A&nbsp;R&nbsp;C&nbsp;H&nbsp;I&nbsp;V&nbsp;E\n    </a>\n\n    <!-- BOTTOM ROW -->\n    <div class=\"bottom-row\">\n      <a href=\"/pages/narrative\"\n        class=\"amerikid-button bottom-left {% if request.path == '/pages/narrative' %}active{% endif %} fade-slide\"\n        style=\"animation-delay: 0.40s;\">\n        N&nbsp;A&nbsp;R&nbsp;R&nbsp;A&nbsp;T&nbsp;I&nbsp;V&nbsp;E\n      </a>\n\n      <!-- CENTER DUO -->\n      <div class=\"bottom-center\">\n        <div class=\"products-duo\" id=\"products-duo\" style=\"animation-delay: 0.50s;\">\n          <!-- BAD -->\n          <a href=\"/pages/2025\"\n             class=\"amerikid-button image-btn duo-btn bad-btn {% if request.path == '/pages/2025' %}active{% endif %} fade-slide\"\n             aria-label=\"BAD Music\"\n             style=\"animation-delay: 0.50s;\">\n            <span class=\"bad-logo\" role=\"img\" aria-label=\"BAD Music\"></span>\n            <img class=\"bad-fallback\" src=\"{{ 'Bad.png' | file_url }}\" alt=\"BAD Music\" />\n          </a>\n\n          <!-- CANDY FACTS -->\n          <a href=\"/pages/mystery-box\"\n             class=\"amerikid-button image-btn duo-btn box-btn {% if request.path == '/pages/mystery-box' %}active{% endif %} fade-slide\"\n             aria-label=\"Candy Facts\"\n             style=\"animation-delay: 0.55s;\">\n            <img class=\"box-img\" src=\"{{ 'candyfacts.png' | file_url }}\" alt=\"Candy Facts\" />\n          </a>\n        </div>\n      </div>\n\n      <a href=\"/pages/contact\"\n        class=\"amerikid-button bottom-right {% if request.path == '/pages/contact' %}active{% endif %} fade-slide\"\n        style=\"animation-delay: 0.60s;\">\n        C&nbsp;O&nbsp;N&nbsp;T&nbsp;A&nbsp;C&nbsp;T\n      </a>\n    </div>\n  </div>\n</div>\n\n<!-- FULL-SCREEN MOBILE DRAWER -->\n<div id=\"mobile-drawer\">\n  <button id=\"drawer-close\" aria-label=\"Close menu\">✕</button>\n\n  <a href=\"/pages/the-collective\"\n     class=\"{% if request.path == '/pages/the-collective' %}active{% endif %}\">\n     L&nbsp;I&nbsp;F&nbsp;E&nbsp;/&nbsp;S&nbsp;T&nbsp;Y&nbsp;L&nbsp;E\n  </a>\n\n  <a href=\"/collections/master-collection\"\n     class=\"{% if request.path == '/collections/master-collection' %}active{% endif %}\">\n     P&nbsp;R&nbsp;O&nbsp;D&nbsp;U&nbsp;C&nbsp;T&nbsp;S\n  </a>\n\n  <a href=\"/collections/\"\n     class=\"{% if request.path == '/collections' or request.path == '/collections/' %}active{% endif %}\">\n     A&nbsp;R&nbsp;C&nbsp;H&nbsp;I&nbsp;V&nbsp;E\n  </a>\n\n  <a href=\"/pages/narrative\"\n     class=\"{% if request.path == '/pages/narrative' %}active{% endif %}\">\n     N&nbsp;A&nbsp;R&nbsp;R&nbsp;A&nbsp;T&nbsp;I&nbsp;V&nbsp;E\n  </a>\n\n  <!-- BAD -->\n  <a href=\"/pages/2025\"\n     class=\"mobile-image-link {% if request.path == '/pages/2025' %}active{% endif %}\"\n     aria-label=\"BAD Music\">\n     <img src=\"{{ 'Bad.png' | file_url }}\" alt=\"BAD Music\" class=\"mobile-bad-img\" />\n  </a>\n\n  <!-- CANDY FACTS -->\n  <a href=\"/pages/mystery-box\"\n     class=\"mobile-image-link {% if request.path == '/pages/mystery-box' %}active{% endif %}\"\n     aria-label=\"Candy Facts\">\n     <img src=\"{{ 'candyfacts.png' | file_url }}\" alt=\"Candy Facts\" class=\"mobile-box-img\" />\n  </a>\n\n  <a href=\"/pages/contact\"\n     class=\"{% if request.path == '/pages/contact' %}active{% endif %}\">\n     C&nbsp;O&nbsp;N&nbsp;T&nbsp;A&nbsp;C&nbsp;T\n  </a>\n</div>\n\n<style>\n  :root {\n    --ak-purple: #ff33ff;\n\n    /* Responsive sizing so the nav never clips between tablet and desktop */\n    --nav-font: clamp(18px, 2.2vw, 34px);\n    --nav-font-center: clamp(20px, 2.6vw, 40px);\n\n    /* Keep the spaced-out vibe, but scale spacing down on smaller screens */\n    --nav-letter: clamp(0.14em, 0.9vw, 0.30em);\n    --nav-letter-center: clamp(0.16em, 1.0vw, 0.32em);\n\n    /* Responsive padding and gaps */\n    --nav-pad-x: clamp(0.6rem, 1.6vw, 1.5rem);\n    --nav-gap-row: clamp(1.4rem, 3vw, 3.5rem);\n    --nav-gap-col: clamp(1.6rem, 4vw, 5rem);\n\n    /* Responsive image height */\n    --duo-img-height: clamp(92px, 9vw, 135px);\n    --bad-aspect: 2.6;\n  }\n\n  /* Prevent edge-cropping */\n  #amerikid-button-wrapper{\n    overflow: visible !important;\n  }\n\n  .amerikid-defense-grid {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;\n    grid-template-rows: auto auto;\n    gap: var(--nav-gap-row) var(--nav-gap-col);\n    width: 100%;\n    max-width: 100%;\n    padding: 0 clamp(1rem, 3vw, 2rem);\n    box-sizing: border-box;\n    align-items: center;\n    justify-items: center;\n  }\n\n  .amerikid-defense-grid > a { grid-row: 1; }\n  .left-edge  { justify-self: start; }\n  .center-btn { justify-self: center; }\n  .right-edge { justify-self: end; }\n\n  .bottom-row {\n    grid-column: 1 / span 3;\n    grid-row: 2;\n    width: 100%;\n    display: grid;\n\n    /* 3 equal columns so center can’t push right side */\n    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr);\n\n    align-items: center;\n    column-gap: clamp(1.8rem, 4.2vw, 5rem); /* a bit more breathing room */\n    margin-top: clamp(0.75rem, 2vw, 2rem);\n  }\n\n  /* Lock each item to its column */\n  .bottom-left   { grid-column: 1; justify-self: start; }\n  .bottom-center { grid-column: 2; justify-self: center; width: 100%; min-width: 0; }\n  .bottom-right  { grid-column: 3; justify-self: end; }\n\n  /* Prevent weird overflow sizing behavior */\n  .bottom-row > * { min-width: 0; }\n\n  /*\n    KEY FIX:\n    Make the duo constrained to the center column width\n    so CandyFacts never crowds CONTACT\n  */\n  .products-duo{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n\n    width: 100%;\n    max-width: 100%;\n\n    gap: clamp(22px, 3vw, 64px);\n    margin: 0 auto;\n  }\n\n  .amerikid-button {\n    background: none;\n    color: white;\n    font-weight: 900;\n    font-size: var(--nav-font);\n    padding: 0.5rem var(--nav-pad-x);\n    text-align: center;\n    text-decoration: none;\n    text-transform: uppercase;\n\n    letter-spacing: var(--nav-letter);\n    white-space: nowrap;\n\n    opacity: 0;\n    transform: translateY(20px);\n    animation: fadeSlideIn 0.8s ease forwards;\n    transition: color 0.3s ease, transform 0.2s ease;\n  }\n\n  .amerikid-button.center-btn {\n    font-size: var(--nav-font-center);\n    padding: 0.6rem calc(var(--nav-pad-x) * 1.2);\n    letter-spacing: var(--nav-letter-center);\n  }\n\n  .amerikid-button:hover,\n  .amerikid-button.active { color: var(--ak-purple); }\n\n  .amerikid-button.image-btn {\n    line-height: 0;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    padding: 0.25rem 0.25rem;\n  }\n\n  .duo-btn{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    padding: 0.35rem 0.55rem;\n  }\n\n  .bad-logo {\n    width: calc(var(--duo-img-height) * var(--bad-aspect));\n    height: var(--duo-img-height);\n    display: inline-block;\n    background-color: currentColor;\n    -webkit-mask-image: url({{ 'Bad.png' | file_url }});\n    mask-image: url({{ 'Bad.png' | file_url }});\n    -webkit-mask-size: contain; mask-size: contain;\n    -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;\n    -webkit-mask-position: center;  mask-position: center;\n    transition: transform 0.2s ease, filter 0.2s ease;\n  }\n  .amerikid-button.image-btn:hover .bad-logo { transform: translateY(-2px); }\n  .amerikid-button.image-btn.active .bad-logo { transform: translateY(-1px); }\n\n  .bad-fallback {\n    height: var(--duo-img-height);\n    width: auto;\n    display: inline-block;\n    transition: transform 0.2s ease, filter 0.2s ease;\n  }\n  .amerikid-button.image-btn:hover .bad-fallback { transform: translateY(-2px); }\n\n  @supports (-webkit-mask-image: url(\"\")) or (mask-image: url(\"\")) {\n    .bad-fallback { display: none; }\n  }\n  @supports not ((-webkit-mask-image: url(\"\")) or (mask-image: url(\"\"))) {\n    .amerikid-button.image-btn:hover .bad-fallback,\n    .amerikid-button.image-btn.active .bad-fallback {\n      filter: brightness(0) saturate(100%) invert(29%) sepia(93%) saturate(7490%) hue-rotate(294deg) brightness(110%);\n    }\n  }\n\n  /* CandyFacts sizing bump (PNG likely has extra whitespace) */\n  .box-btn{ --box-scale: 1.12; }\n\n  .box-img{\n    height: calc(var(--duo-img-height) * var(--box-scale, 1));\n    width: auto;\n    display: block;\n    object-fit: contain;\n    transition: transform 0.2s ease, filter 0.2s ease;\n  }\n\n  .box-btn:hover .box-img{ transform: translateY(-2px); }\n  .box-btn.active .box-img{ transform: translateY(-1px); }\n  .box-btn:hover .box-img,\n  .box-btn.active .box-img{\n    filter: brightness(0) saturate(100%) invert(29%) sepia(93%) saturate(7490%) hue-rotate(294deg) brightness(110%);\n  }\n\n  @keyframes fadeSlideIn { to { opacity: 1; transform: translateY(0); } }\n  @keyframes bobHover    { from { transform: translateY(0); } to { transform: translateY(-4px); } }\n\n  .amerikid-button:hover {\n    animation: fadeSlideIn 0.8s ease forwards,\n               bobHover    1.2s ease-in-out infinite alternate;\n    animation-delay: 0s, 0.8s;\n    animation-fill-mode: forwards, alternate;\n    animation-iteration-count: 1, infinite;\n  }\n\n  @font-face {\n    font-family: 'Impact';\n    src: local('Impact'), local('Impact Regular'),\n         url('https://fonts.gstatic.com/s/impact/v11/H4cnBXaW.woff2') format('woff2');\n    font-display: swap;\n  }\n\n  #mobile-menu-text {\n    display: none;\n    font-family: 'Impact', sans-serif;\n    font-size: clamp(28px, 9vw, 48px);\n    text-transform: uppercase;\n    letter-spacing: 0.35em;\n    margin: 1.2rem auto 0;\n    padding: 0.25rem 0.75rem;\n    width: max-content;\n    cursor: pointer;\n    user-select: none;\n    color: #fff;\n    text-shadow: none;\n    animation: none;\n    transform: none;\n    transition: none;\n  }\n\n  #mobile-drawer {\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-start;\n    align-items: center;\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100vw;\n    height: 100vh;\n    background: black;\n    padding: 2rem 1rem 4rem;\n    z-index: 1000;\n    transform: translateX(-100%);\n    transition: transform 0.4s ease;\n  }\n  #mobile-drawer.open { transform: translateX(0); }\n  #drawer-close {\n    align-self: flex-start;\n    background: none;\n    border: none;\n    color: white;\n    font-size: 36px;\n    cursor: pointer;\n    margin-bottom: 3rem;\n  }\n  #mobile-drawer a {\n    display: block;\n    width: 100%;\n    text-align: center;\n    color: white;\n    font-weight: 900;\n    font-size: 36px;\n    line-height: 1.8;\n    padding: 2.2rem 1rem;\n    text-transform: uppercase;\n    text-decoration: none;\n    letter-spacing: 0.2em;\n  }\n  #mobile-drawer a:hover  { color: var(--ak-purple); background: rgba(255,255,255,0.05); }\n  #mobile-drawer a.active { color: var(--ak-purple); }\n\n  #mobile-drawer a.mobile-image-link { padding: 1.6rem 0; }\n  .mobile-bad-img,\n  .mobile-box-img{\n    display: block;\n    height: 64px;\n    width: auto;\n    margin: 0 auto;\n  }\n\n  @media (max-width: 768px) {\n    .amerikid-defense-grid { display: none; }\n    #mobile-menu-text      { display: block; }\n    .mobile-bad-img,\n    .mobile-box-img{ height: 128px; }\n  }\n</style>\n\n<script>\n  const menuLabel = document.getElementById('mobile-menu-text');\n  const drawer    = document.getElementById('mobile-drawer');\n  const closeBtn  = document.getElementById('drawer-close');\n\n  menuLabel.addEventListener('click', () => {\n    drawer.classList.add('open');\n  });\n  menuLabel.addEventListener('keydown', (e) => {\n    if (e.key === 'Enter' || e.key === ' ') drawer.classList.add('open');\n  });\n  closeBtn.addEventListener('click', () => {\n    drawer.classList.remove('open');\n  });\n  document.addEventListener('click', (e) => {\n    if (!drawer.contains(e.target) && !menuLabel.contains(e.target)) {\n      drawer.classList.remove('open');\n    }\n  });\n</script>",
        "color_scheme": "scheme-4",
        "padding_top": 0,
        "padding_bottom": 0
      }
