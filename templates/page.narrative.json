unt);\n\n      for(var i = 0; i < count; i++){\n        var color = pickDustColor();\n        var isAccent = (color !== COLORS.white);\n\n        var bx = rand(0, w);\n        var by = rand(0, h);\n\n        var vx = rand(-0.030, 0.030);\n        var vy = rand(-0.024, 0.024);\n\n        var tw = rand(0.25, 1.10);\n        var ph = rand(0, Math.PI * 2);\n\n        var a0 = isAccent ? rand(0.20, 0.46) : rand(0.06, 0.18);\n\n        var size = isAccent\n          ? rand(1.7, 3.4)\n          : ((Math.random() < 0.78) ? rand(1.1, 2.1) : rand(2.1, 3.0));\n\n        dust[i] = {\n          bx: bx, by: by,\n          vx: vx, vy: vy,\n          color: color,\n          isAccent: isAccent,\n          a0: a0,\n          size: size,\n          tw: tw, ph: ph\n        };\n      }\n    }\n\n    function drawRoundRect(x, y, ww, hh, rr){\n      var r = Math.min(rr, ww/2, hh/2);\n      ctx.beginPath();\n      ctx.moveTo(x + r, y);\n      ctx.lineTo(x + ww - r, y);\n      ctx.quadraticCurveTo(x + ww, y, x + ww, y + r);\n      ctx.lineTo(x + ww, y + hh - r);\n      ctx.quadraticCurveTo(x + ww, y + hh, x + ww - r, y + hh);\n      ctx.lineTo(x + r, y + hh);\n      ctx.quadraticCurveTo(x, y + hh, x, y + hh - r);\n      ctx.lineTo(x, y + r);\n      ctx.quadraticCurveTo(x, y, x + r, y);\n      ctx.closePath();\n      ctx.fill();\n    }\n\n    function seedFloaters(){\n      var area = w * h;\n      var s = densityScale();\n      var vw = (window.innerWidth || 1200);\n      var tiny = vw < 520;\n      var mobile = vw < 750;\n\n      var div = mobile ? (tiny ? 6200 : 5200) : 1200;\n      var minC = mobile ? (tiny ? 55 : 70) : 320;\n      var maxC = mobile ? (tiny ? 150 : 180) : 620;\n\n      var count = Math.round(clamp((area / div) * s, minC, maxC));\n      floaters = new Array(count);\n\n      for(var i = 0; i < count; i++){\n        var kind = pickFloaterKind();\n        var color = pickFloaterColor();\n        var isAccent = (color !== COLORS.white);\n\n        var bx = rand(0, w);\n        var by = rand(0, h);\n\n        var vx = rand(-0.18, 0.18);\n        var vy = rand(-0.15, 0.15);\n\n        var tw = rand(0.35, 1.35);\n        var ph = rand(0, Math.PI * 2);\n\n        var a0 = isAccent ? rand(0.22, 0.55) : rand(0.08, 0.20);\n        if(kind === \"blob\") a0 *= 0.78;\n        if(kind === \"pill\") a0 *= 0.90;\n\n        var p = {\n          bx: bx, by: by,\n          vx: vx, vy: vy,\n          kind: kind,\n          color: color,\n          isAccent: isAccent,\n          a0: a0,\n          tw: tw, ph: ph\n        };\n\n        if(kind === \"dot\"){\n          p.r = isAccent ? rand(3.2, 6.4) : ((Math.random() < 0.60) ? rand(2.0, 3.8) : rand(3.8, 5.6));\n        } else if(kind === \"pill\"){\n          p.pw = rand(10, 30);\n          p.phh = rand(2.4, 5.2);\n          p.rot = rand(-0.85, 0.85);\n        } else {\n          p.br = rand(7, 16);\n        }\n        if(isAccent) p.glowSize = rand(7, 18);\n\n        floaters[i] = p;\n      }\n    }\n\n    function scheduleNextShooter(now){ nextShooterAt = now + rand(2200, 6500); }\n    function pickMeteorColor(){ return (Math.random() < 0.78) ? COLORS.white : pickAccent(); }\n\n    function createSpark(x, y, baseVx, baseVy, color, depth){\n      var spreadAngle = rand(-0.8, 0.8);\n      var speedMult = rand(0.08, 0.25);\n      var cos = Math.cos(spreadAngle);\n      var sin = Math.sin(spreadAngle);\n      var vx = (baseVx * cos - baseVy * sin) * speedMult + rand(-30, 30);\n      var vy = (baseVx * sin + baseVy * cos) * speedMult + rand(-20, 20);\n\n      return {\n        x: x + rand(-3, 3),\n        y: y + rand(-2, 2),\n        vx: vx,\n        vy: vy,\n        t: 0,\n        life: rand(0.15, 0.4),\n        r: rand(0.8, 2.0) * depth,\n        a0: rand(0.5, 0.9),\n        color: color\n      };\n    }\n\n    function noise1D(seed, t){\n      var x = Math.sin(seed + t * 1.7) * 43758.5453;\n      return (x - Math.floor(x)) * 2 - 1;\n    }\n\n    function spawnShooter(now, isFragment, parentData){\n      isFragment = !!isFragment;\n      parentData = parentData || null;\n\n      var fromLeft = parentData ? parentData.fromLeft : (Math.random() < 0.5);\n      var depth = isFragment ? rand(0.45, 0.7) : rand(0.4, 1.0);\n\n      var y, startX, angle, speed, life;\n\n      if(parentData){\n        startX = parentData.x + rand(-8, 8);\n        y = parentData.y + rand(-6, 6);\n        angle = parentData.angle + rand(-0.5, 0.5);\n        speed = parentData.speed * rand(0.45, 0.7);\n        life = rand(0.2, 0.4);\n      } else {\n        y = rand(h * 0.05, h * 0.95);\n        startX = fromLeft ? -rand(50, 140) : (w + rand(50, 140));\n        angle = fromLeft ? rand(-0.45, 0.45) : rand(Math.PI - 0.45, Math.PI + 0.45);\n        speed = rand(650, 1400) * (0.65 + depth * 0.45);\n        life = rand(0.55, 1.15);\n      }\n\n      var color = pickMeteorColor();\n      var curvature = rand(-0.12, 0.12);\n      var noiseSeed = rand(0, 1000);\n      var noiseAmp = rand(0.3, 1.2);\n\n      var willFragment = !isFragment && Math.random() < 0.12;\n      var fragmentTime = willFragment ? rand(0.25, 0.55) : -1;\n      var fragmentCount = willFragment ? Math.floor(rand(2, 4)) : 0;\n\n      var sparkCount = isFragment ? Math.floor(rand(1, 3)) : Math.floor(rand(3, 9));\n      var sparkTimes = [];\n      for(var i = 0; i < sparkCount; i++) sparkTimes.push(rand(0.08, 0.82) * life);\n      sparkTimes.sort(function(a,b){ return a-b; });\n\n      var shimmerPhase = rand(0, Math.PI * 2);\n      var shimmerSpeed = rand(18, 35);\n      var shimmerAmp = rand(0.04, 0.10);\n\n      var tailLen = rand(90, 200) * depth * (speed / 1000);\n\n      shooters.push({\n        x: startX,\n        y: y,\n        vx: Math.cos(angle) * speed,\n        vy: Math.sin(angle) * speed,\n        angle: angle,\n        speed: speed,\n        curvature: curvature,\n        noiseSeed: noiseSeed,\n        noiseAmp: noiseAmp,\n        t: 0,\n        life: life,\n        depth: depth,\n        tailLen: tailLen,\n        w: rand(1.0, 2.4) * depth,\n        color: color,\n        fromLeft: fromLeft,\n        willFragment: willFragment,\n        fragmentTime: fragmentTime,\n        fragmentCount: fragmentCount,\n        fragmented: false,\n        sparkTimes: sparkTimes,\n        sparkIndex: 0,\n        sparks: [],\n        shimmerPhase: shimmerPhase,\n        shimmerSpeed: shimmerSpeed,\n        shimmerAmp: shimmerAmp,\n        isFragment: isFragment\n      });\n\n      if(!isFragment) scheduleNextShooter(now);\n    }\n\n    function drawShooter(s, dt){\n      var p = clamp(s.t / s.life, 0, 1);\n\n      var fadeIn = Math.pow(clamp(p / 0.12, 0, 1), 0.7);\n      var peakHold = 1 - 0.15 * clamp((p - 0.12) / 0.30, 0, 1);\n      var fadeOut = 1 - Math.pow(clamp((p - 0.45) / 0.55, 0, 1), 1.8);\n      var alpha = fadeIn * peakHold * fadeOut;\n\n      var shimmer = 1 - s.shimmerAmp + s.shimmerAmp * (0.5 + 0.5 * Math.sin(s.t * s.shimmerSpeed + s.shimmerPhase));\n      var finalAlpha = alpha * shimmer;\n\n      if(finalAlpha < 0.005) return;\n\n      var spd = Math.sqrt(s.vx * s.vx + s.vy * s.vy) || 1;\n      var dirX = s.vx / spd;\n      var dirY = s.vy / spd;\n\n      var perpX = -dirY;\n      var perpY = dirX;\n\n      var noiseDrift = noise1D(s.noiseSeed, s.t * 8) * s.noiseAmp;\n\n      var dynamicTailLen = s.tailLen * (0.6 + 0.4 * alpha);\n      var curveOffset = s.curvature * dynamicTailLen * 0.35 * Math.sin(p * Math.PI);\n      var totalOffset = curveOffset + noiseDrift;\n\n      var tailX = s.x - dirX * dynamicTailLen + perpX * totalOffset;\n      var tailY = s.y - dirY * dynamicTailLen + perpY * totalOffset;\n\n      var midFactor = 0.45;\n      var midX = s.x - dirX * dynamicTailLen * midFactor + perpX * totalOffset * 0.6;\n      var midY = s.y - dirY * dynamicTailLen * midFactor + perpY * totalOffset * 0.6;\n\n      var coreStartFactor = 0.38;\n      var coreStartX = s.x - dirX * dynamicTailLen * coreStartFactor;\n      var coreStartY = s.y - dirY * dynamicTailLen * coreStartFactor;\n\n      ctx.save();\n      ctx.lineCap = \"round\";\n\n      var gradOuter = ctx.createLinearGradient(tailX, tailY, s.x, s.y);\n      gradOuter.addColorStop(0, \"rgba(\" + s.color.rgb + \",0)\");\n      gradOuter.addColorStop(0.25, \"rgba(\" + s.color.rgb + \",\" + (0.03 * finalAlpha).toFixed(4) + \")\");\n      gradOuter.addColorStop(0.55, \"rgba(\" + s.color.rgb + \",\" + (0.08 * finalAlpha).toFixed(4) + \")\");\n      gradOuter.addColorStop(0.80, \"rgba(\" + s.color.rgb + \",\" + (0.14 * finalAlpha).toFixed(4) + \")\");\n      gradOuter.addColorStop(1, \"rgba(\" + s.color.rgb + \",\" + (0.22 * finalAlpha).toFixed(4) + \")\");\n      ctx.strokeStyle = gradOuter;\n      ctx.lineWidth = s.w * 6 * s.depth;\n      ctx.beginPath();\n      ctx.moveTo(tailX, tailY);\n      ctx.quadraticCurveTo(midX, midY, s.x, s.y);\n      ctx.stroke();\n\n      var gradMid = ctx.createLinearGradient(tailX, tailY, s.x, s.y);\n      gradMid.addColorStop(0, \"rgba(\" + s.color.rgb + \",0)\");\n      gradMid.addColorStop(0.30, \"rgba(\" + s.color.rgb + \",\" + (0.12 * finalAlpha).toFixed(4) + \")\");\n      gradMid.addColorStop(0.60, \"rgba(\" + s.color.rgb + \",\" + (0.28 * finalAlpha).toFixed(4) + \")\");\n      gradMid.addColorStop(0.85, \"rgba(\" + s.color.rgb + \",\" + (0.50 * finalAlpha).toFixed(4) + \")\");\n      gradMid.addColorStop(1, \"rgba(\" + s.color.rgb + \",\" + (0.70 * finalAlpha).toFixed(4) + \")\");\n      ctx.strokeStyle = gradMid;\n      ctx.lineWidth = s.w * 2.5;\n      ctx.beginPath();\n      var midStartX = tailX + (s.x - tailX) * 0.15;\n      var midStartY = tailY + (s.y - tailY) * 0.15;\n      ctx.moveTo(midStartX, midStartY);\n      ctx.quadraticCurveTo(midX, midY, s.x, s.y);\n      ctx.stroke();\n\n      var gradCore = ctx.createLinearGradient(coreStartX, coreStartY, s.x, s.y);\n      gradCore.addColorStop(0, \"rgba(255,255,255,0)\");\n      gradCore.addColorStop(0.20, \"rgba(255,255,255,\" + (0.35 * finalAlpha).toFixed(4) + \")\");\n      gradCore.addColorStop(0.50, \"rgba(255,255,255,\" + (0.65 * finalAlpha).toFixed(4) + \")\");\n      gradCore.addColorStop(0.80, \"rgba(255,255,255,\" + (0.88 * finalAlpha).toFixed(4) + \")\");\n      gradCore.addColorStop(1, \"rgba(255,255,255,\" + (0.98 * finalAlpha).toFixed(4) + \")\");\n      ctx.strokeStyle = gradCore;\n      ctx.lineWidth = s.w * 0.9;\n      ctx.beginPath();\n      ctx.moveTo(coreStartX, coreStartY);\n      ctx.lineTo(s.x, s.y);\n      ctx.stroke();\n\n      var headRadius = s.w * 2.2 * s.depth;\n\n      ctx.shadowBlur = 14 * s.depth;\n      ctx.shadowColor = s.color.hex;\n\n      var headGradOuter = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, headRadius * 3);\n      headGradOuter.addColorStop(0, \"rgba(255,255,255,\" + (0.85 * finalAlpha).toFixed(4) + \")\");\n      headGradOuter.addColorStop(0.15, \"rgba(\" + s.color.rgb + \",\" + (0.70 * finalAlpha).toFixed(4) + \")\");\n      headGradOuter.addColorStop(0.40, \"rgba(\" + s.color.rgb + \",\" + (0.35 * finalAlpha).toFixed(4) + \")\");\n      headGradOuter.addColorStop(0.70, \"rgba(\" + s.color.rgb + \",\" + (0.12 * finalAlpha).toFixed(4) + \")\");\n      headGradOuter.addColorStop(1, \"rgba(\" + s.color.rgb + \",0)\");\n      ctx.fillStyle = headGradOuter;\n      ctx.beginPath();\n      ctx.arc(s.x, s.y, headRadius * 3, 0, Math.PI * 2);\n      ctx.fill();\n\n      ctx.shadowBlur = 8 * s.depth;\n      ctx.shadowColor = \"#ffffff\";\n      var headGradInner = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, headRadius * 1.2);\n      headGradInner.addColorStop(0, \"rgba(255,255,255,\" + (0.98 * finalAlpha).toFixed(4) + \")\");\n      headGradInner.addColorStop(0.5, \"rgba(255,255,255,\" + (0.75 * finalAlpha).toFixed(4) + \")\");\n      headGradInner.addColorStop(1, \"rgba(255,255,255,\" + (0.25 * finalAlpha).toFixed(4) + \")\");\n      ctx.fillStyle = headGradInner;\n      ctx.beginPath();\n      ctx.arc(s.x, s.y, headRadius * 1.2, 0, Math.PI * 2);\n      ctx.fill();\n\n      ctx.shadowBlur = 4;\n      ctx.fillStyle = \"rgba(255,255,255,\" + (0.95 * finalAlpha).toFixed(4) + \")\";\n      ctx.beginPath();\n      ctx.arc(s.x, s.y, headRadius * 0.35, 0, Math.PI * 2);\n      ctx.fill();\n\n      ctx.shadowBlur = 0;\n      ctx.shadowColor = \"transparent\";\n\n      for(var i = s.sparks.length - 1; i >= 0; i--){\n        var spark = s.sparks[i];\n        spark.t += dt;\n        spark.x += spark.vx * dt;\n        spark.y += spark.vy * dt;\n        spark.vx *= 0.94;\n        spark.vy *= 0.94;\n        spark.vy += 25 * dt;\n\n        var sparkP = clamp(spark.t / spark.life, 0, 1);\n        var sparkFade = (1 - sparkP) * (1 - sparkP);\n        var sparkAlpha = sparkFade * spark.a0 * alpha;\n\n        if(sparkAlpha > 0.008){\n          ctx.shadowBlur = 4 * sparkFade;\n          ctx.shadowColor = spark.color.hex;\n          ctx.fillStyle = \"rgba(\" + spark.color.rgb + \",\" + sparkAlpha.toFixed(4) + \")\";\n          ctx.beginPath();\n          ctx.arc(spark.x, spark.y, spark.r * (1 - sparkP * 0.6), 0, Math.PI * 2);\n          ctx.fill();\n        }\n\n        if(spark.t >= spark.life) s.sparks.splice(i, 1);\n      }\n\n      ctx.restore();\n      ctx.shadowBlur = 0;\n      ctx.shadowColor = \"transparent\";\n    }\n\n    function step(t){\n      t = t || performance.now();\n      var time = t * 0.001;\n\n      var realDt = lastFrameTime ? clamp((t - lastFrameTime) / 1000, 0.001, 0.05) : (1/60);\n      lastFrameTime = t;\n\n      ctx.clearRect(0, 0, w, h);\n      ctx.globalCompositeOperation = \"lighter\";\n\n      for(var i = 0; i < dust.length; i++){\n        var d = dust[i];\n        d.bx += d.vx; d.by += d.vy;\n\n        if(d.bx < -3) d.bx = w + 3;\n        if(d.bx > w + 3) d.bx = -3;\n        if(d.by < -3) d.by = h + 3;\n        if(d.by > h + 3) d.by = -3;\n\n        var twk = 0.70 + 0.30 * Math.sin(time * d.tw + d.ph);\n        var a = d.a0 * twk;\n\n        if(d.isAccent){\n          ctx.shadowBlur = 5;\n          ctx.shadowColor = d.color.hex;\n        } else {\n          ctx.shadowBlur = 0;\n          ctx.shadowColor = \"transparent\";\n        }\n\n        ctx.fillStyle = \"rgba(\" + d.color.rgb + \",\" + a.toFixed(3) + \")\";\n        ctx.fillRect(d.bx - d.size * 0.5, d.by - d.size * 0.5, d.size, d.size);\n      }\n\n      for(var j = 0; j < floaters.length; j++){\n        var p = floaters[j];\n        p.bx += p.vx; p.by += p.vy;\n\n        if(p.bx < -35) p.bx = w + 35;\n        if(p.bx > w + 35) p.bx = -35;\n        if(p.by < -35) p.by = h + 35;\n        if(p.by > h + 35) p.by = -35;\n\n        var twk2 = 0.65 + 0.35 * Math.sin(time * p.tw + p.ph);\n        var a2 = p.a0 * twk2;\n\n        if(p.isAccent && p.glowSize){\n          ctx.shadowBlur = p.glowSize * twk2;\n          ctx.shadowColor = p.color.hex;\n        } else {\n          ctx.shadowBlur = 0;\n          ctx.shadowColor = \"transparent\";\n        }\n\n        ctx.fillStyle = \"rgba(\" + p.color.rgb + \",\" + a2.toFixed(3) + \")\";\n\n        if(p.kind === \"dot\"){\n          ctx.beginPath();\n          ctx.arc(p.bx, p.by, p.r, 0, Math.PI * 2);\n          ctx.fill();\n        } else if(p.kind === \"pill\"){\n          ctx.save();\n          ctx.translate(p.bx, p.by);\n          ctx.rotate(p.rot);\n          drawRoundRect(-p.pw/2, -p.phh/2, p.pw, p.phh, p.phh/2);\n          ctx.restore();\n        } else {\n          var rr = p.br;\n          ctx.beginPath();\n          ctx.arc(p.bx, p.by, rr, 0, Math.PI * 2);\n          ctx.arc(p.bx + rr * 0.5, p.by - rr * 0.2, rr * 0.7, 0, Math.PI * 2);\n          ctx.arc(p.bx - rr * 0.4, p.by + rr * 0.15, rr * 0.6, 0, Math.PI * 2);\n          ctx.fill();\n        }\n      }\n\n      if(!nextShooterAt) scheduleNextShooter(t);\n      if(t >= nextShooterAt) spawnShooter(t, false, null);\n\n      for(var k = shooters.length - 1; k >= 0; k--){\n        var s = shooters[k];\n        s.t += realDt;\n\n        var curveFactor = s.curvature * 0.5;\n        var perpVx = -s.vy / s.speed;\n        var perpVy = s.vx / s.speed;\n        s.x += (s.vx + perpVx * curveFactor * s.speed * 0.1) * realDt;\n        s.y += (s.vy + perpVy * curveFactor * s.speed * 0.1) * realDt;\n\n        while(s.sparkIndex < s.sparkTimes.length && s.t >= s.sparkTimes[s.sparkIndex]){\n          s.sparks.push(createSpark(s.x, s.y, -s.vx, -s.vy, s.color, s.depth));\n          s.sparkIndex++;\n        }\n\n        if(s.willFragment && !s.fragmented && s.t >= s.fragmentTime * s.life){\n          s.fragmented = true;\n          for(var f = 0; f < s.fragmentCount; f++){\n            spawnShooter(t, true, { x:s.x, y:s.y, angle:s.angle, speed:s.speed, fromLeft:s.fromLeft });\n          }\n        }\n\n        drawShooter(s, realDt);\n\n        var margin = 450;\n        if(s.t >= s.life || s.x < -margin || s.x > w + margin || s.y < -margin || s.y > h + margin){\n          shooters.splice(k, 1);\n        }\n      }\n\n      ctx.globalCompositeOperation = \"source-over\";\n      ctx.shadowBlur = 0;\n      ctx.shadowColor = \"transparent\";\n\n      animationId = requestAnimationFrame(step);\n    }\n\n    var animationId = null;\n    var seededOnce = false;\n    var resizeRaf = 0;\n\n    function hardSeedOnce(){\n      resize();\n      seedDust();\n      seedFloaters();\n      seededOnce = true;\n    }\n\n    function softResizeKeepPositions(){\n      var oldW = w || 1;\n      var oldH = h || 1;\n\n      resize();\n\n      if(!seededOnce){\n        seedDust();\n        seedFloaters();\n        seededOnce = true;\n        return;\n      }\n\n      var sx = w / oldW;\n      var sy = h / oldH;\n\n      for(var i = 0; i < dust.length; i++){\n        dust[i].bx *= sx;\n        dust[i].by *= sy;\n      }\n      for(var j = 0; j < floaters.length; j++){\n        floaters[j].bx *= sx;\n        floaters[j].by *= sy;\n      }\n\n      shooters.length = 0;\n      nextShooterAt = 0;\n    }\n\n    function requestSoftResize(){\n      if(resizeRaf) return;\n      resizeRaf = requestAnimationFrame(function(){\n        resizeRaf = 0;\n        softResizeKeepPositions();\n      });\n    }\n\n    hardSeedOnce();\n    animationId = requestAnimationFrame(step);\n\n    if('IntersectionObserver' in window){\n      var io = new IntersectionObserver(function(entries){\n        entries.forEach(function(entry){\n          if(entry.isIntersecting){\n            lastFrameTime = 0;\n            if(!animationId) animationId = requestAnimationFrame(step);\n          } else {\n            if(animationId){ cancelAnimationFrame(animationId); animationId = null; }\n          }\n        });\n      }, { threshold: 0 });\n      io.observe(wrap);\n    }\n\n    window.addEventListener('resize', requestSoftResize, { passive: true });\n\n    if(window.visualViewport){\n      window.visualViewport.addEventListener('resize', requestSoftResize, { passive: true });\n    }\n\n    if('ResizeObserver' in window){\n      var ro = new ResizeObserver(function(){ requestSoftResize(); });\n      ro.observe(wrap);\n    }\n  })();\n});\n})();\n</script>",
