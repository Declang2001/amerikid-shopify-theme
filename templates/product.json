    "custom_liquid_6wWQFN": {
      "type": "custom-liquid",
      "name": "back button",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  AMERIKID BACK BUTTON (Ambient) \u2014 v5 (visible-cost reduction)\n  \u2022 Full-bleed (no white gaps)\n  \u2022 No container border / no rounded corner artifacts\n  \u2022 Impact font\n  \u2022 Dust cap reduced: desktop 400\u20132,000, mobile 200\u20131,000\n  \u2022 Floater cap reduced: desktop 120\u2013600, mobile 50\u2013300\n  \u2022 Dust shadowBlur removed (floater + shooter glow preserved)\n{%- endcomment -%}\n\n{% assign ak_id = section.id | default: 'ak-back' %}\n\n<div id=\"ak-back-{{ ak_id }}\" class=\"ak-back-bleed\" aria-label=\"Back button\">\n  <canvas class=\"ak-back-field\" id=\"ak-back-canvas-{{ ak_id }}\" aria-hidden=\"true\"></canvas>\n\n  <div class=\"ak-back-inner\">\n    <a\n      class=\"ak-back-btn\"\n      href=\"{{ routes.all_products_collection_url | default: routes.root_url }}\"\n      data-ak-back\n      aria-label=\"Go back\"\n    >\n      BACK\n    </a>\n  </div>\n</div>\n\n<style>\n  #ak-back-{{ ak_id }},\n  #ak-back-{{ ak_id }} *{\n    font-family: Impact, Haettenschweiler, \"Arial Narrow Bold\", sans-serif !important;\n    letter-spacing: 0.06em;\n  }\n\n  #ak-back-{{ ak_id }}.ak-back-bleed{\n    position: relative;\n    isolation: isolate;\n    overflow: hidden;\n\n    background: #000 !important;\n    border: 0 !important;\n    border-radius: 0 !important;\n    box-shadow: none !important;\n\n    width: 100vw;\n    left: 50%;\n    transform: translateX(-50%);\n    max-width: none;\n\n    margin-top: calc(-1 * var(--spacing-sections-mobile, 28px));\n    margin-bottom: calc(-1 * var(--spacing-sections-mobile, 28px));\n    padding-top: var(--spacing-sections-mobile, 28px);\n    padding-bottom: var(--spacing-sections-mobile, 28px);\n  }\n\n  @media (min-width: 750px){\n    #ak-back-{{ ak_id }}.ak-back-bleed{\n      margin-top: calc(-1 * var(--spacing-sections-desktop, 44px));\n      margin-bottom: calc(-1 * var(--spacing-sections-desktop, 44px));\n      padding-top: var(--spacing-sections-desktop, 44px);\n      padding-bottom: var(--spacing-sections-desktop, 44px);\n    }\n  }\n\n  #ak-back-{{ ak_id }} .ak-back-field{\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    z-index: 0;\n    pointer-events: none;\n    mix-blend-mode: screen;\n    opacity: 1;\n    filter: contrast(1.10) saturate(1.10);\n  }\n\n  #ak-back-{{ ak_id }} .ak-back-inner{\n    position: relative;\n    z-index: 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n\n    min-height: clamp(120px, 16vw, 220px);\n    padding: clamp(14px, 3vw, 22px) 0;\n  }\n\n  #ak-back-{{ ak_id }} .ak-back-btn{\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n\n    text-decoration: none !important;\n    color: #fff !important;\n\n    font-size: clamp(28px, 4vw, 56px);\n    line-height: 1;\n    padding: 22px 56px;\n\n    border-radius: 22px;\n    border: 1px solid rgba(255,255,255,0.16);\n    background: radial-gradient(120% 120% at 70% 30%,\n      rgba(255,51,255,0.20) 0%,\n      rgba(127,212,255,0.10) 18%,\n      rgba(0,0,0,0.86) 55%,\n      rgba(0,0,0,0.96) 100%\n    );\n    box-shadow:\n      0 10px 30px rgba(0,0,0,0.55),\n      0 0 0 1px rgba(255,255,255,0.06) inset;\n\n    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;\n    -webkit-tap-highlight-color: transparent;\n  }\n\n  #ak-back-{{ ak_id }} .ak-back-btn:hover{\n    transform: translateY(-1px) scale(1.02);\n    border-color: rgba(255,255,255,0.22);\n    box-shadow:\n      0 14px 40px rgba(0,0,0,0.60),\n      0 0 26px rgba(255,51,255,0.22),\n      0 0 0 1px rgba(255,255,255,0.08) inset;\n  }\n\n  #ak-back-{{ ak_id }} .ak-back-btn:active{\n    transform: translateY(0px) scale(0.99);\n  }\n\n  @media (prefers-reduced-motion: reduce){\n    #ak-back-{{ ak_id }} .ak-back-field{ display:none; }\n    #ak-back-{{ ak_id }} .ak-back-btn{ transition:none; }\n  }\n</style>\n\n<script>\n(function(){\n  var root = document.getElementById('ak-back-{{ ak_id }}');\n  var canvas = document.getElementById('ak-back-canvas-{{ ak_id }}');\n  if(!root || !canvas) return;\n\n  if(canvas.dataset.akInit === '1') return;\n  canvas.dataset.akInit = '1';\n\n  var backBtn = root.querySelector('[data-ak-back]');\n  if(backBtn){\n    backBtn.addEventListener('click', function(e){\n      e.preventDefault();\n      if(window.history && window.history.length > 1) window.history.back();\n      else window.location.href = backBtn.getAttribute('href') || '/';\n    });\n  }\n\n  var reduced = false;\n  try { reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch(e){}\n  if(reduced) return;\n\n  var ctx = canvas.getContext('2d', { alpha:true });\n  var w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);\n\n  var dust = [];\n  var floaters = [];\n  var shooters = [];\n  var nextShooterAt = 0;\n  var lastFrameTime = 0;\n  var isVisible = true;\n  var animationId = null;\n\n  var COLORS = {\n    white:  { rgb: \"255,255,255\", hex: \"#ffffff\" },\n    purple: { rgb: \"255,51,255\",  hex: \"#ff33ff\" },\n    blue:   { rgb: \"127,212,255\", hex: \"#7fd4ff\" },\n    yellow: { rgb: \"255,211,74\",  hex: \"#ffd34a\" }\n  };\n\n  function clamp(v, a, b){ return Math.min(b, Math.max(a, v)); }\n  function rand(a, b){ return a + Math.random() * (b - a); }\n  function isMobile(){ return (window.innerWidth || 1200) < 750; }\n\n  function resize(){\n    var rect = root.getBoundingClientRect();\n    w = Math.max(1, Math.floor(rect.width));\n    h = Math.max(1, Math.floor(rect.height));\n    dpr = Math.min(window.devicePixelRatio || 1, 2);\n    canvas.width = Math.floor(w * dpr);\n    canvas.height = Math.floor(h * dpr);\n    canvas.style.width = w + \"px\";\n    canvas.style.height = h + \"px\";\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n\n  function pickAccent(){\n    var r = Math.random();\n    if(r < 0.44) return COLORS.purple;\n    if(r < 0.76) return COLORS.blue;\n    return COLORS.yellow;\n  }\n  function pickDustColor(){ return (Math.random() < 0.90) ? COLORS.white : pickAccent(); }\n  function pickFloaterColor(){ return (Math.random() < 0.78) ? COLORS.white : pickAccent(); }\n\n  function densityScale(){\n    var mobile = isMobile();\n    return mobile ? 0.85 : 1.15;\n  }\n\n  /* mobile particles smaller */\n  function sizeScale(){\n    var mobile = isMobile();\n    return mobile ? 0.60 : 1.0;\n  }\n\n  function seedDust(){\n    var area = w * h;\n    var s = densityScale();\n    var ss = sizeScale();\n    var mobile = isMobile();\n\n    /* MOBILE ONLY: allow much lower counts (desktop unchanged) */\n    var minDust = mobile ? 200 : 400;\n    var maxDust = mobile ? 1000 : 2000;\n\n    var count = Math.round(clamp((area / 140) * s, minDust, maxDust));\n    dust = new Array(count);\n\n    for(var i=0;i<count;i++){\n      var color = pickDustColor();\n      var isAccent = (color !== COLORS.white);\n\n      var vx = rand(-0.028, 0.028);\n      var vy = rand(-0.022, 0.022);\n\n      var tw = rand(0.25, 1.05);\n      var ph = rand(0, Math.PI * 2);\n\n      var a0 = isAccent ? rand(0.20, 0.44) : rand(0.06, 0.18);\n      var size = (isAccent ? rand(2.6, 6.0) : rand(1.3, 3.6)) * ss;\n\n      dust[i] = { x: rand(0,w), y: rand(0,h), vx:vx, vy:vy, color:color, isAccent:isAccent, a0:a0, size:size, tw:tw, ph:ph };\n    }\n  }\n\n  function pickFloaterKind(){\n    var r = Math.random();\n    if(r < 0.02) return \"blob\";\n    if(r < 0.22) return \"pill\";\n    return \"dot\";\n  }\n\n  function seedFloaters(){\n    var area = w * h;\n    var s = densityScale();\n    var ss = sizeScale();\n    var mobile = isMobile();\n\n    /* MOBILE ONLY: lower floater caps (desktop unchanged) */\n    var minF = mobile ? 50 : 120;\n    var maxF = mobile ? 300 : 600;\n\n    var count = Math.round(clamp((area / 2200) * s, minF, maxF));\n    floaters = new Array(count);\n\n    for(var i=0;i<count;i++){\n      var kind = pickFloaterKind();\n      var color = pickFloaterColor();\n      var isAccent = (color !== COLORS.white);\n\n      var vx = rand(-0.16, 0.16);\n      var vy = rand(-0.13, 0.13);\n\n      var tw = rand(0.35, 1.30);\n      var ph = rand(0, Math.PI * 2);\n\n      var a0 = isAccent ? rand(0.20, 0.52) : rand(0.08, 0.22);\n      if(kind === \"blob\") a0 *= 0.80;\n\n      var p = { x: rand(0,w), y: rand(0,h), vx:vx, vy:vy, kind:kind, color:color, isAccent:isAccent, a0:a0, tw:tw, ph:ph };\n\n      if(kind === \"dot\"){\n        p.r = (isAccent ? rand(3.8, 9.2) : rand(2.8, 6.8)) * ss;\n      } else if(kind === \"pill\"){\n        p.pw = rand(12, 40) * ss;\n        p.phh = rand(3.2, 8.0) * ss;\n        p.rot = rand(-0.85, 0.85);\n      } else {\n        p.br = rand(10, 24) * ss;\n      }\n\n      if(isAccent) p.glowSize = rand(14, 34) * ss;\n      floaters[i] = p;\n    }\n  }\n\n  function drawRoundRect(x,y,ww,hh,rr){\n    var r = Math.min(rr, ww/2, hh/2);\n    ctx.beginPath();\n    ctx.moveTo(x+r,y);\n    ctx.lineTo(x+ww-r,y);\n    ctx.quadraticCurveTo(x+ww,y,x+ww,y+r);\n    ctx.lineTo(x+ww,y+hh-r);\n    ctx.quadraticCurveTo(x+ww,y+hh,x+ww-r,y+hh);\n    ctx.lineTo(x+r,y+hh);\n    ctx.quadraticCurveTo(x,y+hh,x,y+hh-r);\n    ctx.lineTo(x,y+r);\n    ctx.quadraticCurveTo(x,y,x+r,y);\n    ctx.closePath();\n    ctx.fill();\n  }\n\n  function scheduleNextShooter(now){ nextShooterAt = now + rand(2200, 6200); }\n  function pickMeteorColor(){ return (Math.random() < 0.80) ? COLORS.white : pickAccent(); }\n\n  function spawnShooter(now){\n    var fromLeft = (Math.random() < 0.5);\n    var depth = rand(0.55, 1.0);\n    var y = rand(h * 0.10, h * 0.90);\n    var startX = fromLeft ? -rand(60, 160) : (w + rand(60, 160));\n    var angle = fromLeft ? rand(-0.42, 0.42) : rand(Math.PI - 0.42, Math.PI + 0.42);\n    var speed = rand(650, 1250) * (0.70 + depth * 0.40);\n    var life = rand(0.60, 1.20);\n\n    var ss = sizeScale();\n\n    shooters.push({\n      x:startX, y:y,\n      vx: Math.cos(angle) * speed,\n      vy: Math.sin(angle) * speed,\n      t:0, life:life, depth:depth,\n      tail: (rand(95, 215) * depth * (speed/1000)) * ss,\n      w: (rand(0.95, 2.1) * depth) * ss,\n      color: pickMeteorColor()\n    });\n\n    scheduleNextShooter(now);\n  }\n\n  function drawShooter(s){\n    var p = clamp(s.t / s.life, 0, 1);\n    var fadeIn = Math.pow(clamp(p / 0.12, 0, 1), 0.75);\n    var fadeOut = 1 - Math.pow(clamp((p - 0.45) / 0.55, 0, 1), 1.9);\n    var alpha = fadeIn * fadeOut;\n    if(alpha < 0.01) return;\n\n    var spd = Math.sqrt(s.vx*s.vx + s.vy*s.vy) || 1;\n    var dx = s.vx / spd;\n    var dy = s.vy / spd;\n\n    var tailX = s.x - dx * s.tail;\n    var tailY = s.y - dy * s.tail;\n\n    ctx.save();\n    ctx.lineCap = \"round\";\n\n    var g1 = ctx.createLinearGradient(tailX, tailY, s.x, s.y);\n    g1.addColorStop(0, \"rgba(\" + s.color.rgb + \",0)\");\n    g1.addColorStop(0.55, \"rgba(\" + s.color.rgb + \",\" + (0.09*alpha).toFixed(4) + \")\");\n    g1.addColorStop(1, \"rgba(\" + s.color.rgb + \",\" + (0.26*alpha).toFixed(4) + \")\");\n    ctx.strokeStyle = g1;\n    ctx.lineWidth = s.w * 4.9;\n    ctx.beginPath();\n    ctx.moveTo(tailX, tailY);\n    ctx.lineTo(s.x, s.y);\n    ctx.stroke();\n\n    var g2 = ctx.createLinearGradient(tailX, tailY, s.x, s.y);\n    g2.addColorStop(0, \"rgba(255,255,255,0)\");\n    g2.addColorStop(0.55, \"rgba(255,255,255,\" + (0.20*alpha).toFixed(4) + \")\");\n    g2.addColorStop(1, \"rgba(255,255,255,\" + (0.72*alpha).toFixed(4) + \")\");\n    ctx.strokeStyle = g2;\n    ctx.lineWidth = s.w * 1.10;\n    ctx.beginPath();\n    ctx.moveTo(s.x - dx * s.tail * 0.45, s.y - dy * s.tail * 0.45);\n    ctx.lineTo(s.x, s.y);\n    ctx.stroke();\n\n    ctx.shadowBlur = 14 * s.depth;\n    ctx.shadowColor = s.color.hex;\n\n    var r = s.w * 2.2 * s.depth;\n    var hg = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, r * 3.0);\n    hg.addColorStop(0, \"rgba(255,255,255,\" + (0.82*alpha).toFixed(4) + \")\");\n    hg.addColorStop(0.18, \"rgba(\" + s.color.rgb + \",\" + (0.50*alpha).toFixed(4) + \")\");\n    hg.addColorStop(0.55, \"rgba(\" + s.color.rgb + \",\" + (0.15*alpha).toFixed(4) + \")\");\n    hg.addColorStop(1, \"rgba(\" + s.color.rgb + \",0)\");\n    ctx.fillStyle = hg;\n    ctx.beginPath();\n    ctx.arc(s.x, s.y, r * 3.0, 0, Math.PI*2);\n    ctx.fill();\n\n    ctx.restore();\n    ctx.shadowBlur = 0;\n    ctx.shadowColor = \"transparent\";\n  }\n\n  function reseed(){\n    resize();\n    seedDust();\n    seedFloaters();\n    shooters.length = 0;\n    nextShooterAt = 0;\n    lastFrameTime = 0;\n  }\n\n  function step(t){\n    if(!isVisible){\n      animationId = null;\n      return;\n    }\n\n    var now = (t || performance.now());\n    var time = now * 0.001;\n    var dt = lastFrameTime ? clamp((now - lastFrameTime) / 1000, 0.001, 0.05) : (1/60);\n    lastFrameTime = now;\n\n    ctx.clearRect(0,0,w,h);\n    ctx.globalCompositeOperation = \"lighter\";\n\n    for(var i=0;i<dust.length;i++){\n      var d = dust[i];\n      d.x += d.vx; d.y += d.vy;\n\n      if(d.x < -2) d.x = w + 2;\n      if(d.x > w + 2) d.x = -2;\n      if(d.y < -2) d.y = h + 2;\n      if(d.y > h + 2) d.y = -2;\n\n      var twk = 0.70 + 0.30 * Math.sin(time * d.tw + d.ph);\n      var a = d.a0 * twk;\n\n      ctx.shadowBlur = 0;\n\n      ctx.fillStyle = \"rgba(\" + d.color.rgb + \",\" + a.toFixed(3) + \")\";\n      ctx.fillRect(d.x - d.size*0.5, d.y - d.size*0.5, d.size, d.size);\n    }\n\n    for(var j=0;j<floaters.length;j++){\n      var p = floaters[j];\n\n      p.x += p.vx; p.y += p.vy;\n\n      if(p.x < -30) p.x = w + 30;\n      if(p.x > w + 30) p.x = -30;\n      if(p.y < -30) p.y = h + 30;\n      if(p.y > h + 30) p.y = -30;\n\n      var twk2 = 0.65 + 0.35 * Math.sin(time * p.tw + p.ph);\n      var a2 = p.a0 * twk2;\n\n      if(p.isAccent && p.glowSize){\n        ctx.shadowBlur = p.glowSize * twk2;\n        ctx.shadowColor = p.color.hex;\n      } else {\n        ctx.shadowBlur = 0;\n        ctx.shadowColor = \"transparent\";\n      }\n\n      ctx.fillStyle = \"rgba(\" + p.color.rgb + \",\" + a2.toFixed(3) + \")\";\n\n      if(p.kind === \"dot\"){\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);\n        ctx.fill();\n      } else if(p.kind === \"pill\"){\n        ctx.save();\n        ctx.translate(p.x, p.y);\n        ctx.rotate(p.rot);\n        drawRoundRect(-p.pw/2, -p.phh/2, p.pw, p.phh, p.phh/2);\n        ctx.restore();\n      } else {\n        var r2 = p.br;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, r2, 0, Math.PI*2);\n        ctx.arc(p.x + r2*0.5, p.y - r2*0.2, r2*0.7, 0, Math.PI*2);\n        ctx.arc(p.x - r2*0.4, p.y + r2*0.15, r2*0.6, 0, Math.PI*2);\n        ctx.fill();\n      }\n    }\n\n    if(!nextShooterAt) scheduleNextShooter(now);\n    if(now >= nextShooterAt) spawnShooter(now);\n\n    for(var k=shooters.length-1;k>=0;k--){\n      var s = shooters[k];\n      s.t += dt;\n      s.x += s.vx * dt;\n      s.y += s.vy * dt;\n\n      drawShooter(s);\n\n      var margin = 420;\n      if(s.t >= s.life || s.x < -margin || s.x > w + margin || s.y < -margin || s.y > h + margin){\n        shooters.splice(k, 1);\n      }\n    }\n\n    ctx.globalCompositeOperation = \"source-over\";\n    ctx.shadowBlur = 0;\n    ctx.shadowColor = \"transparent\";\n\n    animationId = requestAnimationFrame(step);\n  }\n\n  reseed();\n  animationId = requestAnimationFrame(step);\n\n  window.addEventListener('resize', function(){ reseed(); }, { passive:true });\n\n  if('ResizeObserver' in window){\n    var ro = new ResizeObserver(function(){ reseed(); });\n    ro.observe(root);\n  }\n\n  if('IntersectionObserver' in window){\n    var io = new IntersectionObserver(function(entries){\n      entries.forEach(function(entry){\n        var wasVisible = isVisible;\n        isVisible = entry.isIntersecting;\n        if(isVisible && !wasVisible){\n          lastFrameTime = 0;\n          if(!animationId) animationId = requestAnimationFrame(step);\n        }\n      });\n    }, { threshold: 0 });\n    io.observe(root);\n  }\n})();\n</script>",
