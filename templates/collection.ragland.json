    "custom_liquid_J6HYJT": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- ---------------------  STYLESHEET IMPORTS  --------------------- -->\n<link rel=\"stylesheet\" href=\"{{ 'component-list-menu.css'      | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n<link rel=\"stylesheet\" href=\"{{ 'component-menu-drawer.css'    | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n<link rel=\"stylesheet\" href=\"{{ 'component-cart-notification.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n\n{% if settings.predictive_search_enabled %}\n  <link rel=\"stylesheet\" href=\"{{ 'component-price.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n{% endif %}\n{% if section.settings.menu_type_desktop == 'mega' %}\n  <link rel=\"stylesheet\" href=\"{{ 'component-mega-menu.css' | asset_url }}\" media=\"print\" onload=\"this.media='all'\">\n{% endif %}\n\n<style>\n  /* ——— GENERAL HEADER OVERRIDES ——— */\n  .header-wrapper            { background:black!important; overflow:visible!important; }\n  .header__heading-logo-wrapper{ cursor:pointer; display:inline-block; }\n  .header__heading-link      { text-decoration:none; display:inline-block; }\n\n  .header__heading-logo{\n    max-width:180px; height:auto; display:block; opacity:0;\n    transform:scale(.8); animation:kidLogoEntrance .8s ease-out forwards;\n  }\n  .header__heading-logo:hover{\n    animation:kidLogoEntrance .8s ease-out forwards,\n             bobHover .6s ease-in-out infinite alternate;\n  }\n\n  @keyframes kidLogoEntrance{\n    0%{opacity:0; transform:scale(.8) rotate(-10deg);}  \n    50%{opacity:1; transform:scale(1.05) rotate( 2deg);} \n    100%{opacity:1; transform:scale(1   ) rotate( 0);}      \n  }\n  @keyframes bobHover{from{transform:scale(1) translateY(0);}to{transform:scale(1.02) translateY(-6px);}}\n\n  @media(max-width:749px){\n    .header__heading-logo{max-width:140px;}\n    .header__search,#shopify-section-header-search,.header__search-toggle{display:none!important;}\n  }\n\n  header-drawer{justify-self:start; margin-left:-1.2rem;}\n  .menu-drawer-container{display:flex;}\n  .list-menu{list-style:none; padding:0; margin:0;}\n  .list-menu--inline{display:inline-flex; flex-wrap:wrap;}\n  summary.list-menu__item{padding-right:2.7rem;}\n  .list-menu__item{display:flex; align-items:center; line-height:calc(1 + .3/var(--font-body-scale));}\n  .list-menu__item--link{text-decoration:none; padding:1rem 0; line-height:calc(1 + .8/var(--font-body-scale));}\n  @media(min-width:750px){.list-menu__item--link{padding:.5rem 0;}}\n\n  /* ——— CART BUTTON ——— */\n  .cart-bubble-container{position:fixed; top:1rem; right:1rem; z-index:9999;}\n  .cart-icon-link{position:relative; display:inline-block; padding:0; border-radius:0; transition:transform .2s ease;}\n  .cart-icon-img{width:72px; height:72px; object-fit:contain; display:block;}\n\n  /* ring + hue shift only when cart has items */\n  {% if cart.item_count > 0 %}\n    .cart-icon-link {\n      padding: 8px;\n      border-radius: 14px;\n      overflow: hidden;\n    }\n    .cart-icon-link::before{\n      content:\"\"; position:absolute; inset:-4px; border-radius:inherit;\n      background:conic-gradient(from 0deg,#39ff14 0 90deg,#00f6ff 90 180deg,#8a2be2 180 270deg,#ff2cc3 270 360deg);\n      animation:spinRing 8s linear infinite; z-index:-1; filter:blur(6px); opacity:.7;\n    }\n    @keyframes spinRing{to{transform:rotate(1turn);} }\n    .cart-icon-img{animation:iconHue 6s linear infinite;}\n    @keyframes iconHue{from{filter:hue-rotate(0);}to{filter:hue-rotate(360deg);}}\n  {% endif %}\n\n  /* NEW green glow pulse (always toggled via JS) */\n  .cart-icon-img.cart-glow{animation:cartGlowPulse 2s ease-in-out infinite;}\n  @keyframes cartGlowPulse{\n    0%,100%{filter:drop-shadow(0 0 4px #39ff14) drop-shadow(0 0 12px #39ff14);}\n    50%    {filter:drop-shadow(0 0 8px #39ff14) drop-shadow(0 0 18px #39ff14);}\n  }\n</style>\n\n{% style %}\n  .header{\n    padding:{{ section.settings.padding_top | times:0.5 | round:0 }}px 3rem\n            {{ section.settings.padding_bottom | times:0.5 | round:0 }}px 3rem;\n    background-color:black;\n  }\n  .section-header{\n    position:sticky;\n    margin-bottom:{{ section.settings.margin_bottom | times:0.75 | round:0 }}px;\n  }\n  @media(min-width:750px){.section-header{margin-bottom:{{ section.settings.margin_bottom }}px;}}\n  @media(min-width:990px){\n    .header{\n      padding-top:{{ section.settings.padding_top }}px;\n      padding-bottom:{{ section.settings.padding_bottom }}px;\n    }\n  }\n{% endstyle %}\n\n<script src=\"{{ 'cart-notification.js' | asset_url }}\" defer></script>\n\n{% liquid\n  assign header_tag = 'div'\n  if section.settings.sticky_header_type != 'none'\n    assign header_tag = 'sticky-header'\n  endif\n%}\n\n<{{ header_tag }}\n  class=\"header-wrapper color-{{ section.settings.color_scheme }}{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}\"\n  {% if header_tag == 'sticky-header' %} data-sticky-type=\"{{ section.settings.sticky_header_type }}\"{% endif %}>\n  <header\n    class=\"header\n           header--{{ section.settings.logo_position }}\n           header--mobile-{{ section.settings.mobile_logo_position }}\n           page-width\n           {% if section.settings.menu_type_desktop == 'drawer' %}drawer-menu{% endif %}\n           {% if section.settings.menu != blank %}header--has-menu{% endif %}\">\n    {% if section.settings.menu != blank %}\n      {% render 'header-drawer' %}\n    {% endif %}\n\n    {% if section.settings.menu != blank and section.settings.menu_type_desktop == 'drawer' %}\n      <a href=\"javascript:void(0)\"\n         id=\"logo-menu-toggle-left\"\n         aria-label=\"Toggle menu\"\n         class=\"header__heading-link focus-inset\">\n        <div class=\"header__heading-logo-wrapper\">\n          <svg width=\"24\" height=\"24\" fill=\"currentColor\">\n            <rect y=\"4\"  width=\"24\" height=\"2\"/>\n            <rect y=\"11\" width=\"24\" height=\"2\"/>\n            <rect y=\"18\" width=\"24\" height=\"2\"/>\n          </svg>\n        </div>\n      </a>\n    {% endif %}\n\n    <!-- LOGO -->\n    <a href=\"{{ shop.url }}\"\n       class=\"header__heading-link link link--text focus-inset\"\n       style=\"margin:0 auto;\">\n      {% if settings.logo != blank %}\n        <div class=\"header__heading-logo-wrapper\">\n          {% assign logo_alt    = settings.logo.alt | default: shop.name | escape %}\n          {% assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio %}\n          {% capture sizes  %}(min-width: 750px) 180px, 50vw{% endcapture %}\n          {% capture widths %}180, 320, 440{% endcapture %}\n\n          {{ settings.logo\n             | image_url: width:440\n             | image_tag:\n                 class:'header__heading-logo',\n                 widths:widths,\n                 height:logo_height,\n                 width:180,\n                 alt:logo_alt,\n                 sizes:sizes,\n                 preload:true }}\n        </div>\n      {% endif %}\n    </a>\n\n    <!-- CART BUTTON -->\n    <div class=\"cart-bubble-container\">\n      <a href=\"/cart\" aria-label=\"View cart\" class=\"cart-icon-link\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0930/3267/7656/files/cart.png?v=1750659934\"\n             alt=\"Cart\"\n             class=\"cart-icon-img\">\n      </a>\n    </div>\n  </header>\n</{{ header_tag }}>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    /* drawer toggle (desktop) */\n    const toggle = document.getElementById('logo-menu-toggle-left');\n    if (toggle) {\n      toggle.addEventListener('click', () => {\n        const drawer = document.querySelector('header-drawer');\n        if (drawer) drawer.open = !drawer.open;\n      });\n    }\n\n    /* glow toggle */\n    const cartImg = document.querySelector('.cart-icon-img');\n\n    async function updateCartGlow() {\n      try {\n        const cart = await fetch('/cart.js').then(r => r.json());\n        if (cart && cart.item_count > 0) {\n          cartImg.classList.add('cart-glow');\n        } else {\n          cartImg.classList.remove('cart-glow');\n        }\n      } catch (err) {\n        console.error('Cart glow check failed:', err);\n      }\n    }\n\n    updateCartGlow();\n    document.addEventListener('cart:updated', updateCartGlow);\n    setInterval(updateCartGlow, 10000);\n  });\n</script>",
        "color_scheme": "scheme-4",
        "padding_top": 12,
        "padding_bottom": 0
      }
