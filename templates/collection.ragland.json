    "custom_liquid_BCikwr": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div\n  id=\"amerikid-button-wrapper\"\n  style=\"position: relative; overflow: hidden; background: black; z-index: 999; padding: 2rem 0;\"\n>\n  <!-- Mobile “MENU” label (acts like a button) -->\n  <span id=\"mobile-menu-text\" role=\"button\" aria-label=\"Open navigation\" tabindex=\"0\">\n    M&nbsp;E&nbsp;N&nbsp;U\n  </span>\n\n  <!-- DESKTOP NAV -->\n  <div class=\"amerikid-defense-grid\">\n    <!-- TOP ROW (SWAPPED: LIFE/STYLE on the LEFT, PRODUCTS in the CENTER) -->\n    <a href=\"/pages/the-collective\"\n       class=\"amerikid-button left-edge {% if request.path == '/pages/the-collective' %}active{% endif %} fade-slide\">\n      L&nbsp;I&nbsp;F&nbsp;E&nbsp;/&nbsp;S&nbsp;T&nbsp;Y&nbsp;L&nbsp;E\n    </a>\n\n    <a href=\"/collections/master-collection\"\n       class=\"amerikid-button center-btn {% if request.path == '/collections/master-collection' %}active{% endif %} fade-slide\">\n      P&nbsp;R&nbsp;O&nbsp;D&nbsp;U&nbsp;C&nbsp;T&nbsp;S\n    </a>\n\n    <!-- ARCHIVE stays on right -->\n    <a href=\"/collections/\"\n       class=\"amerikid-button right-edge {% if request.path == '/collections' or request.path == '/collections/' %}active{% endif %} fade-slide\">\n      A&nbsp;R&nbsp;C&nbsp;H&nbsp;I&nbsp;V&nbsp;E\n    </a>\n\n    <!-- BOTTOM ROW (perfectly centered BAD under the center column) -->\n    <div class=\"bottom-row\">\n      <!-- NARRATIVE (left) -->\n      <a href=\"/pages/narrative\"\n        class=\"amerikid-button bottom-left {% if request.path == '/pages/narrative' %}active{% endif %} fade-slide\">\n        N&nbsp;A&nbsp;R&nbsp;R&nbsp;A&nbsp;T&nbsp;I&nbsp;V&nbsp;E\n      </a>\n\n      <!-- BAD (center) -->\n      <a href=\"/pages/2025\"\n         class=\"amerikid-button image-btn bottom-center {% if request.path == '/pages/2025' %}active{% endif %} fade-slide\"\n         aria-label=\"BAD\">\n        <span class=\"bad-logo\" role=\"img\" aria-label=\"BAD Music\"></span>\n        <img class=\"bad-fallback\" src=\"{{ 'Bad.png' | file_url }}\" alt=\"BAD Music\" />\n      </a>\n\n      <!-- CONTACT (right) -->\n      <a href=\"/pages/contact\"\n        class=\"amerikid-button bottom-right {% if request.path == '/pages/contact' %}active{% endif %} fade-slide\">\n        C&nbsp;O&nbsp;N&nbsp;T&nbsp;A&nbsp;C&nbsp;T\n      </a>\n    </div>\n  </div>\n</div>\n\n<!-- FULL-SCREEN MOBILE DRAWER -->\n<div id=\"mobile-drawer\">\n  <button id=\"drawer-close\" aria-label=\"Close menu\">✕</button>\n\n  <!-- Order updated to mirror desktop left→center→right -->\n  <a href=\"/pages/the-collective\"\n     class=\"{% if request.path == '/pages/the-collective' %}active{% endif %}\">\n     L&nbsp;I&nbsp;F&nbsp;E&nbsp;/&nbsp;S&nbsp;T&nbsp;Y&nbsp;L&nbsp;E\n  </a>\n\n  <a href=\"/collections/master-collection\"\n     class=\"{% if request.path == '/collections/master-collection' %}active{% endif %}\">\n     P&nbsp;R&nbsp;O&nbsp;D&nbsp;U&nbsp;C&nbsp;T&nbsp;S\n  </a>\n\n  <a href=\"/collections/\"\n     class=\"{% if request.path == '/collections' or request.path == '/collections/' %}active{% endif %}\">\n     A&nbsp;R&nbsp;C&nbsp;H&nbsp;I&nbsp;V&nbsp;E\n  </a>\n\n  <a href=\"/pages/narrative\"\n     class=\"{% if request.path == '/pages/narrative' %}active{% endif %}\">\n     N&nbsp;A&nbsp;R&nbsp;R&nbsp;A&nbsp;T&nbsp;I&nbsp;V&nbsp;E\n  </a>\n\n  <!-- BAD.png instead of \"2025\" text on mobile -->\n  <a href=\"/pages/2025\"\n     class=\"mobile-image-link {% if request.path == '/pages/2025' %}active{% endif %}\"\n     aria-label=\"BAD\">\n     <img src=\"{{ 'Bad.png' | file_url }}\" alt=\"BAD\" class=\"mobile-bad-img\" />\n  </a>\n\n  <a href=\"/pages/contact\"\n     class=\"{% if request.path == '/pages/contact' %}active{% endif %}\">\n     C&nbsp;O&nbsp;N&nbsp;T&nbsp;A&nbsp;C&nbsp;T\n  </a>\n</div>\n\n<style>\n  :root {\n    --btn-img-height: 150px;   /* BAD logo height (desktop). Adjust freely */\n    --bad-aspect: 2.6;         /* BAD logo width/height ratio for the mask */\n    --ak-purple: #ff33ff;      /* AmeriKid purple */\n  }\n\n  /* -------------- LAYOUT -------------- */\n  .amerikid-defense-grid {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;  /* left / center / right */\n    grid-template-rows: auto auto;        /* top row / bottom row */\n    gap: 3.5rem 5rem;\n    width: 100%;\n    max-width: 100%;\n    padding: 0 2rem;\n    box-sizing: border-box;\n    align-items: center;\n    justify-items: center;\n  }\n  .amerikid-defense-grid > a { grid-row: 1; }\n  .left-edge  { justify-self: start; }\n  .center-btn { justify-self: center; }\n  .right-edge { justify-self: end;   }\n\n  /* Bottom row – 3 columns aligned under top row */\n  .bottom-row {\n    grid-column: 1 / span 3;\n    grid-row: 2;\n    width: 100%;\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;\n    align-items: center;\n    column-gap: 5rem;\n    margin-top: 2rem;\n  }\n  .bottom-left  { justify-self: start; }\n  .bottom-center{ justify-self: center; }\n  .bottom-right { justify-self: end; }\n\n  /* -------------- BUTTONS -------------- */\n  .amerikid-button {\n    background: none;\n    color: white;\n    font-weight: 900;\n    font-size: 34px;\n    padding: 0.5rem 1.5rem;\n    text-align: center;\n    text-decoration: none;\n    text-transform: uppercase;\n    letter-spacing: 0.3em;\n    white-space: nowrap;\n    opacity: 0;\n    transform: translateY(20px);\n    animation: fadeSlideIn 0.8s ease forwards;\n    transition: color 0.3s ease, transform 0.2s ease;\n  }\n\n  .amerikid-button.center-btn {\n    font-size: 40px;\n    padding: 0.6rem 1.8rem;\n    letter-spacing: 0.32em;\n  }\n\n  .amerikid-button:hover,\n  .amerikid-button.active { color: var(--ak-purple); }\n\n  .amerikid-button.image-btn {\n    line-height: 0;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    padding: 0.5rem 1.5rem;\n  }\n\n  /* BAD logo (tinted via currentColor) */\n  .bad-logo {\n    width: calc(var(--btn-img-height) * var(--bad-aspect));\n    height: var(--btn-img-height);\n    display: inline-block;\n    background-color: currentColor;\n    -webkit-mask-image: url({{ 'Bad.png' | file_url }});\n    mask-image: url({{ 'Bad.png' | file_url }});\n    -webkit-mask-size: contain; mask-size: contain;\n    -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;\n    -webkit-mask-position: center;  mask-position: center;\n    transition: transform 0.2s ease, filter 0.2s ease;\n  }\n  .amerikid-button.image-btn:hover .bad-logo { transform: translateY(-2px); }\n\n  /* Fallback PNG for browsers without mask support (desktop) */\n  .bad-fallback {\n    height: var(--btn-img-height);\n    width: auto;\n    display: inline-block;\n    transition: transform 0.2s ease, filter 0.2s ease;\n  }\n  .amerikid-button.image-btn:hover .bad-fallback { transform: translateY(-2px); }\n  @supports (-webkit-mask-image: url(\"\")) or (mask-image: url(\"\")) {\n    .bad-fallback { display: none; }\n  }\n  @supports not ((-webkit-mask-image: url(\"\")) or (mask-image: url(\"\"))) {\n    .amerikid-button.image-btn:hover .bad-fallback {\n      filter: brightness(0) saturate(100%) invert(29%) sepia(93%) saturate(7490%) hue-rotate(294deg) brightness(110%);\n    }\n    .amerikid-button.image-btn.active .bad-fallback {\n      filter: brightness(0) saturate(100%) invert(29%) sepia(93%) saturate(7490%) hue-rotate(294deg) brightness(110%);\n    }\n  }\n\n  /* Entrance + hover bob */\n  @keyframes fadeSlideIn { to { opacity: 1; transform: translateY(0); } }\n  @keyframes bobHover    { from { transform: translateY(0); } to { transform: translateY(-4px); } }\n  .amerikid-button:hover {\n    animation: fadeSlideIn 0.8s ease forwards,\n               bobHover    1.2s ease-in-out infinite alternate;\n    animation-delay: 0s, 0.8s;\n    animation-fill-mode: forwards, alternate;\n    animation-iteration-count: 1, infinite;\n  }\n\n  /* stagger */\n  .amerikid-button:nth-of-type(1) { animation-delay: 0.1s; }\n  .amerikid-button:nth-of-type(2) { animation-delay: 0.2s; }\n  .amerikid-button:nth-of-type(3) { animation-delay: 0.3s; }\n  .bottom-row .amerikid-button:nth-of-type(1) { animation-delay: 0.4s; }\n  .bottom-row .amerikid-button:nth-of-type(2) { animation-delay: 0.5s; }\n  .bottom-row .amerikid-button:nth-of-type(3) { animation-delay: 0.6s; }\n\n  /* -------------- MOBILE MENU LABEL (no glow) -------------- */\n  @font-face {\n    font-family: 'Impact';\n    src: local('Impact'), local('Impact Regular'),\n         url('https://fonts.gstatic.com/s/impact/v11/H4cnBXaW.woff2') format('woff2');\n    font-display: swap;\n  }\n  #mobile-menu-text {\n    display: none;\n    font-family: 'Impact', sans-serif;\n    font-size: clamp(28px, 9vw, 48px);\n    text-transform: uppercase;\n    letter-spacing: 0.35em;\n    margin: 1.2rem auto 0;\n    padding: 0.25rem 0.75rem;\n    width: max-content;\n    cursor: pointer;\n    user-select: none;\n    color: #fff;              /* stays white */\n    text-shadow: none;        /* remove glow */\n    animation: none;          /* no color pulse or scale */\n    transform: none;\n    transition: none;\n  }\n\n  /* -------------- MOBILE DRAWER -------------- */\n  #mobile-drawer {\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-start;\n    align-items: center;\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100vw;\n    height: 100vh;\n    background: black;\n    padding: 2rem 1rem 4rem;\n    z-index: 1000;\n    transform: translateX(-100%);\n    transition: transform 0.4s ease;\n  }\n  #mobile-drawer.open { transform: translateX(0); }\n  #drawer-close {\n    align-self: flex-start;\n    background: none;\n    border: none;\n    color: white;\n    font-size: 36px;\n    cursor: pointer;\n    margin-bottom: 3rem;\n  }\n  #mobile-drawer a {\n    display: block;\n    width: 100%;\n    text-align: center;\n    color: white;\n    font-weight: 900;\n    font-size: 36px;\n    line-height: 1.8;\n    padding: 2.2rem 1rem;\n    text-transform: uppercase;\n    text-decoration: none;\n    letter-spacing: 0.2em;\n  }\n  #mobile-drawer a:hover  { color: var(--ak-purple); background: rgba(255,255,255,0.05); }\n  #mobile-drawer a.active { color: var(--ak-purple); }\n\n  /* Special styling for the BAD.png item in the mobile drawer */\n  #mobile-drawer a.mobile-image-link {\n    padding: 2.2rem 0;\n  }\n  .mobile-bad-img {\n    display: block;\n    height: 64px;     /* base; overridden on mobile below */\n    width: auto;\n    margin: 0 auto;\n  }\n\n  /* -------------- RESPONSIVE -------------- */\n  @media (max-width: 768px) {\n    .amerikid-defense-grid { display: none; }\n    #mobile-menu-text      { display: block; }\n    :root { --btn-img-height: 64px; --bad-aspect: 2.6; }\n\n    /* Bigger BAD.png in the mobile drawer only */\n    .mobile-bad-img { height: 128px; } /* increase size here */\n  }\n</style>\n\n<script>\n  const menuLabel = document.getElementById('mobile-menu-text');\n  const drawer    = document.getElementById('mobile-drawer');\n  const closeBtn  = document.getElementById('drawer-close');\n\n  menuLabel.addEventListener('click', () => {\n    drawer.classList.add('open');\n  });\n  menuLabel.addEventListener('keydown', (e) => {\n    if (e.key === 'Enter' || e.key === ' ') drawer.classList.add('open');\n  });\n  closeBtn.addEventListener('click', () => {\n    drawer.classList.remove('open');\n  });\n  document.addEventListener('click', (e) => {\n    if (!drawer.contains(e.target) && !menuLabel.contains(e.target)) {\n      drawer.classList.remove('open');\n    }\n  });\n</script>",
        "color_scheme": "scheme-4",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
